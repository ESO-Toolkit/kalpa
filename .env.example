# Vite dev server port - must match devUrl in src-tauri/tauri.conf.json
VITE_PORT=1430

# Optional real ESO Logs benchmark/proof settings.
# Put real values in .env.bench.local, which is gitignored. Linked worktrees also
# check the main checkout's .env.bench.local, or you can point to a shared file:
# KALPA_BENCH_ENV_FILE=C:\path\to\.env.bench.local
# KALPA_BENCH_NATIVE_UPLOAD_LOG can be omitted when .decode-samples/sunspire_raw.log exists;
# the proof benchmark will use its largest single-session prefix.
# KALPA_BENCH_NATIVE_UPLOAD_LOG=C:\path\to\prepared.log
# KALPA_BENCH_ESOLOGS_COOKIE=wcl_session=...; XSRF-TOKEN=...
# KALPA_BENCH_NATIVE_UPLOAD_CONFIRM=upload
# KALPA_BENCH_REPORT_READY_BROWSER=1
# KALPA_BENCH_BASELINE_FULLY_LOADED_MS=120000
# KALPA_BENCH_REQUIRE_10X=1
