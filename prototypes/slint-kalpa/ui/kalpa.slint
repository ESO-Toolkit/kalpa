            copy-status-label: root.svm-copy-status-label;
            copy-ready: root.svm-copy-ready;
            copy-has-file: root.svm-copy-has-file;
            copy-has-source: root.svm-copy-has-source;
            copy-has-dest: root.svm-copy-has-dest;
            editor-file-label: root.svm-editor-file-label;
            editor-path-label: root.svm-editor-path-label;
            editor-message-label: root.svm-editor-message-label;
            editor-has-file: root.svm-editor-has-file;
            editor-dirty: root.svm-editor-dirty;
            refresh => { root.svm-refresh(); }
            clean-orphans => { root.svm-clean-orphans(); }
            orphan-selection-toggled(index) => { root.svm-orphan-selection-toggled(index); }
            orphan-select-all(selected) => { root.svm-orphan-select-all(selected); }
            copy-select-file => { root.svm-copy-select-file(); }
            copy-select-source => { root.svm-copy-select-source(); }
            copy-select-dest => { root.svm-copy-select-dest(); }
            copy-profile => { root.svm-copy-profile(); }
            editor-select-file => { root.svm-editor-select-file(); }
            editor-save => { root.svm-editor-save(); }
            editor-preview => { root.svm-editor-preview(); }
            editor-discard => { root.svm-editor-discard(); }
            editor-restore => { root.svm-editor-restore(); }
            editor-copy-raw => { root.svm-editor-copy-raw(); }
            editor-toggle-setting(index) => { root.svm-editor-toggle-setting(index); }
            editor-select-path(path) => { root.svm-editor-select-path(path); }
            editor-edit-setting(index, value) => { root.svm-editor-edit-setting(index, value); }
            editor-tree-filter <=> root.svm-editor-tree-filter;
            editor-tree-filter-edited(value) => { root.svm-editor-tree-filter-edited(value); }
            editor-expand-all => { root.svm-editor-expand-all(); }
            editor-collapse-all => { root.svm-editor-collapse-all(); }
        }

        if (root.uploader-open) : UploaderOverlay {
            width: root.width;
            height: root.height;
            open <=> root.uploader-open;
            view <=> root.uploader-view;
            logs: root.uploader-logs;
            fights: root.uploader-fights;
            logs-summary: root.uploader-logs-summary;
            selected-log-label: root.uploader-selected-log-label;
            fight-count-label: root.uploader-fight-count-label;
            route-label: root.uploader-route-label;
            live-active: root.uploader-live-active;
            native-route: root.uploader-native-route;
            signed-in: root.uploader-signed-in;
            report-code: root.uploader-report-code;
            status-title: root.uploader-status-title;
            status-detail: root.uploader-status-detail;
            live-status-label: root.uploader-live-status-label;
            live-log-label: root.uploader-live-log-label;
            live-fight-label: root.uploader-live-fight-label;
            live-detail: root.uploader-live-detail;
            region <=> root.uploader-region;
            visibility-mode <=> root.uploader-visibility;
            refresh => { root.uploader-refresh(); }
            log-selected(index) => { root.uploader-select-log(index); }
            upload-requested => { root.uploader-upload(); }
            live-toggle => { root.uploader-live-toggle(); }
            options-changed => { root.uploader-options-changed(); }
            split-requested => { root.uploader-split-open-requested(); }
            sign-in => { root.uploader-sign-in(); }
            sign-out => { root.uploader-sign-out(); }
            open-report => { root.uploader-open-report(); }
        }

        if (root.uploader-split-open) : SplitWorkbench {
            width: root.width;
            height: root.height;
            open <=> root.uploader-split-open;
            mode <=> root.uploader-split-mode;
            items: root.uploader-split-items;
            summary: root.uploader-split-summary;
            source-label: root.uploader-split-source-label;
            status: root.uploader-split-status;
            selected-count: root.uploader-split-selected-count;
            busy: root.uploader-split-busy;
            mode-changed(m) => { root.uploader-split-mode-changed(m); }
            item-toggled(i) => { root.uploader-split-item-toggled(i); }
            select-all => { root.uploader-split-select-all(); }
            select-none => { root.uploader-split-select-none(); }
            run => { root.uploader-split-run(); }
            close => { root.uploader-split-open = false; }
        }

        if (root.backup-restore-open) : BackupRestoreOverlay {
            width: root.width;
            height: root.height;
            open <=> root.backup-restore-open;
            view <=> root.backup-restore-view;
            backups: root.settings-backups;
            status-title: root.backup-status-title;
            status-subtitle: root.backup-status-subtitle;
            status-kind: root.backup-status-kind;
            backup-list-summary: root.backup-list-summary;
            backup-label-draft <=> root.backup-label-draft;
            refresh-backups => { root.backup-restore-refresh(); }
            create-backup(label) => { root.backup-restore-create(label); }
            restore-backup(index) => { root.backup-restore-restore(index); }
            delete-backup(index) => { root.backup-restore-delete(index); }
            reveal-backups-folder => { root.backup-restore-reveal-folder(); }
        }

        if (root.characters-open) : CharactersOverlay {
            width: root.width;
            height: root.height;
            open <=> root.characters-open;
            characters: root.characters;
            summary: root.characters-summary;
            warning: root.characters-warning;
            backup-label-draft <=> root.character-backup-label-draft;
            refresh-characters => { root.characters-refresh(); }
            backup-character(index, label) => { root.character-backup(index, label); }
        }

        if (root.safety-open) : SafetyCenterOverlay {
            width: root.width;
            height: root.height;
            open <=> root.safety-open;
            view <=> root.safety-view;
            snapshots: root.safety-snapshots;
            issues: root.safety-issues;
            logs: root.safety-logs;
            snapshot-summary: root.safety-snapshot-summary;
            integrity-summary: root.safety-integrity-summary;
            integrity-addons-ok: root.safety-integrity-addons-ok;
            integrity-sv-ok: root.safety-integrity-sv-ok;
            integrity-addon-count: root.safety-integrity-addon-count;
            refresh-safety => { root.safety-refresh(); }
            run-integrity => { root.safety-run-integrity(); }
            restore-snapshot(index) => { root.safety-restore-snapshot(index); }
            delete-snapshot(index) => { root.safety-delete-snapshot(index); }
        }

        if (root.migration-open) : MinionMigrationOverlay {
            width: root.width;
            height: root.height;
            open <=> root.migration-open;
            phase <=> root.migration-phase;
            include-addons <=> root.migration-include-addons;
            checks: root.migration-checks;
            preview: root.migration-preview;
            can-proceed: root.migration-can-proceed;
            status: root.migration-status;
            snapshot-summary: root.migration-snapshot-summary;
            result-summary: root.migration-result-summary;
            recheck => { root.migration-recheck(); }
            continue-to-backup => { root.migration-continue(); }
            create-snapshot(value) => { root.migration-create-snapshot(value); }
            execute-migration => { root.migration-execute(); }
        }

        AppearanceOverlay {
            width: root.width;
            height: root.height;
            open <=> root.settings-open;
            active-tab <=> root.settings-tab;
            editor-open <=> root.settings-editor-open;
            active-theme-id <=> root.active-theme-id;
            draft-theme <=> root.draft-theme;
            draft-theme-id <=> root.draft-theme-id;
            draft-theme-name <=> root.draft-theme-name;
            draft-theme-description <=> root.draft-theme-description;
            draft-theme-new <=> root.draft-theme-new;
            draft-bg-base <=> root.draft-bg-base;
            draft-background <=> root.draft-background;
            draft-surface <=> root.draft-surface;
            draft-foreground <=> root.draft-foreground;
            draft-muted-foreground <=> root.draft-muted-foreground;
            draft-primary <=> root.draft-primary;
            draft-primary-foreground <=> root.draft-primary-foreground;
            draft-accent <=> root.draft-accent;
            draft-border <=> root.draft-border;
            draft-orb1 <=> root.draft-orb1;
            draft-orb2 <=> root.draft-orb2;
            draft-orb3 <=> root.draft-orb3;
            draft-skin-id <=> root.draft-skin-id;
            draft-contrast-checks <=> root.draft-contrast-checks;
            draft-contrast-warning <=> root.draft-contrast-warning;
            auto-update <=> root.settings-auto-update;
            warn-eso-running <=> root.settings-warn-eso-running;
            native-performance-mode <=> root.settings-native-performance-mode;
            official-uploader <=> root.settings-official-uploader;
            auto-open-analysis <=> root.settings-auto-open-analysis;
            conflict-policy <=> root.settings-conflict-policy;
            addons-path <=> root.settings-addons-path;
            minion-detected <=> root.settings-minion-detected;
            pack-hub-authenticated <=> root.settings-pack-hub-authenticated;
            themes: root.themes;
            close => { root.settings-open = false; }
            theme-selected(id) => {
                root.active-theme-id = id;
                root.theme-selected(id);
            }
            theme-create => { root.theme-create(); }
            theme-edit(id) => { root.theme-edit(id); }
            theme-fork(id) => { root.theme-fork(id); }
            theme-save(name) => { root.theme-save(name); }
            theme-delete(id) => { root.theme-delete(id); }
            theme-export(id) => { root.theme-export(id); }
            theme-import => { root.theme-import(); }
            theme-draft-updated => { root.theme-draft-updated(); }
            theme-editor-cancelled => { root.theme-editor-cancelled(); }
            settings-changed => { root.settings-changed(); }
            performance-mode-changed(value) => { root.settings-performance-mode-changed(value); }
            addons-path-opened => { root.settings-addons-path-opened(); }
            addons-path-redetected => { root.settings-addons-path-redetected(); }
            addons-path-applied(path) => { root.settings-addons-path-applied(path); }
            api-compat-clicked => { root.settings-api-compat(); }
            app-update-clicked => { root.settings-app-update(); }
            minion-migration-clicked => {
                root.settings-open = false;
                root.migration-open = true;
                root.migration-phase = 0;
                root.open-migration();
            }
            safety-center-clicked => {
                root.settings-open = false;
                root.safety-open = true;
                root.safety-view = 0;
                root.open-safety();
            }
            addon-list-exported => { root.settings-addon-list-export(); }
            addon-list-imported => { root.settings-addon-list-import(); }
            pack-hub-account-data-clicked => {
                root.settings-open = false;
                root.pack-hub-open-full-hub();
            }
            backup-restore-clicked => {
                root.settings-open = false;
                root.backup-restore-open = true;
                root.backup-restore-view = 0;
                root.open-backup-restore();
            }
            characters-clicked => {
                root.settings-open = false;
                root.characters-open = true;
                root.open-characters();
            }
        }

        // Frameless window edge: a subtle hairline drawn above all content so the
        // borderless window reads as a distinct surface against the desktop and
        // the resizable edges are visible. Non-interactive (no TouchArea), so it
        // never intercepts clicks or the winit edge-resize hit-testing.
        Rectangle {
            x: 0px;
            y: 0px;
            width: root.width;
            height: root.height;
            background: transparent;
            border-width: 1px;
            // Match the native DWMWCP_ROUND radius (~8px) so the stroke follows
            // the rounded window clip; square it when the OS squares the window
            // (maximize / snap) so a rounded stroke never floats in square corners.
            border-radius: root.window-maximized ? 0px : 8px;
            // Theme-adaptive accent at half intensity: follows the active theme's
            // primary color (kept in sync by apply_theme_selection) so the frame
            // recolors per theme, muted to ~50% so it reads as a defined edge
            // without the brightness of a full accent border.
            border-color: Tokens.primary.with-alpha(0.5);
        }
    }
}
