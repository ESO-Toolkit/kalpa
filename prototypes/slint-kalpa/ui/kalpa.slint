        Text {
            width: parent.width;
            height: parent.height;
            text: "Optional";
            color: root.optional ? Palette.gold : Palette.muted-half;
            font-size: 10px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

