    no-frame: true;
    // Frameless windows have no OS resize handles; a non-zero resize border tells
    // the winit backend to enable edge/corner drag-resize (with resize cursors).
    resize-border-width: 8px;
    // Driven from Rust so the edge overlay can drop its rounded corners when the
    // OS squares the window (maximize / snap), matching DWM's corner clipping.
    in-out property <bool> window-maximized;
    preferred-width: 1462px;
    preferred-height: 822px;
    min-width: 1180px;
    min-height: 680px;
    background: Tokens.bg-base;
    default-font-family: "Geist";

    Rectangle {
        width: root.width;
        height: root.height;
        background: #00000000;

        AppBackdrop {
            width: root.width;
            height: root.height;
        }

        Header {
            x: 0px;
            y: 0px;
            width: root.chrome-width;
            chrome-width: root.chrome-width;
            addons-count: root.total-addon-count;
            batch-active: root.batch-active;
            selected-count: root.selected-addon-count;
            checking-updates: root.checking-updates;
            minimize-requested => { root.minimize-requested(); }
            maximize-requested => { root.maximize-requested(); }
            close-requested => { root.close-requested(); }
            window-drag => { root.window-drag-requested(); }
            window-toggle-maximize => { root.maximize-requested(); }
            batch-update => { root.batch-update(); }
            batch-disable => { root.batch-disable(); }
            batch-tag => { root.batch-tag(); }
            batch-remove => { root.batch-remove(); }
            batch-clear => { root.batch-clear(); }
            refresh-requested => { root.refresh-requested(); }
            open-pack-hub-clicked => {
                root.pack-hub-open = true;
                root.pack-hub-view = 0;
                root.open-pack-hub();
            }
            open-svm-clicked => {
                root.svm-open = true;
                root.svm-view = 0;
                root.open-svm();
            }
            open-uploader-clicked => {
                root.uploader-open = true;
                root.uploader-view = 0;
                root.open-uploader();
            }
            open-settings-clicked => {
                root.settings-open = true;
                root.open-settings();
            }
        }

        AppBannerStack {
            x: 0px;
            y: 48px;
            width: root.chrome-width;
            status-error-message: root.status-error-message;
            offline-active: root.offline-active;
            app-update-message: root.app-update-message;
            app-update-action-label: root.app-update-action-label;
            update-available-count: root.update-available-count;
            pending-conflict-count: root.pending-conflict-count;
            open-settings-clicked => {
                root.settings-open = true;
                root.open-settings();
            }
            dismiss-offline-clicked => { root.offline-active = false; }
            app-update-action-clicked => { root.app-update-action(); }
            update-all-clicked => { root.batch-update(); }
            review-conflicts-clicked => { root.review-conflicts(); }
        }

        side := Sidebar {
            x: 0px;
            y: 48px + root.banner-height;
            width: root.sidebar-width;
            height: root.height - 48px - root.banner-height;
            addons: root.addons;
            discover-results: root.discover-results;
            batch-active: root.batch-active;
            total-addon-count: root.total-addon-count;
