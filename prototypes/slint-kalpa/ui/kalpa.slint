    drop-shadow-blur: touch.has-hover ? 18px : 10px;
    drop-shadow-offset-y: touch.has-hover ? 7px : 3px;
    drop-shadow-color: #0000005f;

    animate border-color, drop-shadow-blur, drop-shadow-offset-y { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    Rectangle {
        x: 0px;
        y: 0px;
        width: 188px;
        height: parent.height;
        background: @linear-gradient(90deg, root.identity-wash 0%, #00000000 100%);
    }

    Rectangle {
        width: 3px;
        height: parent.height;
        border-radius: 3px;
        border-width: 0px;
