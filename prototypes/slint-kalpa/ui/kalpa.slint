        x: 1px;
        y: 1px;
        width: parent.width - 2px;
        height: parent.height - 2px;
        border-radius: 9px;
        border-width: 0px;
        background: Palette.white-02;
    }

    Text {
        x: 14px;
        y: 0px;
        width: parent.width - 42px;
        height: parent.height;
        text: root.label;
        color: Palette.foreground;
        font-size: 12px;
        font-weight: 800;
        vertical-alignment: center;
        overflow: elide;
    }

    Image {
        x: parent.width - 28px;
        y: 11px;
        width: 14px;
        height: 14px;
        source: @image-url("../assets/icons/chevron-down.svg");
        image-fit: contain;
        colorize: Palette.muted-half;
    }
}

component PackHubStep inherits Rectangle {
    in property <string> number;
    in property <string> label;
    in property <bool> active: false;
    width: label-text.preferred-width + 34px;
    height: 24px;
    background: #00000000;

    Rectangle {
        x: 0px;
        y: 2px;
        width: 20px;
        height: 20px;
        border-radius: 10px;
        border-width: 0px;
        background: root.active ? Palette.gold-20 : Palette.white-04;

        Text {
            width: parent.width;
            height: parent.height;
            text: root.number;
            color: root.active ? Palette.gold : Palette.muted-half;
            font-size: 11px;
            font-weight: 900;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    label-text := Text {
        x: 28px;
        width: root.width - 28px;
        height: root.height;
        text: root.label;
        color: root.active ? Palette.gold : Palette.muted-half;
        font-size: 12px;
        font-weight: 800;
        vertical-alignment: center;
        overflow: elide;
    }
}

component PackHubTag inherits Rectangle {
    in property <string> label;
    in property <color> tone: Palette.muted-strong;
    width: label-text.preferred-width + 16px;
    height: 21px;
    border-radius: 7px;
    border-width: 0px;
    background: Palette.white-03;

    label-text := Text {
        x: 8px;
        y: 0px;
        height: parent.height;
        text: root.label;
        color: root.tone;
        font-size: 11px;
        font-weight: 800;
        vertical-alignment: center;
    }
}

component PackHubPackCard inherits Rectangle {
    in property <string> title;
    in property <string> description;
    in property <string> tag;
    in property <string> addon-count;
    in property <bool> trial: false;
    callback open-detail;
    height: 98px;
    border-radius: 12px;
    border-width: 0px;
    background: touch.has-hover ? Palette.white-06 : Palette.white-03;
    clip: true;

    animate background { duration: 150ms; easing: ease-in-out; }

    Rectangle {
        x: 0px;
        y: 0px;
        width: 2px;
        height: parent.height;
        border-radius: 2px;
        border-width: 0px;
        background: Palette.gold;
    }

    title-text := Text {
        x: 16px;
        y: 14px;
        width: parent.width - 190px;
        text: root.title;
        color: Palette.foreground;
        font-size: 14px;
        font-weight: 900;
        overflow: elide;
    }

    Pill {
        x: min(16px + title-text.preferred-width + 14px, parent.width - 158px);
        y: 12px;
        label: "Addon Pack";
        tone: Palette.gold;
        fill: Palette.gold-04;
        pill-height: 21px;
        label-font-size: 11px;
    }

    Text {
        x: 16px;
        y: 48px;
        width: parent.width - 132px;
        text: root.description;
        color: Palette.muted-half;
        font-size: 12px;
        font-weight: 600;
        overflow: elide;
    }

    PackHubTag {
        x: 16px;
        y: 72px;
        label: root.tag;
        tone: root.trial ? Palette.red : Palette.muted-strong;
    }

    Image {
        x: 96px;
        y: 77px;
        width: 12px;
        height: 12px;
        source: @image-url("../assets/icons/package.svg");
        image-fit: contain;
        colorize: Palette.muted-half;
    }

    Text {
        x: 114px;
        y: 73px;
        width: 90px;
        height: 20px;
        text: root.addon-count;
        color: Palette.muted-half;
        font-size: 12px;
        font-weight: 600;
        vertical-alignment: center;
    }

    Rectangle {
        x: parent.width - 48px;
        y: 14px;
        width: 32px;
        height: 42px;
        border-radius: 8px;
        border-width: 0px;
        background: Palette.white-04;

        Image {
            x: 9px;
            y: 7px;
            width: 14px;
            height: 14px;
            source: @image-url("../assets/icons/chevron-down.svg");
            transform-rotation: 180deg;
            image-fit: contain;
            colorize: Palette.muted-half;
        }

        Text {
            x: 0px;
            y: 21px;
            width: parent.width;
            text: "1";
            color: Palette.muted-half;
            font-size: 12px;
            font-weight: 800;
            horizontal-alignment: center;
        }
    }

    Rectangle {
        x: parent.width - 78px;
        y: 73px;
        width: 18px;
        height: 18px;
        border-radius: 9px;
        border-width: 0px;
        background: Palette.white-08;

        Text {
            width: parent.width;
            height: parent.height;
            text: "S";
            color: Palette.muted-half;
            font-size: 9px;
            font-weight: 900;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        x: parent.width - 52px;
        y: 74px;
        width: 42px;
        text: "Spike'jo";
        color: Palette.muted-half;
        font-size: 11px;
        font-weight: 600;
        overflow: elide;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.open-detail(); }
    }
}

