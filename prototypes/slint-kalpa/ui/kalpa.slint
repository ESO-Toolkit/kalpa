    in-out property <bool> svm-editor-dirty: false;
    in-out property <string> backup-status-title: "No backup yet";
    in-out property <string> backup-status-subtitle: "Your addon settings aren't protected. Create your first backup below.";
    in-out property <int> backup-status-kind: 0;
    in-out property <string> backup-list-summary: "0 - 0 B total";
    private property <length> error-banner-height: root.status-error-message != "" ? 36px : 0px;
    private property <length> offline-banner-height: root.offline-active ? 36px : 0px;
    private property <length> app-update-banner-height: root.app-update-message != "" ? 36px : 0px;
    private property <length> update-banner-height: root.update-available-count > 0 ? 36px : 0px;
    private property <length> conflict-banner-height: root.pending-conflict-count > 0 ? 36px : 0px;
    private property <length> banner-height: root.error-banner-height + root.offline-banner-height + root.app-update-banner-height + root.update-banner-height + root.conflict-banner-height;
    private property <length> chrome-width: root.width;
    private property <length> sidebar-width: 380px;
    private property <length> content-width: root.chrome-width - root.sidebar-width;
