import "../assets/fonts/GeistVariable.ttf";
import "../assets/fonts/SpaceGroteskVariable.ttf";
import { ListView, ScrollView, TextEdit } from "std-widgets.slint";

export struct DependencyEntry {
    name: string,
    version: string,
    missing: bool,
    outdated: bool,
    install-action: bool,
}

export struct TagEntry {
    id: string,
    label: string,
    kind: int,
    active: bool,
    preset: bool,
}

export struct FileEntry {
    name: string,
    relative-path: string,
    size: string,
    extension: string,
    extension-kind: int,
    indent-level: int,
    folder: bool,
    expanded: bool,
    modified: bool,
    binary: bool,
}

export struct BackupEntry {
    backed-up-at: string,
    update-from: string,
    update-to: string,
    relative-path: string,
}

export struct SavedVariableEntry {
    file-name: string,
    addon-name: string,
    title: string,
    meta: string,
    size-label: string,
    size-bytes: int,
    meter-width: int,
    system: bool,
    orphaned: bool,
}

export struct SettingsBackupEntry {
    name: string,
    display-name: string,
    kind-label: string,
    kind: int,
    meta: string,
    detail: string,
    file-count: int,
    total-size-label: string,
    latest: bool,
    restorable: bool,
}

export struct DiscoverEntry {
    esoui-id: string,
    title: string,
    author: string,
    category: string,
    version: string,
    downloads: string,
    monthly-downloads: string,
    favorites: string,
    updated: string,
    created: string,
    md5: string,
    compatibility: string,
    description: string,
    installed: bool,
    rank: int,
}

export struct ThemeEntry {
    id: string,
    name: string,
    category: string,
    description: string,
    skin-id: string,
    bg-base: color,
    background: color,
    surface: color,
    foreground: color,
    muted-foreground: color,
    primary: color,
    primary-foreground: color,
    accent: color,
    border: color,
    orb1: color,
    orb2: color,
    orb3: color,
    row: int,
    col: int,
    gallery-y: int,
    category-heading: string,
}

export struct ContrastEntry {
    label: string,
    ratio: string,
    level: int,
}

export struct AddonEntry {
    title: string,
    meta: string,
    folder-name: string,
    esoui-id: string,
    author: string,
    version: string,
    api-version: string,
    addon-type: string,
    last-updated: string,
    installed-at: string,
    description: string,
    favorite: bool,
    selected: bool,
    is-library: bool,
    disabled: bool,
    state: int,
    badge: string,
    badge-kind: int,
    badge2: string,
    badge2-kind: int,
    badge3: string,
    badge3-kind: int,
    dependent-summary: string,
    tags: [TagEntry],
    required-dependencies: [DependencyEntry],
    optional-dependencies: [DependencyEntry],
}

