    }

    Hairline { visible: !root.compact-discover-chrome; y: 164px; width: root.width; height: 1px; opacity: 0.5; }

    list-key-focus := FocusScope {
        x: 0px;
        y: 165px;
        width: root.width;
        height: root.height - 165px;
        enabled: !root.discover-active;

        key-pressed(event) => {
            if (root.addons.length == 0) {
                return reject;
            }

            if (event.text == Key.DownArrow) {
                root.selected-index = root.selected-index < root.addons.length - 1 ? root.selected-index + 1 : 0;
                root.addon-selected(root.selected-index);
                return accept;
            } else if (event.text == Key.UpArrow) {
                root.selected-index = root.selected-index > 0 ? root.selected-index - 1 : root.addons.length - 1;
                root.addon-selected(root.selected-index);
                return accept;
            } else if (event.text == Key.Home) {
                root.selected-index = 0;
                root.addon-selected(root.selected-index);
                return accept;
            } else if (event.text == Key.End) {
                root.selected-index = root.addons.length - 1;
                root.addon-selected(root.selected-index);
                return accept;
            } else if (event.text == " ") {
                root.addon-selection-toggled(root.selected-index);
                return accept;
            }

            return reject;
        }
    }

    list-scroll := ListView {
        x: 0px;
        y: 165px;
        width: root.width;
        height: root.height - 165px;
        visible: !root.discover-active;
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        for addon[index] in root.addons : AddonRow {
            width: parent.width;
            title: addon.title;
            meta: addon.meta;
            current: index == root.selected-index;
            favorite: addon.favorite;
            selected: addon.selected;
            batch-active: root.batch-active;
            library: addon.is-library;
            disabled: addon.disabled;
            state: addon.state;
            badge: addon.badge;
            badge-kind: addon.badge-kind;
            badge2: addon.badge2;
            badge2-kind: addon.badge2-kind;
            badge3: addon.badge3;
            badge3-kind: addon.badge3-kind;
            clicked => {
                root.selected-index = index;
                root.addon-selected(index);
            }
            selected-toggled => { root.addon-selection-toggled(index); }
            context-open-folder => {
                root.selected-index = index;
                root.addon-context-open-folder(index);
            }
            context-open-esoui => {
                root.selected-index = index;
                root.addon-context-open-esoui(index);
            }
            context-favorite => {
                root.selected-index = index;
                root.addon-context-favorite(index);
            }
            context-toggle-disable => {
                root.selected-index = index;
                root.addon-context-toggle-disable(index);
            }
            context-remove => {
                root.selected-index = index;
                root.addon-context-remove(index);
            }
        }
    }

    if (!root.discover-active && root.addons.length == 0) : DiscoverEmptyState {
        x: 0px;
        y: 165px;
        width: root.width;
        height: root.height - 165px;
        icon: @image-url("../assets/icons/search.svg");
        title: "No addons found";
        subtitle: "Adjust the search or filter to restore the list.";
    }

    if (root.discover-active) : DiscoverModePanel {
        x: 0px;
        y: root.discover-panel-y;
        width: root.width;
        height: root.height - root.discover-panel-y;
        tab: root.discover-tab;
        entries: root.discover-results;
        selected-index <=> root.selected-discover-index;
        query <=> root.discover-query;
        url-input <=> root.discover-url-input;
        result-selected(index) => { root.discover-selected(index); }
        install-result(index) => { root.discover-install(index); }
        query-edited(value) => { root.discover-query-edited(value); }
        url-edited(value) => { root.discover-url-edited(value); }
    }

    Rectangle {
        visible: root.compact-discover-chrome && root.discover-results.length > 6;
        x: root.width - 10px;
        y: root.discover-panel-y + 46px;
        width: 10px;
        height: root.height - root.discover-panel-y - 46px;
        border-radius: 6px;
        background: Palette.white-03;
    }

    Rectangle {
        visible: root.compact-discover-chrome && root.discover-results.length > 6;
        x: root.width - 8px;
        y: root.discover-panel-y + 58px;
        width: 6px;
        height: 360px;
        border-radius: 6px;
        background: #38bdf84f;
    }

    Rectangle {
        x: root.width - 10px;
        y: 165px;
        width: 10px;
        height: root.height - 165px;
        border-radius: 6px;
        background: Palette.white-03;
        visible: !root.discover-active && list-scroll.viewport-height > list-scroll.height;
    }

    Rectangle {
        x: root.width - 8px;
        y: list-scroll.viewport-height > list-scroll.height ? 165px + (-list-scroll.viewport-y) * ((root.height - 165px - self.height) / (list-scroll.viewport-height - list-scroll.height)) : 165px;
        width: 6px;
        height: 54px;
        border-radius: 6px;
        background: Palette.sky-scroll-thumb;
        visible: !root.discover-active && list-scroll.viewport-height > list-scroll.height;
    }

    if (root.sort-menu-open && !root.discover-active) : Rectangle {
        x: root.width - 146px;
        y: 168px;
        width: 134px;
        height: 122px;
        border-radius: 10px;
        border-width: 0px;
        background: Tokens.bg-base-85;
        drop-shadow-blur: 20px;
        drop-shadow-offset-y: 8px;
        drop-shadow-color: #00000080;
        clip: true;

        sort-name := SortMenuRow {
            y: 8px;
            width: parent.width;
            label: "Name";
            active: root.sort-mode == 0;
            clicked => {
                root.sort-mode = 0;
                root.sort-menu-open = false;
                root.sort-selected(0);
            }
        }
        sort-author := SortMenuRow {
            y: 36px;
            width: parent.width;
            label: "Author";
            active: root.sort-mode == 1;
            clicked => {
                root.sort-mode = 1;
                root.sort-menu-open = false;
                root.sort-selected(1);
            }
        }
        sort-updated := SortMenuRow {
            y: 64px;
            width: parent.width;
            label: "Updated";
            active: root.sort-mode == 2;
            clicked => {
                root.sort-mode = 2;
                root.sort-menu-open = false;
                root.sort-selected(2);
            }
        }
        sort-install := SortMenuRow {
            y: 92px;
            width: parent.width;
            label: "Install Folder";
            active: root.sort-mode == 3;
            clicked => {
                root.sort-mode = 3;
                root.sort-menu-open = false;
                root.sort-selected(3);
            }
        }
    }
}

component ConflictChoiceButton inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    in property <color> tone: Palette.gold;
    callback clicked;
    width: label-text.preferred-width + 22px;
    preferred-width: self.width;
    height: 28px;
    border-radius: 7px;
    border-width: 0px;
    background: root.active ? Palette.gold-15 : (touch.has-hover ? Palette.white-06 : Palette.white-03);

    animate background { duration: 150ms; easing: ease-in-out; }

    label-text := Text {
        x: 11px;
        height: root.height;
        text: root.label;
        color: root.active ? root.tone : (touch.has-hover ? Palette.foreground : Palette.muted-strong);
        font-size: 12px;
        font-weight: 700;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component ConflictFileRow inherits Rectangle {
    in property <string> relative-path;
    in-out property <int> decision: 0;
    callback view-diff;
    height: 72px;
    border-radius: 10px;
    border-width: 0px;
    background: Palette.white-02;

    Text {
        x: 12px;
        y: 10px;
        width: parent.width - 250px;
        text: root.relative-path;
        color: Palette.foreground;
        font-family: "Space Grotesk Light";
        font-size: 13px;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        visible: root.decision != 0;
        x: parent.width - 140px;
        y: 10px;
        width: 128px;
        text: root.decision == 1 ? "KEEPING YOURS" : "TAKING UPDATE";
        color: root.decision == 1 ? Palette.gold : Palette.sky;
        font-family: "Space Grotesk Light";
        font-size: 10px;
        font-weight: 800;
        horizontal-alignment: right;
        overflow: elide;
    }

    ConflictChoiceButton {
        x: 12px;
        y: 36px;
        label: "Keep my version";
        active: root.decision == 1;
        tone: Palette.gold;
        clicked => { root.decision = 1; }
    }

    ConflictChoiceButton {
        x: 136px;
        y: 36px;
        label: "Take the update";
        active: root.decision == 2;
        tone: Palette.sky;
        clicked => { root.decision = 2; }
    }

    ConflictChoiceButton {
        x: 272px;
        y: 36px;
        label: "View differences";
        tone: Palette.muted-strong;
        clicked => { root.view-diff(); }
    }
}

component DetailConflictPanel inherits Rectangle {
    in property <AddonEntry> addon;
    in property <int> conflict-count: 0;
    in-out property <int> decision-one: 0;
    in-out property <int> decision-two: 0;
    in-out property <bool> show-diff: false;
    height: root.show-diff ? 390px : 334px;
    background: #00000000;

    stack := VerticalLayout {
        width: root.width;
        height: root.height;
        spacing: 8px;

        Rectangle {
            width: parent.width;
            height: 74px;
            border-radius: 12px;
            border-width: 0px;
            background: Palette.amber-04;

            Text {
                x: 14px;
                y: 12px;
                width: parent.width - 28px;
                text: root.addon.folder-name + " " + root.addon.version + " -> update";
                color: Palette.amber;
                font-family: "Space Grotesk Light";
                font-size: 14px;
                font-weight: 800;
                overflow: elide;
            }

            Text {
                x: 14px;
                y: 38px;
                width: parent.width - 28px;
                text: "You've edited " + root.conflict-count + " files that this update also changed. Choose which version to keep for each.";
                color: Palette.muted-strong;
                font-size: 12px;
                font-weight: 500;
                overflow: elide;
            }
        }

        Text {
            width: parent.width;
            height: 18px;
            text: "1 of your edited files is unchanged in this update - automatically preserved";
            color: Palette.emerald;
            font-size: 12px;
            font-weight: 600;
            overflow: elide;
        }

        ConflictFileRow {
            width: parent.width;
            relative-path: root.addon.folder-name + ".lua";
            decision <=> root.decision-one;
            view-diff => { root.show-diff = !root.show-diff; }
        }

        ConflictFileRow {
            width: parent.width;
            relative-path: root.addon.folder-name + ".xml";
            decision <=> root.decision-two;
            view-diff => { root.show-diff = !root.show-diff; }
        }

        if (root.show-diff) : Rectangle {
            width: parent.width;
            height: 48px;
            border-radius: 9px;
            border-width: 0px;
            background: Palette.white-02;

            Text { x: 12px; y: 8px; width: parent.width / 2 - 18px; text: "Your version"; color: Palette.gold; font-size: 11px; font-weight: 700; }
            Text { x: parent.width / 2 + 8px; y: 8px; width: parent.width / 2 - 20px; text: "The update"; color: Palette.sky; font-size: 11px; font-weight: 700; }
            Text { x: 12px; y: 28px; width: parent.width / 2 - 18px; text: "- local edited line"; color: Palette.gold; font-family: "Space Grotesk Light"; font-size: 11px; overflow: elide; }
            Text { x: parent.width / 2 + 8px; y: 28px; width: parent.width / 2 - 20px; text: "+ upstream changed line"; color: Palette.sky; font-family: "Space Grotesk Light"; font-size: 11px; overflow: elide; }
            Rectangle { x: parent.width / 2; y: 4px; width: 1px; height: parent.height - 8px; background: Palette.white-04; }
        }

        Rectangle {
            width: parent.width;
            height: 34px;
            background: #00000000;

            Text {
                x: 2px;
                height: parent.height;
                width: 260px;
                text: "3 other files will update normally";
                color: Palette.muted-half;
                font-size: 11px;
                font-weight: 500;
                vertical-alignment: center;
            }

            SettingsActionButton {
                x: parent.width - self.width - 116px;
                y: 3px;
                icon: @image-url("../assets/icons/save.svg");
                label: "Apply & Update";
                primary: true;
            }

            SettingsActionButton {
                x: parent.width - self.width;
                y: 3px;
                icon: @image-url("../assets/icons/chevron-right.svg");
                label: "Skip Update";
            }
        }
    }
}

component DetailPane inherits Rectangle {
    in property <AddonEntry> addon;
    in property <[FileEntry]> files;
    in property <[BackupEntry]> edit-backups;
    in property <int> file-modified-count: 0;
    in property <int> pending-conflict-count: 0;
    in-out property <bool> files-active: false;
    in-out property <string> selected-file-path;
    in-out property <string> selected-file-name;
    in-out property <string> selected-file-content;
    in-out property <string> selected-original-content;
    in-out property <string> editor-line-numbers;
    in-out property <string> editor-message;
    in-out property <length> file-tree-scroll-y: 0px;
    in-out property <string> custom-tag-draft;
    in-out property <bool> editor-open: false;
    in-out property <bool> editor-editable: false;
    in-out property <bool> editor-binary: false;
    in-out property <bool> editor-error: false;
    in-out property <bool> show-backups: false;
    callback file-selected(string);
    callback folder-toggled(string);
    callback file-content-edited(string);
    callback save-file(string, string);
    callback open-folder;
    callback open-external(string);
    callback rescan;
    callback load-backups;
    callback restore-backup(int);
    callback tag-clicked(string);
    callback add-tag-clicked;
    callback custom-tag-submitted(string);
    callback open-esoui(string);
    callback toggle-addon-disabled;
    callback remove-addon;
    callback install-dependency(string, bool);
    callback remove-dependency(string, bool);
    background: #00000000;
    clip: true;

    detail-scroll := ScrollView {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        viewport-width: root.width;
        viewport-height: root.files-active ? 750px : (root.pending-conflict-count > 0 ? 1518px : root.height);
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        detail-content := VerticalLayout {
            x: 24px;
            y: 29px;
            width: root.width - 48px;
            height: root.files-active ? 730px : (root.pending-conflict-count > 0 ? 1458px : root.height - 58px);
            spacing: 0px;

            GradientHeading {
                width: parent.width;
                label: root.addon.title;
            }

            Rectangle { height: 2px; background: #00000000; }

            HorizontalLayout {
                height: 22px;
                spacing: 8px;
                Pill {
                    label: root.addon.folder-name + "/";
                    tone: Palette.muted-dim;
                    fill: Palette.white-03;
                    line: Palette.white-10;
                }
                Pill {
                    label: "ESOUI #" + root.addon.esoui-id;
                    tone: Palette.sky;
                    fill: Palette.sky-04;
                    line: Palette.sky-20;
                }
            }

            if (!root.files-active && root.pending-conflict-count > 0) : Rectangle { height: 16px; background: #00000000; }

            if (!root.files-active && root.pending-conflict-count > 0) : DetailConflictPanel {
                width: parent.width;
                addon: root.addon;
                conflict-count: root.pending-conflict-count;
            }

            Rectangle { height: 7px; background: #00000000; }

            Rectangle {
                height: 36px;
                background: #00000000;
                DetailTabStrip {
                    x: 0px;
                    y: 0px;
                    width: 176px;
                    height: 36px;
                    files-active: root.files-active;
                    details-clicked => { root.files-active = false; }
                    files-clicked => { root.files-active = true; }
                }
            }

            Rectangle { height: 14px; background: #00000000; }

            if (root.files-active) : DetailFilesPanel {
                width: parent.width;
                panel-width: parent.width;
                addon: root.addon;
                files: root.files;
                backups: root.edit-backups;
                modified-count: root.file-modified-count;
                selected-file-path <=> root.selected-file-path;
                selected-file-name <=> root.selected-file-name;
                selected-file-content <=> root.selected-file-content;
                selected-original-content <=> root.selected-original-content;
                editor-line-numbers <=> root.editor-line-numbers;
                editor-message <=> root.editor-message;
                tree-scroll-y <=> root.file-tree-scroll-y;
                editor-open <=> root.editor-open;
                editor-editable <=> root.editor-editable;
                editor-binary <=> root.editor-binary;
                editor-error <=> root.editor-error;
                show-backups <=> root.show-backups;
                file-selected(path) => { root.file-selected(path); }
                folder-toggled(path) => { root.folder-toggled(path); }
                file-content-edited(content) => { root.file-content-edited(content); }
                save-file(path, content) => { root.save-file(path, content); }
                open-folder => { root.open-folder(); }
                open-external(path) => { root.open-external(path); }
                rescan => { root.rescan(); }
                load-backups => { root.load-backups(); }
                restore-backup(index) => { root.restore-backup(index); }
            }

            if (!root.files-active) : DetailInfoPanel {
                width: parent.width;
                addon: root.addon;
                open-esoui(id) => { root.open-esoui(id); }
            }

            if (!root.files-active) : Rectangle { height: 14px; background: #00000000; }

            if (!root.files-active) : DetailSectionTitle {
                width: parent.width;
                label: "TAGS";
            }

            if (!root.files-active) : Rectangle { height: 8px; background: #00000000; }

            if (!root.files-active) : DetailTagsSection {
                width: parent.width;
                tags: root.addon.tags;
                custom-tag-draft <=> root.custom-tag-draft;
                tag-clicked(id) => { root.tag-clicked(id); }
                add-tag-clicked => { root.add-tag-clicked(); }
                custom-tag-submitted(value) => { root.custom-tag-submitted(value); }
            }

            if (!root.files-active) : Rectangle { height: 28px; background: #00000000; }

            if (!root.files-active) : DetailSectionTitle {
                width: parent.width;
                label: "DESCRIPTION";
            }

            if (!root.files-active) : Rectangle { height: 8px; background: #00000000; }

            if (!root.files-active) : DetailDescriptionSection {
                width: parent.width;
                description: root.addon.description;
            }

            if (!root.files-active) : Rectangle { height: 24px; background: #00000000; }

            if (!root.files-active && root.addon.required-dependencies.length > 0) : DetailSectionTitle {
                width: parent.width;
                label: "REQUIRED DEPENDENCIES";
            }

            if (!root.files-active && root.addon.required-dependencies.length > 0) : Rectangle { height: 16px; background: #00000000; }

            if (!root.files-active && root.addon.required-dependencies.length > 0) : DetailDependencySection {
                width: parent.width;
                dependencies: root.addon.required-dependencies;
                install-dependency(name, optional) => { root.install-dependency(name, optional); }
                remove-dependency(name, optional) => { root.remove-dependency(name, optional); }
            }

            if (!root.files-active && root.addon.optional-dependencies.length > 0) : Rectangle { height: 24px; background: #00000000; }

            if (!root.files-active && root.addon.optional-dependencies.length > 0) : DetailSectionTitle {
                width: parent.width;
                label: "OPTIONAL DEPENDENCIES";
            }

            if (!root.files-active && root.addon.optional-dependencies.length > 0) : Rectangle { height: 16px; background: #00000000; }

            if (!root.files-active && root.addon.optional-dependencies.length > 0) : DetailDependencySection {
                width: parent.width;
                dependencies: root.addon.optional-dependencies;
                optional-section: true;
                install-dependency(name, optional) => { root.install-dependency(name, optional); }
                remove-dependency(name, optional) => { root.remove-dependency(name, optional); }
            }

            if (!root.files-active) : Rectangle { height: 24px; background: #00000000; }

            if (!root.files-active) : DetailActionFooter {
                width: parent.width;
                addon-disabled: root.addon.disabled;
                dependent-summary: root.addon.dependent-summary;
                toggle-disabled => { root.toggle-addon-disabled(); }
                remove-addon => { root.remove-addon(); }
            }

            Rectangle { height: 40px; background: #00000000; }
        }

    }

    Rectangle {
        x: root.width - 10px;
        y: 8px;
        width: 10px;
        height: root.height - 16px;
        border-radius: 6px;
        background: Palette.white-03;
        visible: detail-scroll.viewport-height > detail-scroll.height;
    }

    Rectangle {
        x: root.width - 8px;
        y: detail-scroll.viewport-height > detail-scroll.height ? 8px + (-detail-scroll.viewport-y) * ((root.height - 16px - self.height) / (detail-scroll.viewport-height - detail-scroll.height)) : 8px;
        width: 6px;
        height: 156px;
        border-radius: 6px;
        background: Palette.sky-scroll-thumb;
        visible: detail-scroll.viewport-height > detail-scroll.height;
    }
}

component DiscoverStatCard inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <string> value;
    in property <int> accent-kind: 0;
    in property <length> card-width: 120px;
    private property <color> tone: root.accent-kind == 1 ? Palette.emerald : (root.accent-kind == 2 ? Palette.gold : (root.accent-kind == 3 ? Palette.violet : Palette.sky));
    width: root.card-width;
    height: 64px;
    border-radius: 12px;
    border-width: 0px;
    background: Palette.white-08;
    clip: true;

    Rectangle {
        x: 1px;
        y: 1px;
        width: parent.width - 2px;
        height: parent.height - 2px;
        border-radius: 11px;
        border-width: 0px;
        background: @linear-gradient(180deg, Palette.white-02 0%, #ffffff03 100%);
    }

    Image {
        x: 10px;
        y: 10px;
        width: 14px;
        height: 14px;
        source: root.icon;
        image-fit: contain;
        colorize: root.tone;
    }

    Text {
        x: 30px;
        y: 10px;
        width: parent.width - 40px;
        text: root.label;
        color: Palette.muted-dim;
        font-family: "Space Grotesk Light";
        font-size: 10px;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        x: 10px;
        y: 32px;
        width: parent.width - 20px;
        text: root.value == "" ? "-" : root.value;
        color: Palette.foreground;
        font-size: 14px;
        font-weight: 700;
        overflow: elide;
    }
}

component DiscoverDetailPane inherits Rectangle {
    in property <DiscoverEntry> entry;
    in property <int> selected-index: 0;
    in property <length> pane-width: 1082px;
    callback install-clicked(int);
    callback open-esoui(string);
    private property <bool> show-screenshots: root.entry.esoui-id == "1346";
    background: #00000000;
    clip: true;

    detail-scroll := ScrollView {
        width: root.pane-width;
        height: root.height;
        viewport-width: root.pane-width;
        viewport-height: root.show-screenshots ? 1360px : 900px;
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        content := VerticalLayout {
            x: 24px;
            y: 29px;
            width: root.pane-width - 48px;
            height: root.show-screenshots ? 1340px : 860px;
            spacing: 0px;

            Rectangle {
                width: parent.width;
                height: 74px;
                background: #00000000;

                Text {
                    x: 0px;
                    y: 0px;
                    width: parent.width - 180px;
                    text: root.entry.title;
                    color: Palette.gold;
                    font-family: "Space Grotesk Light";
                    font-size: 20px;
                    font-weight: 600;
                    overflow: elide;
                }

                Text {
                    x: 0px;
                    y: 0px;
                    width: parent.width - 180px;
                    text: root.entry.title;
                    color: Palette.gold-hot;
                    opacity: 0.34;
                    font-family: "Space Grotesk Light";
                    font-size: 20px;
                    font-weight: 600;
                    overflow: elide;
                }

                author-line := Text {
                    x: 0px;
                    y: 44px;
                    width: parent.width - 340px;
                    text: root.entry.author == "" ? "" : "by " + root.entry.author;
                    color: Palette.muted-half;
                    font-size: 14px;
                    font-weight: 500;
                    overflow: elide;
                }

                Pill {
                    visible: root.entry.category != "";
                    x: min(author-line.preferred-width + 14px, parent.width - self.width - 190px);
                    y: 40px;
                    label: root.entry.category;
                    tone: Palette.muted-strong;
                    fill: Palette.white-03;
                    line: Palette.white-10;
                }

                SmallAction {
                    x: parent.width - self.width;
                    y: 0px;
                    label: root.entry.installed ? "Reinstall" : "Install";
                    tone: Palette.gold;
                    fill: Palette.gold-10;
                    fill-hover: Palette.gold-15;
                    fill-pressed: Palette.gold-20;
                    clicked => { root.install-clicked(root.selected-index); }
                }

                PlainLinkAction {
                    x: parent.width - self.width;
                    y: 34px;
                    label: "View on ESOUI";
                    tone: Palette.muted-half;
                    clicked => { root.open-esoui(root.entry.esoui-id); }
                }
            }

            Rectangle { height: 2px; background: #00000000; }

            stats-row := Rectangle {
                width: parent.width;
                height: 68px;
                background: #00000000;
                private property <length> stat-gap: 8px;
                private property <length> stat-width: (self.width - self.stat-gap * 3) / 4;

                DiscoverStatCard {
                    x: 0px;
                    card-width: parent.stat-width;
                    icon: @image-url("../assets/icons/cloud-upload.svg");
                    label: "DOWNLOADS";
                    value: root.entry.downloads;
                    accent-kind: 0;
                }

                DiscoverStatCard {
                    x: parent.stat-width + parent.stat-gap;
                    card-width: parent.stat-width;
                    icon: @image-url("../assets/icons/package.svg");
                    label: "MONTHLY";
                    value: root.entry.monthly-downloads;
                    accent-kind: 1;
                }

                DiscoverStatCard {
                    x: (parent.stat-width + parent.stat-gap) * 2;
                    card-width: parent.stat-width;
                    icon: @image-url("../assets/icons/square.svg");
                    label: "FAVORITES";
                    value: root.entry.favorites;
                    accent-kind: 2;
                }

                DiscoverStatCard {
                    x: (parent.stat-width + parent.stat-gap) * 3;
                    card-width: parent.stat-width;
                    icon: @image-url("../assets/icons/refresh-cw.svg");
                    label: "UPDATED";
                    value: root.entry.updated;
                    accent-kind: 3;
                }
            }

            Rectangle { height: 20px; background: #00000000; }

            Rectangle {
                width: parent.width;
                height: 118px;
                border-radius: 12px;
                border-width: 0px;
                background: Palette.white-08;
                clip: true;

                Rectangle {
                    x: 1px;
                    y: 1px;
                    width: parent.width - 2px;
                    height: parent.height - 2px;
                    border-radius: 11px;
                    border-width: 0px;
                    background: @linear-gradient(180deg, Palette.white-02 0%, #ffffff03 100%);
                }

                DetailSectionTitle { x: 22px; y: 18px; width: 180px; label: "VERSION"; }
                Text { x: 22px; y: 46px; width: 260px; text: root.entry.version; color: Palette.foreground; font-size: 15px; font-weight: 700; overflow: elide; }

                DetailSectionTitle { x: parent.width * 0.34; y: 18px; width: 220px; label: "COMPATIBILITY"; }
                Text { x: parent.width * 0.34; y: 46px; width: parent.width * 0.27; text: root.entry.compatibility; color: Palette.foreground; font-size: 15px; font-weight: 700; overflow: elide; }

                DetailSectionTitle { x: parent.width * 0.68; y: 18px; width: 180px; label: "MD5"; }
                Text { x: parent.width * 0.68; y: 46px; width: parent.width * 0.30 - 20px; text: root.entry.md5; color: Palette.foreground; font-family: "Space Grotesk Light"; font-size: 14px; font-weight: 700; overflow: elide; }

                DetailSectionTitle { x: 22px; y: 76px; width: 180px; label: "CREATED"; }
                Text { x: 22px; y: 96px; width: 280px; text: root.entry.created; color: Palette.foreground; font-size: 15px; font-weight: 700; overflow: elide; }
            }

            Rectangle { height: 26px; background: #00000000; }

            if (root.show-screenshots) : DetailSectionTitle {
                width: parent.width;
                label: "SCREENSHOTS (3)";
            }

            if (root.show-screenshots) : Rectangle { height: 8px; background: #00000000; }

            if (root.show-screenshots) : Rectangle {
                width: parent.width;
                height: 300px;
                border-radius: 12px;
                border-width: 0px;
                background: Palette.white-08;
                drop-shadow-blur: 16px;
                drop-shadow-offset-y: 8px;
                drop-shadow-color: #00000033;
                clip: true;

                Rectangle {
                    x: 1px;
                    y: 1px;
                    width: parent.width - 2px;
                    height: parent.height - 2px;
                    border-radius: 11px;
                    border-width: 0px;
                    background: @linear-gradient(180deg, Palette.white-03 0%, Palette.white-02 100%);
                }

                Image {
                    x: parent.width / 2 - 258px;
                    y: 8px;
                    width: 516px;
                    height: 268px;
                    source: @image-url("../assets/discover/lazy-writ-crafter-main.png");
                    image-fit: cover;
                }

                Rectangle {
                    x: 16px;
                    y: parent.height / 2 - 18px;
                    width: 36px;
                    height: 36px;
                    border-radius: 18px;
                    border-width: 0px;
                    background: #00000059;

                    Image { x: 11px; y: 11px; width: 14px; height: 14px; source: @image-url("../assets/icons/chevron-right.svg"); image-fit: contain; colorize: Palette.foreground; transform-rotation: 180deg; }
                }

                Rectangle {
                    x: parent.width - 52px;
                    y: parent.height / 2 - 18px;
                    width: 36px;
                    height: 36px;
                    border-radius: 18px;
                    border-width: 0px;
                    background: #00000059;

                    Image { x: 11px; y: 11px; width: 14px; height: 14px; source: @image-url("../assets/icons/chevron-right.svg"); image-fit: contain; colorize: Palette.foreground; }
                }

                Rectangle {
                    x: parent.width - 60px;
                    y: 12px;
                    width: 44px;
                    height: 22px;
                    border-radius: 8px;
                    border-width: 0px;
                    background: #00000066;

                    Text { width: parent.width; height: parent.height; text: "1 / 3"; color: Palette.foreground; font-size: 10px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    x: parent.width / 2 - 26px;
                    y: parent.height - 42px;
                    width: 52px;
                    height: 18px;
                    border-radius: 9px;
                    border-width: 0px;
                    background: #00000059;

                    Rectangle { x: 11px; y: 6px; width: 6px; height: 6px; border-radius: 3px; background: Palette.gold; }
                    Rectangle { x: 23px; y: 6px; width: 6px; height: 6px; border-radius: 3px; background: Palette.muted-half; }
                    Rectangle { x: 35px; y: 6px; width: 6px; height: 6px; border-radius: 3px; background: Palette.muted-half; }
                }
            }

            if (root.show-screenshots) : Rectangle { height: 16px; background: #00000000; }

            if (root.show-screenshots) : Rectangle {
                width: parent.width;
                height: 58px;
                background: #00000000;

                Rectangle { x: 0px; y: 0px; width: 100px; height: 58px; border-radius: 7px; border-width: 0px; background: Palette.gold-25; }
                Image { x: 2px; y: 2px; width: 96px; height: 54px; source: @image-url("../assets/discover/lazy-writ-crafter-thumb-1.png"); image-fit: cover; opacity: 0.98; }
                Image { x: 112px; y: 0px; width: 100px; height: 58px; source: @image-url("../assets/discover/lazy-writ-crafter-thumb-2.png"); image-fit: cover; opacity: 0.45; }
                Image { x: 224px; y: 0px; width: 100px; height: 58px; source: @image-url("../assets/discover/lazy-writ-crafter-thumb-3.png"); image-fit: cover; opacity: 0.45; }
            }

            if (root.show-screenshots) : Rectangle { height: 24px; background: #00000000; }

            DetailSectionTitle {
                width: parent.width;
                label: "DESCRIPTION";
            }

            Rectangle { height: 8px; background: #00000000; }

            Rectangle {
                width: parent.width;
                height: 178px;
                border-radius: 12px;
                border-width: 0px;
                background: @linear-gradient(180deg, Palette.white-03 0%, Palette.white-02 100%);

                Text {
                    x: 16px;
                    y: 15px;
                    width: parent.width - 32px;
                    height: parent.height - 30px;
                    text: root.entry.description;
                    color: Palette.text-soft;
                    font-size: 14px;
                    font-weight: 500;
                    wrap: word-wrap;
                    overflow: elide;
                }
            }

            Rectangle { height: 40px; background: #00000000; }
        }
    }

    Rectangle {
        x: root.pane-width - 10px;
        y: 8px;
        width: 10px;
        height: root.height - 16px;
        border-radius: 6px;
        background: Palette.white-02;
        visible: detail-scroll.viewport-height > detail-scroll.height;
    }

    Rectangle {
        x: root.pane-width - 8px;
        y: detail-scroll.viewport-height > detail-scroll.height ? 8px + (-detail-scroll.viewport-y) * ((root.height - 16px - self.height) / (detail-scroll.viewport-height - detail-scroll.height)) : 8px;
        width: 6px;
        height: 156px;
        border-radius: 6px;
        background: Palette.white-10;
        visible: detail-scroll.viewport-height > detail-scroll.height;
    }
}

export component KalpaWindow inherits Window {
    in property <[AddonEntry]> addons;
    in property <[FileEntry]> addon-files;
    in property <[BackupEntry]> edit-backups;
    in property <[DiscoverEntry]> discover-results;
    in property <[SavedVariableEntry]> svm-files;
    in property <[SavedVariableEntry]> svm-orphaned-files;
    in property <[SettingsBackupEntry]> settings-backups;
    in property <[ThemeEntry]> themes;
    in property <int> total-addon-count: 0;
    in property <int> addon-kind-count: 0;
    in property <int> library-kind-count: 0;
    in property <int> favorite-addon-count: 0;
    in property <int> outdated-addon-count: 0;
    in property <int> issue-addon-count: 0;
    in property <int> disabled-addon-count: 0;
    in property <int> testing-tag-count: 0;
    in property <int> broken-tag-count: 0;
    in property <int> essential-tag-count: 0;
    in property <int> raid-tag-count: 0;
    in-out property <bool> batch-active: false;
    in-out property <int> selected-addon-count: 0;
    in-out property <int> file-modified-count: 0;
    in-out property <string> selected-file-path;
    in-out property <string> selected-file-name;
    in-out property <string> selected-file-content;
    in-out property <string> selected-original-content;
    in-out property <string> editor-line-numbers;
    in-out property <string> editor-message;
    in-out property <length> file-tree-scroll-y: 0px;
    in-out property <string> addon-search-query;
    in-out property <string> custom-tag-draft;
    in-out property <bool> editor-open: false;
    in-out property <bool> editor-editable: false;
    in-out property <bool> editor-binary: false;
    in-out property <bool> editor-error: false;
    in-out property <bool> show-file-backups: false;
    in-out property <bool> settings-open: false;
    in-out property <int> settings-tab: 0;
    in-out property <bool> settings-editor-open: false;
    in-out property <bool> pack-hub-open: false;
    in-out property <int> pack-hub-view: 0;
    in-out property <bool> uploader-open: false;
    in-out property <int> uploader-view: 0;
    in-out property <bool> svm-open: false;
    in-out property <int> svm-view: 0;
    in-out property <bool> backup-restore-open: false;
    in-out property <int> backup-restore-view: 0;
    in-out property <string> backup-label-draft;
    in-out property <int> selected-index: 5;
    in-out property <int> selected-discover-index: 0;
    in-out property <bool> detail-files-active: false;
    in-out property <bool> discover-active: false;
    in-out property <int> filter-mode: 0;
    in-out property <int> sort-mode: 0;
    in-out property <int> discover-tab: 0;
    in-out property <string> discover-query;
    in-out property <string> discover-url-input;
    in-out property <string> status-error-message;
    in-out property <bool> offline-active: false;
    in-out property <string> app-update-message;
    in-out property <int> update-available-count: 0;
    in-out property <int> pending-conflict-count: 0;
    in-out property <string> active-theme-id: "nordic-runestone";
    in-out property <ThemeEntry> draft-theme;
    in-out property <string> draft-theme-id;
    in-out property <string> draft-theme-name;
    in-out property <string> draft-theme-description;
    in-out property <bool> draft-theme-new: true;
    in-out property <string> draft-bg-base;
    in-out property <string> draft-background;
    in-out property <string> draft-surface;
    in-out property <string> draft-foreground;
    in-out property <string> draft-muted-foreground;
    in-out property <string> draft-primary;
    in-out property <string> draft-primary-foreground;
    in-out property <string> draft-accent;
    in-out property <string> draft-border;
    in-out property <string> draft-orb1;
    in-out property <string> draft-orb2;
    in-out property <string> draft-orb3;
    in-out property <[ContrastEntry]> draft-contrast-checks;
    in-out property <string> draft-contrast-warning;
    in-out property <bool> settings-auto-update: false;
    in-out property <bool> settings-warn-eso-running: true;
    in-out property <bool> settings-native-performance-mode: true;
    in-out property <bool> settings-official-uploader: false;
    in-out property <bool> settings-auto-open-analysis: false;
    in-out property <int> settings-conflict-policy: 0;
    in-out property <string> settings-addons-path;
    in-out property <bool> settings-minion-detected: false;
    in-out property <bool> settings-pack-hub-authenticated: false;
    in-out property <string> svm-file-count-label: "0";
    in-out property <string> svm-total-size-label: "0 B";
    in-out property <string> svm-orphan-count-label: "0";
    in-out property <string> svm-orphan-size-label: "0 B";
    in-out property <string> svm-large-count-label: "0";
    in-out property <bool> svm-has-orphans: false;
    in-out property <bool> svm-has-files: false;
    in-out property <string> backup-status-title: "No backup yet";
    in-out property <string> backup-status-subtitle: "Your addon settings aren't protected. Create your first backup below.";
    in-out property <int> backup-status-kind: 0;
    in-out property <string> backup-list-summary: "0 - 0 B total";
    private property <length> error-banner-height: root.status-error-message != "" ? 36px : 0px;
    private property <length> offline-banner-height: root.offline-active ? 36px : 0px;
    private property <length> app-update-banner-height: root.app-update-message != "" ? 36px : 0px;
    private property <length> update-banner-height: root.update-available-count > 0 ? 36px : 0px;
    private property <length> conflict-banner-height: root.pending-conflict-count > 0 ? 36px : 0px;
    private property <length> banner-height: root.error-banner-height + root.offline-banner-height + root.app-update-banner-height + root.update-banner-height + root.conflict-banner-height;
    private property <length> chrome-width: root.width;
    private property <length> sidebar-width: 380px;
    private property <length> content-width: root.chrome-width - root.sidebar-width;
    title: "Kalpa";
    callback minimize-requested;
    callback maximize-requested;
    callback close-requested;
    callback addon-selected(int);
    callback addon-selection-toggled(int);
    callback addon-context-open-folder(int);
    callback addon-context-open-esoui(int);
    callback addon-context-favorite(int);
    callback addon-context-toggle-disable(int);
    callback addon-context-remove(int);
    callback addon-search-edited(string);
    callback filter-selected(int);
    callback sort-selected(int);
    callback batch-update;
    callback batch-disable;
    callback batch-tag;
    callback batch-remove;
    callback batch-clear;
    callback refresh-requested;
    callback file-selected(string);
    callback folder-toggled(string);
    callback file-content-edited(string);
    callback save-file(string, string);
    callback open-folder;
    callback open-external(string);
    callback rescan-files;
    callback load-edit-backups;
    callback restore-edit-backup(int);
    callback tag-clicked(string);
    callback add-tag-clicked;
    callback custom-tag-submitted(string);
    callback open-esoui(string);
    callback toggle-addon-disabled;
    callback remove-addon;
    callback install-dependency(string, bool);
    callback remove-dependency(string, bool);
    callback discover-tab-selected(int);
    callback discover-selected(int);
    callback discover-install(int);
    callback discover-open-esoui(string);
    callback discover-query-edited(string);
    callback discover-url-edited(string);
    callback open-pack-hub;
    callback open-uploader;
    callback open-svm;
    callback svm-refresh;
    callback open-backup-restore;
    callback backup-restore-refresh;
    callback backup-restore-create(string);
    callback backup-restore-restore(int);
    callback backup-restore-delete(int);
    callback backup-restore-reveal-folder;
    callback open-settings;
    callback theme-selected(string);
    callback theme-create;
    callback theme-edit(string);
    callback theme-fork(string);
    callback theme-save(string);
    callback theme-delete(string);
    callback theme-export(string);
    callback theme-import;
    callback theme-draft-updated;
    callback theme-editor-cancelled;
    callback settings-changed;
    callback settings-performance-mode-changed(bool);
    callback settings-addons-path-opened;
    callback settings-addons-path-redetected;
    callback settings-addons-path-applied(string);
    callback settings-api-compat;
    callback settings-addon-list-export;
    callback settings-addon-list-import;
    callback review-conflicts;
    no-frame: true;
    preferred-width: 1462px;
    preferred-height: 822px;
    min-width: 1180px;
    min-height: 680px;
    background: Tokens.bg-base;
    default-font-family: "Geist";

    Rectangle {
        width: root.width;
        height: root.height;
        background: #00000000;

        AppBackdrop {
            width: root.width;
            height: root.height;
        }

        Header {
            x: 0px;
            y: 0px;
            width: root.chrome-width;
            chrome-width: root.chrome-width;
            addons-count: root.total-addon-count;
            batch-active: root.batch-active;
            selected-count: root.selected-addon-count;
            minimize-requested => { root.minimize-requested(); }
            maximize-requested => { root.maximize-requested(); }
            close-requested => { root.close-requested(); }
            batch-update => { root.batch-update(); }
            batch-disable => { root.batch-disable(); }
            batch-tag => { root.batch-tag(); }
            batch-remove => { root.batch-remove(); }
            batch-clear => { root.batch-clear(); }
            refresh-requested => { root.refresh-requested(); }
            open-pack-hub-clicked => {
                root.pack-hub-open = true;
                root.pack-hub-view = 0;
                root.open-pack-hub();
            }
            open-svm-clicked => {
                root.svm-open = true;
                root.svm-view = 0;
                root.open-svm();
            }
            open-uploader-clicked => {
                root.uploader-open = true;
                root.uploader-view = 0;
                root.open-uploader();
            }
            open-settings-clicked => {
                root.settings-open = true;
                root.open-settings();
            }
        }

        AppBannerStack {
            x: 0px;
            y: 48px;
            width: root.chrome-width;
            status-error-message: root.status-error-message;
            offline-active: root.offline-active;
            app-update-message: root.app-update-message;
            update-available-count: root.update-available-count;
            pending-conflict-count: root.pending-conflict-count;
            open-settings-clicked => {
                root.settings-open = true;
                root.open-settings();
            }
            dismiss-offline-clicked => { root.offline-active = false; }
            update-all-clicked => { root.batch-update(); }
            review-conflicts-clicked => { root.review-conflicts(); }
        }

        side := Sidebar {
            x: 0px;
            y: 48px + root.banner-height;
            width: root.sidebar-width;
            height: root.height - 48px - root.banner-height;
            addons: root.addons;
            discover-results: root.discover-results;
            batch-active: root.batch-active;
            total-addon-count: root.total-addon-count;
            addon-kind-count: root.addon-kind-count;
            library-kind-count: root.library-kind-count;
            favorite-addon-count: root.favorite-addon-count;
            outdated-addon-count: root.outdated-addon-count;
            issue-addon-count: root.issue-addon-count;
            disabled-addon-count: root.disabled-addon-count;
            testing-tag-count: root.testing-tag-count;
            broken-tag-count: root.broken-tag-count;
            essential-tag-count: root.essential-tag-count;
            raid-tag-count: root.raid-tag-count;
            selected-index <=> root.selected-index;
            selected-discover-index <=> root.selected-discover-index;
            discover-active <=> root.discover-active;
            filter-mode <=> root.filter-mode;
            sort-mode <=> root.sort-mode;
            addon-search-query <=> root.addon-search-query;
            discover-tab <=> root.discover-tab;
            discover-query <=> root.discover-query;
            discover-url-input <=> root.discover-url-input;
            addon-selected(index) => { root.addon-selected(index); }
            addon-selection-toggled(index) => { root.addon-selection-toggled(index); }
            addon-context-open-folder(index) => { root.addon-context-open-folder(index); }
            addon-context-open-esoui(index) => { root.addon-context-open-esoui(index); }
            addon-context-favorite(index) => { root.addon-context-favorite(index); }
            addon-context-toggle-disable(index) => { root.addon-context-toggle-disable(index); }
            addon-context-remove(index) => { root.addon-context-remove(index); }
            addon-search-edited(value) => { root.addon-search-edited(value); }
            filter-selected(mode) => { root.filter-selected(mode); }
            sort-selected(mode) => { root.sort-selected(mode); }
            discover-tab-selected(tab) => { root.discover-tab-selected(tab); }
            discover-selected(index) => { root.discover-selected(index); }
            discover-install(index) => { root.discover-install(index); }
            discover-query-edited(value) => { root.discover-query-edited(value); }
            discover-url-edited(value) => { root.discover-url-edited(value); }
        }

        if (!side.discover-active && root.addons.length > 0) : DetailPane {
            x: root.sidebar-width;
            y: 48px + root.banner-height;
            width: root.content-width;
            height: root.height - 48px - root.banner-height;
            addon: root.addons[root.selected-index];
            files: root.addon-files;
            edit-backups: root.edit-backups;
            file-modified-count: root.file-modified-count;
            pending-conflict-count: root.pending-conflict-count;
            files-active <=> root.detail-files-active;
            selected-file-path <=> root.selected-file-path;
            selected-file-name <=> root.selected-file-name;
            selected-file-content <=> root.selected-file-content;
            selected-original-content <=> root.selected-original-content;
            editor-line-numbers <=> root.editor-line-numbers;
            editor-message <=> root.editor-message;
            file-tree-scroll-y <=> root.file-tree-scroll-y;
            custom-tag-draft <=> root.custom-tag-draft;
            editor-open <=> root.editor-open;
            editor-editable <=> root.editor-editable;
            editor-binary <=> root.editor-binary;
            editor-error <=> root.editor-error;
            show-backups <=> root.show-file-backups;
            file-selected(path) => { root.file-selected(path); }
            folder-toggled(path) => { root.folder-toggled(path); }
            file-content-edited(content) => { root.file-content-edited(content); }
            save-file(path, content) => { root.save-file(path, content); }
            open-folder => { root.open-folder(); }
            open-external(path) => { root.open-external(path); }
            rescan => { root.rescan-files(); }
            load-backups => { root.load-edit-backups(); }
            restore-backup(index) => { root.restore-edit-backup(index); }
            tag-clicked(id) => { root.tag-clicked(id); }
            add-tag-clicked => { root.add-tag-clicked(); }
            custom-tag-submitted(value) => { root.custom-tag-submitted(value); }
            open-esoui(id) => { root.open-esoui(id); }
            toggle-addon-disabled => { root.toggle-addon-disabled(); }
            remove-addon => { root.remove-addon(); }
            install-dependency(name, optional) => { root.install-dependency(name, optional); }
            remove-dependency(name, optional) => { root.remove-dependency(name, optional); }
        }

        if (!side.discover-active && root.addons.length == 0) : DiscoverEmptyState {
            x: root.sidebar-width;
            y: 48px + root.banner-height;
            width: root.content-width;
            height: root.height - 48px - root.banner-height;
            icon: @image-url("../assets/icons/search.svg");
            title: "No Addon Selected";
            subtitle: "Clear search or choose a different filter to show addon details.";
        }

        if (side.discover-active && root.discover-results.length > 0) : DiscoverDetailPane {
            x: root.sidebar-width;
            y: 48px + root.banner-height;
            width: root.content-width;
            pane-width: root.content-width;
            height: root.height - 48px - root.banner-height;
            entry: root.discover-results[root.selected-discover-index];
            selected-index: root.selected-discover-index;
            install-clicked(index) => { root.discover-install(index); }
            open-esoui(id) => { root.discover-open-esoui(id); }
        }

        if (side.discover-active && root.discover-results.length == 0) : DiscoverEmptyState {
            x: root.sidebar-width;
            y: 48px + root.banner-height;
            width: root.content-width;
            height: root.height - 48px - root.banner-height;
            icon: @image-url("../assets/icons/search.svg");
            title: "Discover Addons";
            subtitle: "Search or browse to see addon details here";
        }

        if (false) : DetailFilesPanelLegacy {
            addon: root.addons[root.selected-index];
        }

        if (false) : DetailTagsSectionLegacy { }

        if (root.pack-hub-open) : PackHubOverlay {
            width: root.width;
            height: root.height;
            open <=> root.pack-hub-open;
            view <=> root.pack-hub-view;
        }

        if (root.svm-open) : SavedVariablesOverlay {
            width: root.width;
            height: root.height;
            open <=> root.svm-open;
            view <=> root.svm-view;
            files: root.svm-files;
            orphaned-files: root.svm-orphaned-files;
            file-count-label: root.svm-file-count-label;
            total-size-label: root.svm-total-size-label;
            orphan-count-label: root.svm-orphan-count-label;
            orphan-size-label: root.svm-orphan-size-label;
            large-count-label: root.svm-large-count-label;
            has-orphans: root.svm-has-orphans;
            has-files: root.svm-has-files;
            refresh => { root.svm-refresh(); }
        }

        if (root.uploader-open) : UploaderOverlay {
            width: root.width;
            height: root.height;
            open <=> root.uploader-open;
            view <=> root.uploader-view;
        }

        if (root.backup-restore-open) : BackupRestoreOverlay {
            width: root.width;
            height: root.height;
            open <=> root.backup-restore-open;
            view <=> root.backup-restore-view;
            backups: root.settings-backups;
            status-title: root.backup-status-title;
            status-subtitle: root.backup-status-subtitle;
            status-kind: root.backup-status-kind;
            backup-list-summary: root.backup-list-summary;
            backup-label-draft <=> root.backup-label-draft;
            refresh-backups => { root.backup-restore-refresh(); }
            create-backup(label) => { root.backup-restore-create(label); }
            restore-backup(index) => { root.backup-restore-restore(index); }
            delete-backup(index) => { root.backup-restore-delete(index); }
            reveal-backups-folder => { root.backup-restore-reveal-folder(); }
        }

        AppearanceOverlay {
            width: root.width;
            height: root.height;
            open <=> root.settings-open;
            active-tab <=> root.settings-tab;
            editor-open <=> root.settings-editor-open;
            active-theme-id <=> root.active-theme-id;
            draft-theme <=> root.draft-theme;
            draft-theme-id <=> root.draft-theme-id;
            draft-theme-name <=> root.draft-theme-name;
            draft-theme-description <=> root.draft-theme-description;
            draft-theme-new <=> root.draft-theme-new;
            draft-bg-base <=> root.draft-bg-base;
            draft-background <=> root.draft-background;
            draft-surface <=> root.draft-surface;
            draft-foreground <=> root.draft-foreground;
            draft-muted-foreground <=> root.draft-muted-foreground;
            draft-primary <=> root.draft-primary;
            draft-primary-foreground <=> root.draft-primary-foreground;
            draft-accent <=> root.draft-accent;
            draft-border <=> root.draft-border;
            draft-orb1 <=> root.draft-orb1;
            draft-orb2 <=> root.draft-orb2;
            draft-orb3 <=> root.draft-orb3;
            draft-contrast-checks <=> root.draft-contrast-checks;
            draft-contrast-warning <=> root.draft-contrast-warning;
            auto-update <=> root.settings-auto-update;
            warn-eso-running <=> root.settings-warn-eso-running;
            native-performance-mode <=> root.settings-native-performance-mode;
            official-uploader <=> root.settings-official-uploader;
            auto-open-analysis <=> root.settings-auto-open-analysis;
            conflict-policy <=> root.settings-conflict-policy;
            addons-path <=> root.settings-addons-path;
            minion-detected <=> root.settings-minion-detected;
            pack-hub-authenticated <=> root.settings-pack-hub-authenticated;
            themes: root.themes;
            close => { root.settings-open = false; }
            theme-selected(id) => {
                root.active-theme-id = id;
                root.theme-selected(id);
            }
            theme-create => { root.theme-create(); }
            theme-edit(id) => { root.theme-edit(id); }
            theme-fork(id) => { root.theme-fork(id); }
            theme-save(name) => { root.theme-save(name); }
            theme-delete(id) => { root.theme-delete(id); }
            theme-export(id) => { root.theme-export(id); }
            theme-import => { root.theme-import(); }
            theme-draft-updated => { root.theme-draft-updated(); }
            theme-editor-cancelled => { root.theme-editor-cancelled(); }
            settings-changed => { root.settings-changed(); }
            performance-mode-changed(value) => { root.settings-performance-mode-changed(value); }
            addons-path-opened => { root.settings-addons-path-opened(); }
            addons-path-redetected => { root.settings-addons-path-redetected(); }
            addons-path-applied(path) => { root.settings-addons-path-applied(path); }
            api-compat-clicked => { root.settings-api-compat(); }
            addon-list-exported => { root.settings-addon-list-export(); }
            addon-list-imported => { root.settings-addon-list-import(); }
            backup-restore-clicked => {
                root.settings-open = false;
                root.backup-restore-open = true;
                root.backup-restore-view = 0;
                root.open-backup-restore();
            }
            characters-clicked => {
                root.settings-open = false;
                root.svm-open = true;
                root.svm-view = 0;
                root.open-svm();
            }
        }

    }
}
