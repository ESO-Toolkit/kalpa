    out property <color> border: #ffffff0f;
    out property <color> border-strong: #ffffff17;
}

component Hairline inherits Rectangle {
    background: Palette.border;
}

component AppBackdrop inherits Rectangle {
    in-out property <bool> drift-one: false;
    in-out property <bool> drift-two: false;
    in-out property <bool> drift-three: false;
    background: Tokens.bg-base;

    drift-one-timer := Timer {
        interval: 25000ms;
        running: Tokens.ambient-motion && !Tokens.reduced-motion;
        triggered => {
            root.drift-one = !root.drift-one;
        }
    }

    drift-two-timer := Timer {
        interval: 20000ms;
        running: Tokens.ambient-motion && !Tokens.reduced-motion;
        triggered => {
            root.drift-two = !root.drift-two;
        }
    }

    drift-three-timer := Timer {
        interval: 30000ms;
        running: Tokens.ambient-motion && !Tokens.reduced-motion;
        triggered => {
            root.drift-three = !root.drift-three;
        }
    }

    Rectangle {
        width: root.width;
        height: root.height;
        background: Tokens.bg-base;
    }

    Image {
        visible: Tokens.skin-kind != 0;
        width: root.width;
        height: root.height;
        source: Tokens.skin-kind == 1 ? @image-url("../assets/skins/elder-scroll-ancient-tome.svg") :
            (Tokens.skin-kind == 2 ? @image-url("../assets/skins/daedric-obsidian.svg") :
            (Tokens.skin-kind == 3 ? @image-url("../assets/skins/dwemer-brass.svg") :
            (Tokens.skin-kind == 4 ? @image-url("../assets/skins/ayleid-welkynd.svg") :
            (Tokens.skin-kind == 5 ? @image-url("../assets/skins/sithis-brotherhood.svg") :
            (Tokens.skin-kind == 6 ? @image-url("../assets/skins/apocrypha-mora.svg") :
            (Tokens.skin-kind == 7 ? @image-url("../assets/skins/clockwork-city.svg") :
            @image-url("../assets/skins/nordic-runestone.svg")))))));
        image-fit: cover;
        opacity: 0.38;
    }

    Image {
        x: -root.width * 0.10 + (root.drift-one ? 30px : 0px);
        y: -root.height * 0.15 + (root.drift-one ? -20px : 0px);
        width: Tokens.low-memory-preset ? 420px : 640px;
        height: Tokens.low-memory-preset ? 420px : 640px;
        source: BackdropSkins.orb-one;
        image-fit: ImageFit.fill;
        image-rendering: smooth;
        animate x, y { duration: Tokens.low-memory-preset ? 0ms : 25000ms; easing: ease-in-out; }
    }

    Image {
        x: root.width * 1.10 - 500px + (root.drift-two ? -20px : 0px);
        y: root.height * 1.20 - 500px + (root.drift-two ? 15px : 0px);
        width: Tokens.low-memory-preset ? 340px : 540px;
        height: Tokens.low-memory-preset ? 340px : 540px;
        source: BackdropSkins.orb-two;
        image-fit: ImageFit.fill;
        image-rendering: smooth;
        animate x, y { duration: Tokens.low-memory-preset ? 0ms : 20000ms; easing: ease-in-out; }
    }

    Image {
        x: root.width * 0.40 + (root.drift-three ? 30px : 0px);
        y: root.height * 0.30 + (root.drift-three ? -20px : 0px);
        width: Tokens.low-memory-preset ? 260px : 440px;
        height: Tokens.low-memory-preset ? 260px : 440px;
        source: BackdropSkins.orb-three;
        image-fit: ImageFit.fill;
        image-rendering: smooth;
        animate x, y { duration: Tokens.low-memory-preset ? 0ms : 30000ms; easing: ease-in-out; }
    }

    Rectangle {
        width: root.width;
        height: root.height;
        background: @linear-gradient(115deg, #ffffff02 0%, #00000000 34%, #0000000d 100%);
    }

    Image {
        width: root.width;
        height: root.height;
        source: @image-url("../assets/skins/noise.svg");
        image-fit: cover;
        opacity: 0.025;
    }
}

component HeaderIcon inherits Rectangle {
    in property <image> icon;
    in property <angle> rotation: 0deg;
    in property <bool> close: false;
    callback clicked;

    border-radius: 8px;
    background: touch.pressed ? (close ? #ef444444 : Palette.white-10) : (touch.has-hover ? (close ? #ef444433 : Palette.white-06) : #00000000);

    animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    Image {
        x: (root.width - 16px) / 2;
        y: (root.height - 16px) / 2 + (touch.pressed ? 1px : 0px);
        width: 16px;
        height: 16px;
        source: root.icon;
        image-fit: contain;
        colorize: root.close && touch.has-hover ? Palette.foreground : (touch.has-hover ? Palette.foreground : Palette.muted-strong);
        transform-rotation: root.rotation;

        animate transform-rotation { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: linear; }
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component Pill inherits Rectangle {
    in property <string> label;
    in property <color> tone: Palette.muted;
    in property <color> fill: Palette.white-02;
    in property <color> line: Palette.white-10;
    in property <length> pill-max-width: 220px;
    in property <length> pill-height: 22px;
    in property <length> pill-padding-x: 8px;
    in property <length> label-font-size: 12px;
    width: min(label-text.preferred-width + root.pill-padding-x * 2 + 2px, root.pill-max-width);
    preferred-width: self.width;
    horizontal-stretch: 0;
    height: root.pill-height;
    border-radius: root.pill-height / 2;
    border-width: 1px;
    border-color: root.line;
    background: root.fill;
    inner-shadow-offset-y: 0px;
    inner-shadow-blur: 0px;
    inner-shadow-color: #00000000;
    clip: true;

    label-text := Text {
        x: root.pill-padding-x;
        y: 0px;
        width: root.width - root.pill-padding-x * 2;
        height: root.height;
        text: root.label;
        color: root.tone;
        font-size: root.label-font-size;
        font-weight: 650;
        vertical-alignment: center;
        overflow: elide;
    }
}

component GradientHeading inherits Rectangle {
    in property <string> label;
    width: 320px;
    height: 30px;
    background: #00000000;
    clip: true;

    Text {
        x: 0px;
        y: 0px;
        text: root.label;
        color: Palette.gold;
        font-family: "Space Grotesk Light";
        font-size: 20px;
        font-weight: 600;
    }

    Text {
        x: 0px;
        y: 0px;
        text: root.label;
        color: Palette.gold-hot;
        opacity: 0.34;
        font-family: "Space Grotesk Light";
        font-size: 20px;
        font-weight: 600;
    }
}

component FilterTab inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    in property <bool> hovered: false;
    callback clicked;
    width: label-text.preferred-width + 20px;
    preferred-width: self.width;
    height: 24px;
    horizontal-stretch: 0;
    border-radius: 8px;
    border-width: 0px;
    background: #00000000;

    label-text := Text {
        x: 10px;
        y: 0px;
        height: root.height;
        text: root.label;
        color: active ? Palette.gold : (root.hovered ? Palette.muted : Palette.muted-dim);
        font-size: 12px;
        font-weight: 500;
        vertical-alignment: center;

        animate color { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
    }
}

component SortMenuRow inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked;
    height: 28px;
    background: root.active ? Palette.gold-06 : (touch.has-hover ? Palette.white-04 : #00000000);

    animate background { duration: Tokens.low-memory-preset ? 0ms : 120ms; easing: ease-in-out; }

    Rectangle {
        x: 8px;
        y: 6px;
        width: 3px;
        height: 16px;
        border-radius: 2px;
        background: root.active ? Palette.gold : #00000000;
    }

    Text {
        x: 18px;
        width: root.width - 26px;
        height: root.height;
        text: root.label;
        color: root.active ? Palette.gold : (touch.has-hover ? Palette.foreground : Palette.muted-strong);
        font-size: 12px;
        font-weight: 650;
        vertical-alignment: center;
        overflow: elide;

        animate color { duration: Tokens.low-memory-preset ? 0ms : 120ms; easing: ease-in-out; }
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component ContextMenuRow inherits Rectangle {
    in property <string> label;
    in property <bool> danger: false;
    callback clicked;
    height: 28px;
    background: touch.has-hover ? (root.danger ? Palette.red-04 : Palette.white-04) : #00000000;

    animate background { duration: Tokens.low-memory-preset ? 0ms : 120ms; easing: ease-in-out; }

    Text {
        x: 12px;
        width: root.width - 24px;
        height: root.height;
        text: root.label;
        color: root.danger ? (touch.has-hover ? Palette.red : Palette.red-20) : (touch.has-hover ? Palette.foreground : Palette.muted-strong);
        font-size: 12px;
        font-weight: 600;
        vertical-alignment: center;
        overflow: elide;

        animate color { duration: Tokens.low-memory-preset ? 0ms : 120ms; easing: ease-in-out; }
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component DetailTabStrip inherits Rectangle {
    in property <bool> files-active: false;
    callback details-clicked;
    callback files-clicked;
    width: 176px;
    preferred-width: self.width;
    horizontal-stretch: 0;
    height: 36px;
    preferred-height: self.height;
    vertical-stretch: 0;
    border-radius: 12px;
    border-width: 0px;
    background: Palette.white-03;
    inner-shadow-offset-y: 1px;
    inner-shadow-blur: 1px;
    inner-shadow-color: #00000033;

    Rectangle {
        x: root.files-active ? 90px : 4px;
        y: 4px;
        width: 82px;
        height: 28px;
        border-radius: 8px;
        border-width: 0px;
        background: Palette.white-08;
        drop-shadow-blur: 2px;
        drop-shadow-offset-y: 1px;
        drop-shadow-color: #00000033;

        animate x { duration: Tokens.low-memory-preset ? 0ms : 180ms; easing: ease-in-out; }
    }

    Text {
        x: 4px;
        y: 0px;
        width: 82px;
        height: root.height;
        text: "Details";
        color: root.files-active ? Palette.muted-strong : Palette.foreground;
        font-size: 12px;
        font-weight: root.files-active ? 650 : 700;
        horizontal-alignment: center;
        vertical-alignment: center;

        animate color { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
    }

    Image {
        x: 100px;
        y: 11px;
        width: 14px;
        height: 14px;
        source: @image-url("../assets/icons/files.svg");
        image-fit: contain;
        colorize: root.files-active ? Palette.foreground : Palette.muted-strong;

        animate colorize { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
    }

    Text {
        x: 116px;
        y: 0px;
        width: 52px;
        height: root.height;
        text: "Files";
        color: root.files-active ? Palette.foreground : Palette.muted-strong;
        font-size: 12px;
        font-weight: root.files-active ? 700 : 650;
        horizontal-alignment: center;
        vertical-alignment: center;

        animate color { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
    }

    TouchArea {
        x: 4px;
        y: 4px;
        width: 82px;
        height: 28px;
        clicked => { root.details-clicked(); }
    }

    TouchArea {
        x: 90px;
        y: 4px;
        width: 82px;
        height: 28px;
        clicked => { root.files-clicked(); }
    }
}

component TagChip inherits Rectangle {
    in property <string> label;
    in property <int> kind: 0;
    in-out property <bool> active: false;
    callback clicked;
    private property <color> active-tone: kind == 0 ? Palette.gold : (kind == 1 ? Palette.amber : (kind == 2 ? Palette.red : (kind == 3 ? Palette.emerald : (kind == 4 ? Palette.violet : Palette.sky))));
    private property <color> active-fill: kind == 0 ? Palette.gold-10 : (kind == 1 ? Palette.amber-04 : (kind == 2 ? Palette.red-04 : (kind == 3 ? Palette.emerald-04 : (kind == 4 ? Palette.violet-04 : Palette.sky-10))));
    in property <length> chip-max-width: 132px;
    width: min(label-text.preferred-width + 20px, root.chip-max-width);
    preferred-width: self.width;
    horizontal-stretch: 0;
    height: 22px;
    border-radius: 6px;
    border-width: 1px;
    border-color: active ? Palette.white-10 : (touch.has-hover ? Palette.white-10 : Palette.white-06);
    background: active ? root.active-fill : (touch.has-hover ? Palette.white-06 : Palette.white-03);

    animate background, border-color { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    label-text := Text {
        x: 10px;
        width: root.width - 20px;
        height: root.height;
        text: root.label;
        color: active ? root.active-tone : (touch.has-hover ? Palette.muted : Palette.muted-half);
        font-size: 12px;
        font-weight: 500;
        vertical-alignment: center;
        overflow: elide;

        animate color { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            root.clicked();
        }
    }
}

component TagInput inherits Rectangle {
    in-out property <string> draft;
    callback submit(string);
    width: root.draft == "" ? 56px : 112px;
    preferred-width: self.width;
    horizontal-stretch: 0;
    height: 22px;
    border-radius: 6px;
    border-width: 1px;
    border-color: tag-input.has-focus ? Palette.white-10 : Palette.white-06;
    background: tag-input.has-focus ? Palette.white-06 : Palette.white-03;

    animate background, border-color { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    Text {
        visible: root.draft == "" && !tag-input.has-focus;
        x: 10px;
        height: root.height;
        text: "+ tag";
        color: Palette.muted-half;
        font-size: 12px;
        font-weight: 500;
        vertical-alignment: center;

        animate color { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
    }

    tag-input := TextInput {
        x: 10px;
        y: 0px;
        width: root.draft == "" ? root.width - 20px : root.width - 38px;
        height: root.height;
        text: root.draft;
        color: Palette.foreground;
        font-size: 12px;
        font-family: "Geist";
        single-line: true;
        vertical-alignment: center;
        selection-background-color: Palette.sky-25;
        edited => { root.draft = self.text; }
        accepted => {
            if (root.draft != "") {
                root.submit(root.draft);
                root.draft = "";
            }
        }
    }

    if (root.draft != "") : Rectangle {
        x: root.width - 24px;
        y: 2px;
        width: 20px;
        height: 18px;
        border-radius: 5px;
        background: add-touch.has-hover ? Palette.sky-16 : Palette.sky-10;

        Text {
            width: parent.width;
            height: parent.height;
            text: "+";
            color: Palette.sky;
            font-size: 13px;
            font-weight: 900;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        add-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.submit(root.draft);
                root.draft = "";
            }
        }
    }

}

component SmallAction inherits Rectangle {
    in property <string> label;
    in property <color> tone: Palette.sky;
    in property <color> fill: Palette.sky-10;
    in property <color> fill-hover: Palette.sky-16;
    in property <color> fill-pressed: Palette.sky-22;
    in property <color> line: Palette.white-10;
    callback clicked;
    private property <length> label-width: min(label-text.preferred-width, root.width - 18px);
    private property <length> content-x: max(8px, (root.width - root.label-width) / 2);
    width: label-text.preferred-width + 18px;
    preferred-width: self.width;
    horizontal-stretch: 0;
    height: 24px;
    border-radius: 7px;
    border-width: 1px;
    border-color: root.line;
    background: touch.pressed ? root.fill-pressed : (touch.has-hover ? root.fill-hover : root.fill);

    animate background, border-color { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    label-text := Text {
        x: root.content-x;
        y: touch.pressed ? 1px : 0px;
        width: root.label-width;
        height: root.height;
        text: root.label;
        color: root.tone;
        font-size: 12px;
        font-weight: 600;
        vertical-alignment: center;
        horizontal-alignment: center;
        overflow: elide;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component LinkAction inherits Rectangle {
    in property <string> label;
    in property <color> tone: Palette.sky;
    callback clicked;
    private property <length> icon-size: 12px;
    private property <length> icon-gap: 6px;
    private property <length> content-width: root.icon-size + root.icon-gap + label-text.preferred-width;
    private property <length> content-x: max(0px, (root.width - root.content-width) / 2);
    width: label-text.preferred-width + 38px;
    preferred-width: self.width;
    horizontal-stretch: 0;
    height: 28px;
    border-radius: 6px;
    border-width: 0px;
    background: touch.pressed ? Palette.sky-22 : (touch.has-hover ? Palette.sky-16 : Palette.sky-10);

    animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    Image {
        x: root.content-x;
        y: (root.height - root.icon-size) / 2 + (touch.pressed ? 1px : 0px);
        width: root.icon-size;
        height: root.icon-size;
        source: @image-url("../assets/icons/external-link.svg");
        image-fit: contain;
        colorize: root.tone;
    }

    label-text := Text {
        x: root.content-x + root.icon-size + root.icon-gap;
        y: touch.pressed ? 1px : 0px;
        width: label-text.preferred-width;
        height: root.height;
        text: root.label;
        color: root.tone;
        font-size: 12px;
        font-weight: 600;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component PlainLinkAction inherits Rectangle {
    in property <string> label;
    in property <color> tone: Palette.muted-half;
    callback clicked;
    private property <length> icon-size: 12px;
    private property <length> icon-gap: 5px;
    width: label-text.preferred-width + root.icon-size + root.icon-gap;
    preferred-width: self.width;
    horizontal-stretch: 0;
    height: 20px;
    background: #00000000;

    Image {
        x: 0px;
        y: (root.height - root.icon-size) / 2 + (touch.pressed ? 1px : 0px);
        width: root.icon-size;
        height: root.icon-size;
        source: @image-url("../assets/icons/external-link.svg");
        image-fit: contain;
        colorize: touch.has-hover ? Palette.muted-strong : root.tone;
    }

    label-text := Text {
        x: root.icon-size + root.icon-gap;
        y: touch.pressed ? 1px : 0px;
        width: label-text.preferred-width;
        height: root.height;
        text: root.label;
        color: touch.has-hover ? Palette.muted-strong : root.tone;
        font-size: 11px;
        font-weight: 600;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component DetailToggleAction inherits Rectangle {
    in property <string> label;
    in property <bool> enabled-tone: true;
    callback clicked;
    private property <color> tone: enabled-tone ? Palette.emerald : Palette.amber;
    private property <color> line: enabled-tone ? Palette.emerald-25 : Palette.amber-25;
    private property <color> hover-fill: enabled-tone ? Palette.emerald-04 : Palette.amber-04;
    private property <length> icon-size: 16px;
    private property <length> icon-gap: 6px;
    private property <length> content-width: root.icon-size + root.icon-gap + label-text.preferred-width;
    private property <length> content-x: max(0px, (root.width - root.content-width) / 2);
    width: label-text.preferred-width + 44px;
    preferred-width: self.width;
    horizontal-stretch: 0;
    height: 32px;
    border-radius: 8px;
    border-width: 0px;
    background: touch.pressed ? root.hover-fill : (touch.has-hover ? root.hover-fill : Palette.white-04);

    animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    Image {
        x: root.content-x;
        y: (root.height - root.icon-size) / 2 + (touch.pressed ? 1px : 0px);
        width: root.icon-size;
        height: root.icon-size;
        source: @image-url("../assets/icons/power.svg");
        image-fit: contain;
        colorize: root.tone;
    }

    label-text := Text {
        x: root.content-x + root.icon-size + root.icon-gap;
        y: touch.pressed ? 1px : 0px;
        width: label-text.preferred-width;
        height: root.height;
        text: root.label;
        color: root.tone;
        font-size: 14px;
        font-weight: 600;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component DetailRemoveAction inherits Rectangle {
    callback clicked;
    width: label-text.preferred-width + 20px;
    preferred-width: self.width;
    horizontal-stretch: 0;
    height: 32px;
    border-radius: 8px;
    border-width: 0px;
    background: touch.pressed ? Palette.red-15 : (touch.has-hover ? Palette.red-15 : Palette.red-04);

    animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    label-text := Text {
        x: 10px;
        y: touch.pressed ? 1px : 0px;
        height: root.height;
        text: "Remove Addon";
        color: Palette.red;
        font-size: 14px;
        font-weight: 600;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component GhostIconButton inherits Rectangle {
    in property <image> icon;
    in property <color> tone: Palette.muted-strong;
    in property <bool> danger: false;
    callback clicked;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: touch.pressed ? (danger ? Palette.red-15 : Palette.white-08) : (touch.has-hover ? (danger ? Palette.red-15 : Palette.white-04) : #00000000);

    animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    Image {
        x: 7px;
        y: 7px + (touch.pressed ? 1px : 0px);
        width: 14px;
        height: 14px;
        source: root.icon;
        image-fit: contain;
        colorize: touch.has-hover && root.danger ? Palette.red : (touch.has-hover ? Palette.muted : root.tone);

        animate colorize { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component Checkbox inherits Rectangle {
    in property <bool> checked: false;
    callback clicked;
    private property <bool> hover-active: touch.has-hover && !Tokens.low-memory-preset;
    width: 16px;
    height: 16px;
    border-radius: 5px;
    border-width: 1px;
    border-color: checked ? Palette.gold-20 : (touch.pressed || root.hover-active ? Palette.white-10 : Palette.white-08);
    background: checked ? Palette.gold-25 : (touch.pressed || root.hover-active ? Palette.white-10 : Palette.white-08);

    animate background, border-color { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    Rectangle {
        x: 1px;
        y: 1px;
        width: parent.width - 2px;
        height: parent.height - 2px;
        border-radius: 4px;
        background: root.checked ? Palette.gold-15 : Tokens.surface-66;
    }

    Image {
        visible: root.checked;
        x: 3px;
        y: 3px;
        width: 10px;
        height: 10px;
        source: @image-url("../assets/icons/check.svg");
        image-fit: contain;
        colorize: Palette.gold;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                root.clicked();
            }
        }
    }
}

component RowBadge inherits Rectangle {
    in property <string> label;
    in property <int> kind: 0;
    private property <color> tone: kind == 1 ? Palette.amber : (kind == 2 ? Palette.red : (kind == 3 ? Palette.violet : (kind == 4 ? Palette.gold : (kind == 5 ? #a1a1aa : Palette.muted-strong))));
    private property <color> fill: kind == 1 ? Palette.amber-04 : (kind == 2 ? Palette.red-04 : (kind == 3 ? Palette.violet-04 : (kind == 4 ? Palette.gold-04 : (kind == 5 ? #a1a1aa0a : Palette.white-03))));
    private property <color> line: kind == 1 ? Palette.amber-20 : (kind == 2 ? Palette.red-20 : (kind == 3 ? Palette.violet-20 : (kind == 4 ? Palette.gold-20 : (kind == 5 ? #a1a1aa24 : Palette.white-10))));
    width: label-text.preferred-width + 16px;
    height: 20px;
    border-radius: 10px;
    border-width: Tokens.low-memory-preset ? 0px : 1px;
    border-color: root.line;
    background: Tokens.low-memory-preset ? Palette.white-03 : root.fill;

    label-text := Text {
        x: 8px;
        height: root.height;
        text: root.label;
        color: root.tone;
        font-size: 10px;
        font-weight: 650;
        vertical-alignment: center;
    }
}

component AddonRow inherits Rectangle {
    in property <string> title;
    in property <string> meta;
    in property <bool> current: false;
    in property <bool> favorite: false;
    in property <bool> selected: false;
    in property <bool> batch-active: false;
    in property <bool> library: false;
    in property <bool> disabled: false;
    in property <int> state: 0;
    in property <string> badge: "";
    in property <int> badge-kind: 0;
    in property <string> badge2: "";
    in property <int> badge2-kind: 0;
    in property <string> badge3: "";
    in property <int> badge3-kind: 0;
    callback clicked;
    callback selected-toggled;
    callback context-open-folder;
    callback context-open-esoui;
    callback context-favorite;
    callback context-toggle-disable;
    callback context-remove;
    private property <bool> hovered: touch.has-hover || select-touch.has-hover;
    private property <bool> hover-affordance: root.hovered && !Tokens.low-memory-preset;
    private property <bool> rail-open: root.selected || root.batch-active || root.hover-affordance;
    private property <bool> checkbox-visible: Tokens.low-memory-preset || root.rail-open;
    private property <length> content-x: Tokens.low-memory-preset ? 42px : (root.rail-open ? 42px : 16px);
    private property <bool> active-current: current && !root.batch-active;
    private property <color> state-rail: disabled ? #71717a : (state == 2 ? Palette.red : (state == 1 ? Palette.amber : (state == 3 ? Palette.violet : (state == 5 ? Palette.emerald : #00000000))));
    private property <color> state-wash: disabled ? #71717a0a : (state == 2 ? Palette.red-04 : (state == 1 ? Palette.amber-04 : (state == 3 ? Palette.violet-04 : (state == 5 ? Palette.emerald-04 : #00000000))));
    in-out property <length> menu-x: 42px;
    in-out property <length> menu-y: 18px;

    height: 52px;
    background: root.active-current ? Palette.gold-06 : (root.selected ? Palette.gold-06 : (root.hover-affordance ? Palette.white-04 : #00000000));
    inner-shadow-offset-y: 0px;
    inner-shadow-blur: 0px;
    inner-shadow-color: #00000000;
    opacity: disabled ? 0.55 : 1.0;

    animate background, opacity { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    Rectangle {
        x: 0px;
        y: 0px;
        width: 3px;
        height: root.height;
        background: root.active-current || root.selected ? Palette.gold : root.state-rail;
    }

    Rectangle {
        x: 3px;
        y: 0px;
        width: Tokens.low-memory-preset ? 8px : 34px;
        height: root.height;
        visible: !root.active-current && !root.selected && (state != 0 || disabled);
        background: Tokens.low-memory-preset ? root.state-wash : @linear-gradient(90deg, root.state-wash 0%, #00000000 100%);
    }

    Checkbox {
        x: 18px;
        y: 17px;
        checked: root.selected;
        opacity: root.checkbox-visible ? 1.0 : 0.0;
        animate opacity { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }
        clicked => { root.selected-toggled(); }
    }

    Text {
        x: root.content-x;
        y: 8px;
        visible: root.favorite;
        text: "★";
        color: Palette.gold;
        font-size: 13px;
        font-weight: 900;
    }

    Text {
        x: root.content-x + (root.favorite ? 16px : 0px);
        y: 10px;
        visible: root.library;
        text: "LIB";
        color: Palette.violet;
        font-size: 10px;
        font-weight: 500;
    }

    Text {
        x: root.content-x + (root.favorite ? 16px : 0px) + (root.library ? 28px : 0px);
        y: 8px;
        width: root.width - root.content-x - (root.favorite ? 16px : 0px) - (root.library ? 28px : 0px) - 16px;
        text: root.title;
        color: Palette.foreground;
        font-size: 14px;
        font-weight: 500;
        overflow: elide;
    }

    Text {
        x: root.content-x;
        y: 30px;
        width: root.badge != "" || root.badge2 != "" || root.badge3 != "" ? root.width - root.content-x - 190px : root.width - root.content-x - 18px;
        text: root.meta;
        color: Palette.muted-half;
        font-size: 12px;
        font-weight: 500;
        overflow: elide;
    }

    badge-one := RowBadge {
        visible: root.badge != "";
        x: root.width - self.width - 14px;
        y: 26px;
        label: root.badge;
        kind: root.badge-kind;
    }

    badge-two := RowBadge {
        visible: root.badge2 != "";
        x: root.badge != "" ? badge-one.x - self.width - 4px : root.width - self.width - 14px;
        y: 26px;
        label: root.badge2;
        kind: root.badge2-kind;
    }

    RowBadge {
        visible: root.badge3 != "";
        x: root.badge2 != "" ? badge-two.x - self.width - 4px : (root.badge != "" ? badge-one.x - self.width - 4px : root.width - self.width - 14px);
        y: 26px;
        label: root.badge3;
        kind: root.badge3-kind;
    }

    touch := TouchArea {
        x: 40px;
        width: root.width - 40px;
        height: root.height;
        clicked => { root.clicked(); }
        pointer-event(event) => {
            if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                root.menu-x = 40px + touch.mouse-x;
                root.menu-y = touch.mouse-y;
                context-popup.show();
            }
        }
    }

    select-touch := TouchArea {
        x: 0px;
        y: 0px;
        width: 40px;
        height: root.height;
        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                root.selected-toggled();
            } else if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                root.menu-x = select-touch.mouse-x;
                root.menu-y = select-touch.mouse-y;
                context-popup.show();
            }
        }
    }

    context-popup := PopupWindow {
        x: min(root.menu-x, root.width - 184px);
        y: root.menu-y;
        width: 176px;
        height: 204px;

        Rectangle {
            width: parent.width;
            height: parent.height;
            border-radius: 10px;
            border-width: 0px;
            background: Tokens.bg-base-85;
            drop-shadow-blur: 24px;
            drop-shadow-offset-y: 10px;
            drop-shadow-color: #00000099;
            clip: true;

            ContextMenuRow {
                y: 8px;
                width: parent.width;
                label: "Open Folder";
                clicked => {
                    context-popup.close();
                    root.context-open-folder();
                }
            }

            ContextMenuRow {
                y: 36px;
                width: parent.width;
                label: "View on ESOUI";
                clicked => {
                    context-popup.close();
                    root.context-open-esoui();
                }
            }

            Rectangle { x: 8px; y: 70px; width: parent.width - 16px; height: 1px; background: Palette.white-03; }

            ContextMenuRow {
                y: 78px;
                width: parent.width;
                label: root.favorite ? "Unfavorite" : "Favorite";
                clicked => {
                    context-popup.close();
                    root.context-favorite();
                }
            }

            ContextMenuRow {
                y: 106px;
                width: parent.width;
                label: root.disabled ? "Enable" : "Disable";
                clicked => {
                    context-popup.close();
                    root.context-toggle-disable();
                }
            }

            ContextMenuRow {
                y: 134px;
                width: parent.width;
                label: root.selected ? "Deselect" : "Select";
                clicked => {
                    context-popup.close();
                    root.selected-toggled();
                }
            }

            Rectangle { x: 8px; y: 168px; width: parent.width - 16px; height: 1px; background: Palette.white-03; }

            ContextMenuRow {
                y: 176px;
                width: parent.width;
                label: "Remove";
                danger: true;
                clicked => {
                    context-popup.close();
                    root.context-remove();
                }
            }
        }
    }
}

component DiscoverEmptyState inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> subtitle;
    background: #00000000;

    Rectangle {
        x: parent.width / 2 - 29px;
        y: parent.height / 2 - 82px;
        width: 58px;
        height: 58px;
        border-radius: 16px;
        border-width: 0px;
        background: Palette.white-03;
        drop-shadow-blur: 24px;
        drop-shadow-color: Palette.gold-04;

        Image {
            x: 15px;
            y: 15px;
            width: 28px;
            height: 28px;
            source: root.icon;
            image-fit: contain;
            colorize: Palette.muted-soft;
        }
    }

    Text {
        x: 24px;
        y: parent.height / 2 - 10px;
        width: parent.width - 48px;
        text: root.title;
        color: Palette.foreground;
        font-size: 14px;
        font-weight: 600;
        horizontal-alignment: center;
    }

    Text {
        x: 42px;
        y: parent.height / 2 + 15px;
        width: parent.width - 84px;
        text: root.subtitle;
        color: Palette.muted-half;
        font-size: 12px;
        font-weight: 500;
        horizontal-alignment: center;
        wrap: word-wrap;
    }
}

component DiscoverResultSkeletonRow inherits Rectangle {
    in property <int> index: 0;
    in property <bool> ranked: false;
    private property <length> body-x: root.ranked ? 54px : 16px;
    private property <length> title-width: root.index == 1 ? 148px : (root.index == 2 ? 214px : (root.index == 3 ? 132px : 188px));
    private property <length> meta-width: root.index == 1 ? 74px : (root.index == 2 ? 112px : (root.index == 3 ? 86px : 98px));
    height: 62px;
    background: #00000000;

    Rectangle {
        visible: root.ranked;
        x: 16px;
        y: 14px;
        width: 24px;
        height: 24px;
        border-radius: 6px;
        border-width: 0px;
        background: Palette.white-04;
    }

    Rectangle {
        x: root.body-x;
        y: 15px;
        width: min(root.title-width, parent.width - root.body-x - 116px);
        height: 13px;
        border-radius: 4px;
        border-width: 0px;
        background: Palette.white-08;
    }

    Rectangle {
        x: parent.width - 82px;
        y: 19px;
        width: 66px;
        height: 18px;
        border-radius: 5px;
        border-width: 0px;
        background: Palette.white-04;
    }

    Rectangle {
        x: root.body-x;
        y: 39px;
        width: root.meta-width;
        height: 10px;
        border-radius: 4px;
        border-width: 0px;
        background: Palette.white-04;
    }

    Rectangle {
        x: root.body-x + root.meta-width + 8px;
        y: 35px;
        width: 52px;
        height: 18px;
        border-radius: 9px;
        border-width: 0px;
        background: Palette.white-03;
    }
}

component DiscoverResultSkeletonList inherits Rectangle {
    in property <bool> ranked: false;
    background: #00000000;

    DiscoverResultSkeletonRow { y: 0px; width: parent.width; index: 0; ranked: root.ranked; }
    DiscoverResultSkeletonRow { y: 62px; width: parent.width; index: 1; ranked: root.ranked; }
    DiscoverResultSkeletonRow { y: 124px; width: parent.width; index: 2; ranked: root.ranked; }
    DiscoverResultSkeletonRow { y: 186px; width: parent.width; index: 3; ranked: root.ranked; }
    DiscoverResultSkeletonRow { y: 248px; width: parent.width; index: 4; ranked: root.ranked; }
    DiscoverResultSkeletonRow { y: 310px; width: parent.width; index: 5; ranked: root.ranked; }
    DiscoverResultSkeletonRow { y: 372px; width: parent.width; index: 6; ranked: root.ranked; }
}

component DiscoverResultRow inherits Rectangle {
    in property <string> title;
    in property <string> meta;
    in property <string> category;
    in property <string> downloads;
    in property <string> updated;
    in property <int> rank: 0;
    in property <bool> selected: false;
    in property <bool> installed: false;
    in property <bool> show-extra-meta: false;
    callback row-selected;
    callback install-clicked;
    private property <bool> has-rank: root.rank > 0;
    private property <length> body-x: root.has-rank ? 54px : 16px;
    private property <length> action-reserve: 96px;
    private property <length> meta-y: 38px;
    private property <length> extra-y: 57px;
    private property <bool> hover-affordance: touch.has-hover && !Tokens.low-memory-preset;
    height: root.show-extra-meta ? 78px : 62px;
    background: root.selected ? Palette.gold-06 : (root.hover-affordance ? Palette.white-04 : #00000000);
    border-radius: 0px;
    inner-shadow-offset-y: 0px;
    inner-shadow-blur: 0px;
    inner-shadow-color: #00000000;

    animate background { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.row-selected(); }
    }

    Rectangle {
        visible: root.selected;
        x: 0px;
        y: 0px;
        width: 3px;
        height: parent.height;
        border-radius: 0px;
        border-width: 0px;
        background: Palette.gold;
    }

    Rectangle {
        visible: root.has-rank;
        x: 16px;
        y: 14px;
        width: 24px;
        height: 24px;
        border-radius: 6px;
        border-width: 1px;
        border-color: root.rank <= 3 ? Palette.gold-20 : Palette.white-08;
        background: root.rank <= 3 ? Palette.gold-15 : Palette.white-04;

        Text {
            width: parent.width;
            height: parent.height;
            text: root.rank;
            color: root.rank <= 3 ? Palette.gold : Palette.muted-half;
            font-family: "Space Grotesk Light";
            font-size: 11px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    title-text := Text {
        x: root.body-x;
        y: 12px;
        width: parent.width - root.body-x - root.action-reserve;
        text: root.title;
        color: Palette.foreground;
        font-size: 13px;
        font-weight: 700;
        overflow: elide;
    }

    author-text := Text {
        visible: root.meta != "";
        x: root.body-x;
        y: root.meta-y;
        width: min(author-text.preferred-width, max(48px, parent.width - root.body-x - root.action-reserve - (root.category == "" ? 0px : 76px)));
        text: root.meta;
        color: Palette.muted-half;
        font-size: 11px;
        font-weight: 500;
        overflow: elide;
    }

    category-chip := Pill {
        visible: root.category != "";
        x: root.meta == "" ? root.body-x : author-text.x + author-text.width + 8px;
        y: root.meta-y - 3px;
        label: root.category;
        tone: Palette.muted-strong;
        fill: Palette.white-03;
        line: Palette.white-10;
        pill-height: 18px;
        pill-padding-x: 7px;
        label-font-size: 10px;
        pill-max-width: max(58px, parent.width - self.x - root.action-reserve);
    }

    Image {
        visible: root.show-extra-meta && root.downloads != "";
        x: root.body-x;
        y: root.extra-y + 3px;
        width: 10px;
        height: 10px;
        source: @image-url("../assets/icons/cloud-upload.svg");
        image-fit: contain;
        colorize: Palette.muted-dim;
    }

    Text {
        visible: root.show-extra-meta && root.downloads != "";
        x: root.body-x + 14px;
        y: root.extra-y;
        width: 78px;
        text: root.downloads;
        color: Palette.muted-half;
        font-size: 10px;
        font-weight: 600;
        overflow: elide;
    }

    Text {
        visible: root.show-extra-meta && root.updated != "";
        x: root.body-x + 96px;
        y: root.extra-y;
        width: parent.width - root.body-x - root.action-reserve - 96px;
        text: root.updated;
        color: Palette.muted-half;
        font-size: 10px;
        font-weight: 600;
        overflow: elide;
    }

    SmallAction {
        visible: root.installed || root.selected || Tokens.low-memory-preset || root.hover-affordance;
        x: parent.width - self.width - 16px;
        y: (root.height - self.height) / 2;
        label: root.installed ? "Installed" : "Install";
        tone: root.installed ? Palette.emerald : Palette.gold;
        fill: root.installed ? Palette.emerald-04 : Palette.gold-10;
        fill-hover: root.installed ? Palette.emerald-15 : Palette.gold-15;
        fill-pressed: root.installed ? Palette.emerald-20 : Palette.gold-20;
        line: root.installed ? Palette.emerald-20 : Palette.gold-20;
        clicked => { root.install-clicked(); }
    }
}

component DiscoverSortChip inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> active: false;
    in property <length> chip-width: label-text.preferred-width + 42px;
    callback clicked;
    private property <length> icon-size: 11px;
    private property <length> icon-gap: 7px;
    private property <length> label-width: min(label-text.preferred-width, max(28px, root.width - root.icon-size - root.icon-gap - 22px));
    private property <length> content-width: root.icon-size + root.icon-gap + root.label-width;
    private property <length> content-x: max(11px, (root.width - root.content-width) / 2);
    width: root.chip-width;
    preferred-width: self.width;
    horizontal-stretch: 0;
    height: 28px;
    border-radius: 8px;
    border-width: 1px;
    border-color: root.active ? Palette.gold-20 : (touch.has-hover ? Palette.white-10 : Palette.white-08);
    background: root.active ? Palette.gold-10 : (touch.has-hover ? Palette.white-06 : Palette.white-04);
    inner-shadow-offset-y: 0px;
    inner-shadow-blur: 0px;
    inner-shadow-color: #00000000;
    clip: true;

    Image {
        x: root.content-x;
        y: (root.height - root.icon-size) / 2;
        width: root.icon-size;
        height: root.icon-size;
        source: root.icon;
        image-fit: contain;
        colorize: root.active ? Palette.gold : Palette.muted-half;
    }

    label-text := Text {
        x: root.content-x + root.icon-size + root.icon-gap;
        width: root.label-width;
        height: root.height;
        text: root.label;
        color: root.active ? Palette.gold : (touch.has-hover ? Palette.foreground : Palette.muted-strong);
        font-size: 11px;
        font-weight: 700;
        vertical-alignment: center;
        overflow: elide;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component DiscoverSelectChip inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> active: false;
    in property <length> chip-width: 120px;
    callback clicked;
    width: root.chip-width;
    height: 32px;
    border-radius: 10px;
    border-width: 1px;
    border-color: touch.has-hover ? Palette.white-10 : Palette.white-08;
    background: touch.has-hover ? Palette.white-06 : Palette.white-04;
    inner-shadow-offset-y: 0px;
    inner-shadow-blur: 0px;
    inner-shadow-color: #00000000;
    clip: true;

    Image {
        x: 11px;
        y: 10px;
        width: 12px;
        height: 12px;
        source: root.icon;
        image-fit: contain;
        colorize: touch.has-hover ? Palette.foreground : Palette.muted-half;
    }

    Text {
        x: 31px;
        width: root.width - 60px;
        height: root.height;
        text: root.label;
        color: touch.has-hover ? Palette.foreground : Palette.muted-strong;
        font-size: 11px;
        font-weight: 700;
        vertical-alignment: center;
        overflow: elide;
    }

    Image {
        x: parent.width - 26px;
        y: 10px;
        width: 12px;
        height: 12px;
        source: @image-url("../assets/icons/chevron-down.svg");
        image-fit: contain;
        colorize: touch.has-hover ? Palette.foreground : Palette.muted-half;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component DiscoverSelectMenuRow inherits Rectangle {
    in property <string> label;
    in property <int> depth: 0;
    in property <bool> selected: false;
    callback clicked;
    height: 28px;
    border-radius: 7px;
    border-width: 0px;
    background: root.selected ? Palette.gold-10 : (touch.has-hover ? Palette.white-06 : #00000000);

    animate background { duration: Tokens.low-memory-preset ? 0ms : 120ms; easing: ease-in-out; }

    Image {
        visible: root.selected;
        x: 9px;
        y: 8px;
        width: 12px;
        height: 12px;
        source: @image-url("../assets/icons/check.svg");
        image-fit: contain;
        colorize: Palette.gold;
    }

    Text {
        x: 12px + root.depth * 12px + (root.selected ? 15px : 0px);
        width: parent.width - self.x - 10px;
        height: root.height;
        text: root.label;
        color: root.selected ? Palette.gold : (touch.has-hover ? Palette.foreground : Palette.muted-strong);
        font-size: 11px;
        font-weight: root.selected ? 750 : 600;
        vertical-alignment: center;
        overflow: elide;

        animate color { duration: Tokens.low-memory-preset ? 0ms : 120ms; easing: ease-in-out; }
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component DiscoverSubTab inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> active: false;
    callback clicked;
    private property <length> icon-size: 12px;
    private property <length> icon-gap: 5px;
    private property <length> label-width: min(label-text.preferred-width, max(24px, root.width - root.icon-size - root.icon-gap - 14px));
    private property <length> content-width: root.icon-size + root.icon-gap + root.label-width;
    private property <length> content-x: max(7px, (root.width - root.content-width) / 2);
    height: 24px;
    border-radius: 8px;
    border-width: 0px;
    background: root.active ? Palette.gold-15 : (touch.has-hover ? Palette.white-04 : #00000000);

    animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    Image {
        x: root.content-x;
        y: (root.height - root.icon-size) / 2;
        width: root.icon-size;
        height: root.icon-size;
        source: root.icon;
        image-fit: contain;
        colorize: root.active ? Palette.gold : (touch.has-hover ? Palette.foreground : Palette.muted-strong);

        animate colorize { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
    }

    label-text := Text {
        x: root.content-x + root.icon-size + root.icon-gap;
        width: root.label-width;
        height: root.height;
        text: root.label;
        color: root.active ? Palette.gold : (touch.has-hover ? Palette.foreground : Palette.muted-strong);
        font-size: 11px;
        font-weight: 500;
        vertical-alignment: center;
        overflow: elide;

        animate color { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component DiscoverModePanel inherits Rectangle {
    in property <int> tab: 0;
    in property <[DiscoverEntry]> entries;
    in property <int> popular-sort: 0;
    in property <string> category-label: "Combat";
    in property <string> category-sort-label: "Downloads";
    in property <[DiscoverSelectOption]> category-options;
    in property <[DiscoverSelectOption]> category-sort-options;
    in property <bool> loading: false;
    in property <bool> has-more: false;
    in property <string> message: "";
    in-out property <int> selected-index: 0;
    in-out property <string> query;
    in-out property <string> url-input;
    in-out property <string> category-filter;
    callback result-selected(int);
    callback install-result(int);
    callback query-edited(string);
    callback url-edited(string);
    callback category-filter-edited(string);
    callback popular-sort-selected(int);
    callback category-next;
    callback category-sort-next;
    callback category-selected(int);
    callback category-sort-selected(int);
    callback load-more;
    callback retry;
    private property <bool> category-menu-open: false;
    private property <bool> category-sort-menu-open: false;
    private property <bool> category-filter-visible: root.tab == 2 && (root.entries.length > 0 || root.category-filter != "");
    private property <length> list-y: root.tab == 1 ? 38px : (root.tab == 2 ? (root.category-filter-visible ? 120px : 82px) : 0px);
    private property <bool> footer-visible: (root.tab == 1 || root.tab == 2) && (root.loading || root.has-more);
    private property <length> footer-height: root.footer-visible ? 42px : 0px;
    background: Tokens.low-memory-preset ? Tokens.background : #00000000;
    clip: true;

    if (root.tab == 1) : HorizontalLayout {
        x: 12px;
        y: 0px;
        width: parent.width - 24px;
        height: 28px;
        spacing: 8px;
        DiscoverSortChip { chip-width: (parent.width - 8px) / 2; label: "Most Popular"; active: root.popular-sort == 0; icon: @image-url("../assets/icons/flame.svg"); clicked => { root.popular-sort-selected(0); } }
        DiscoverSortChip { chip-width: (parent.width - 8px) / 2; label: "Recently Updated"; active: root.popular-sort == 1; icon: @image-url("../assets/icons/refresh-cw.svg"); clicked => { root.popular-sort-selected(1); } }
    }

    if (root.tab == 2) : Rectangle {
        x: 12px;
        y: 0px;
        width: parent.width - 24px;
        height: 74px;
        background: #00000000;

        DiscoverSelectChip {
            chip-width: parent.width;
            icon: @image-url("../assets/icons/folder-open.svg");
            label: root.category-label;
            active: true;
            clicked => {
                root.category-menu-open = !root.category-menu-open;
                root.category-sort-menu-open = false;
            }
        }

        DiscoverSelectChip {
            y: 40px;
            chip-width: parent.width;
            icon: @image-url("../assets/icons/refresh-cw.svg");
            label: root.category-sort-label;
            clicked => {
                root.category-sort-menu-open = !root.category-sort-menu-open;
                root.category-menu-open = false;
            }
        }
    }

    if (root.category-filter-visible) : Rectangle {
        x: 12px;
        y: 82px;
        width: parent.width - 24px;
        height: 30px;
        border-radius: 9px;
        border-width: 1px;
        border-color: Palette.white-08;
        background: Palette.white-04;
        inner-shadow-offset-y: 0px;
        inner-shadow-blur: 0px;
        inner-shadow-color: #00000000;
        clip: true;

        Image {
            x: 11px;
            y: 9px;
            width: 12px;
            height: 12px;
            source: @image-url("../assets/icons/search.svg");
            image-fit: contain;
            colorize: Palette.muted-half;
        }

        Text {
            visible: root.category-filter == "";
            x: 31px;
            width: parent.width - 42px;
            height: parent.height;
            text: "Filter " + root.category-label + "...";
            color: Palette.muted-half;
            font-size: 12px;
            font-weight: 600;
            vertical-alignment: center;
            overflow: elide;
        }

        TextInput {
            x: 31px;
            y: 0px;
            width: parent.width - 42px;
            height: parent.height;
            text: root.category-filter;
            color: Palette.foreground;
            font-size: 13px;
            font-family: "Geist";
            single-line: true;
            vertical-alignment: center;
            selection-background-color: Palette.sky-25;
            edited => {
                root.category-filter = self.text;
                root.category-filter-edited(self.text);
            }
        }
    }

    if (root.loading && root.entries.length == 0) : DiscoverResultSkeletonList {
        y: root.list-y;
        width: parent.width;
        height: parent.height - root.list-y;
        ranked: root.tab == 1;
    }

    if (!root.loading && root.entries.length == 0 && root.message == "") : DiscoverEmptyState {
        y: root.list-y;
        width: parent.width;
        height: parent.height - root.list-y;
        icon: @image-url("../assets/icons/search.svg");
        title: root.category-filter != "" ? "No matches" : (root.tab == 3 ? "URL / ID Install" : "Search ESOUI");
        subtitle: root.category-filter != "" ? "No addons match that filter." : (root.tab == 3 ? "Paste an ESOUI link or addon ID to install directly." : "Search ESOUI or choose a category to find addons.");
    }

    if (!root.loading && root.entries.length == 0 && root.message != "") : Rectangle {
        y: root.list-y;
        width: parent.width;
        height: parent.height - root.list-y;
        border-radius: 12px;
        border-width: 1px;
        border-color: Palette.red-20;
        background: Palette.white-02;

        Text {
            x: 24px;
            y: 64px;
            width: parent.width - 48px;
            text: "Could not load addons";
            color: Palette.red;
            font-size: 14px;
            font-weight: 900;
            horizontal-alignment: center;
            overflow: elide;
        }

        Text {
            x: 32px;
            y: 96px;
            width: parent.width - 64px;
            height: 44px;
            text: root.message;
            color: Palette.muted-strong;
            font-size: 12px;
            font-weight: 600;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        SmallAction {
            x: (parent.width - self.width) / 2;
            y: 154px;
            label: "Retry";
            tone: Palette.red;
            fill: Palette.red-04;
            fill-hover: Palette.red-15;
            fill-pressed: Palette.red-20;
            line: Palette.red-20;
            clicked => { root.retry(); }
        }
    }

    ListView {
        visible: root.entries.length > 0;
        y: root.list-y;
        width: parent.width;
        height: parent.height - root.list-y - root.footer-height;
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        for entry[index] in root.entries : DiscoverResultRow {
            width: parent.width;
            rank: root.tab == 1 ? entry.rank : 0;
            selected: index == root.selected-index;
            title: entry.title;
            meta: entry.author == "" ? "" : "by " + entry.author;
            category: entry.category;
            downloads: entry.downloads;
            updated: entry.updated;
            show-extra-meta: root.tab == 1 || root.tab == 2;
            installed: entry.installed;
            row-selected => {
                root.selected-index = index;
                root.result-selected(index);
            }
            install-clicked => { root.install-result(index); }
        }
    }

    if (root.tab == 2 && root.category-menu-open) : Rectangle {
        x: 12px;
        y: 34px;
        width: parent.width - 24px;
        height: min(238px, max(42px, root.category-options.length * 28px + 8px));
        border-radius: 10px;
        border-width: 1px;
        border-color: Palette.white-10;
        background: Palette.panel;
        inner-shadow-offset-y: 0px;
        inner-shadow-blur: 0px;
        inner-shadow-color: #00000000;
        drop-shadow-blur: 18px;
        drop-shadow-offset-y: 8px;
        drop-shadow-color: #00000080;
        clip: true;

        if (root.category-options.length == 0) : Text {
            x: 12px;
            width: parent.width - 24px;
            height: parent.height;
            text: root.loading ? "Loading categories..." : "No categories loaded";
            color: Palette.muted-half;
            font-size: 11px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-alignment: center;
            overflow: elide;
        }

        if (root.category-options.length > 0) : ScrollView {
            x: 4px;
            y: 4px;
            width: parent.width - 8px;
            height: parent.height - 8px;
            viewport-width: self.width;
            viewport-height: root.category-options.length * 28px;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            Rectangle {
                width: parent.width;
                height: root.category-options.length * 28px;
                background: #00000000;

                for option[index] in root.category-options : DiscoverSelectMenuRow {
                    y: index * 28px;
                    width: parent.width;
                    label: option.label;
                    depth: option.depth;
                    selected: option.selected;
                    clicked => {
                        root.category-menu-open = false;
                        root.category-selected(index);
                    }
                }
            }
        }
    }

    if (root.tab == 2 && root.category-sort-menu-open) : Rectangle {
        x: 12px;
        y: 74px;
        width: parent.width - 24px;
        height: max(42px, root.category-sort-options.length * 28px + 8px);
        border-radius: 10px;
        border-width: 1px;
        border-color: Palette.white-10;
        background: Palette.panel;
        inner-shadow-offset-y: 0px;
        inner-shadow-blur: 0px;
        inner-shadow-color: #00000000;
        drop-shadow-blur: 18px;
        drop-shadow-offset-y: 8px;
        drop-shadow-color: #00000080;
        clip: true;

        if (root.category-sort-options.length == 0) : Text {
            x: 12px;
            width: parent.width - 24px;
            height: parent.height;
            text: "No sort options";
            color: Palette.muted-half;
            font-size: 11px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-alignment: center;
            overflow: elide;
        }

        if (root.category-sort-options.length > 0) : Rectangle {
            x: 4px;
            y: 4px;
            width: parent.width - 8px;
            height: parent.height - 8px;
            background: #00000000;

            for option[index] in root.category-sort-options : DiscoverSelectMenuRow {
                y: index * 28px;
                width: parent.width;
                label: option.label;
                depth: option.depth;
                selected: option.selected;
                clicked => {
                    root.category-sort-menu-open = false;
                    root.category-sort-selected(index);
                }
            }
        }
    }

    if (root.footer-visible && root.entries.length > 0) : Rectangle {
        y: parent.height - 42px;
        width: parent.width;
        height: 42px;
        background: @linear-gradient(0deg, Palette.panel 0%, Palette.glass-soft 72%, #00000000 100%);

        SmallAction {
            x: (parent.width - self.width) / 2;
            y: 9px;
            label: root.loading ? "Loading..." : "Load More";
            tone: Palette.gold;
            fill: root.loading ? Palette.white-04 : Palette.gold-10;
            fill-hover: root.loading ? Palette.white-04 : Palette.gold-15;
            fill-pressed: root.loading ? Palette.white-04 : Palette.gold-20;
            line: root.loading ? Palette.white-10 : Palette.gold-20;
            clicked => {
                if (!root.loading) {
                    root.load-more();
                }
            }
        }
    }
}

component LabelValue inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <length> label-width: 120px;
    in property <length> label-gap: 16px;
    height: 28px;
    background: #00000000;
    clip: true;

    Text {
        x: 0px;
        width: root.label-width;
        height: root.height;
        text: root.label;
        color: Palette.muted-dim;
        font-size: 12px;
        font-weight: 700;
        vertical-alignment: center;
        overflow: elide;
    }

    Text {
        x: root.label-width + root.label-gap;
        y: 0px;
        width: root.width - root.label-width - root.label-gap - 18px;
        height: root.height;
        text: root.value;
        color: Palette.foreground;
        font-size: 14px;
        font-weight: 400;
        vertical-alignment: center;
        overflow: elide;
    }
}

component DependencyRow inherits Rectangle {
    in property <string> name;
    in property <string> version;
    in property <bool> missing: false;
    in property <bool> outdated: false;
    in property <bool> install: false;
    in property <bool> optional: false;
    callback install-clicked;
    callback remove-clicked;
    private property <bool> optional-missing: root.optional && root.missing;
    height: 44px;
    border-radius: 4px;
    background: touch.has-hover ? Palette.white-03 : #00000000;

    animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    Rectangle {
        x: 8px;
        y: 9px;
        width: 20px;
        height: 20px;
        border-radius: 10px;
        background: root.optional-missing ? Palette.white-04 : (root.missing ? Palette.red-15 : (root.outdated ? Palette.amber-15 : Palette.emerald-15));

        Text {
            width: parent.width;
            height: parent.height;
            text: root.optional-missing ? "-" : (root.missing || root.outdated ? "!" : "✓");
            color: root.optional-missing ? Palette.muted-half : (root.missing ? Palette.red : (root.outdated ? Palette.amber : Palette.emerald));
            font-size: 12px;
            font-weight: 900;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        x: 40px;
        y: 5px;
        width: root.width - 40px - (root.install ? 98px : 46px);
        text: root.name;
        color: root.optional-missing ? Palette.muted-strong : Palette.foreground;
        font-size: 14px;
        font-weight: 500;
        overflow: elide;
    }

    Text {
        x: 40px;
        y: 25px;
        width: root.width - 40px - (root.install ? 98px : 46px);
        text: root.version;
        color: outdated ? Palette.amber : Palette.muted-half;
        font-size: 11px;
        font-weight: 500;
        overflow: elide;
    }

    SmallAction {
        x: root.width - 76px;
        y: 10px;
        visible: install;
        label: "Install";
        tone: Palette.sky;
        fill: Palette.sky-10;
        fill-hover: Palette.sky-16;
        fill-pressed: Palette.sky-22;
        line: Palette.sky-20;
        clicked => { root.install-clicked(); }
    }

    GhostIconButton {
        x: root.width - 34px;
        y: 8px;
        visible: !install;
        icon: @image-url("../assets/icons/trash-2.svg");
        tone: Palette.muted-faint;
        danger: true;
        clicked => { root.remove-clicked(); }
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
    }
}

component DetailSectionTitle inherits Text {
    in property <string> label;
    height: 14px;
    text: root.label;
    color: Palette.muted-dim;
    font-family: "Space Grotesk Light";
    font-size: 11px;
    font-weight: 900;
    vertical-alignment: center;
}

component DetailInfoPanel inherits Rectangle {
    in property <AddonEntry> addon;
    callback open-esoui(string);
    private property <bool> has-last-updated: root.addon.last-updated != "";
    private property <bool> has-downloaded: root.addon.installed-at != "";
    private property <length> downloaded-y: root.has-last-updated ? 162px : 132px;
    private property <length> divider-y: root.has-downloaded ? (root.has-last-updated ? 188px : 158px) : (root.has-last-updated ? 158px : 128px);
    private property <length> action-y: root.divider-y + 12px;
    height: root.divider-y + 68px;
    border-radius: 12px;
    border-width: 1px;
    border-color: Palette.white-06;
    background: Palette.white-02;
    drop-shadow-blur: 0px;
    drop-shadow-offset-y: 0px;
    drop-shadow-color: #00000000;

    LabelValue { x: 12px; y: 12px; width: parent.width - 24px; label: "AUTHOR"; value: root.addon.author; }
    LabelValue { x: 12px; y: 42px; width: parent.width - 24px; label: "VERSION"; value: root.addon.version; }
    LabelValue { x: 12px; y: 72px; width: parent.width - 24px; label: "API VERSION"; value: root.addon.api-version; }

    Text {
        x: 12px;
        y: 105px;
        width: 120px;
        text: "TYPE";
        color: Palette.muted-dim;
        font-size: 12px;
        font-weight: 700;
    }

    Pill {
        x: 148px;
        y: 98px;
        label: root.addon.addon-type;
        tone: root.addon.is-library ? Palette.emerald : Palette.gold;
        fill: root.addon.is-library ? Palette.emerald-04 : Palette.gold-04;
        line: root.addon.is-library ? Palette.emerald-20 : Palette.gold-20;
    }

    if (root.has-last-updated) : LabelValue {
        x: 12px;
        y: 132px;
        width: parent.width - 24px;
        label: "LAST UPDATED";
        value: root.addon.last-updated;
    }

    if (root.has-downloaded) : LabelValue {
        x: 12px;
        y: root.downloaded-y;
        width: parent.width - 24px;
        label: "DOWNLOADED";
        value: root.addon.installed-at;
    }

    Hairline {
        x: 12px;
        y: root.divider-y;
        width: parent.width - 24px;
        height: 1px;
        opacity: 0.5;
    }

    LinkAction {
        x: 12px;
        y: root.action-y;
        label: "View on ESOUI";
        tone: Palette.sky;
        clicked => { root.open-esoui(root.addon.esoui-id); }
    }
}

component DetailTagsSectionLegacy inherits Rectangle {
    height: 22px;
    background: #00000000;

    HorizontalLayout {
        spacing: 6px;
        TagChip { label: "☆ favorite"; kind: 0; }
        TagChip { label: "testing"; kind: 1; }
        TagChip { label: "broken"; kind: 2; }
        TagChip { label: "essential"; kind: 3; }
        TagChip { label: "raid"; kind: 4; }
        TagInput { }
    }
}

component DetailTagsSection inherits Rectangle {
    in property <[TagEntry]> tags;
    in-out property <string> custom-tag-draft;
    callback tag-clicked(string);
    callback add-tag-clicked;
    callback custom-tag-submitted(string);
    height: 22px;
    background: #00000000;

    HorizontalLayout {
        spacing: 6px;
        for tag[index] in root.tags : TagChip {
            label: tag.label;
            kind: tag.kind;
            active: tag.active;
            clicked => { root.tag-clicked(tag.id); }
        }
        TagInput {
            draft <=> root.custom-tag-draft;
            submit(value) => { root.custom-tag-submitted(value); }
        }
    }
}

component DetailDescriptionSection inherits Rectangle {
    in property <string> description;
    // Grow with the wrapped description so the full text is reachable once the pane
    // scrolls (was a fixed 56px box that elided everything past ~2 lines).
    height: max(56px, desc-text.preferred-height + 24px);
    background: #00000000;

    Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: 12px;
        border-width: 0px;
        background: Palette.white-02;
        drop-shadow-blur: 0px;
        drop-shadow-offset-y: 0px;
        drop-shadow-color: #00000000;

        desc-text := Text {
            x: 16px;
            y: 12px;
            width: parent.width - 32px;
            text: root.description;
            color: Palette.text-soft;
            font-size: 14px;
            font-weight: 400;
            wrap: word-wrap;
        }
    }
}

component DetailDependencySection inherits Rectangle {
    in property <[DependencyEntry]> dependencies;
    in property <bool> optional-section: false;
    callback install-dependency(string, bool);
    callback remove-dependency(string, bool);
    height: root.dependencies.length * 44px;
    background: #00000000;

    for dep[index] in root.dependencies : DependencyRow {
        y: index * 44px;
        width: parent.width;
        name: dep.name;
        version: dep.version;
        missing: dep.missing;
        outdated: dep.outdated;
        install: dep.install-action;
        optional: root.optional-section;
        install-clicked => { root.install-dependency(dep.name, root.optional-section); }
        remove-clicked => { root.remove-dependency(dep.name, root.optional-section); }
    }
}

component FileToolbarAction inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> ghost: false;
    in property <bool> primary: false;
    in property <bool> enabled: true;
    callback clicked;
    private property <length> icon-size: 14px;
    private property <length> icon-gap: 7px;
    private property <length> content-width: root.icon-size + root.icon-gap + label-text.preferred-width;
    private property <length> content-x: max(0px, (root.width - root.content-width) / 2);
    width: label-text.preferred-width + 42px;
    preferred-width: self.width;
    horizontal-stretch: 0;
    height: 28px;
    border-radius: 8px;
    opacity: enabled ? 1 : 0.42;
    border-width: 0px;
    background: !enabled ? (ghost ? #00000000 : Palette.white-02) : (touch.pressed ? (primary ? Palette.gold-20 : Palette.white-08) : (touch.has-hover ? (primary ? Palette.gold-15 : Palette.white-06) : (primary ? Palette.gold-10 : (ghost ? #00000000 : Palette.white-04))));

    animate background, opacity { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    content := Rectangle {
        x: root.content-x;
        y: touch.pressed ? 1px : 0px;
        height: root.height;
        width: root.content-width;
        background: #00000000;

        Image {
            x: 0px;
            y: (parent.height - root.icon-size) / 2;
            width: root.icon-size;
            height: root.icon-size;
            source: root.icon;
            image-fit: contain;
            colorize: primary ? Palette.gold : (touch.has-hover ? Palette.foreground : Palette.muted-strong);

            animate colorize { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
        }

        label-text := Text {
            x: root.icon-size + root.icon-gap;
            width: label-text.preferred-width;
            height: parent.height;
            text: root.label;
            color: primary ? Palette.gold : (touch.has-hover ? Palette.foreground : Palette.muted-strong);
            font-size: 12px;
            font-weight: 600;
            vertical-alignment: center;

            animate color { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
        }
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            if (root.enabled) {
                root.clicked();
            }
        }
    }
}

component FileKindPill inherits Rectangle {
    in property <string> label;
    in property <int> kind: 0;
    private property <color> tone: kind == 1 ? Palette.amber : (kind == 2 ? Palette.emerald : Palette.sky);
    private property <color> fill: kind == 1 ? Palette.amber-04 : (kind == 2 ? Palette.emerald-04 : Palette.sky-04);
    width: label-text.preferred-width + 13px;
    preferred-width: self.width;
    horizontal-stretch: 0;
    height: 16px;
    border-radius: 8px;
    border-width: 0px;
    background: root.fill;

    label-text := Text {
        x: 6px;
        height: root.height;
        text: root.label;
        color: root.tone;
        font-size: 10px;
        font-weight: 700;
        vertical-alignment: center;
    }
}

component FileTreeRow inherits Rectangle {
    in property <string> name;
    in property <string> size;
    in property <string> extension;
    in property <int> extension-kind: 0;
    in property <int> indent-level: 0;
    in property <length> indent: 0px;
    in property <bool> folder: false;
    in property <bool> expanded: false;
    in property <bool> selected: false;
    in property <bool> modified: false;
    in property <bool> binary: false;
    callback clicked;
    height: 28px;
    border-radius: 4px;
    background: selected ? Palette.sky-06 : (touch.has-hover ? Palette.white-04 : #00000000);

    animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    Rectangle {
        visible: root.selected;
        x: 0px;
        y: 4px;
        width: 2px;
        height: root.height - 8px;
        border-radius: 1px;
        background: Palette.sky-25;
    }

    Image {
        visible: root.folder;
        x: 6px + root.indent;
        y: 8px;
        width: 12px;
        height: 12px;
        source: root.expanded ? @image-url("../assets/icons/chevron-down.svg") : @image-url("../assets/icons/chevron-right.svg");
        image-fit: contain;
        colorize: Palette.muted-half;
    }

    Image {
        visible: root.folder;
        x: 23px + root.indent;
        y: 7px;
        width: 14px;
        height: 14px;
        source: @image-url("../assets/icons/folder-open.svg");
        image-fit: contain;
        colorize: Palette.muted-strong;
    }

    Image {
        visible: !root.folder;
        x: 8px + root.indent;
        y: 7px;
        width: 14px;
        height: 14px;
        source: @image-url("../assets/icons/file-text.svg");
        image-fit: contain;
        colorize: Palette.muted-half;
    }

    Text {
        x: (root.folder ? 43px : 28px) + root.indent;
        y: 0px;
        width: root.width - self.x - 150px;
        height: root.height;
        text: root.folder ? root.name + "/" : root.name;
        color: root.folder ? Palette.muted-strong : Palette.text-soft;
        font-size: 13px;
        font-weight: root.folder ? 600 : 500;
        vertical-alignment: center;
        overflow: elide;
    }

    Rectangle {
        visible: root.modified;
        x: root.width - 120px;
        y: 10px;
        width: 8px;
        height: 8px;
        border-radius: 4px;
        background: Palette.gold;
    }

    FileKindPill {
        visible: !root.folder && root.extension != "";
        x: root.width - 96px;
        y: 6px;
        label: root.extension;
        kind: root.extension-kind;
    }

    Text {
        visible: !root.folder;
        x: root.width - 48px;
        y: 0px;
        width: 42px;
        height: root.height;
        text: root.size;
        color: Palette.muted-soft;
        font-size: 10px;
        font-weight: 500;
        horizontal-alignment: right;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component DetailFilesPanelLegacy inherits Rectangle {
    in property <AddonEntry> addon;
    in-out property <bool> selected-lua: true;
    height: 430px;
    background: #00000000;

    HorizontalLayout {
        x: 0px;
        y: 0px;
        height: 28px;
        spacing: 8px;
        FileToolbarAction { label: "Open Folder"; icon: @image-url("../assets/icons/folder-open.svg"); }
        FileToolbarAction { visible: root.selected-lua; label: "Open in Editor"; icon: @image-url("../assets/icons/external-link.svg"); }
        FileToolbarAction { label: "Rescan"; icon: @image-url("../assets/icons/refresh-cw.svg"); ghost: true; }
        FileToolbarAction { label: "Backups"; icon: @image-url("../assets/icons/files.svg"); ghost: true; }
    }

    Rectangle {
        x: 0px;
        y: 40px;
        width: parent.width;
        height: 314px;
        border-radius: 12px;
        border-width: 0px;
        background: @linear-gradient(180deg, Palette.white-04 0%, Palette.white-02 100%);

        FileTreeRow { x: 8px; y: 8px; width: parent.width - 16px; folder: true; expanded: true; name: root.addon.folder-name; }
        FileTreeRow { x: 8px; y: 38px; width: parent.width - 16px; indent: 18px; name: root.addon.folder-name + ".lua"; extension: "LUA"; extension-kind: 0; size: "22.4 KB"; selected: root.selected-lua; modified: true; clicked => { root.selected-lua = true; } }
        FileTreeRow { x: 8px; y: 68px; width: parent.width - 16px; indent: 18px; name: root.addon.folder-name + ".xml"; extension: "XML"; extension-kind: 1; size: "4.8 KB"; selected: !root.selected-lua; clicked => { root.selected-lua = false; } }
        FileTreeRow { x: 8px; y: 98px; width: parent.width - 16px; folder: true; expanded: true; indent: 18px; name: "lang"; }
        FileTreeRow { x: 8px; y: 128px; width: parent.width - 16px; indent: 36px; name: "en.lua"; extension: "LUA"; extension-kind: 0; size: "6.2 KB"; }
        FileTreeRow { x: 8px; y: 158px; width: parent.width - 16px; indent: 36px; name: "de.lua"; extension: "LUA"; extension-kind: 0; size: "6.0 KB"; }
        FileTreeRow { x: 8px; y: 188px; width: parent.width - 16px; folder: true; expanded: false; indent: 18px; name: "textures"; }
    }

    Rectangle {
        x: 0px;
        y: 368px;
        width: 8px;
        height: 8px;
        border-radius: 4px;
        background: Palette.gold;
    }

    Text {
        x: 18px;
        y: 361px;
        width: parent.width - 18px;
        height: 22px;
        text: "1 file edited   ·   Protected on update";
        color: Palette.muted-strong;
        font-size: 12px;
        font-weight: 500;
        vertical-alignment: center;
    }
}

component DetailFilesPanel inherits Rectangle {
    in property <AddonEntry> addon;
    in property <[FileEntry]> files;
    in property <[BackupEntry]> backups;
    in property <int> modified-count: 0;
    in property <length> panel-width: 1034px;
    in-out property <string> selected-file-path;
    in-out property <string> selected-file-name;
    in-out property <string> selected-file-content;
    in-out property <string> selected-original-content;
    in-out property <string> editor-line-numbers;
    in-out property <string> editor-message;
    in-out property <length> tree-scroll-y: 0px;
    in-out property <string> custom-tag-draft;
    in-out property <bool> editor-open: false;
    in-out property <bool> editor-editable: false;
    in-out property <bool> editor-binary: false;
    in-out property <bool> editor-error: false;
    in-out property <bool> show-backups: false;
    callback file-selected(string);
    callback folder-toggled(string);
    callback file-content-edited(string);
    callback save-file(string, string);
    callback open-folder;
    callback open-external(string);
    callback rescan;
    callback load-backups;
    callback restore-backup(int);
    private property <bool> editor-dirty: root.editor-open && root.selected-file-content != root.selected-original-content;
    private property <length> tree-height: root.editor-open ? 132px : 314px;
    private property <length> editor-y: 40px + root.tree-height + 28px;
    private property <length> backup-panel-height: root.backups.length == 0 ? 86px : 58px + root.backups.length * 38px;
    height: root.editor-open ? (root.show-backups ? 520px + root.backup-panel-height : 500px) : (root.show-backups ? 410px + root.backup-panel-height : 390px);
    background: #00000000;

    HorizontalLayout {
        x: 0px;
        y: 0px;
        height: 28px;
        spacing: 8px;
        FileToolbarAction { label: "Open Folder"; icon: @image-url("../assets/icons/folder-open.svg"); clicked => { root.open-folder(); } }
        FileToolbarAction { label: "Open in Editor"; icon: @image-url("../assets/icons/external-link.svg"); enabled: root.editor-open && !root.editor-binary && !root.editor-error; clicked => { root.open-external(root.selected-file-path); } }
        FileToolbarAction { label: "Rescan"; icon: @image-url("../assets/icons/refresh-cw.svg"); ghost: true; clicked => { root.rescan(); } }
        FileToolbarAction {
            label: "Backups";
            icon: @image-url("../assets/icons/files.svg");
            ghost: true;
            primary: root.show-backups;
            clicked => {
                if (!root.show-backups) {
                    root.load-backups();
                }
                root.show-backups = !root.show-backups;
            }
        }
    }

    Rectangle {
        x: 0px;
        y: 40px;
        width: parent.width;
        height: root.tree-height;
        border-radius: 12px;
        border-width: 0px;
        background: @linear-gradient(180deg, Palette.white-04 0%, Palette.white-02 100%);
        clip: true;

        Rectangle {
            x: 1px;
            y: 1px;
            width: parent.width - 2px;
            height: 1px;
            background: #ffffff08;
        }

        tree-scroll := ListView {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            viewport-y <=> root.tree-scroll-y;
            vertical-scrollbar-policy: ScrollBarPolicy.always-on;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            for file[index] in root.files : Rectangle {
                width: parent.width;
                height: 30px;
                background: #00000000;

                FileTreeRow {
                    x: 8px;
                    y: 1px;
                    width: parent.width - 16px;
                    folder: file.folder;
                    expanded: file.expanded;
                    indent-level: file.indent-level;
                    indent: file.indent-level * 18px;
                    name: file.name;
                    extension: file.extension;
                    extension-kind: file.extension-kind;
                    size: file.size;
                    selected: !file.folder && file.relative-path == root.selected-file-path;
                    modified: file.modified;
                    binary: file.binary;
                    clicked => {
                        if (file.folder) {
                            root.folder-toggled(file.relative-path);
                        } else {
                            root.file-selected(file.relative-path);
                        }
                    }
                }
            }
        }

        Rectangle {
            x: parent.width - 8px;
            y: 8px;
            width: 4px;
            height: parent.height - 16px;
            border-radius: 2px;
            background: Palette.sky-scroll;
            visible: tree-scroll.viewport-height > tree-scroll.height;
        }

        Rectangle {
            x: parent.width - 8px;
            y: tree-scroll.viewport-height > tree-scroll.height ? 8px + (-tree-scroll.viewport-y) * ((parent.height - 16px - self.height) / (tree-scroll.viewport-height - tree-scroll.height)) : 8px;
            width: 4px;
            height: 48px;
            border-radius: 2px;
            background: Palette.sky-scroll-thumb;
            visible: tree-scroll.viewport-height > tree-scroll.height;
        }
    }

    if (root.modified-count > 0) : Rectangle {
        x: 0px;
        y: 40px + root.tree-height + 8px;
        width: 8px;
        height: 8px;
        border-radius: 4px;
        background: Palette.gold;
    }

    if (root.modified-count > 0) : Text {
        x: 18px;
        y: 40px + root.tree-height + 1px;
        width: parent.width - 18px;
        height: 22px;
        text: root.modified-count + (root.modified-count == 1 ? " file edited" : " files edited") + "   -   Protected on update";
        color: Palette.muted-strong;
        font-size: 12px;
        font-weight: 500;
        vertical-alignment: center;
    }

    if (root.editor-open) : Rectangle {
        x: 0px;
        y: root.editor-y;
        width: root.panel-width;
        height: 256px;
        background: #00000000;

        Text {
            x: 0px;
            y: 0px;
            width: root.panel-width - 280px;
            height: 28px;
            text: root.selected-file-path;
            color: Palette.foreground;
            font-size: 13px;
            font-weight: 600;
            vertical-alignment: center;
            overflow: elide;
        }

        if (root.editor-dirty) : Text {
            x: root.panel-width - 346px;
            y: 0px;
            width: 78px;
            height: 28px;
            text: "UNSAVED";
            color: Palette.amber;
            font-size: 10px;
            font-weight: 800;
            horizontal-alignment: right;
            vertical-alignment: center;
        }

        FileToolbarAction {
            visible: !root.editor-editable && !root.editor-binary && !root.editor-error;
            x: root.panel-width - 166px;
            y: 0px;
            label: "Enable Editing";
            icon: @image-url("../assets/icons/pencil.svg");
            clicked => { root.editor-editable = true; }
        }

        FileToolbarAction {
            visible: root.editor-editable && !root.editor-binary && !root.editor-error;
            x: root.panel-width - 208px;
            y: 0px;
            label: "Revert";
            icon: @image-url("../assets/icons/undo-2.svg");
            enabled: root.editor-dirty;
            clicked => { root.selected-file-content = root.selected-original-content; }
        }

        FileToolbarAction {
            visible: root.editor-editable && !root.editor-binary && !root.editor-error;
            x: root.panel-width - 112px;
            y: 0px;
            label: "Save";
            icon: @image-url("../assets/icons/save.svg");
            primary: true;
            enabled: root.editor-dirty;
            clicked => { root.save-file(root.selected-file-path, root.selected-file-content); }
        }

        FileToolbarAction {
            x: root.panel-width - 30px;
            y: 0px;
            label: "";
            icon: @image-url("../assets/icons/x.svg");
            ghost: true;
            clicked => {
                if (root.editor-dirty) {
                    root.editor-message = "Save or revert this file before closing.";
                } else {
                    root.editor-open = false;
                }
            }
        }

        if (!root.editor-editable && !root.editor-binary && !root.editor-error) : Rectangle {
            x: 0px;
            y: 38px;
            width: parent.width;
            height: 30px;
            border-radius: 8px;
            border-width: 0px;
            background: Palette.white-02;

            Text {
                x: 12px;
                width: parent.width - 24px;
                height: parent.height;
                text: "This file has not been edited. Enable editing to modify it.";
                color: Palette.muted-half;
                font-size: 12px;
                font-weight: 500;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Rectangle {
            x: 0px;
            y: (!root.editor-editable && !root.editor-binary && !root.editor-error) ? 78px : 38px;
            width: parent.width;
            height: parent.height - self.y;
            border-radius: 10px;
            border-width: 0px;
            background: @linear-gradient(180deg, Palette.white-04 0%, Palette.white-02 100%);
            clip: true;

            Rectangle {
                x: 1px;
                y: 1px;
                width: parent.width - 2px;
                height: 1px;
                background: #ffffff08;
            }

            if (root.editor-binary || root.editor-error) : Rectangle {
                width: parent.width;
                height: parent.height;
                background: #00000000;

                Text {
                    x: 18px;
                    y: 16px;
                    width: parent.width - 36px;
                    height: 22px;
                    text: root.selected-file-name;
                    color: Palette.foreground;
                    font-size: 14px;
                    font-weight: 700;
                    overflow: elide;
                }

                Text {
                    x: 18px;
                    y: 42px;
                    width: parent.width - 36px;
                    height: 42px;
                    text: root.editor-message;
                    color: root.editor-error ? Palette.red : Palette.muted-strong;
                    font-size: 12px;
                    font-weight: 500;
                    wrap: word-wrap;
                }
            }

            if (!root.editor-binary && !root.editor-error) : Rectangle {
                width: parent.width;
                height: parent.height;
                background: #00000000;

                Rectangle {
                    x: 44px;
                    y: 9px;
                    width: parent.width - 56px;
                    height: 20px;
                    background: Palette.gold-06;
                }

                Rectangle {
                    x: 0px;
                    y: 0px;
                    width: 56px;
                    height: parent.height;
                    background: #00000021;
                }

                Image {
                    x: 8px;
                    y: 14px;
                    width: 10px;
                    height: 10px;
                    source: @image-url("../assets/icons/chevron-down.svg");
                    image-fit: contain;
                    colorize: Palette.muted-soft;
                }

                Image {
                    x: 8px;
                    y: 94px;
                    width: 10px;
                    height: 10px;
                    source: @image-url("../assets/icons/chevron-right.svg");
                    image-fit: contain;
                    colorize: Palette.muted-soft;
                }

                Text {
                    x: 18px;
                    y: 11px;
                    width: 28px;
                    height: parent.height - 22px;
                    text: root.editor-line-numbers;
                    color: Palette.muted-soft;
                    font-size: 12px;
                    font-family: "Space Grotesk Light";
                    horizontal-alignment: right;
                }

                TextInput {
                    x: 66px;
                    y: 10px;
                    width: parent.width - 78px;
                    height: parent.height - 20px;
                    text: root.selected-file-content;
                    color: Palette.foreground;
                    read-only: !root.editor-editable;
                    font-size: 12px;
                    font-family: "Consolas";
                    wrap: word-wrap;
                    selection-background-color: Palette.sky-25;
                    edited => {
                        root.selected-file-content = self.text;
                        root.file-content-edited(self.text);
                    }
                }
            }
        }
    }

    if (root.show-backups) : Rectangle {
        x: 0px;
        y: root.editor-open ? root.editor-y + 272px : 40px + root.tree-height + 42px;
        width: parent.width;
        height: root.backup-panel-height;
        border-radius: 10px;
        border-width: 0px;
        background: Palette.white-02;

        Text {
            x: 14px;
            y: 12px;
            width: parent.width - 28px;
            height: 18px;
            text: "EDIT BACKUPS";
            color: Palette.muted-half;
            font-family: "Space Grotesk Light";
            font-size: 11px;
            font-weight: 800;
        }

        if (root.backups.length == 0) : Text {
            x: 14px;
            y: 36px;
            width: parent.width - 28px;
            height: 34px;
            text: "No backups yet. Backups are created when edited files are overwritten by an update.";
            color: Palette.muted-strong;
            font-size: 12px;
            font-weight: 500;
            wrap: word-wrap;
        }

        for backup[index] in root.backups : Rectangle {
            x: 10px;
            y: 34px + index * 38px;
            width: parent.width - 20px;
            height: 34px;
            border-radius: 8px;
            background: index - (index / 2) * 2 == 0 ? Palette.white-03 : #00000000;

            Text {
                x: 10px;
                y: 4px;
                width: parent.width - 116px;
                height: 15px;
                text: backup.relative-path;
                color: Palette.foreground;
                font-size: 12px;
                font-weight: 600;
                overflow: elide;
            }

            Text {
                x: 10px;
                y: 18px;
                width: parent.width - 116px;
                height: 12px;
                text: backup.update-from + " -> " + backup.update-to + "  " + backup.backed-up-at;
                color: Palette.muted-half;
                font-size: 10px;
                font-weight: 500;
                overflow: elide;
            }

            FileToolbarAction {
                x: parent.width - self.width - 8px;
                y: 5px;
                label: "Restore";
                icon: @image-url("../assets/icons/undo-2.svg");
                ghost: true;
                clicked => { root.restore-backup(index); }
            }
        }
    }
}

component DetailActionFooter inherits Rectangle {
    in property <bool> addon-disabled: false;
    in property <string> dependent-summary;
    callback toggle-disabled;
    callback remove-addon;
    height: root.dependent-summary == "" ? 94px : 124px;
    background: #00000000;

    Hairline {
        y: 0px;
        width: parent.width;
        height: 1px;
        opacity: 0.5;
    }

    DetailToggleAction {
        x: 0px;
        y: 17px;
        label: root.addon-disabled ? "Enable Addon" : "Disable Addon";
        enabled-tone: root.addon-disabled;
        clicked => { root.toggle-disabled(); }
    }

    DetailRemoveAction {
        x: 0px;
        y: root.dependent-summary == "" ? 61px : 91px;
        clicked => { root.remove-addon(); }
    }

    Text {
        visible: root.dependent-summary != "";
        x: 0px;
        y: 56px;
        width: parent.width;
        text: root.dependent-summary;
        color: Palette.amber;
        font-size: 12px;
        font-weight: 600;
        overflow: elide;
    }
}

component StatusBanner inherits Rectangle {
    in property <string> message;
    in property <string> action-label: "";
    in property <int> tone: 0;
    callback action-clicked;
    private property <color> accent: tone == 2 ? Palette.red : (tone == 1 ? Palette.amber : (tone == 3 ? Palette.gold : Palette.muted));
    private property <color> fill: tone == 2 ? Palette.red-04 : (tone == 1 ? Palette.amber-04 : (tone == 3 ? Palette.gold-04 : Palette.white-03));
    private property <color> line: tone == 2 ? Palette.red-20 : (tone == 1 ? Palette.amber-20 : (tone == 3 ? Palette.gold-20 : Palette.white-06));
    height: 36px;
    background: @linear-gradient(90deg, root.fill 0%, #00000000 100%);

    Rectangle {
        y: root.height - 1px;
        width: root.width;
        height: 1px;
        background: root.line;
    }

    Rectangle {
        x: 18px;
        y: 14px;
        width: 8px;
        height: 8px;
        border-radius: 4px;
        background: root.accent;
        opacity: root.tone == 1 ? 0.9 : 0.75;
    }

    message-text := Text {
        x: 36px;
        y: 0px;
        width: root.action-label == "" ? root.width - 54px : root.width - action.width - 72px;
        height: root.height;
        text: root.message;
        color: root.tone == 0 ? Palette.muted-strong : root.accent;
        font-size: 12px;
        font-weight: 600;
        vertical-alignment: center;
        overflow: elide;
    }

    action := SmallAction {
        visible: root.action-label != "";
        x: root.width - self.width - 16px;
        y: 6px;
        label: root.action-label;
        tone: root.accent;
        fill: root.tone == 2 ? Palette.red-04 : (root.tone == 1 ? Palette.amber-04 : (root.tone == 3 ? Palette.gold-10 : Palette.white-04));
        fill-hover: root.tone == 2 ? Palette.red-15 : (root.tone == 1 ? Palette.amber-15 : (root.tone == 3 ? Palette.gold-15 : Palette.white-06));
        fill-pressed: root.tone == 2 ? Palette.red-20 : (root.tone == 1 ? Palette.amber-20 : (root.tone == 3 ? Palette.gold-20 : Palette.white-08));
        line: root.tone == 2 ? Palette.red-20 : (root.tone == 1 ? Palette.amber-20 : (root.tone == 3 ? Palette.gold-20 : Palette.white-10));
        clicked => { root.action-clicked(); }
    }
}

component AppBannerStack inherits Rectangle {
    in property <string> status-error-message;
    in property <bool> offline-active: false;
    in property <string> app-update-message;
    in property <string> app-update-action-label;
    in property <int> update-available-count: 0;
    in property <int> pending-conflict-count: 0;
    callback open-settings-clicked;
    callback dismiss-offline-clicked;
    callback app-update-action-clicked;
    callback update-all-clicked;
    callback review-conflicts-clicked;
    private property <length> error-height: root.status-error-message != "" ? 36px : 0px;
    private property <length> offline-height: root.offline-active ? 36px : 0px;
    private property <length> app-update-height: root.app-update-message != "" ? 36px : 0px;
    private property <length> update-height: root.update-available-count > 0 ? 36px : 0px;
    private property <length> conflict-height: root.pending-conflict-count > 0 ? 36px : 0px;
    height: root.error-height + root.offline-height + root.app-update-height + root.update-height + root.conflict-height;
    background: #00000000;
    clip: true;

    if (root.status-error-message != "") : StatusBanner {
        y: 0px;
        width: root.width;
        message: root.status-error-message;
        action-label: "Open Settings";
        tone: 2;
        action-clicked => { root.open-settings-clicked(); }
    }

    if (root.offline-active) : StatusBanner {
        y: root.error-height;
        width: root.width;
        message: "You're offline - updates, installs, and discovery are unavailable until you reconnect.";
        action-label: "Dismiss";
        tone: 0;
        action-clicked => { root.dismiss-offline-clicked(); }
    }

    if (root.app-update-message != "") : StatusBanner {
        y: root.error-height + root.offline-height;
        width: root.width;
        message: root.app-update-message;
        action-label: root.app-update-action-label;
        tone: 3;
        action-clicked => { root.app-update-action-clicked(); }
    }

    if (root.update-available-count > 0) : StatusBanner {
        y: root.error-height + root.offline-height + root.app-update-height;
        width: root.width;
        message: root.update-available-count + " addon update" + (root.update-available-count == 1 ? "" : "s") + " available";
        action-label: "Update All";
        tone: 3;
        action-clicked => { root.update-all-clicked(); }
    }

    if (root.pending-conflict-count > 0) : StatusBanner {
        y: root.error-height + root.offline-height + root.app-update-height + root.update-height;
        width: root.width;
        message: root.pending-conflict-count + " addon" + (root.pending-conflict-count == 1 ? "" : "s") + " need your attention - click one to review your edited files";
        action-label: "Review";
        tone: 1;
        action-clicked => { root.review-conflicts-clicked(); }
    }
}

component SettingsTabButton inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> active: false;
    callback clicked;
    width: 138px;
    height: 28px;
    border-radius: 7px;
    border-width: 0px;
    background: root.active ? Palette.white-08 : (touch.has-hover ? Palette.white-03 : #00000000);

    animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    Image {
        x: root.width / 2 - label-text.preferred-width / 2 - 18px;
        y: 7px;
        width: 14px;
        height: 14px;
        source: root.icon;
        image-fit: contain;
        colorize: root.active ? Palette.foreground : (touch.has-hover ? Palette.muted-strong : Palette.muted-half);
    }

    label-text := Text {
        x: root.width / 2 - self.preferred-width / 2 + 2px;
        height: root.height;
        text: root.label;
        color: root.active ? Palette.foreground : (touch.has-hover ? Palette.muted-strong : Palette.muted-half);
        font-size: 12px;
        font-weight: 700;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component SettingsActionButton inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> primary: false;
    in property <bool> danger: false;
    callback clicked;
    private property <length> icon-size: 14px;
    private property <length> icon-gap: 7px;
    private property <length> content-width: root.icon-size + root.icon-gap + label-text.preferred-width;
    private property <length> content-x: max(0px, (root.width - root.content-width) / 2);
    width: label-text.preferred-width + 42px;
    preferred-width: self.width;
    height: 28px;
    border-radius: 7px;
    border-width: 1px;
    border-color: root.primary ? Palette.gold-20 : (root.danger ? Palette.red-20 : (touch.has-hover ? Palette.white-10 : Palette.white-08));
    background: touch.pressed ? (root.primary ? Palette.gold-20 : (root.danger ? Palette.red-15 : Palette.white-08)) : (touch.has-hover ? (root.primary ? Palette.gold-15 : (root.danger ? Palette.red-15 : Palette.white-06)) : (root.primary ? Palette.gold-10 : (root.danger ? Palette.red-04 : Palette.white-03)));

    animate background, border-color { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    content := Rectangle {
        x: root.content-x;
        y: touch.pressed ? 1px : 0px;
        height: root.height;
        width: root.content-width;
        background: #00000000;

        Image {
            x: 0px;
            y: (parent.height - root.icon-size) / 2;
            width: root.icon-size;
            height: root.icon-size;
            source: root.icon;
            image-fit: contain;
            colorize: root.primary ? Palette.gold : (root.danger ? Palette.red : (touch.has-hover ? Palette.foreground : Palette.muted-strong));
        }

        label-text := Text {
            x: root.icon-size + root.icon-gap;
            width: label-text.preferred-width;
            height: parent.height;
            text: root.label;
            color: root.primary ? Palette.gold : (root.danger ? Palette.red : (touch.has-hover ? Palette.foreground : Palette.muted-strong));
            font-size: 12px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component SettingsToggleRow inherits Rectangle {
    in property <string> label;
    in property <string> description;
    in-out property <bool> checked: false;
    callback changed(bool);
    height: 64px;
    border-radius: 11px;
    border-width: 1px;
    border-color: touch.has-hover ? Palette.white-08 : Palette.white-06;
    background: touch.has-hover ? Palette.white-04 : Palette.white-02;

    animate background, border-color { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    Rectangle {
        x: 12px;
        y: (root.height - self.height) / 2;
        width: 18px;
        height: 18px;
        border-radius: 5px;
        border-width: 0px;
        background: root.checked ? Palette.gold-25 : Palette.white-08;

        Image {
            visible: root.checked;
            x: 3px;
            y: 3px;
            width: 12px;
            height: 12px;
            source: @image-url("../assets/icons/check.svg");
            image-fit: contain;
            colorize: Palette.gold;
        }
    }

    Text {
        x: 44px;
        y: root.height <= 54px ? 8px : 11px;
        width: parent.width - 58px;
        text: root.label;
        color: Palette.foreground;
        font-size: 14px;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        x: 44px;
        y: root.height <= 54px ? 30px : 34px;
        width: parent.width - 58px;
        text: root.description;
        color: Palette.muted-half;
        font-size: 12px;
        font-weight: 500;
        overflow: elide;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            root.checked = !root.checked;
            root.changed(root.checked);
        }
    }
}

component SettingsRadioRow inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked;
    height: 28px;
    background: touch.has-hover ? Palette.white-03 : #00000000;
    border-radius: 7px;

    Rectangle {
        x: 8px;
        y: 6px;
        width: 16px;
        height: 16px;
        border-radius: 8px;
        border-width: 0px;
        background: root.active ? Palette.gold-20 : Palette.white-04;

        Rectangle {
            visible: root.active;
            x: 4px;
            y: 4px;
            width: 6px;
            height: 6px;
            border-radius: 3px;
            background: Palette.gold;
        }
    }

    Text {
        x: 34px;
        height: root.height;
        text: root.label;
        color: Palette.muted-strong;
        font-size: 12px;
        font-weight: 600;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component SettingsToolRow inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <string> description;
    in property <bool> accent: false;
    callback clicked;
    height: 58px;
    border-radius: 10px;
    border-width: 1px;
    border-color: root.accent ? Palette.gold-20 : (touch.has-hover ? Palette.white-08 : Palette.white-06);
    background: touch.has-hover ? Palette.white-04 : Palette.white-02;

    animate background, border-color { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    Image {
        x: 13px;
        y: 18px;
        width: 18px;
        height: 18px;
        source: root.icon;
        image-fit: contain;
        colorize: root.accent ? Palette.gold : Palette.muted-strong;
    }

    Text {
        x: 44px;
        y: 9px;
        width: parent.width - 78px;
        text: root.label;
        color: Palette.foreground;
        font-size: 13px;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        x: 44px;
        y: 31px;
        width: parent.width - 78px;
        text: root.description;
        color: Palette.muted-half;
        font-size: 11px;
        font-weight: 500;
        overflow: elide;
    }

    Image {
        x: parent.width - 28px;
        y: 21px;
        width: 14px;
        height: 14px;
        source: @image-url("../assets/icons/chevron-right.svg");
        image-fit: contain;
        colorize: touch.has-hover ? Palette.muted-strong : Palette.muted-dim;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component ThemeSwatchPreview inherits Rectangle {
    in property <ThemeEntry> theme;
    in property <bool> active: false;
    border-radius: 8px;
    background: root.theme.bg-base;
    clip: true;

    Rectangle { x: -12px; y: -18px; width: 64px; height: 64px; border-radius: 32px; background: root.theme.orb1; opacity: 0.50; }
    Rectangle { x: parent.width - 54px; y: parent.height - 44px; width: 64px; height: 64px; border-radius: 32px; background: root.theme.orb2; opacity: 0.40; }
    Rectangle { x: parent.width - 82px; y: 10px; width: 48px; height: 48px; border-radius: 24px; background: root.theme.orb3; opacity: 0.30; }
    Rectangle { width: parent.width; height: parent.height; background: root.theme.background; opacity: 0.70; }

    Rectangle {
        x: 8px;
        y: 8px;
        width: parent.width - 16px;
        height: parent.height - 16px;
        border-radius: 6px;
        border-width: 0px;
        border-color: root.active ? root.theme.primary : root.theme.border;
        background: root.theme.surface;

        Rectangle { x: 8px; y: 9px; width: 7px; height: 7px; border-radius: 4px; background: root.theme.primary; }
        Rectangle { x: 20px; y: 10px; width: 58px; height: 5px; border-radius: 3px; background: root.theme.foreground; opacity: 0.86; }
        Rectangle { x: 8px; y: 25px; width: 92px; height: 4px; border-radius: 2px; background: root.theme.muted-foreground; opacity: 0.70; }
        Rectangle { x: 8px; y: 36px; width: 74px; height: 4px; border-radius: 2px; background: root.theme.muted-foreground; opacity: 0.52; }
        Rectangle { x: 8px; y: parent.height - 19px; width: 42px; height: 11px; border-radius: 3px; background: root.theme.primary; }
        Rectangle { x: 57px; y: parent.height - 19px; width: 11px; height: 11px; border-radius: 6px; background: root.theme.accent; }
        Rectangle { x: parent.width - 20px; y: parent.height - 18px; width: 9px; height: 9px; border-radius: 5px; border-width: 0px; background: root.theme.surface; opacity: 0.92; }
    }
}

component ThemeChoiceCard inherits Rectangle {
    in property <ThemeEntry> theme;
    in property <bool> active: false;
    in property <length> card-width: 170px;
    callback selected(string);
    callback edited(string);
    callback forked(string);
    width: root.card-width;
    height: 140px;
    border-radius: 12px;
    border-width: 1px;
    border-color: root.active ? Palette.gold-25 : (touch.has-hover ? Palette.white-10 : Palette.white-06);
    background: root.active ? Palette.gold-06 : (touch.has-hover ? Palette.white-04 : Palette.white-02);
    clip: true;

    animate background, border-color, y { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    ThemeSwatchPreview {
        x: 7px;
        y: 7px;
        width: parent.width - 14px;
        height: 82px;
        theme: root.theme;
        active: root.active;
    }

    Text {
        x: 10px;
        y: 96px;
        width: parent.width - 34px;
        text: root.theme.name;
        color: Palette.foreground;
        font-size: 12px;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        x: 10px;
        y: 116px;
        width: parent.width - 20px;
        text: root.theme.description;
        color: Palette.muted-half;
        font-size: 10px;
        font-weight: 500;
        overflow: elide;
    }

    Image {
        visible: root.active;
        x: parent.width - 24px;
        y: 96px;
        width: 16px;
        height: 16px;
        source: @image-url("../assets/icons/check.svg");
        image-fit: contain;
        colorize: Palette.gold;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.selected(root.theme.id); }
    }

    Rectangle {
        visible: touch.has-hover && root.theme.category == "Custom";
        x: parent.width - 62px;
        y: 13px;
        width: 22px;
    height: 22px;
    border-radius: 11px;
        border-width: 1px;
        border-color: Palette.white-10;
        background: #00000066;

        Image { x: 5px; y: 5px; width: 12px; height: 12px; source: @image-url("../assets/icons/pencil.svg"); image-fit: contain; colorize: Palette.muted-strong; }
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.edited(root.theme.id); }
        }
    }

    Rectangle {
        visible: touch.has-hover;
        x: root.theme.category == "Custom" ? parent.width - 34px : parent.width - 36px;
        y: 13px;
        width: 22px;
    height: 22px;
    border-radius: 11px;
        border-width: 1px;
        border-color: Palette.white-10;
        background: #00000066;

        Image { x: 5px; y: 5px; width: 12px; height: 12px; source: @image-url("../assets/icons/copy-plus.svg"); image-fit: contain; colorize: Palette.muted-strong; }
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.forked(root.theme.id); }
        }
    }
}

component ThemeEditorColorTile inherits Rectangle {
    in property <string> label;
    in property <string> hint;
    in property <color> value;
    in-out property <string> value-text;
    callback edited;
    width: 174px;
    height: 62px;
    border-radius: 8px;
    border-width: 1px;
    border-color: field-touch.has-hover ? Palette.white-10 : Palette.white-06;
    background: field-touch.has-hover ? Palette.white-04 : Palette.white-02;

    animate background, border-color { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    field-touch := TouchArea {
        width: root.width;
        height: root.height;
    }

    Rectangle {
        x: 10px;
        y: 14px;
        width: 34px;
        height: 34px;
        border-radius: 7px;
        border-width: 1px;
        border-color: Palette.white-10;
        background: root.value;

        Rectangle {
            x: 1px;
            y: 1px;
            width: parent.width - 2px;
            height: 1px;
            background: #ffffff24;
        }
    }

    Text {
        x: 54px;
        y: 7px;
        width: parent.width - 64px;
        text: root.label;
        color: Palette.foreground;
        font-size: 11px;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        x: 54px;
        y: 22px;
        width: parent.width - 64px;
        text: root.hint;
        color: Palette.muted-soft;
        font-size: 9px;
        font-weight: 500;
        overflow: elide;
    }

    Rectangle {
        x: 54px;
        y: 37px;
        width: parent.width - 64px;
        height: 20px;
        border-radius: 5px;
        border-width: 1px;
        border-color: field-touch.has-hover ? Palette.white-10 : Palette.white-06;
        background: field-touch.has-hover ? #ffffff08 : #00000024;
        clip: true;

        TextInput {
            x: 6px;
            y: 0px;
            width: parent.width - 12px;
            height: parent.height;
            text: root.value-text;
            color: Palette.foreground;
            font-size: 10px;
            font-family: "Consolas";
            single-line: true;
            vertical-alignment: center;
            selection-background-color: Palette.sky-25;
            edited => {
                root.value-text = self.text;
                root.edited();
            }
        }
    }
}

component AppearanceOverlay inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <string> active-theme-id;
    in property <[ThemeEntry]> themes;
    in-out property <ThemeEntry> draft-theme;
    in-out property <string> draft-theme-id;
    in-out property <string> draft-theme-name;
    in-out property <string> draft-theme-description;
    in-out property <bool> draft-theme-new: true;
    in-out property <string> draft-bg-base;
    in-out property <string> draft-background;
    in-out property <string> draft-surface;
    in-out property <string> draft-foreground;
    in-out property <string> draft-muted-foreground;
    in-out property <string> draft-primary;
    in-out property <string> draft-primary-foreground;
    in-out property <string> draft-accent;
    in-out property <string> draft-border;
    in-out property <string> draft-orb1;
    in-out property <string> draft-orb2;
    in-out property <string> draft-orb3;
    in-out property <string> draft-skin-id;
    in property <[ContrastEntry]> draft-contrast-checks;
    in-out property <string> draft-contrast-warning;
    in-out property <int> active-tab: 0;
    in-out property <bool> editor-open: false;
    in-out property <bool> theme-delete-confirming: false;
    in-out property <bool> auto-update: false;
    in-out property <bool> warn-eso-running: true;
    in-out property <bool> native-performance-mode: true;
    in-out property <bool> official-uploader: false;
    in-out property <bool> auto-open-analysis: false;
    in-out property <int> conflict-policy: 0;
    in-out property <string> addons-path;
    in-out property <bool> minion-detected: false;
    in-out property <bool> pack-hub-authenticated: false;
    callback close;
    callback theme-selected(string);
    callback theme-create;
    callback theme-edit(string);
    callback theme-fork(string);
    callback theme-save(string);
    callback theme-delete(string);
    callback theme-export(string);
    callback theme-import;
    callback theme-draft-updated;
    callback theme-editor-cancelled;
    callback settings-changed;
    callback performance-mode-changed(bool);
    callback addons-path-opened;
    callback addons-path-redetected;
    callback addons-path-applied(string);
    callback backup-restore-clicked;
    callback characters-clicked;
    callback api-compat-clicked;
    callback app-update-clicked;
    callback minion-migration-clicked;
    callback safety-center-clicked;
    callback addon-list-exported;
    callback addon-list-imported;
    callback pack-hub-account-data-clicked;
    visible: root.open;
    background: #000000c8;

    TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            if (root.editor-open) {
                root.theme-editor-cancelled();
            }
            root.theme-delete-confirming = false;
            root.close();
        }
    }

    panel := Rectangle {
        width: root.width < 700px ? root.width - 44px : 620px;
        height: root.height < 790px ? root.height - 44px : 720px;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        border-radius: 16px;
        border-width: 1px;
        border-color: Palette.border-strong;
        background: Tokens.surface;
        drop-shadow-blur: 30px;
        drop-shadow-offset-y: 12px;
        drop-shadow-color: #00000099;
        clip: true;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { }
        }

        Image {
            x: 22px;
            y: 20px;
            width: 18px;
            height: 18px;
            source: @image-url("../../../src/assets/logo-icon.svg");
            image-fit: contain;
            colorize: Palette.logo;
        }

        Text {
            x: 50px;
            y: 18px;
            width: parent.width - 100px;
            text: "Settings";
            color: Palette.gold;
            font-size: 16px;
            font-weight: 800;
        }

        GhostIconButton {
            x: parent.width - 42px;
            y: 14px;
            icon: @image-url("../assets/icons/x.svg");
            clicked => {
                if (root.editor-open) {
                    root.theme-editor-cancelled();
                }
                root.theme-delete-confirming = false;
                root.close();
            }
        }

        Rectangle {
            x: 22px;
            y: 58px;
            width: parent.width - 44px;
            height: 36px;
            border-radius: 10px;
            border-width: 0px;
            background: Palette.white-03;

            SettingsTabButton {
                x: 4px;
                y: 4px;
                icon: @image-url("../assets/icons/folder-open.svg");
                label: "General";
                active: root.active-tab == 0;
                clicked => {
                    if (root.editor-open) {
                        root.theme-editor-cancelled();
                    }
                    root.active-tab = 0;
                    root.editor-open = false;
                    root.theme-delete-confirming = false;
                }
            }
            SettingsTabButton { x: 150px; y: 4px; icon: @image-url("../assets/icons/square.svg"); label: "Appearance"; active: root.active-tab == 1; clicked => { root.active-tab = 1; } }
            SettingsTabButton {
                x: 296px;
                y: 4px;
                icon: @image-url("../assets/icons/settings.svg");
                label: "Tools";
                active: root.active-tab == 2;
                clicked => {
                    if (root.editor-open) {
                        root.theme-editor-cancelled();
                    }
                    root.active-tab = 2;
                    root.editor-open = false;
                    root.theme-delete-confirming = false;
                }
            }
            SettingsTabButton {
                x: 442px;
                y: 4px;
                icon: @image-url("../assets/icons/files.svg");
                label: "Data";
                active: root.active-tab == 3;
                clicked => {
                    if (root.editor-open) {
                        root.theme-editor-cancelled();
                    }
                    root.active-tab = 3;
                    root.editor-open = false;
                    root.theme-delete-confirming = false;
                }
            }
        }

        if (root.active-tab == 0) : ScrollView {
            x: 22px;
            y: 112px;
            width: parent.width - 44px;
            height: parent.height - 134px;
            viewport-width: self.width;
            viewport-height: 602px;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            Rectangle {
                width: parent.width;
                height: 602px;
                border-radius: 12px;
                border-width: 0px;
                background: #00000000;

                Rectangle {
                    x: 0px;
                    y: 0px;
                    width: parent.width;
                    height: 126px;
                    border-radius: 12px;
                    border-width: 0px;
                    background: Palette.white-02;
                }

                DetailSectionTitle { x: 14px; y: 13px; width: parent.width - 28px; label: "ADDONS FOLDER"; }

                Rectangle {
                    x: 14px;
                    y: 38px;
                    width: parent.width - 28px;
                    height: 38px;
                    border-radius: 9px;
                    border-width: 0px;
                    background: Palette.white-03;

                    Text {
                        x: 12px;
                        y: 0px;
                        width: parent.width - 24px;
                        height: parent.height;
                        text: root.addons-path == "" ? "No AddOns folder configured" : root.addons-path;
                        color: Palette.muted-strong;
                        font-size: 12px;
                        font-weight: 600;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                SettingsActionButton { x: 14px; y: 88px; icon: @image-url("../assets/icons/folder-open.svg"); label: "Browse"; clicked => { root.addons-path-opened(); } }
                SettingsActionButton { x: 106px; y: 88px; icon: @image-url("../assets/icons/refresh-cw.svg"); label: "Re-detect"; clicked => { root.addons-path-redetected(); } }
                SettingsActionButton { x: parent.width - self.width - 14px; y: 88px; icon: @image-url("../assets/icons/save.svg"); label: "Apply"; primary: true; clicked => { root.addons-path-applied(root.addons-path); } }

                SettingsToggleRow { x: 0px; y: 144px; width: parent.width; height: 58px; label: "Auto-update on launch"; description: "Automatically update all addons when Kalpa starts"; checked <=> root.auto-update; changed(_) => { root.settings-changed(); } }
                SettingsToggleRow { x: 0px; y: 208px; width: parent.width; height: 58px; label: "Native performance UI"; description: "Use the smooth Slint shell instead of the WebView shell"; checked <=> root.native-performance-mode; changed(value) => { root.performance-mode-changed(value); } }
                SettingsToggleRow { x: 0px; y: 272px; width: parent.width; height: 52px; label: "Warn when ESO is running"; description: "Remind me to /reloadui after changing addons while the game is open"; checked <=> root.warn-eso-running; changed(_) => { root.settings-changed(); } }
                SettingsToggleRow { x: 0px; y: 332px; width: parent.width; height: 52px; label: "Use the official ESO Logs uploader"; description: "Off by default - Kalpa uploads directly and falls back when needed"; checked <=> root.official-uploader; changed(_) => { root.settings-changed(); } }
                SettingsToggleRow { x: 0px; y: 392px; width: parent.width; height: 52px; label: "Open analysis after upload"; description: "Open finished reports in the ESO Log Aggregator"; checked <=> root.auto-open-analysis; changed(_) => { root.settings-changed(); } }

                Rectangle {
                    x: 0px;
                    y: 472px;
                    width: parent.width;
                    height: 112px;
                    border-radius: 11px;
                    border-width: 0px;
                    background: Palette.white-02;

                    DetailSectionTitle { x: 12px; y: 10px; width: parent.width - 24px; label: "WHEN YOUR EDITED FILES CONFLICT WITH AN UPDATE"; }
                    SettingsRadioRow { x: 8px; y: 32px; width: parent.width - 16px; label: "Ask me each time"; active: root.conflict-policy == 0; clicked => { root.conflict-policy = 0; root.settings-changed(); } }
                    SettingsRadioRow { x: 8px; y: 58px; width: parent.width - 16px; label: "Always keep my version"; active: root.conflict-policy == 1; clicked => { root.conflict-policy = 1; root.settings-changed(); } }
                    SettingsRadioRow { x: 8px; y: 84px; width: parent.width - 16px; label: "Always take the update (back up my files)"; active: root.conflict-policy == 2; clicked => { root.conflict-policy = 2; root.settings-changed(); } }
                }
            }
        }

        if (root.active-tab == 1 && !root.editor-open) : ScrollView {
            x: 22px;
            y: 112px;
            width: parent.width - 44px;
            height: parent.height - 134px;
            viewport-width: self.width;
            viewport-height: ((root.themes.length + 2) / 3) * 152px + 360px;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            content := Rectangle {
                width: parent.width;
                height: ((root.themes.length + 2) / 3) * 152px + 360px;
                background: #00000000;
                private property <length> card-w: (self.width - 20px) / 3;

                SettingsActionButton { x: 0px; y: 0px; icon: @image-url("../assets/icons/plus.svg"); label: "Create theme"; primary: true; clicked => { root.theme-delete-confirming = false; root.theme-create(); } }
                SettingsActionButton { x: 128px; y: 0px; icon: @image-url("../assets/icons/clipboard-paste.svg"); label: "Import"; clicked => { root.theme-delete-confirming = false; root.theme-import(); } }

                for theme[index] in root.themes : DetailSectionTitle {
                    visible: theme.category-heading != "";
                    x: 0px;
                    y: 48px + theme.gallery-y * 1px;
                    width: parent.width;
                    label: theme.category-heading;
                }

                for theme[index] in root.themes : ThemeChoiceCard {
                    x: theme.col * (parent.card-w + 10px);
                    y: 70px + theme.gallery-y * 1px;
                    card-width: parent.card-w;
                    theme: theme;
                    active: root.active-theme-id == theme.id;
                    selected(id) => { root.theme-delete-confirming = false; root.theme-selected(id); }
                    edited(id) => { root.theme-delete-confirming = false; root.theme-edit(id); }
                    forked(id) => { root.theme-delete-confirming = false; root.theme-fork(id); }
                }
            }
        }

        if (root.active-tab == 1 && root.editor-open) : ScrollView {
            x: 22px;
            y: 112px;
            width: parent.width - 44px;
            height: parent.height - 196px;
            viewport-width: self.width;
            viewport-height: 1030px;
            vertical-scrollbar-policy: ScrollBarPolicy.always-on;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            Rectangle {
                width: parent.width;
                height: 1030px;
                background: #00000000;

                GhostIconButton { x: 0px; y: 0px; icon: @image-url("../assets/icons/arrow-left.svg"); clicked => { root.theme-delete-confirming = false; root.theme-editor-cancelled(); } }

                Rectangle {
                    x: 40px;
                    y: 0px;
                    width: parent.width - 158px;
                    height: 32px;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: Palette.white-08;
                    background: Palette.white-04;
                    clip: true;

                    TextInput {
                        x: 12px;
                        y: 0px;
                        width: parent.width - 24px;
                        height: parent.height;
                        text: root.draft-theme-name;
                        color: Palette.foreground;
                        font-size: 13px;
                        font-weight: 700;
                        font-family: "Geist";
                        single-line: true;
                        vertical-alignment: center;
                        selection-background-color: Palette.sky-25;
                        edited => {
                            root.draft-theme-name = self.text;
                            root.theme-draft-updated();
                        }
                    }
                }

                SettingsActionButton { x: parent.width - self.width; y: 2px; icon: @image-url("../assets/icons/copy.svg"); label: "Export"; clicked => { root.theme-export(root.draft-theme-id); } }

                Rectangle {
                    x: 0px;
                    y: 48px;
                    width: parent.width;
                    height: 162px;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Palette.white-06;
                    background: Palette.white-02;

                    ThemeSwatchPreview {
                        x: 14px;
                        y: 14px;
                        width: 280px;
                        height: 118px;
                        theme: root.draft-theme;
                        active: true;
                    }

                    Text {
                        x: 310px;
                        y: 15px;
                        width: parent.width - 324px;
                        text: "DESCRIPTION";
                        color: Palette.muted-half;
                        font-family: "Space Grotesk Light";
                        font-size: 10px;
                        font-weight: 900;
                        overflow: elide;
                    }

                    Rectangle {
                        x: 310px;
                        y: 36px;
                        width: parent.width - 324px;
                        height: 56px;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Palette.white-08;
                        background: Palette.white-03;
                        clip: true;

                        Text {
                            visible: root.draft-theme-description == "";
                            x: 10px;
                            y: 0px;
                            width: parent.width - 20px;
                            height: parent.height;
                            text: "Short note for this theme";
                            color: Palette.muted-half;
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                            wrap: word-wrap;
                        }

                        TextInput {
                            x: 10px;
                            y: 6px;
                            width: parent.width - 20px;
                            height: parent.height - 12px;
                            text: root.draft-theme-description;
                            color: Palette.foreground;
                            font-size: 12px;
                            font-family: "Geist";
                            wrap: word-wrap;
                            selection-background-color: Palette.sky-25;
                            edited => {
                                root.draft-theme-description = self.text;
                                root.theme-draft-updated();
                            }
                        }
                    }

                    Text {
                        x: 14px;
                        y: 138px;
                        width: parent.width - 28px;
                        text: root.draft-theme-new ? "Forked from the selected theme. Nothing is saved until Save." : "Editing a saved custom theme. Nothing is saved until Save.";
                        color: Palette.muted-half;
                        font-size: 11px;
                        font-weight: 500;
                        overflow: elide;
                    }
                }

                DetailSectionTitle { x: 0px; y: 232px; width: parent.width; label: "BASE & SURFACES"; }
                ThemeEditorColorTile { x: 0px; y: 256px; label: "Base"; hint: "Window base"; value: root.draft-theme.bg-base; value-text <=> root.draft-bg-base; edited => { root.theme-draft-updated(); } }
                ThemeEditorColorTile { x: 186px; y: 256px; label: "Background"; hint: "Content backdrop"; value: root.draft-theme.background; value-text <=> root.draft-background; edited => { root.theme-draft-updated(); } }
                ThemeEditorColorTile { x: 372px; y: 256px; label: "Surface"; hint: "Panels/cards"; value: root.draft-theme.surface; value-text <=> root.draft-surface; edited => { root.theme-draft-updated(); } }
                ThemeEditorColorTile { x: 0px; y: 324px; label: "Border"; hint: "Subtle dividers"; value: root.draft-theme.border; value-text <=> root.draft-border; edited => { root.theme-draft-updated(); } }

                DetailSectionTitle { x: 0px; y: 400px; width: parent.width; label: "TEXT & ACCENTS"; }
                ThemeEditorColorTile { x: 0px; y: 424px; label: "Foreground"; hint: "Primary text"; value: root.draft-theme.foreground; value-text <=> root.draft-foreground; edited => { root.theme-draft-updated(); } }
                ThemeEditorColorTile { x: 186px; y: 424px; label: "Muted"; hint: "Secondary text"; value: root.draft-theme.muted-foreground; value-text <=> root.draft-muted-foreground; edited => { root.theme-draft-updated(); } }
                ThemeEditorColorTile { x: 372px; y: 424px; label: "Primary"; hint: "Main action"; value: root.draft-theme.primary; value-text <=> root.draft-primary; edited => { root.theme-draft-updated(); } }
                ThemeEditorColorTile { x: 0px; y: 492px; label: "Primary Label"; hint: "Button text"; value: root.draft-theme.primary-foreground; value-text <=> root.draft-primary-foreground; edited => { root.theme-draft-updated(); } }
                ThemeEditorColorTile { x: 186px; y: 492px; label: "Accent"; hint: "Highlights"; value: root.draft-theme.accent; value-text <=> root.draft-accent; edited => { root.theme-draft-updated(); } }

                DetailSectionTitle { x: 0px; y: 568px; width: parent.width; label: "AMBIENT GLOW"; }
                ThemeEditorColorTile { x: 0px; y: 592px; label: "Glow one"; hint: "Orb color"; value: root.draft-theme.orb1; value-text <=> root.draft-orb1; edited => { root.theme-draft-updated(); } }
                ThemeEditorColorTile { x: 186px; y: 592px; label: "Glow two"; hint: "Orb color"; value: root.draft-theme.orb2; value-text <=> root.draft-orb2; edited => { root.theme-draft-updated(); } }
                ThemeEditorColorTile { x: 372px; y: 592px; label: "Glow three"; hint: "Orb color"; value: root.draft-theme.orb3; value-text <=> root.draft-orb3; edited => { root.theme-draft-updated(); } }

                DetailSectionTitle { x: 0px; y: 668px; width: parent.width; label: "ELDER SCROLLS SKIN"; }
                for skin[i] in [
                    { id: "", label: "None" },
                    { id: "nordic-runestone", label: "Nordic" },
                    { id: "daedric-obsidian", label: "Daedric" },
                    { id: "dwemer-brass", label: "Dwemer" },
                    { id: "ayleid-welkynd", label: "Ayleid" },
                    { id: "sithis-brotherhood", label: "Sithis" },
                    { id: "apocrypha-mora", label: "Apocrypha" },
                    { id: "clockwork-city", label: "Clockwork" },
                    { id: "elder-scroll-ancient-tome", label: "Tome" },
                ] : Rectangle {
                    x: mod(i, 5) * (parent.width / 5);
                    y: 692px + floor(i / 5) * 34px;
                    width: parent.width / 5 - 6px;
                    height: 28px;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: root.draft-skin-id == skin.id ? Palette.gold-20 : Palette.white-10;
                    background: root.draft-skin-id == skin.id ? Palette.gold-10 : (skin-touch.has-hover ? Palette.white-06 : Palette.white-03);

                    Text {
                        width: parent.width;
                        height: parent.height;
                        text: skin.label;
                        color: root.draft-skin-id == skin.id ? Palette.gold : Palette.muted-strong;
                        font-size: 11px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    skin-touch := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            root.draft-skin-id = skin.id;
                            root.theme-draft-updated();
                        }
                    }
                }

                Rectangle {
                    x: 0px;
                    y: 784px;
                    width: parent.width;
                    height: 206px;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Palette.white-06;
                    background: Palette.white-02;

                    DetailSectionTitle { x: 12px; y: 12px; width: parent.width - 24px; label: "READABILITY (WCAG)"; }

                    for check[index] in root.draft-contrast-checks : Rectangle {
                        x: 12px;
                        y: 38px + index * 22px;
                        width: parent.width - 24px;
                        height: 18px;
                        background: #00000000;

                        Rectangle {
                            x: 0px;
                            y: 1px;
                            width: 16px;
                            height: 16px;
                            border-radius: 8px;
                            background: check.level == 0 ? Palette.red-15 : (check.level == 1 ? Palette.amber-15 : Palette.emerald-15);

                            Text {
                                visible: check.level != 2;
                                width: parent.width;
                                height: parent.height;
                                text: check.level == 0 ? "!" : "~";
                                color: check.level == 0 ? Palette.red : (check.level == 1 ? Palette.amber : Palette.emerald);
                                font-size: 9px;
                                font-weight: 900;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            Image {
                                visible: check.level == 2;
                                x: 4px;
                                y: 4px;
                                width: 8px;
                                height: 8px;
                                source: @image-url("../assets/icons/check.svg");
                                image-fit: contain;
                                colorize: Palette.emerald;
                            }
                        }

                        Text {
                            x: 24px;
                            width: parent.width - 86px;
                            height: parent.height;
                            text: check.label;
                            color: Palette.muted-strong;
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        Text {
                            x: parent.width - 58px;
                            width: 58px;
                            height: parent.height;
                            text: check.ratio;
                            color: Palette.muted-half;
                            font-size: 11px;
                            font-weight: 600;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                        }
                    }

                    if (root.draft-contrast-warning != "") : Rectangle {
                        x: 12px;
                        y: 154px;
                        width: parent.width - 24px;
                        height: 38px;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Palette.amber-20;
                        background: Palette.amber-04;

                        Image {
                            x: 9px;
                            y: 11px;
                            width: 14px;
                            height: 14px;
                            source: @image-url("../assets/icons/triangle-alert.svg");
                            image-fit: contain;
                            colorize: Palette.amber;
                        }

                        Text {
                            x: 30px;
                            y: 7px;
                            width: parent.width - 40px;
                            height: 24px;
                            text: root.draft-contrast-warning;
                            color: Palette.amber;
                            font-size: 11px;
                            font-weight: 600;
                            wrap: word-wrap;
                        }
                    }
                }

            }
        }

        if (root.active-tab == 1 && root.editor-open) : Rectangle {
            x: 18px;
            y: parent.height - 58px;
            width: parent.width - 36px;
            height: 50px;
            background: @linear-gradient(0deg, Tokens.surface 0%, Tokens.surface-84 78%, #00000000 100%);

            SettingsActionButton { x: 4px; y: 14px; icon: @image-url("../assets/icons/save.svg"); label: root.draft-theme-new ? "Save theme" : "Save changes"; primary: true; clicked => { root.theme-delete-confirming = false; root.theme-save(root.draft-theme-name); } }
            SettingsActionButton { x: 132px; y: 14px; icon: @image-url("../assets/icons/x.svg"); label: "Cancel"; clicked => { root.theme-delete-confirming = false; root.theme-editor-cancelled(); } }

            if (!root.draft-theme-new && !root.theme-delete-confirming) : SettingsActionButton {
                x: parent.width - self.width - 4px;
                y: 14px;
                icon: @image-url("../assets/icons/trash-2.svg");
                label: "Delete";
                danger: true;
                clicked => { root.theme-delete-confirming = true; }
            }

            if (!root.draft-theme-new && root.theme-delete-confirming) : Text {
                x: parent.width - 198px;
                y: 14px;
                width: 62px;
                height: 28px;
                text: "Delete?";
                color: Palette.muted-half;
                font-size: 11px;
                font-weight: 700;
                horizontal-alignment: right;
                vertical-alignment: center;
            }

            if (!root.draft-theme-new && root.theme-delete-confirming) : SettingsActionButton {
                x: parent.width - 128px;
                y: 14px;
                icon: @image-url("../assets/icons/trash-2.svg");
                label: "Yes";
                danger: true;
                clicked => {
                    root.theme-delete-confirming = false;
                    root.theme-delete(root.draft-theme-id);
                }
            }

            if (!root.draft-theme-new && root.theme-delete-confirming) : SettingsActionButton {
                x: parent.width - 60px;
                y: 14px;
                icon: @image-url("../assets/icons/x.svg");
                label: "No";
                clicked => { root.theme-delete-confirming = false; }
            }
        }

        if (root.active-tab == 2) : Rectangle {
            x: 22px;
            y: 112px;
            width: parent.width - 44px;
            height: parent.height - 134px;
            background: #00000000;

            SettingsToolRow { x: 0px; y: 0px; width: parent.width; icon: @image-url("../assets/icons/package.svg"); label: "Backup & Restore"; description: "Save and recover your addon settings"; clicked => { root.backup-restore-clicked(); } }
            SettingsToolRow { x: 0px; y: 68px; width: parent.width; icon: @image-url("../assets/icons/files.svg"); label: "Characters"; description: "View and manage your ESO characters"; clicked => { root.characters-clicked(); } }
            SettingsToolRow { x: 0px; y: 136px; width: parent.width; icon: @image-url("../assets/icons/file-sliders.svg"); label: "API Compatibility"; description: "Check addons against current API version"; clicked => { root.api-compat-clicked(); } }
            SettingsToolRow { x: 0px; y: 204px; width: parent.width; icon: @image-url("../assets/icons/cloud-upload.svg"); label: "Check for App Updates"; description: "See if a newer version of Kalpa is available"; clicked => { root.app-update-clicked(); } }
            SettingsToolRow { visible: root.minion-detected; x: 0px; y: 272px; width: parent.width; icon: @image-url("../assets/icons/flame.svg"); label: "Minion Migration"; description: "Import tracking data from Minion with backup and preview"; accent: true; clicked => { root.minion-migration-clicked(); } }
            SettingsToolRow { x: 0px; y: root.minion-detected ? 340px : 272px; width: parent.width; icon: @image-url("../assets/icons/power.svg"); label: "Safety Center"; description: "Snapshots, integrity checks, and operation log"; clicked => { root.safety-center-clicked(); } }
        }

        if (root.active-tab == 3) : Rectangle {
            x: 22px;
            y: 112px;
            width: parent.width - 44px;
            height: parent.height - 134px;
            background: #00000000;

            Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: 132px;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.white-06;
                background: Palette.white-02;

                DetailSectionTitle { x: 14px; y: 14px; width: parent.width - 28px; label: "ADDON LIST BACKUP"; }
                Text { x: 14px; y: 42px; width: parent.width - 28px; height: 36px; text: "Export your tracked addon list to clipboard, or import a previously exported list to restore on a new machine."; color: Palette.muted-half; font-size: 12px; font-weight: 500; wrap: word-wrap; }
                SettingsActionButton { x: 14px; y: 88px; icon: @image-url("../assets/icons/files.svg"); label: "Export to Clipboard"; clicked => { root.addon-list-exported(); } }
                SettingsActionButton { x: 176px; y: 88px; icon: @image-url("../assets/icons/save.svg"); label: "Import from Clipboard"; clicked => { root.addon-list-imported(); } }
            }

            Rectangle {
                visible: root.pack-hub-authenticated;
                x: 0px;
                y: 150px;
                width: parent.width;
                height: 132px;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.red-20;
                background: Palette.red-04;

                DetailSectionTitle { x: 14px; y: 14px; width: parent.width - 28px; label: "PACK HUB DATA"; }
                Text { x: 14px; y: 42px; width: parent.width - 28px; height: 34px; text: "Account deletion requires the signed-in Pack Hub session. Open the full Hub to delete packs, votes, and share codes."; color: Palette.muted-strong; font-size: 12px; font-weight: 500; wrap: word-wrap; }
                SettingsActionButton { x: 14px; y: 86px; icon: @image-url("../assets/icons/external-link.svg"); label: "Open Full Hub"; danger: true; clicked => { root.pack-hub-account-data-clicked(); } }
            }
        }
    }
}

component PackHubTabButton inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked;
    height: 28px;
    border-radius: 7px;
    border-width: 0px;
    background: root.active ? Palette.white-08 : (touch.has-hover ? Palette.white-03 : #00000000);

    animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: root.active ? Palette.foreground : (touch.has-hover ? Palette.muted-strong : Palette.muted-half);
        font-size: 12px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component PackHubButton inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> disabled: false;
    in property <bool> show-icon: true;
    callback clicked;
    private property <length> icon-size: root.show-icon ? 15px : 0px;
    private property <length> icon-gap: root.show-icon ? 7px : 0px;
    private property <length> label-width: min(button-label.preferred-width, max(0px, root.width - root.icon-size - root.icon-gap - 18px));
    private property <length> content-width: root.icon-size + root.icon-gap + root.label-width;
    private property <length> content-x: max(0px, (root.width - root.content-width) / 2);
    private property <length> content-y: touch.pressed ? 1px : 0px;
    height: 32px;
    border-radius: 7px;
    border-width: 1px;
    border-color: root.disabled ? Palette.white-04 : (root.primary ? Palette.gold-25 : (root.danger ? Palette.red-20 : (touch.has-hover ? Palette.white-10 : Palette.white-08)));
    background: root.disabled ? Palette.white-02 : (touch.pressed ? (root.primary ? Palette.gold : (root.danger ? Palette.red-15 : Palette.white-08)) : (touch.has-hover ? (root.primary ? Palette.gold-hot : (root.danger ? Palette.red-15 : Palette.white-06)) : (root.primary ? Palette.gold : (root.danger ? Palette.red-04 : Palette.white-03))));

    animate background, border-color { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    Image {
        visible: root.show-icon;
        x: root.content-x;
        y: (root.height - root.icon-size) / 2 + root.content-y;
        width: root.icon-size;
        height: root.icon-size;
        source: root.icon;
        image-fit: contain;
        // Disabled must win over `primary` — a disabled primary button has a DARK
        // background, so the dark `#111827` primary ink would be invisible on it.
        colorize: root.disabled ? Palette.muted-dim : (root.primary ? #111827 : (root.danger ? Palette.red : Palette.foreground));
        opacity: root.disabled ? 0.55 : 1.0;
    }

    button-label := Text {
        x: root.content-x + root.icon-size + root.icon-gap;
        y: root.content-y;
        width: root.label-width;
        height: root.height;
        text: root.label;
        color: root.disabled ? Palette.muted-dim : (root.primary ? #111827 : (root.danger ? Palette.red : Palette.foreground));
        font-size: 12px;
        font-weight: root.primary ? 800 : 700;
        vertical-alignment: center;
        horizontal-alignment: left;
        overflow: elide;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            if (!root.disabled) {
                root.clicked();
            }
        }
    }
}

component PackHubField inherits Rectangle {
    in property <string> placeholder;
    in property <bool> search: true;
    in property <bool> focused: false;
    in property <bool> editable: false;
    in-out property <string> value;
    callback edited(string);
    height: 36px;
    border-radius: 10px;
    border-width: 1px;
    border-color: root.focused || root.editable ? Palette.white-10 : (field-touch.has-hover ? Palette.white-10 : Palette.white-08);
    background: root.focused || root.editable ? Palette.white-04 : (field-touch.has-hover ? Palette.white-06 : Palette.white-03);

    animate background, border-color { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    field-touch := TouchArea {
        width: root.width;
        height: root.height;
    }

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height / 2;
        border-radius: 10px;
        border-width: 0px;
        background: #00000000;
    }

    Image {
        visible: root.search;
        x: 13px;
        y: 11px;
        width: 14px;
        height: 14px;
        source: @image-url("../assets/icons/search.svg");
        image-fit: contain;
        colorize: field-touch.has-hover || root.focused || root.editable ? Palette.foreground : Palette.muted-half;
    }

    Text {
        visible: root.value == "";
        x: root.search ? 36px : 14px;
        y: 0px;
        width: parent.width - (root.search ? 48px : 28px);
        height: parent.height;
        text: root.placeholder;
        color: Palette.muted-half;
        font-size: 13px;
        font-weight: 600;
        vertical-alignment: center;
        overflow: elide;
    }

    // Low-level TextInput (NOT the std TextEdit widget, which renders dark default
    // text + its own padding on the dark field). Explicit light ink, inset padding.
    TextInput {
        visible: root.editable;
        x: root.search ? 36px : 14px;
        y: 0px;
        width: parent.width - (root.search ? 48px : 28px);
        height: parent.height;
        text: root.value;
        color: Palette.foreground;
        font-size: 13px;
        font-family: "Geist";
        font-weight: 600;
        single-line: true;
        vertical-alignment: center;
        selection-background-color: Palette.sky-25;
        edited => {
            root.value = self.text;
            root.edited(self.text);
        }
    }

    Text {
        visible: root.value != "" && !root.editable;
        x: root.search ? 36px : 14px;
        y: 0px;
        width: parent.width - (root.search ? 48px : 28px);
        height: parent.height;
        text: root.value;
        color: Palette.foreground;
        font-size: 13px;
        font-weight: 600;
        vertical-alignment: center;
        overflow: elide;
    }
}

component CharacterListRow inherits Rectangle {
    in property <CharacterEntry> character;
    callback backup-clicked;
    height: 62px;
    border-radius: 12px;
    border-width: 0px;
    background: touch.has-hover ? Palette.white-04 : Palette.white-02;

    animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    Rectangle {
        x: 14px;
        y: 13px;
        width: 36px;
        height: 36px;
        border-radius: 10px;
        border-width: 0px;
        background: root.character.recovered ? Palette.gold-10 : Palette.sky-15;

        Image {
            x: 9px;
            y: 9px;
            width: 18px;
            height: 18px;
            source: @image-url("../assets/icons/files.svg");
            image-fit: contain;
            colorize: root.character.recovered ? Palette.gold : Palette.sky;
        }
    }

    Text {
        x: 62px;
        y: 10px;
        width: parent.width - 214px;
        text: root.character.name;
        color: Palette.foreground;
        font-size: 13px;
        font-weight: 850;
        overflow: elide;
    }

    server-pill := Rectangle {
        x: 62px;
        y: 33px;
        width: min(server-label.preferred-width + 20px, parent.width - 232px);
        height: 20px;
        border-radius: 10px;
        border-width: 0px;
        background: root.character.recovered ? Palette.gold-10 : Palette.sky-10;

        server-label := Text {
            x: 10px;
            y: 0px;
            width: parent.width - 20px;
            height: parent.height;
            text: root.character.server + (root.character.recovered ? " - recovered" : "");
            color: root.character.recovered ? Palette.gold : Palette.sky;
            font-size: 10px;
            font-weight: 800;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    PackHubButton {
        x: parent.width - 138px;
        y: 15px;
        width: 122px;
        icon: @image-url("../assets/icons/save.svg");
        label: "Backup";
        clicked => { root.backup-clicked(); }
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
    }
}

component CharactersOverlay inherits Rectangle {
    in-out property <bool> open: false;
    in property <[CharacterEntry]> characters;
    in property <string> summary: "No characters loaded";
    in property <string> warning;
    in-out property <string> backup-label-draft;
    callback refresh-characters;
    callback backup-character(int, string);
    visible: root.open;
    background: #000000c4;
    private property <length> modal-width: root.width < 720px ? root.width - 48px : 640px;
    private property <length> modal-height: root.height < 760px ? root.height - 32px : 700px;
    private property <length> footer-height: 66px;
    private property <length> list-top: root.warning == "" ? 226px : 258px;
    private property <length> list-height: max(120px, root.modal-height - root.footer-height - root.list-top - 10px);

    TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.open = false; }
    }

    panel := Rectangle {
        width: root.modal-width;
        height: root.modal-height;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        border-radius: 16px;
        border-width: 1px;
        border-color: Palette.border-strong;
        background: Tokens.surface;
        drop-shadow-blur: 30px;
        drop-shadow-offset-y: 12px;
        drop-shadow-color: #00000099;
        clip: true;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { }
        }

        Text {
            x: 28px;
            y: 24px;
            width: parent.width - 92px;
            text: "Characters";
            color: Palette.gold;
            font-size: 18px;
            font-weight: 900;
            overflow: elide;
        }

        Text {
            x: 28px;
            y: 54px;
            width: parent.width - 92px;
            height: 50px;
            text: "Your ESO characters. A backup saves just this character's SavedVariables and restores without touching other characters.";
            color: Palette.muted-strong;
            font-size: 14px;
            font-weight: 600;
            wrap: word-wrap;
        }

        GhostIconButton {
            x: parent.width - 52px;
            y: 20px;
            width: 36px;
            height: 36px;
            icon: @image-url("../assets/icons/x.svg");
            clicked => { root.open = false; }
        }

        Hairline { x: 0px; y: 116px; width: parent.width; height: 1px; opacity: 0.45; }

        Text {
            x: 28px;
            y: 132px;
            width: 180px;
            text: "BACKUP NAME";
            color: Palette.muted-half;
            font-family: "Space Grotesk Light";
            font-size: 10px;
            font-weight: 900;
        }

        PackHubField {
            x: 28px;
            y: 150px;
            width: parent.width - 56px;
            placeholder: "Leave blank for auto-name";
            search: false;
            editable: true;
            value <=> root.backup-label-draft;
        }

        Text {
            x: 28px;
            y: 196px;
            width: parent.width - 150px;
            text: root.summary;
            color: Palette.muted-strong;
            font-size: 12px;
            font-weight: 750;
            overflow: elide;
        }

        PackHubButton {
            x: parent.width - 112px;
            y: 188px;
            width: 84px;
            icon: @image-url("../assets/icons/refresh-cw.svg");
            label: "Refresh";
            clicked => { root.refresh-characters(); }
        }

        if (root.warning != "") : Rectangle {
            x: 28px;
            y: 224px;
            width: parent.width - 56px;
            height: 26px;
            border-radius: 10px;
            border-width: 0px;
            background: Palette.gold-10;

            Text {
                x: 12px;
                y: 0px;
                width: parent.width - 24px;
                height: parent.height;
                text: root.warning;
                color: Palette.gold;
                font-size: 11px;
                font-weight: 750;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        if (root.characters.length == 0) : Rectangle {
            x: 28px;
            y: root.list-top;
            width: parent.width - 56px;
            height: min(128px, root.list-height);
            border-radius: 13px;
            border-width: 1px;
            border-color: Palette.white-06;
            background: Palette.white-03;

            Image { x: (parent.width - 28px) / 2; y: 24px; width: 28px; height: 28px; source: @image-url("../assets/icons/files.svg"); image-fit: contain; colorize: Palette.muted-half; }
            Text { x: 24px; y: 62px; width: parent.width - 48px; text: "No characters found"; color: Palette.foreground; font-size: 14px; font-weight: 900; horizontal-alignment: center; }
            Text { x: 44px; y: 88px; width: parent.width - 88px; text: "Launch ESO at least once to generate character data."; color: Palette.muted-strong; font-size: 12px; font-weight: 600; horizontal-alignment: center; wrap: word-wrap; }
        }

        if (root.characters.length > 0) : ScrollView {
            x: 28px;
            y: root.list-top;
            width: parent.width - 56px;
            height: root.list-height;
            viewport-width: self.width;
            viewport-height: root.characters.length * 72px;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            Rectangle {
                width: parent.width;
                height: root.characters.length * 72px;
                background: #00000000;

                for character[index] in root.characters : CharacterListRow {
                    x: 0px;
                    y: index * 72px;
                    width: parent.width;
                    character: character;
                    backup-clicked => { root.backup-character(index, root.backup-label-draft); }
                }
            }
        }

        Rectangle {
            x: 0px;
            y: parent.height - root.footer-height;
            width: parent.width;
            height: root.footer-height;
            background: @linear-gradient(0deg, Tokens.surface 0%, Tokens.surface-84 72%, #00000000 100%);

            PackHubButton { x: parent.width - 96px; y: 20px; width: 68px; icon: @image-url("../assets/icons/x.svg"); label: "Close"; show-icon: false; clicked => { root.open = false; } }
        }
    }
}

component SafetyTabButton inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked;
    height: 34px;
    border-radius: 9px;
    border-width: 0px;
    background: root.active ? Palette.white-08 : (touch.has-hover ? Palette.white-03 : #00000000);

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: root.active ? Palette.foreground : (touch.has-hover ? Palette.muted-strong : Palette.muted-half);
        font-size: 12px;
        font-weight: 850;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component SafetySnapshotRow inherits Rectangle {
    in property <SafetySnapshotEntry> snapshot;
    in property <bool> confirming-delete: false;
    callback restore-clicked;
    callback delete-clicked;
    callback delete-confirmed;
    callback delete-cancelled;
    height: 82px;
    border-radius: 12px;
    border-width: 0px;
    background: touch.has-hover ? Palette.white-04 : Palette.white-02;

    // Declared first so the action buttons (later siblings) stay on top and
    // remain clickable; this only provides the row hover state.
    touch := TouchArea { width: root.width; height: root.height; }

    Text {
        x: 16px;
        y: 12px;
        width: parent.width - 214px;
        text: root.snapshot.label;
        color: Palette.foreground;
        font-size: 13px;
        font-weight: 850;
        overflow: elide;
    }

    Text {
        x: 16px;
        y: 34px;
        width: parent.width - 214px;
        text: root.snapshot.meta;
        color: Palette.muted-strong;
        font-size: 11px;
        font-weight: 650;
        overflow: elide;
    }

    Text {
        x: 16px;
        y: 56px;
        width: parent.width - 214px;
        text: root.snapshot.sources;
        color: Palette.muted-half;
        font-size: 10px;
        font-weight: 600;
        overflow: elide;
    }

    if (!root.confirming-delete) : PackHubButton { x: parent.width - 178px; y: 16px; width: 82px; icon: @image-url("../assets/icons/undo-2.svg"); label: "Restore"; clicked => { root.restore-clicked(); } }
    if (!root.confirming-delete) : PackHubButton { x: parent.width - 88px; y: 16px; width: 72px; icon: @image-url("../assets/icons/trash-2.svg"); label: "Delete"; danger: true; clicked => { root.delete-clicked(); } }

    if (root.confirming-delete) : Text { x: parent.width - 232px; y: 0px; width: 68px; height: parent.height; text: "Delete?"; color: Palette.amber; font-size: 12px; font-weight: 900; horizontal-alignment: right; vertical-alignment: center; }
    if (root.confirming-delete) : PackHubButton { x: parent.width - 156px; y: 16px; width: 70px; icon: @image-url("../assets/icons/trash-2.svg"); label: "Yes"; danger: true; clicked => { root.delete-confirmed(); } }
    if (root.confirming-delete) : PackHubButton { x: parent.width - 78px; y: 16px; width: 58px; icon: @image-url("../assets/icons/x.svg"); label: "No"; clicked => { root.delete-cancelled(); } }
}

component SafetyIssueRow inherits Rectangle {
    in property <SafetyIssueEntry> issue;
    height: 32px;
    border-radius: 10px;
    border-width: 0px;
    background: Palette.gold-10;

    Text {
        x: 12px;
        y: 0px;
        width: parent.width - 24px;
        height: parent.height;
        text: root.issue.message;
        color: Palette.gold;
        font-size: 11px;
        font-weight: 700;
        vertical-alignment: center;
        overflow: elide;
    }
}

component SafetyLogRow inherits Rectangle {
    in property <SafetyLogEntry> entry;
    height: 68px;
    border-radius: 12px;
    border-width: 0px;
    background: Palette.white-02;

    Text { x: 14px; y: 10px; width: parent.width - 116px; text: root.entry.operation; color: Palette.foreground; font-size: 12px; font-weight: 850; overflow: elide; }
    Text { x: parent.width - 94px; y: 10px; width: 80px; text: root.entry.status; color: root.entry.success ? Palette.emerald : Palette.red; font-size: 11px; font-weight: 850; horizontal-alignment: right; overflow: elide; }
    Text { x: 14px; y: 31px; width: parent.width - 28px; text: root.entry.details; color: Palette.muted-strong; font-size: 11px; font-weight: 650; overflow: elide; }
    Text { x: 14px; y: 50px; width: parent.width - 28px; text: root.entry.timing + (root.entry.snapshot-id != "" ? "  |  Snapshot: " + root.entry.snapshot-id : ""); color: Palette.muted-half; font-size: 10px; font-weight: 600; overflow: elide; }
}

component SafetyCenterOverlay inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <int> view: 0;
    in property <[SafetySnapshotEntry]> snapshots;
    in property <[SafetyIssueEntry]> issues;
    in property <[SafetyLogEntry]> logs;
    in property <string> snapshot-summary: "No snapshots yet.";
    in property <string> integrity-summary: "Integrity has not been checked.";
    in property <bool> integrity-addons-ok: false;
    in property <bool> integrity-sv-ok: false;
    in property <string> integrity-addon-count: "0";
    callback refresh-safety;
    callback run-integrity;
    callback restore-snapshot(int);
    callback delete-snapshot(int);
    visible: root.open;
    background: #000000c4;
    private property <length> modal-width: root.width < 720px ? root.width - 48px : 640px;
    private property <length> modal-height: root.height < 760px ? root.height - 32px : 700px;
    private property <length> footer-height: 66px;
    private property <length> content-top: 166px;
    private property <length> content-height: max(160px, root.modal-height - root.footer-height - root.content-top - 12px);
    private property <int> confirm-delete-index: -1;

    TouchArea { width: root.width; height: root.height; clicked => { root.open = false; } }

    panel := Rectangle {
        width: root.modal-width;
        height: root.modal-height;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        border-radius: 16px;
        border-width: 1px;
        border-color: Palette.border-strong;
        background: Tokens.surface;
        drop-shadow-blur: 30px;
        drop-shadow-offset-y: 12px;
        drop-shadow-color: #00000099;
        clip: true;

        TouchArea { width: parent.width; height: parent.height; clicked => { } }

        Text { x: 28px; y: 24px; width: parent.width - 92px; text: "Safety Center"; color: Palette.gold; font-size: 18px; font-weight: 900; overflow: elide; }
        Text { x: 28px; y: 54px; width: parent.width - 92px; height: 42px; text: "Snapshots, integrity checks, and the local operation log for your ESO data."; color: Palette.muted-strong; font-size: 14px; font-weight: 600; wrap: word-wrap; }
        GhostIconButton { x: parent.width - 52px; y: 20px; width: 36px; height: 36px; icon: @image-url("../assets/icons/x.svg"); clicked => { root.open = false; } }
        Hairline { x: 0px; y: 116px; width: parent.width; height: 1px; opacity: 0.45; }

        Rectangle {
            x: 28px;
            y: 130px;
            width: parent.width - 56px;
            height: 38px;
            border-radius: 11px;
            border-width: 0px;
            background: Palette.white-03;

            SafetyTabButton { x: 4px; y: 2px; width: (parent.width - 8px) / 3; label: "Snapshots"; active: root.view == 0; clicked => { root.view = 0; } }
            SafetyTabButton { x: 4px + (parent.width - 8px) / 3; y: 2px; width: (parent.width - 8px) / 3; label: "Integrity"; active: root.view == 1; clicked => { root.view = 1; } }
            SafetyTabButton { x: 4px + ((parent.width - 8px) / 3) * 2; y: 2px; width: (parent.width - 8px) / 3; label: "Activity Log"; active: root.view == 2; clicked => { root.view = 2; } }
        }

        if (root.view == 0) : Rectangle {
            x: 28px;
            y: root.content-top;
            width: parent.width - 56px;
            height: root.content-height;
            background: #00000000;

            Text { x: 0px; y: 8px; width: parent.width - 94px; text: root.snapshot-summary; color: Palette.muted-strong; font-size: 12px; font-weight: 700; overflow: elide; }
            PackHubButton { x: parent.width - 84px; y: 0px; width: 84px; icon: @image-url("../assets/icons/refresh-cw.svg"); label: "Refresh"; clicked => { root.refresh-safety(); } }

            if (root.snapshots.length == 0) : Rectangle {
                x: 0px;
                y: 46px;
                width: parent.width;
                height: min(128px, parent.height - 46px);
                border-radius: 13px;
                border-width: 1px;
                border-color: Palette.white-06;
                background: Palette.white-03;
                Text { x: 24px; y: 44px; width: parent.width - 48px; text: "No snapshots yet."; color: Palette.muted-strong; font-size: 14px; font-weight: 850; horizontal-alignment: center; }
            }

            if (root.snapshots.length > 0) : ScrollView {
                x: 0px;
                y: 46px;
                width: parent.width;
                height: parent.height - 46px;
                viewport-width: self.width;
                viewport-height: root.snapshots.length * 92px;
                vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                Rectangle {
                    width: parent.width;
                    height: root.snapshots.length * 92px;
                    background: #00000000;
                    for snapshot[index] in root.snapshots : SafetySnapshotRow {
                        x: 0px;
                        y: index * 92px;
                        width: parent.width;
                        snapshot: snapshot;
                        confirming-delete: index == root.confirm-delete-index;
                        restore-clicked => {
                            root.confirm-delete-index = -1;
                            root.restore-snapshot(index);
                        }
                        delete-clicked => { root.confirm-delete-index = index; }
                        delete-confirmed => {
                            root.confirm-delete-index = -1;
                            root.delete-snapshot(index);
                        }
                        delete-cancelled => { root.confirm-delete-index = -1; }
                    }
                }
            }
        }

        if (root.view == 1) : Rectangle {
            x: 28px;
            y: root.content-top;
            width: parent.width - 56px;
            height: root.content-height;
            background: #00000000;

            Text { x: 0px; y: 8px; width: parent.width - 150px; text: root.integrity-summary; color: Palette.muted-strong; font-size: 12px; font-weight: 700; overflow: elide; }
            PackHubButton { x: parent.width - 132px; y: 0px; width: 132px; icon: @image-url("../assets/icons/check.svg"); label: "Run Check"; primary: true; clicked => { root.run-integrity(); } }

            Rectangle {
                x: 0px;
                y: 48px;
                width: parent.width;
                height: 58px;
                border-radius: 13px;
                border-width: 0px;
                background: Palette.white-03;
                Text { x: 16px; y: 12px; width: parent.width / 3 - 20px; text: root.integrity-addons-ok ? "AddOns OK" : "AddOns unchecked"; color: root.integrity-addons-ok ? Palette.emerald : Palette.muted-half; font-size: 12px; font-weight: 850; overflow: elide; }
                Text { x: parent.width / 3 + 8px; y: 12px; width: parent.width / 3 - 20px; text: root.integrity-sv-ok ? "SavedVariables OK" : "SavedVariables unchecked"; color: root.integrity-sv-ok ? Palette.emerald : Palette.muted-half; font-size: 12px; font-weight: 850; overflow: elide; }
                Text { x: (parent.width / 3) * 2 + 8px; y: 12px; width: parent.width / 3 - 20px; text: root.integrity-addon-count + " tracked"; color: Palette.foreground; font-size: 12px; font-weight: 850; overflow: elide; }
                Text { x: 16px; y: 34px; width: parent.width - 32px; text: "Checks AddOns, SavedVariables, tracked addon folders, manifests, and empty SavedVariables files."; color: Palette.muted-half; font-size: 10px; font-weight: 650; overflow: elide; }
            }

            if (root.issues.length == 0) : Rectangle {
                x: 0px;
                y: 124px;
                width: parent.width;
                height: 44px;
                border-radius: 12px;
                border-width: 0px;
                background: root.integrity-summary == "All checks passed. No issues found." ? Palette.emerald-15 : Palette.white-02;
                Text { x: 16px; y: 0px; width: parent.width - 32px; height: parent.height; text: root.integrity-summary == "All checks passed. No issues found." ? "All checks passed. No issues found." : "Run an integrity check to list issues here."; color: root.integrity-summary == "All checks passed. No issues found." ? Palette.emerald : Palette.muted-half; font-size: 12px; font-weight: 750; vertical-alignment: center; overflow: elide; }
            }

            if (root.issues.length > 0) : ScrollView {
                x: 0px;
                y: 124px;
                width: parent.width;
                height: parent.height - 124px;
                viewport-width: self.width;
                viewport-height: root.issues.length * 40px;
                vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                Rectangle {
                    width: parent.width;
                    height: root.issues.length * 40px;
                    background: #00000000;
                    for issue[index] in root.issues : SafetyIssueRow {
                        x: 0px;
                        y: index * 40px;
                        width: parent.width;
                        issue: issue;
                    }
                }
            }
        }

        if (root.view == 2) : Rectangle {
            x: 28px;
            y: root.content-top;
            width: parent.width - 56px;
            height: root.content-height;
            background: #00000000;

            Text { x: 0px; y: 8px; width: parent.width - 94px; text: "A record of local Kalpa operations on your ESO data."; color: Palette.muted-strong; font-size: 12px; font-weight: 700; overflow: elide; }
            PackHubButton { x: parent.width - 84px; y: 0px; width: 84px; icon: @image-url("../assets/icons/refresh-cw.svg"); label: "Refresh"; clicked => { root.refresh-safety(); } }

            if (root.logs.length == 0) : Rectangle {
                x: 0px;
                y: 46px;
                width: parent.width;
                height: min(128px, parent.height - 46px);
                border-radius: 13px;
                border-width: 1px;
                border-color: Palette.white-06;
                background: Palette.white-03;
                Text { x: 24px; y: 44px; width: parent.width - 48px; text: "No operations logged."; color: Palette.muted-strong; font-size: 14px; font-weight: 850; horizontal-alignment: center; }
            }

            if (root.logs.length > 0) : ScrollView {
                x: 0px;
                y: 46px;
                width: parent.width;
                height: parent.height - 46px;
                viewport-width: self.width;
                viewport-height: root.logs.length * 76px;
                vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                Rectangle {
                    width: parent.width;
                    height: root.logs.length * 76px;
                    background: #00000000;
                    for entry[index] in root.logs : SafetyLogRow {
                        x: 0px;
                        y: index * 76px;
                        width: parent.width;
                        entry: entry;
                    }
                }
            }
        }

        Rectangle {
            x: 0px;
            y: parent.height - root.footer-height;
            width: parent.width;
            height: root.footer-height;
            background: @linear-gradient(0deg, Tokens.surface 0%, Tokens.surface-84 72%, #00000000 100%);
            PackHubButton { x: parent.width - 96px; y: 20px; width: 68px; icon: @image-url("../assets/icons/x.svg"); label: "Close"; show-icon: false; clicked => { root.open = false; } }
        }
    }
}

component MigrationPhasePill inherits Rectangle {
    in property <string> label;
    in property <int> index: 0;
    in property <int> active-index: 0;
    private property <bool> complete: root.index < root.active-index;
    private property <bool> active: root.index == root.active-index;
    height: 24px;
    border-radius: 12px;
    border-width: 0px;
    background: root.complete ? Palette.emerald-15 : (root.active ? Palette.sky-15 : Palette.white-04);

    Text {
        width: parent.width;
        height: parent.height;
        text: root.complete ? "✓ " + root.label : root.index + 1 + " " + root.label;
        color: root.complete ? Palette.emerald : (root.active ? Palette.sky : Palette.muted-half);
        font-size: 10px;
        font-weight: 850;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component MigrationCheckRow inherits Rectangle {
    in property <MigrationCheckEntry> entry;
    height: 30px;
    border-radius: 10px;
    border-width: 0px;
    background: root.entry.ok ? Palette.emerald-15 : (root.entry.warn ? Palette.gold-10 : Palette.red-04);

    Text {
        x: 12px;
        y: 0px;
        width: 24px;
        height: parent.height;
        text: root.entry.ok ? "✓" : (root.entry.warn ? "!" : "×");
        color: root.entry.ok ? Palette.emerald : (root.entry.warn ? Palette.gold : Palette.red);
        font-size: 12px;
        font-weight: 900;
        vertical-alignment: center;
    }

    Text {
        x: 34px;
        y: 0px;
        width: parent.width - 46px;
        height: parent.height;
        text: root.entry.label;
        color: root.entry.ok ? Palette.foreground : (root.entry.warn ? Palette.gold : Palette.red);
        font-size: 12px;
        font-weight: 750;
        vertical-alignment: center;
        overflow: elide;
    }
}

component MigrationPreviewRow inherits Rectangle {
    in property <MigrationPreviewEntry> entry;
    height: 44px;
    border-radius: 10px;
    border-width: 0px;
    background: root.entry.kind == 0 ? Palette.emerald-15 : (root.entry.kind == 1 ? Palette.sky-10 : (root.entry.kind == 2 ? Palette.gold-10 : Palette.white-03));

    Text {
        x: 14px;
        y: 8px;
        width: parent.width - 28px;
        text: root.entry.title;
        color: root.entry.kind == 0 ? Palette.emerald : (root.entry.kind == 1 ? Palette.sky : (root.entry.kind == 2 ? Palette.gold : Palette.foreground));
        font-size: 12px;
        font-weight: 850;
        overflow: elide;
    }

    Text {
        x: 14px;
        y: 27px;
        width: parent.width - 28px;
        text: root.entry.meta;
        color: Palette.muted-strong;
        font-size: 10px;
        font-weight: 650;
        overflow: elide;
    }
}

component MinionMigrationOverlay inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <int> phase: 0;
    in-out property <bool> include-addons: true;
    in property <[MigrationCheckEntry]> checks;
    in property <[MigrationPreviewEntry]> preview;
    in property <bool> can-proceed: false;
    in property <string> status: "";
    in property <string> snapshot-summary: "";
    in property <string> result-summary: "";
    callback recheck;
    callback continue-to-backup;
    callback create-snapshot(bool);
    callback execute-migration;
    visible: root.open;
    background: #000000c4;
    private property <length> modal-width: root.width < 720px ? root.width - 48px : 640px;
    private property <length> modal-height: root.height < 760px ? root.height - 32px : 700px;
    private property <length> footer-height: 66px;
    private property <length> content-top: 160px;
    private property <length> content-height: max(160px, root.modal-height - root.footer-height - root.content-top - 12px);

    TouchArea { width: root.width; height: root.height; clicked => { root.open = false; } }

    panel := Rectangle {
        width: root.modal-width;
        height: root.modal-height;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        border-radius: 16px;
        border-width: 1px;
        border-color: Palette.border-strong;
        background: Tokens.surface;
        drop-shadow-blur: 30px;
        drop-shadow-offset-y: 12px;
        drop-shadow-color: #00000099;
        clip: true;

        TouchArea { width: parent.width; height: parent.height; clicked => { } }

        Text { x: 28px; y: 24px; width: parent.width - 92px; text: "Safe Minion Migration"; color: Palette.gold; font-size: 18px; font-weight: 900; overflow: elide; }
        Text { x: 28px; y: 54px; width: parent.width - 92px; height: 42px; text: "Import addon tracking metadata from Minion without moving addon folders or SavedVariables."; color: Palette.muted-strong; font-size: 14px; font-weight: 600; wrap: word-wrap; }
        GhostIconButton { x: parent.width - 52px; y: 20px; width: 36px; height: 36px; icon: @image-url("../assets/icons/x.svg"); clicked => { root.open = false; } }
        Hairline { x: 0px; y: 116px; width: parent.width; height: 1px; opacity: 0.45; }

        Rectangle {
            x: 28px;
            y: 128px;
            width: parent.width - 56px;
            height: 26px;
            background: #00000000;
            MigrationPhasePill { x: 0px; y: 0px; width: (parent.width - 32px) / 4; label: "Check"; index: 0; active-index: root.phase; }
            MigrationPhasePill { x: (parent.width - 32px) / 4 + 10px; y: 0px; width: (parent.width - 32px) / 4; label: "Backup"; index: 1; active-index: root.phase; }
            MigrationPhasePill { x: ((parent.width - 32px) / 4 + 10px) * 2; y: 0px; width: (parent.width - 32px) / 4; label: "Preview"; index: 2; active-index: root.phase; }
            MigrationPhasePill { x: ((parent.width - 32px) / 4 + 10px) * 3; y: 0px; width: (parent.width - 32px) / 4; label: "Done"; index: 3; active-index: root.phase; }
        }

        if (root.phase == 0) : Rectangle {
            x: 28px;
            y: root.content-top;
            width: parent.width - 56px;
            height: root.content-height;
            background: #00000000;
            Text { x: 0px; y: 4px; width: parent.width; text: "Kalpa will import addon tracking data from Minion. Your addon files and ESO settings will not be modified."; color: Palette.muted-strong; font-size: 13px; font-weight: 650; wrap: word-wrap; }

            ScrollView {
                x: 0px;
                y: 58px;
                width: parent.width;
                height: min(180px, parent.height - 112px);
                viewport-width: self.width;
                viewport-height: root.checks.length * 38px;
                vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                Rectangle {
                    width: parent.width;
                    height: root.checks.length * 38px;
                    background: #00000000;
                    for check[index] in root.checks : MigrationCheckRow {
                        x: 0px;
                        y: index * 38px;
                        width: parent.width;
                        entry: check;
                    }
                }
            }

            Text { x: 0px; y: parent.height - 42px; width: parent.width - 220px; text: root.status; color: Palette.muted-half; font-size: 11px; font-weight: 650; overflow: elide; }
            PackHubButton { x: parent.width - 206px; y: parent.height - 50px; width: 82px; icon: @image-url("../assets/icons/refresh-cw.svg"); label: "Re-check"; clicked => { root.recheck(); } }
            PackHubButton { x: parent.width - 114px; y: parent.height - 50px; width: 114px; icon: @image-url("../assets/icons/chevron-right.svg"); label: "Continue"; primary: true; disabled: !root.can-proceed; clicked => { root.continue-to-backup(); } }
        }

        if (root.phase == 1) : Rectangle {
            x: 28px;
            y: root.content-top;
            width: parent.width - 56px;
            height: root.content-height;
            background: #00000000;
            Text { x: 0px; y: 4px; width: parent.width; height: 46px; text: "Before importing metadata, Kalpa creates a restore point. SavedVariables, UserSettings.txt, and AddOnSettings.txt are always included."; color: Palette.muted-strong; font-size: 13px; font-weight: 650; wrap: word-wrap; }
            SettingsToggleRow { x: 0px; y: 72px; width: parent.width; height: 58px; label: "Include AddOns folder"; description: "Larger backup, recommended for first migration"; checked <=> root.include-addons; }
            Rectangle {
                x: 0px;
                y: 150px;
                width: parent.width;
                height: 76px;
                border-radius: 12px;
                border-width: 0px;
                background: Palette.white-03;
                Text { x: 16px; y: 14px; width: parent.width - 32px; text: root.snapshot-summary == "" ? "No restore point created yet." : root.snapshot-summary; color: root.snapshot-summary == "" ? Palette.muted-half : Palette.emerald; font-size: 12px; font-weight: 750; overflow: elide; }
                Text { x: 16px; y: 38px; width: parent.width - 32px; text: "You can restore this snapshot later from Settings > Safety Center."; color: Palette.muted-strong; font-size: 11px; font-weight: 650; overflow: elide; }
            }
            PackHubButton { x: parent.width - 196px; y: parent.height - 50px; width: 196px; icon: @image-url("../assets/icons/save.svg"); label: "Create Snapshot & Continue"; primary: true; clicked => { root.create-snapshot(root.include-addons); } }
        }

        if (root.phase == 2) : Rectangle {
            x: 28px;
            y: root.content-top;
            width: parent.width - 56px;
            height: root.content-height;
            background: #00000000;
            Text { x: 0px; y: 4px; width: parent.width; text: root.status; color: Palette.muted-strong; font-size: 13px; font-weight: 650; overflow: elide; }

            ScrollView {
                x: 0px;
                y: 38px;
                width: parent.width;
                height: parent.height - 96px;
                viewport-width: self.width;
                viewport-height: max(80px, root.preview.length * 52px);
                vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                Rectangle {
                    width: parent.width;
                    height: max(80px, root.preview.length * 52px);
                    background: #00000000;
                    if (root.preview.length == 0) : Text { x: 24px; y: 22px; width: parent.width - 48px; text: "All Minion addons are already tracked. Nothing to import."; color: Palette.muted-strong; font-size: 13px; font-weight: 750; horizontal-alignment: center; }
                    for entry[index] in root.preview : MigrationPreviewRow {
                        x: 0px;
                        y: index * 52px;
                        width: parent.width;
                        entry: entry;
                    }
                }
            }
            PackHubButton { x: parent.width - 166px; y: parent.height - 50px; width: 166px; icon: @image-url("../assets/icons/check.svg"); label: "Import Metadata"; primary: true; clicked => { root.execute-migration(); } }
        }

        if (root.phase == 3) : Rectangle {
            x: 28px;
            y: root.content-top;
            width: parent.width - 56px;
            height: root.content-height;
            background: #00000000;
            Rectangle {
                x: 0px;
                y: 16px;
                width: parent.width;
                height: 96px;
                border-radius: 14px;
                border-width: 0px;
                background: Palette.emerald-15;
                Text { x: 20px; y: 18px; width: parent.width - 40px; text: "Migration complete"; color: Palette.emerald; font-size: 15px; font-weight: 900; }
                Text { x: 20px; y: 48px; width: parent.width - 40px; text: root.result-summary; color: Palette.foreground; font-size: 12px; font-weight: 750; overflow: elide; }
            }
            Text { x: 0px; y: 132px; width: parent.width; text: root.snapshot-summary; color: Palette.muted-strong; font-size: 12px; font-weight: 700; wrap: word-wrap; }
        }

        Rectangle {
            x: 0px;
            y: parent.height - root.footer-height;
            width: parent.width;
            height: root.footer-height;
            background: @linear-gradient(0deg, Tokens.surface 0%, Tokens.surface-84 72%, #00000000 100%);
            PackHubButton { x: parent.width - 96px; y: 20px; width: 68px; icon: @image-url("../assets/icons/x.svg"); label: root.phase == 3 ? "Done" : "Cancel"; show-icon: false; clicked => { root.open = false; } }
        }
    }
}

component PackHubSelectField inherits Rectangle {
    in property <string> label;
    callback clicked;
    height: 36px;
    border-radius: 10px;
    border-width: 1px;
    border-color: touch.has-hover ? Palette.white-10 : Palette.white-08;
    background: touch.has-hover ? Palette.white-06 : Palette.white-04;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height / 2;
        border-radius: 10px;
        border-width: 0px;
        background: #00000000;
    }

    Text {
        x: 14px;
        y: 0px;
        width: parent.width - 42px;
        height: parent.height;
        text: root.label;
        color: Palette.foreground;
        font-size: 12px;
        font-weight: 800;
        vertical-alignment: center;
        overflow: elide;
    }

    Image {
        x: parent.width - 28px;
        y: 11px;
        width: 14px;
        height: 14px;
        source: @image-url("../assets/icons/chevron-down.svg");
        image-fit: contain;
        colorize: touch.has-hover ? Palette.foreground : Palette.muted-half;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component PackHubStep inherits Rectangle {
    in property <string> number;
    in property <string> label;
    in property <bool> active: false;
    width: label-text.preferred-width + 34px;
    height: 24px;
    background: #00000000;

    Rectangle {
        x: 0px;
        y: 2px;
        width: 20px;
        height: 20px;
        border-radius: 10px;
        border-width: 0px;
        background: root.active ? Palette.gold-20 : Palette.white-04;

        Text {
            width: parent.width;
            height: parent.height;
            text: root.number;
            color: root.active ? Palette.gold : Palette.muted-half;
            font-size: 11px;
            font-weight: 900;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    label-text := Text {
        x: 28px;
        width: root.width - 28px;
        height: root.height;
        text: root.label;
        color: root.active ? Palette.gold : Palette.muted-half;
        font-size: 12px;
        font-weight: 800;
        vertical-alignment: center;
        overflow: elide;
    }
}

component PackHubTag inherits Rectangle {
    in property <string> label;
    in property <color> tone: Palette.muted-strong;
    width: label-text.preferred-width + 16px;
    height: 21px;
    border-radius: 7px;
    border-width: 1px;
    border-color: Palette.white-10;
    background: Palette.white-03;

    label-text := Text {
        x: 8px;
        y: 0px;
        height: parent.height;
        text: root.label;
        color: root.tone;
        font-size: 11px;
        font-weight: 800;
        vertical-alignment: center;
    }
}

component PackHubPackCard inherits Rectangle {
    in property <string> title;
    in property <string> description;
    in property <string> tag;
    in property <string> addon-count;
    in property <string> vote-count: "0";
    in property <string> author: "";
    in property <string> author-initial: "?";
    in property <string> pack-type-label: "Addon Pack";
    in property <string> monogram: "?";
    in property <int> identity-kind: 0;
    in property <int> type-kind: 0;
    in property <bool> trial: false;
    callback open-detail;
    private property <color> type-tone: root.type-kind == 1 ? Palette.sky : (root.type-kind == 2 ? Palette.violet : Palette.gold);
    private property <color> type-fill: root.type-kind == 1 ? Palette.sky-04 : (root.type-kind == 2 ? Palette.violet-04 : Palette.gold-04);
    private property <color> identity-tone: root.identity-kind == 1 ? Palette.sky : (root.identity-kind == 2 ? Palette.logo : (root.identity-kind == 3 ? Palette.emerald : (root.identity-kind == 4 ? Palette.amber : (root.identity-kind == 5 ? Palette.red : (root.identity-kind == 6 ? Palette.violet : Palette.gold)))));
    private property <color> identity-fill: root.identity-kind == 1 ? Palette.sky-15 : (root.identity-kind == 2 ? #4dc2e626 : (root.identity-kind == 3 ? Palette.emerald-15 : (root.identity-kind == 4 ? Palette.amber-15 : (root.identity-kind == 5 ? Palette.red-15 : (root.identity-kind == 6 ? Palette.violet-15 : Palette.gold-15)))));
    private property <color> identity-wash: root.identity-kind == 1 ? Palette.sky-06 : (root.identity-kind == 2 ? #4dc2e610 : (root.identity-kind == 3 ? Palette.emerald-04 : (root.identity-kind == 4 ? Palette.amber-04 : (root.identity-kind == 5 ? Palette.red-04 : (root.identity-kind == 6 ? Palette.violet-04 : Palette.gold-04)))));
    private property <length> content-x: 66px;
    height: 104px;
    border-radius: 12px;
    border-width: 1px;
    border-color: touch.has-hover ? Palette.border-strong : Palette.border;
    background: @linear-gradient(180deg, Palette.white-06 0%, Palette.white-03 100%);
    clip: true;
    drop-shadow-blur: touch.has-hover ? 20px : 10px;
    drop-shadow-offset-y: touch.has-hover ? 7px : 3px;
    drop-shadow-color: #00000066;

    animate border-color, drop-shadow-blur, drop-shadow-offset-y { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    Rectangle {
        x: 0px;
        y: 0px;
        width: 210px;
        height: parent.height;
        background: @linear-gradient(90deg, root.identity-wash 0%, #00000000 100%);
    }

    Rectangle {
        x: 0px;
        y: 0px;
        width: 3px;
        height: parent.height;
        border-radius: 3px;
        border-width: 0px;
        background: root.type-tone;
    }

    Rectangle {
        x: 14px;
        y: 14px;
        width: 40px;
        height: 40px;
        border-radius: 9px;
        border-width: 1px;
        border-color: root.identity-fill;
        background: @linear-gradient(135deg, root.identity-fill 0%, root.identity-wash 100%);

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 1px;
            background: Palette.white-10;
        }

        Text {
            width: parent.width;
            height: parent.height;
            text: root.monogram;
            color: root.identity-tone;
            font-size: 13px;
            font-weight: 900;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    title-text := Text {
        x: root.content-x;
        y: 14px;
        width: parent.width - root.content-x - 116px;
        text: root.title;
        color: touch.has-hover ? Palette.gold : Palette.foreground;
        font-size: 14px;
        font-weight: 900;
        overflow: elide;
    }

    Pill {
        x: root.content-x;
        y: 38px;
        label: root.pack-type-label;
        tone: root.type-tone;
        fill: root.type-fill;
        pill-height: 21px;
        label-font-size: 11px;
    }

    Text {
        x: root.content-x;
        y: 62px;
        width: parent.width - root.content-x - 80px;
        height: 18px;
        text: root.description;
        color: Palette.muted-strong;
        font-size: 12px;
        font-weight: 600;
        overflow: elide;
    }

    tag-pill := PackHubTag {
        x: root.content-x + 112px;
        y: 38px;
        label: root.tag;
        tone: root.trial ? Palette.red : Palette.muted-strong;
    }

    Image {
        x: root.content-x;
        y: 86px;
        width: 12px;
        height: 12px;
        source: @image-url("../assets/icons/package.svg");
        image-fit: contain;
        colorize: Palette.muted-half;
    }

    Text {
        x: root.content-x + 18px;
        y: 82px;
        width: 112px;
        height: 20px;
        text: root.addon-count;
        color: Palette.muted-half;
        font-size: 12px;
        font-weight: 600;
        vertical-alignment: center;
    }

    Rectangle {
        x: parent.width - 48px;
        y: 14px;
        width: 32px;
        height: 42px;
        border-radius: 8px;
        border-width: 0px;
        background: touch.has-hover ? root.type-fill : Palette.white-04;

        Image {
            x: 9px;
            y: 7px;
            width: 14px;
            height: 14px;
            source: @image-url("../assets/icons/chevron-down.svg");
            transform-rotation: 180deg;
            image-fit: contain;
            colorize: touch.has-hover ? root.type-tone : Palette.muted-half;
        }

        Text {
            x: 0px;
            y: 21px;
            width: parent.width;
            text: root.vote-count;
            color: touch.has-hover ? root.type-tone : Palette.muted-half;
            font-size: 12px;
            font-weight: 800;
            horizontal-alignment: center;
        }
    }

    Rectangle {
        visible: root.author != "";
        x: parent.width - 122px;
        y: 82px;
        width: 18px;
        height: 18px;
        border-radius: 9px;
        border-width: 0px;
        background: Palette.white-06;

        Text {
            width: parent.width;
            height: parent.height;
            text: root.author-initial;
            color: Palette.muted-half;
            font-size: 9px;
            font-weight: 900;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        visible: root.author != "";
        x: parent.width - 98px;
        y: 83px;
        width: 82px;
        text: root.author;
        color: Palette.muted-half;
        font-size: 11px;
        font-weight: 600;
        overflow: elide;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.open-detail(); }
    }
}

component PackHubInstalledPackCard inherits Rectangle {
    in property <string> title;
    in property <string> pack-id;
    in property <string> pack-type-label: "Addon Pack";
    in property <string> author: "";
    in property <string> addon-count: "0 addons";
    in property <string> installed-label: "";
    in property <string> monogram: "?";
    in property <int> identity-kind: 0;
    in property <int> type-kind: 0;
    callback open-detail;
    callback remove;
    private property <color> type-tone: root.type-kind == 1 ? Palette.sky : (root.type-kind == 2 ? Palette.violet : Palette.gold);
    private property <color> type-fill: root.type-kind == 1 ? Palette.sky-04 : (root.type-kind == 2 ? Palette.violet-04 : Palette.gold-04);
    private property <color> identity-tone: root.identity-kind == 1 ? Palette.sky : (root.identity-kind == 2 ? Palette.logo : (root.identity-kind == 3 ? Palette.emerald : (root.identity-kind == 4 ? Palette.amber : (root.identity-kind == 5 ? Palette.red : (root.identity-kind == 6 ? Palette.violet : Palette.gold)))));
    private property <color> identity-fill: root.identity-kind == 1 ? Palette.sky-15 : (root.identity-kind == 2 ? #4dc2e626 : (root.identity-kind == 3 ? Palette.emerald-15 : (root.identity-kind == 4 ? Palette.amber-15 : (root.identity-kind == 5 ? Palette.red-15 : (root.identity-kind == 6 ? Palette.violet-15 : Palette.gold-15)))));
    private property <color> identity-wash: root.identity-kind == 1 ? Palette.sky-06 : (root.identity-kind == 2 ? #4dc2e610 : (root.identity-kind == 3 ? Palette.emerald-04 : (root.identity-kind == 4 ? Palette.amber-04 : (root.identity-kind == 5 ? Palette.red-04 : (root.identity-kind == 6 ? Palette.violet-04 : Palette.gold-04)))));
    height: 76px;
    border-radius: 12px;
    border-width: 1px;
    border-color: touch.has-hover ? Palette.border-strong : Palette.border;
