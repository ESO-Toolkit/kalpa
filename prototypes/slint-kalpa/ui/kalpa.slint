component UploaderProgressBar inherits Rectangle {
    in property <float> progress: 0.0;
    height: 8px;
    border-radius: 4px;
    border-width: 0px;
    background: Palette.white-04;
    clip: true;

    Rectangle {
        width: parent.width * root.progress;
        height: parent.height;
        border-radius: 4px;
        border-width: 0px;
        background: @linear-gradient(90deg, Palette.sky 0%, Palette.gold 100%);
    }
}

component UploaderOverlay inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <int> view: 0;
    visible: root.open;
    background: #000000c4;
    private property <bool> manual: root.view < 2;
    private property <bool> uploading: root.view == 1;
    private property <bool> live-running: root.view == 3;
    private property <length> modal-width: root.width < 850px ? root.width - 48px : 760px;
    private property <length> modal-height: root.height < 700px ? root.height - 48px : 650px;

    TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.open = false; }
    }

    panel := Rectangle {
        width: root.modal-width;
        height: root.modal-height;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        border-radius: 16px;
        border-width: 1px;
        border-color: Palette.border-strong;
        background: Tokens.surface;
        drop-shadow-blur: 30px;
        drop-shadow-offset-y: 12px;
        drop-shadow-color: #00000099;
        clip: true;

        TouchArea { width: parent.width; height: parent.height; clicked => { } }

        Image { x: 28px; y: 26px; width: 18px; height: 18px; source: @image-url("../assets/icons/cloud-upload.svg"); image-fit: contain; colorize: Palette.gold; }
        Text { x: 58px; y: 21px; width: parent.width - 118px; text: "Log Uploader"; color: Palette.gold; font-size: 18px; font-weight: 900; overflow: elide; }
        Text { x: 58px; y: 52px; width: parent.width - 118px; text: root.manual ? "Upload completed encounter logs or inspect fights before sending." : "Stream new ESO Logs fights while the game writes Combat Metrics data."; color: Palette.muted-strong; font-size: 13px; font-weight: 600; overflow: elide; }

        GhostIconButton {
            x: parent.width - 52px;
            y: 22px;
            width: 36px;
            height: 36px;
            icon: @image-url("../assets/icons/x.svg");
            clicked => { root.open = false; }
        }

        Rectangle {
            x: 28px;
            y: 92px;
            width: parent.width - 56px;
            height: 40px;
            border-radius: 12px;
            border-width: 0px;
            background: Palette.white-03;

            UploaderModeButton { x: 5px; y: 4px; width: (parent.width - 10px) / 2; label: "Manual Upload"; active: root.manual; clicked => { root.view = 0; } }
            UploaderModeButton { x: 5px + (parent.width - 10px) / 2; y: 4px; width: (parent.width - 10px) / 2; label: "Live Logging"; active: !root.manual; clicked => { root.view = 2; } }
        }

        Hairline { x: 0px; y: 152px; width: parent.width; height: 1px; opacity: 0.45; }

        if (root.manual) : Rectangle {
            x: 28px;
            y: 176px;
            width: parent.width - 56px;
            height: parent.height - 254px;
            background: #00000000;

            UploaderInfoCard { x: 0px; y: 0px; width: (parent.width - 18px) / 3; height: 74px; icon: @image-url("../assets/icons/file-text.svg"); label: "SELECTED LOG"; value: "Today - 42.8 MB"; tone: Palette.gold; }
            UploaderInfoCard { x: (parent.width - 18px) / 3 + 9px; y: 0px; width: (parent.width - 18px) / 3; height: 74px; icon: @image-url("../assets/icons/check.svg"); label: "FIGHTS"; value: root.uploading ? "2 uploading" : "2 ready"; tone: Palette.emerald; }
            UploaderInfoCard { x: ((parent.width - 18px) / 3 + 9px) * 2; y: 0px; width: (parent.width - 18px) / 3; height: 74px; icon: @image-url("../assets/icons/cloud-upload.svg"); label: "ROUTE"; value: "Direct from Kalpa"; tone: Palette.sky; }

            Rectangle {
                x: 0px;
                y: 96px;
                width: (parent.width - 18px) * 0.42;
                height: 260px;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.border;
                background: Palette.white-02;

                DetailSectionTitle { x: 18px; y: 16px; width: parent.width - 36px; label: "LOG FILES"; }
                UploaderLogRow { x: 18px; y: 46px; width: parent.width - 36px; title: "EncounterLog_20260702.txt"; meta: "Today - 42.8 MB - 2 fights"; selected: true; }
                UploaderLogRow { x: 18px; y: 110px; width: parent.width - 36px; title: "EncounterLog_20260701.txt"; meta: "Yesterday - 19.4 MB - 1 fight"; }
                UploaderLogRow { x: 18px; y: 174px; width: parent.width - 36px; title: "EncounterLog_20260629.txt"; meta: "Jun 29 - 77.2 MB - 5 fights"; }
            }

            Rectangle {
                x: (parent.width - 18px) * 0.42 + 18px;
                y: 96px;
                width: parent.width - self.x;
                height: 260px;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.border;
                background: Palette.white-02;

                Text { x: 18px; y: 16px; width: parent.width - 36px; text: root.uploading ? "Uploading selected fights" : "Ready to upload"; color: Palette.foreground; font-size: 15px; font-weight: 900; overflow: elide; }
                Text { x: 18px; y: 44px; width: parent.width - 36px; text: root.uploading ? "Sending via the native transport. Kalpa keeps the report in-app when possible." : "Two fights passed preflight. Visibility is unlisted and auto-open analysis is off."; color: Palette.muted-strong; font-size: 12px; font-weight: 600; wrap: word-wrap; }

                if (root.uploading) : UploaderProgressBar { x: 18px; y: 92px; width: parent.width - 36px; progress: 0.58; }
                if (root.uploading) : Text { x: 18px; y: 112px; width: parent.width - 36px; text: "58% - packaging segment 2 of 2"; color: Palette.sky; font-size: 11px; font-weight: 800; }

                DetailSectionTitle { x: 18px; y: root.uploading ? 146px : 94px; width: parent.width - 36px; label: "FIGHTS"; }
                UploaderFightRow { x: 18px; y: root.uploading ? 174px : 122px; width: parent.width - 36px; title: "Lucent Citadel - Orphic Shattered Shard"; meta: "11:28 - 4m 16s"; result: root.uploading ? "UPLOADING" : "READY"; }
                UploaderFightRow { x: 18px; y: root.uploading ? 216px : 164px; width: parent.width - 36px; title: "Lucent Citadel - Arcane Knot"; meta: "11:36 - 7m 44s"; result: root.uploading ? "QUEUED" : "READY"; }
            }
        }

        if (!root.manual) : Rectangle {
            x: 28px;
            y: 176px;
            width: parent.width - 56px;
            height: parent.height - 254px;
            background: #00000000;

            UploaderInfoCard { x: 0px; y: 0px; width: (parent.width - 18px) / 3; height: 74px; icon: @image-url("../assets/icons/power.svg"); label: "STATUS"; value: root.live-running ? "Streaming" : "Ready"; tone: root.live-running ? Palette.emerald : Palette.gold; }
            UploaderInfoCard { x: (parent.width - 18px) / 3 + 9px; y: 0px; width: (parent.width - 18px) / 3; height: 74px; icon: @image-url("../assets/icons/file-text.svg"); label: "CURRENT LOG"; value: "CombatMetrics.log"; tone: Palette.sky; }
            UploaderInfoCard { x: ((parent.width - 18px) / 3 + 9px) * 2; y: 0px; width: (parent.width - 18px) / 3; height: 74px; icon: @image-url("../assets/icons/check.svg"); label: "FIGHTS"; value: root.live-running ? "2 detected" : "Waiting"; tone: Palette.emerald; }

            Rectangle {
                x: 0px;
                y: 96px;
                width: parent.width;
                height: 260px;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.border;
                background: Palette.white-02;

                Text { x: 20px; y: 18px; width: parent.width - 40px; text: root.live-running ? "Live report is open" : "Ready for live logging"; color: Palette.foreground; font-size: 16px; font-weight: 900; overflow: elide; }
                Text { x: 20px; y: 48px; width: parent.width - 40px; text: root.live-running ? "Kalpa is watching the current log and posting fights as they close." : "Start live mode before the pull. Kalpa will wait for the next logging session and keep the report active."; color: Palette.muted-strong; font-size: 13px; font-weight: 600; wrap: word-wrap; }

                if (root.live-running) : Rectangle {
                    x: 20px;
                    y: 92px;
                    width: parent.width - 40px;
                    height: 46px;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: Palette.emerald-20;
                    background: Palette.emerald-04;

                    Image { x: 14px; y: 15px; width: 16px; height: 16px; source: @image-url("../assets/icons/check.svg"); image-fit: contain; colorize: Palette.emerald; }
                    Text { x: 42px; y: 12px; width: parent.width - 56px; text: "Report 1ZG23pzRcvMT8V46 - fight=last"; color: Palette.foreground; font-size: 12px; font-weight: 850; overflow: elide; }
                }

                DetailSectionTitle { x: 20px; y: root.live-running ? 164px : 112px; width: parent.width - 40px; label: root.live-running ? "LIVE FIGHTS" : "READINESS"; }

                if (!root.live-running) : UploaderFightRow { x: 20px; y: 142px; width: parent.width - 40px; title: "ESO Logs session"; meta: "Signed in and ready for native upload"; result: "READY"; live: true; }
                if (!root.live-running) : UploaderFightRow { x: 20px; y: 184px; width: parent.width - 40px; title: "Combat log watcher"; meta: "Waiting for BEGIN_LOG"; result: "ARMED"; live: true; }

                if (root.live-running) : UploaderFightRow { x: 20px; y: 194px; width: parent.width - 40px; title: "Dreadsail Reef - Tideborn Taleria"; meta: "Live - 6m 02s"; result: "POSTED"; live: true; }
                if (root.live-running) : UploaderFightRow { x: 20px; y: 236px; width: parent.width - 40px; title: "Dreadsail Reef - Reef Guardian"; meta: "Live - 4m 48s"; result: "POSTED"; live: true; }
            }
        }

        Rectangle {
            x: 0px;
            y: parent.height - 76px;
            width: parent.width;
            height: 76px;
            background: @linear-gradient(0deg, Tokens.surface 0%, Tokens.surface-84 75%, #00000000 100%);

            PackHubButton { x: 28px; y: 22px; width: 116px; icon: @image-url("../assets/icons/settings.svg"); label: "Options"; }
            PackHubButton { x: parent.width - 284px; y: 22px; width: 116px; icon: @image-url("../assets/icons/x.svg"); label: root.live-running ? "Stop" : "Cancel"; danger: root.live-running; clicked => { if (root.live-running) { root.view = 2; } else { root.open = false; } } }
            PackHubButton { x: parent.width - 156px; y: 22px; width: 128px; icon: root.manual ? @image-url("../assets/icons/cloud-upload.svg") : @image-url("../assets/icons/power.svg"); label: root.manual ? (root.uploading ? "Uploading" : "Upload") : (root.live-running ? "View Report" : "Go Live"); primary: true; clicked => { if (root.view == 0) { root.view = 1; } else if (root.view == 2) { root.view = 3; } } }
        }
    }
}

component SvmTabButton inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked;
    width: label-text.preferred-width + 28px;
    height: 38px;
    border-radius: 8px;
    background: touch.has-hover ? Palette.white-04 : #00000000;

    Text {
        x: 10px;
        y: 0px;
        height: parent.height - 4px;
        text: root.label;
        color: root.active ? Palette.foreground : Palette.muted-strong;
        font-size: 13px;
        font-weight: 850;
        vertical-alignment: center;
    }

    label-text := Text {
        visible: false;
        text: root.label;
        font-size: 13px;
        font-weight: 850;
    }

    Rectangle {
        x: 8px;
        y: parent.height - 3px;
        width: parent.width - 16px;
        height: 2px;
        border-radius: 1px;
        background: root.active ? Palette.foreground : #00000000;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component SvmStatCard inherits Rectangle {
    in property <string> value;
    in property <string> label;
    in property <bool> warning: false;
    height: 68px;
    border-radius: 10px;
    border-width: root.warning ? 1px : 0px;
    border-color: root.warning ? Palette.gold-20 : #00000000;
    background: root.warning ? Palette.gold-04 : Palette.white-03;

    Text {
        y: 16px;
        width: parent.width;
        text: root.value;
        color: root.warning ? Palette.gold : Palette.foreground;
        font-size: 20px;
        font-weight: 900;
        horizontal-alignment: center;
    }

    Text {
        y: 43px;
        width: parent.width;
        text: root.label;
        color: Palette.muted-strong;
        font-size: 11px;
        font-weight: 800;
        horizontal-alignment: center;
    }
}

component SvmOverviewRow inherits Rectangle {
    in property <string> title;
    in property <string> meta;
    in property <string> size-label;
    in property <length> meter-width: 42px;
    in property <bool> system: false;
    height: 58px;
    border-radius: 11px;
    border-width: 0px;
    background: touch.has-hover ? Palette.white-04 : Palette.white-03;

    Rectangle {
        x: 12px;
        y: 19px;
        width: 56px;
        height: 6px;
        border-radius: 3px;
        background: Palette.white-06;
    }

    Rectangle {
        x: 12px;
        y: 19px;
        width: root.meter-width;
        height: 6px;
        border-radius: 3px;
        background: Palette.gold;
    }

    Text {
        x: 24px;
        y: 30px;
        width: 56px;
        text: root.size-label;
        color: Palette.gold;
        font-size: 11px;
        font-weight: 900;
        horizontal-alignment: center;
    }

    Text {
        x: 88px;
        y: 10px;
        width: parent.width - 150px;
        text: root.title;
        color: Palette.foreground;
        font-size: 16px;
        font-weight: 850;
        overflow: elide;
    }

    Pill {
        visible: root.system;
        x: 230px;
        y: 10px;
        label: "System";
        tone: Palette.muted-strong;
        fill: Palette.white-06;
        pill-height: 22px;
        label-font-size: 12px;
    }

    Text {
        x: 88px;
        y: 34px;
        width: parent.width - 150px;
        text: root.meta;
        color: Palette.muted-strong;
        font-size: 12px;
        font-weight: 600;
        overflow: elide;
    }

    Image {
        x: parent.width - 34px;
        y: 22px;
        width: 14px;
        height: 14px;
        source: @image-url("../assets/icons/chevron-right.svg");
        image-fit: contain;
        colorize: touch.has-hover ? Palette.muted-strong : Palette.muted-dim;
    }

    touch := TouchArea { width: root.width; height: root.height; }
}

component SvmCleanupRow inherits Rectangle {
    in property <string> title;
    in property <string> meta;
    in property <bool> checked: false;
    height: 58px;
    border-radius: 10px;
    background: touch.has-hover ? Palette.white-04 : Palette.white-03;

    Checkbox { x: 12px; y: 21px; checked: root.checked; }

    Text {
        x: 44px;
        y: 11px;
        width: parent.width - 70px;
        text: root.title;
        color: Palette.foreground;
        font-size: 15px;
        font-weight: 850;
        overflow: elide;
    }

    Text {
        x: 44px;
        y: 35px;
        width: parent.width - 70px;
        text: root.meta;
        color: Palette.muted-strong;
        font-size: 12px;
        font-weight: 600;
        overflow: elide;
    }

    touch := TouchArea { width: root.width; height: root.height; }
}

component SvmSelectField inherits Rectangle {
    in property <string> label;
    height: 38px;
    border-radius: 10px;
    border-width: 0px;
    background: Palette.white-03;

    Text {
        x: 12px;
        y: 0px;
        height: parent.height;
        width: parent.width - 46px;
        text: root.label;
        color: Palette.foreground;
        font-size: 14px;
        font-weight: 850;
        vertical-alignment: center;
        overflow: elide;
    }

    Image {
        x: parent.width - 26px;
        y: 12px;
        width: 14px;
        height: 14px;
        source: @image-url("../assets/icons/chevron-down.svg");
        image-fit: contain;
        colorize: Palette.muted-strong;
    }
}

component SvmToggle inherits Rectangle {
    in property <bool> checked: false;
    width: 40px;
    height: 22px;
    border-radius: 11px;
    background: root.checked ? Palette.gold : Palette.white-08;

    Rectangle {
        x: root.checked ? parent.width - 20px : 2px;
        y: 2px;
        width: 18px;
        height: 18px;
        border-radius: 9px;
        background: Palette.foreground;
    }
}

component SvmEditorTreeRow inherits Rectangle {
    in property <string> label;
    in property <string> count;
    in property <int> indent: 0;
    in property <bool> active: false;
    in property <bool> expanded: false;
    height: 28px;
    border-radius: 7px;
    background: root.active ? Palette.white-10 : #00000000;

    Image {
        visible: root.indent > 0 || root.expanded;
        x: 8px + root.indent * 18px;
        y: 8px;
        width: 12px;
        height: 12px;
        source: root.expanded ? @image-url("../assets/icons/chevron-down.svg") : @image-url("../assets/icons/chevron-right.svg");
        image-fit: contain;
        colorize: Palette.muted-strong;
    }

    Text {
        x: 24px + root.indent * 18px;
        y: 0px;
        height: parent.height;
        width: parent.width - 76px - root.indent * 18px;
        text: root.label;
        color: root.active ? Palette.foreground : Palette.muted-strong;
        font-size: 12px;
        font-weight: root.active ? 900 : 750;
        vertical-alignment: center;
        overflow: elide;
    }

    Text {
        x: parent.width - 46px;
        y: 0px;
        height: parent.height;
        width: 36px;
        text: root.count;
        color: Palette.muted-dim;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
}

component SvmSettingRow inherits Rectangle {
    in property <string> label;
    in property <string> key-name;
    in property <int> kind: 0;
    in property <string> value: "";
    in property <bool> checked: false;
    height: 42px;

    Text {
        x: 12px;
        y: 8px;
        width: parent.width - 250px;
        text: root.label;
        color: Palette.foreground;
        font-size: 13px;
        font-weight: 850;
        overflow: elide;
    }

    Text {
        x: 190px;
        y: 9px;
        width: parent.width - 420px;
        text: root.key-name;
        color: Palette.muted-dim;
        font-size: 11px;
        font-weight: 650;
        overflow: elide;
    }

    if (root.kind == 0) : SvmToggle {
        x: parent.width - 64px;
        y: 8px;
        checked: root.checked;
    }

    if (root.kind == 1) : Rectangle {
        x: parent.width - 210px;
        y: 4px;
        width: 176px;
        height: 30px;
        border-radius: 9px;
        background: Palette.white-03;

        Text {
            x: 12px;
            y: 0px;
            height: parent.height;
            width: parent.width - 24px;
            text: root.value;
            color: Palette.foreground;
            font-size: 13px;
            font-weight: 750;
            vertical-alignment: center;
        }
    }

    if (root.kind == 2) : Rectangle {
        x: parent.width - 190px;
        y: 4px;
        width: 154px;
        height: 30px;
        background: #00000000;

        GhostIconButton { x: 0px; y: 1px; width: 28px; height: 28px; icon: @image-url("../assets/icons/minus.svg"); }
        Rectangle {
            x: 34px;
            y: 0px;
            width: 92px;
            height: 30px;
            border-radius: 9px;
            background: Palette.white-03;

            Text { width: parent.width; height: parent.height; text: root.value; color: Palette.foreground; font-size: 13px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
        }
        GhostIconButton { x: 132px; y: 1px; width: 28px; height: 28px; icon: @image-url("../assets/icons/plus.svg"); }
    }
}

component SavedVariablesOverlay inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <int> view: 0;
    in property <[SavedVariableEntry]> files;
    in property <[SavedVariableEntry]> orphaned-files;
    in property <string> file-count-label;
    in property <string> total-size-label;
    in property <string> orphan-count-label;
    in property <string> orphan-size-label;
    in property <string> large-count-label;
    in property <bool> has-orphans: false;
    in property <bool> has-files: false;
    callback refresh;
    visible: root.open;
    background: #000000c4;
    private property <length> modal-width: root.width < 980px ? root.width - 48px : 900px;
    private property <length> modal-height: root.height < 738px ? root.height - 48px : 690px;

    TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.open = false; }
    }

    panel := Rectangle {
        width: root.modal-width;
        height: root.modal-height;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        border-radius: 16px;
        border-width: 1px;
        border-color: Palette.border-strong;
        background: @linear-gradient(180deg, Tokens.surface 0%, Tokens.background 100%);
        drop-shadow-blur: 34px;
        drop-shadow-offset-y: 14px;
        drop-shadow-color: #00000099;
        clip: true;

        TouchArea { width: parent.width; height: parent.height; clicked => { } }

        Text {
            x: 28px;
            y: 26px;
            width: parent.width - 96px;
            text: "SavedVariables Manager";
            color: Palette.gold;
            font-size: 18px;
            font-weight: 900;
            overflow: elide;
        }

        GhostIconButton {
            x: parent.width - 52px;
            y: 22px;
            width: 36px;
            height: 36px;
            icon: @image-url("../assets/icons/x.svg");
            clicked => { root.open = false; }
        }

        Hairline { x: 0px; y: 72px; width: parent.width; height: 1px; opacity: 0.5; }

        SvmTabButton { x: 28px; y: 88px; label: "Overview"; active: root.view == 0; clicked => { root.view = 0; } }
        SvmTabButton { x: 110px; y: 88px; label: "Cleanup"; active: root.view == 1; clicked => { root.view = 1; } }
        SvmTabButton { x: 192px; y: 88px; label: "Copy Profile"; active: root.view == 2; clicked => { root.view = 2; } }
        SvmTabButton { x: 306px; y: 88px; label: "Editor"; active: root.view == 3; clicked => { root.view = 3; } }

        if (root.view == 0) : Rectangle {
            x: 28px;
            y: 134px;
            width: parent.width - 56px;
            height: parent.height - 222px;
            background: #00000000;

            SvmStatCard { x: 0px; y: 0px; width: (parent.width - 24px) / 3; value: root.file-count-label; label: "FILES"; }
            SvmStatCard { x: (parent.width - 24px) / 3 + 12px; y: 0px; width: (parent.width - 24px) / 3; value: root.total-size-label; label: "TOTAL SIZE"; }
            SvmStatCard { x: ((parent.width - 24px) / 3 + 12px) * 2; y: 0px; width: (parent.width - 24px) / 3; value: root.orphan-count-label; label: "ORPHANED"; warning: root.has-orphans; }

            Rectangle {
                visible: root.has-orphans;
                x: 0px;
                y: 78px;
                width: parent.width;
                height: 42px;
                border-radius: 10px;
                border-width: 1px;
                border-color: Palette.gold-20;
                background: Palette.gold-04;

                Image { x: 14px; y: 13px; width: 16px; height: 16px; source: @image-url("../assets/icons/package.svg"); image-fit: contain; colorize: Palette.gold; }
                Text { x: 40px; y: 0px; height: parent.height; text: root.orphan-count-label + " orphaned files (" + root.orphan-size-label + ") from uninstalled addons. Clean up ->"; color: Palette.gold; font-size: 13px; font-weight: 900; vertical-alignment: center; }
                TouchArea { width: parent.width; height: parent.height; clicked => { root.view = 1; } }
            }

            FilterTab { x: 0px; y: 130px; label: "All"; active: true; }
            FilterTab { x: 58px; y: 130px; label: "Orphaned (" + root.orphan-count-label + ")"; }
            FilterTab { x: 170px; y: 130px; label: "Large (" + root.large-count-label + ")"; }
            Text { x: parent.width - 140px; y: 136px; text: "Size"; color: Palette.muted-strong; font-size: 12px; font-weight: 750; }
            PackHubButton { x: parent.width - 88px; y: 126px; width: 88px; icon: @image-url("../assets/icons/refresh-cw.svg"); label: "Refresh"; clicked => { root.refresh(); } }

            if (!root.has-files) : Rectangle {
                x: 0px;
                y: 176px;
                width: parent.width;
                height: 312px;
                border-radius: 12px;
                background: Palette.white-02;
                clip: true;

                Text { x: 24px; y: 0px; width: parent.width - 48px; height: parent.height; text: "No SavedVariables files found."; color: Palette.muted-strong; font-size: 14px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
            }

            if (root.has-files) : ScrollView {
                x: 0px;
                y: 176px;
                width: parent.width;
                height: 312px;
                viewport-width: self.width;
                viewport-height: root.files.length * 62px;
                vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                Rectangle {
                    width: parent.width;
                    height: root.files.length * 62px;
                    border-radius: 12px;
                    background: Palette.white-02;
                    clip: true;

                    for file[index] in root.files : SvmOverviewRow {
                        x: 0px;
                        y: index * 62px;
                        width: parent.width;
                        title: file.title;
                        meta: file.meta;
                        size-label: file.size-label;
                        meter-width: file.meter-width * 1px;
                        system: file.system;
                    }
                }

                Rectangle { x: parent.width - 10px; y: 14px; width: 5px; height: 260px; border-radius: 3px; background: Palette.white-04; }
                Rectangle { x: parent.width - 10px; y: 26px; width: 5px; height: 34px; border-radius: 3px; background: Palette.sky; }
            }
        }

        if (root.view == 1) : Rectangle {
            x: 28px;
            y: 134px;
            width: parent.width - 56px;
            height: parent.height - 222px;
            background: #00000000;

            Image { x: 0px; y: 5px; width: 16px; height: 16px; source: @image-url("../assets/icons/package.svg"); image-fit: contain; colorize: Palette.gold; }
            Text { x: 24px; y: 0px; text: "Orphaned Files"; color: Palette.foreground; font-size: 16px; font-weight: 900; }
            Text { x: 184px; y: 1px; text: "(" + root.orphan-count-label + " files, " + root.orphan-size-label + ")"; color: Palette.muted-strong; font-size: 15px; font-weight: 700; }
            Text { x: 0px; y: 32px; width: parent.width - 120px; text: "These files belong to addons that are no longer installed."; color: Palette.muted-strong; font-size: 13px; font-weight: 600; }
            Text { x: parent.width - 62px; y: 4px; text: "Select all"; color: Palette.muted-strong; font-size: 13px; font-weight: 800; horizontal-alignment: right; }

            if (root.orphaned-files.length == 0) : Rectangle {
                x: 0px;
                y: 62px;
                width: parent.width;
                height: 244px;
                border-radius: 12px;
                background: Palette.white-02;
                clip: true;

                Text { x: 24px; y: 0px; width: parent.width - 48px; height: parent.height; text: "No orphaned SavedVariables files found."; color: Palette.muted-strong; font-size: 14px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
            }

            if (root.orphaned-files.length > 0) : ScrollView {
                x: 0px;
                y: 62px;
                width: parent.width;
                height: 244px;
                viewport-width: self.width;
                viewport-height: root.orphaned-files.length * 64px;
                vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                Rectangle {
                    width: parent.width;
                    height: root.orphaned-files.length * 64px;
                    border-radius: 12px;
                    background: Palette.white-02;
                    clip: true;

                    for file[index] in root.orphaned-files : SvmCleanupRow {
                        x: 0px;
                        y: index * 64px;
                        width: parent.width;
                        title: file.title;
                        meta: file.size-label + " - " + file.meta;
                    }
                }
                Rectangle { x: parent.width - 10px; y: 8px; width: 5px; height: 214px; border-radius: 3px; background: Palette.white-04; }
                Rectangle { x: parent.width - 10px; y: 16px; width: 5px; height: 42px; border-radius: 3px; background: Palette.sky; }
            }

            Rectangle {
                x: 0px;
                y: 322px;
                width: parent.width;
                height: 56px;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.white-06;
                background: Palette.white-03;

                Text { x: 14px; y: 0px; height: parent.height; text: "Select files to clean up"; color: Palette.muted-strong; font-size: 13px; font-weight: 750; vertical-alignment: center; }
                PackHubButton { x: parent.width - 116px; y: 12px; width: 102px; icon: @image-url("../assets/icons/trash-2.svg"); label: "Clean Up"; primary: true; }
            }
        }

        if (root.view == 2) : Rectangle {
            x: 28px;
            y: 134px;
            width: parent.width - 56px;
            height: parent.height - 222px;
            background: #00000000;

            Text { x: 0px; y: 0px; width: parent.width; text: "Copy addon settings from one character to another within the same SavedVariables file."; color: Palette.muted-strong; font-size: 15px; font-weight: 650; }

            Text { x: 0px; y: 46px; text: "1. Select SavedVariables file"; color: Palette.muted-strong; font-size: 13px; font-weight: 800; }
            SvmSelectField { x: 0px; y: 68px; width: parent.width; label: "Cooldowns.lua"; }

            Text { x: 0px; y: 124px; text: "2. Source character"; color: Palette.muted-strong; font-size: 13px; font-weight: 800; }
            SvmSelectField { x: 0px; y: 146px; width: parent.width; label: "Spike'jo"; }

            Text { x: 0px; y: 202px; text: "3. Destination character"; color: Palette.muted-strong; font-size: 13px; font-weight: 800; }
            SvmSelectField { x: 0px; y: 224px; width: parent.width; label: "Spike jona"; }

            Rectangle {
                x: 0px;
                y: 292px;
                width: parent.width;
                height: 92px;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.gold-20;
                background: Palette.gold-04;

                Text { x: 14px; y: 16px; text: "Copy "; color: Palette.foreground; font-size: 14px; font-weight: 850; }
                Text { x: 52px; y: 16px; text: "Spike'jo"; color: Palette.gold; font-size: 14px; font-weight: 900; }
                Text { x: 116px; y: 16px; text: "->"; color: Palette.foreground; font-size: 14px; font-weight: 850; }
                Text { x: 140px; y: 16px; text: "Spike jona"; color: Palette.sky; font-size: 14px; font-weight: 900; }
                Text { x: 216px; y: 16px; text: "in Cooldowns.lua"; color: Palette.foreground; font-size: 14px; font-weight: 850; }
                PackHubButton { x: 14px; y: 48px; width: 132px; icon: @image-url("../assets/icons/copy.svg"); label: "Copy Profile"; primary: true; }
            }
        }

        if (root.view == 3) : Rectangle {
            x: 28px;
            y: 126px;
            width: parent.width - 56px;
            height: parent.height - 196px;
            background: #00000000;

            SvmSelectField { x: 0px; y: 0px; width: 320px; label: "LuiExtended.lua"; }
            PackHubButton { x: 328px; y: 0px; width: 116px; icon: @image-url("../assets/icons/save.svg"); label: "Save Changes"; primary: true; }
            PackHubButton { x: 452px; y: 0px; width: 78px; icon: @image-url("../assets/icons/file-text.svg"); label: "Preview"; }
            PackHubButton { x: 538px; y: 0px; width: 76px; icon: @image-url("../assets/icons/x.svg"); label: "Discard"; disabled: true; }
            PackHubButton { x: 622px; y: 0px; width: 84px; icon: @image-url("../assets/icons/undo-2.svg"); label: "Restore"; }
            PackHubButton { x: 714px; y: 0px; width: 78px; icon: @image-url("../assets/icons/settings.svg"); label: "Settings"; }
            PackHubButton { x: 800px; y: 0px; width: 44px; icon: @image-url("../assets/icons/file-text.svg"); label: "Raw"; show-icon: false; }

            Rectangle {
                x: 0px;
                y: 50px;
                width: parent.width;
                height: 382px;
                border-radius: 12px;
                background: Palette.white-02;
                clip: true;

                Rectangle {
                    x: 0px;
                    y: 0px;
                    width: 214px;
                    height: parent.height;
                    background: Palette.white-02;
                    border-width: 0px;

                    PackHubField { x: 10px; y: 10px; width: parent.width - 20px; placeholder: "Search..."; }

                    Text { x: 34px; y: 58px; text: "LUIESV"; color: Palette.muted-strong; font-size: 12px; font-weight: 900; }
                    Pill { x: 88px; y: 82px; label: "Default"; tone: Palette.muted-strong; fill: Palette.white-06; pill-height: 18px; label-font-size: 10px; }
                    Pill { x: 84px; y: 108px; label: "@Spike'jo"; tone: Palette.sky; fill: Palette.sky-10; pill-height: 18px; label-font-size: 10px; }

                    SvmEditorTreeRow { x: 10px; y: 132px; width: parent.width - 20px; label: "$AccountWide"; count: "50"; active: true; expanded: true; }
                    SvmEditorTreeRow { x: 10px; y: 160px; width: parent.width - 20px; label: "SpellCastBuffs"; count: "154"; indent: 1; }
                    SvmEditorTreeRow { x: 10px; y: 188px; width: parent.width - 20px; label: "ZO_HUDEquipme..."; count: "2"; indent: 1; }
                    SvmEditorTreeRow { x: 10px; y: 216px; width: parent.width - 20px; label: "ZO_ActiveComba..."; count: "2"; indent: 1; }
                    SvmEditorTreeRow { x: 10px; y: 244px; width: parent.width - 20px; label: "InfoPanel"; count: "10"; indent: 1; }
                    SvmEditorTreeRow { x: 10px; y: 272px; width: parent.width - 20px; label: "ActionBar"; count: "55"; indent: 1; }
                    SvmEditorTreeRow { x: 10px; y: 300px; width: parent.width - 20px; label: "UnitFrames"; count: "203"; indent: 1; }

                    Rectangle { x: parent.width - 8px; y: 64px; width: 5px; height: 266px; border-radius: 3px; background: Palette.white-04; }
                    Rectangle { x: parent.width - 8px; y: 78px; width: 5px; height: 142px; border-radius: 3px; background: Palette.sky; }

                    Hairline { x: 0px; y: parent.height - 34px; width: parent.width; height: 1px; opacity: 0.45; }
                    Text { x: 34px; y: parent.height - 24px; text: "Expand All"; color: Palette.muted-strong; font-size: 11px; font-weight: 800; }
                    Text { x: parent.width - 86px; y: parent.height - 24px; text: "Collapse All"; color: Palette.muted-strong; font-size: 11px; font-weight: 800; }
                }

                Hairline { x: 214px; y: 0px; width: 1px; height: parent.height; opacity: 0.45; }

                Rectangle {
                    x: 226px;
                    y: 14px;
                    width: parent.width - 246px;
                    height: 30px;
                    border-radius: 9px;
                    background: Palette.white-03;

                    Text { x: 12px; y: 0px; height: parent.height; text: "Root  >  LUIESV  >  Default  >  @Spike'jo  >  $AccountWide"; color: Palette.muted-strong; font-size: 12px; font-weight: 800; vertical-alignment: center; }
                }

                Text { x: 226px; y: 58px; text: "SETTINGS"; color: Palette.muted-strong; font-size: 11px; font-weight: 900; }
                SvmSettingRow { x: 226px; y: 88px; width: parent.width - 246px; label: "Snap To Grid unit Frames"; key-name: "snapToGrid_unitFrames"; checked: true; }
                SvmSettingRow { x: 226px; y: 130px; width: parent.width - 246px; label: "Welcome Version"; key-name: "WelcomeVersion"; kind: 1; value: "6.6.9"; }
                SvmSettingRow { x: 226px; y: 172px; width: parent.width - 246px; label: "Snap To Grid Size default"; key-name: "snapToGridSize_default"; kind: 2; value: "15"; }
                SvmSettingRow { x: 226px; y: 214px; width: parent.width - 246px; label: "Combat Text Enabled"; key-name: "CombatText_Enabled"; checked: false; }
                SvmSettingRow { x: 226px; y: 256px; width: parent.width - 246px; label: "Snap To Grid Size buffs"; key-name: "snapToGridSize_buffs"; kind: 2; value: "15"; }
                SvmSettingRow { x: 226px; y: 298px; width: parent.width - 246px; label: "Startup Info"; key-name: "StartupInfo"; checked: false; }
                SvmSettingRow { x: 226px; y: 340px; width: parent.width - 246px; label: "Snap To Grid default"; key-name: "snapToGrid_default"; checked: false; }

                Rectangle { x: parent.width - 14px; y: 64px; width: 5px; height: 286px; border-radius: 3px; background: Palette.white-04; }
                Rectangle { x: parent.width - 14px; y: 80px; width: 5px; height: 72px; border-radius: 3px; background: Palette.sky; }
            }
        }

        Rectangle {
            x: 0px;
            y: parent.height - 76px;
            width: parent.width;
            height: 76px;
            background: @linear-gradient(0deg, Tokens.surface 0%, Tokens.surface-84 72%, #00000000 100%);

            PackHubButton { x: parent.width - 96px; y: 22px; width: 68px; icon: @image-url("../assets/icons/x.svg"); label: "Close"; show-icon: false; clicked => { root.open = false; } }
        }
    }
}

component Header inherits Rectangle {
    in property <int> addons-count: 113;
    in-out property <int> displayed-addons-count: 113;
    in property <length> chrome-width: 1462px;
    in property <bool> batch-active: false;
    in property <int> selected-count: 0;
    in property <bool> loading: false;
    in property <bool> checking-updates: false;
    in-out property <angle> spinner-angle: 0deg;
    callback minimize-requested;
    callback maximize-requested;
    callback close-requested;
    callback batch-update;
    callback batch-disable;
    callback batch-tag;
    callback batch-remove;
    callback batch-clear;
    callback refresh-requested;
    callback open-pack-hub-clicked;
    callback open-svm-clicked;
    callback open-uploader-clicked;
    callback open-settings-clicked;

    background: @linear-gradient(180deg, Tokens.bg-base-85 0%, Tokens.bg-base-60 100%);
    height: 48px;
    drop-shadow-blur: 18px;
    drop-shadow-offset-y: 4px;
    drop-shadow-color: #00000066;

    Rectangle {
        width: root.width;
        height: 1px;
        background: #ffffff0d;
    }

    Hairline { y: root.height - 1px; width: root.width; height: 1px; opacity: 0.5; }

    Rectangle {
        x: 0px;
        y: root.height - 1px;
        width: root.width;
        height: 1px;
        background: @linear-gradient(90deg, #00000000 0%, Palette.gold-20 50%, #00000000 100%);
    }

    spinner-timer := Timer {
        interval: 16ms;
        running: (root.loading || root.checking-updates) && !Tokens.reduced-motion;
        triggered => {
            if (root.spinner-angle >= 354deg) {
                root.spinner-angle = 0deg;
            } else {
                root.spinner-angle += 6deg;
            }
        }
    }

    count-timer := Timer {
        interval: 33ms;
        running: root.displayed-addons-count != root.addons-count;
        triggered => {
            if (Tokens.reduced-motion) {
                root.displayed-addons-count = root.addons-count;
            } else if (root.displayed-addons-count < root.addons-count) {
                root.displayed-addons-count += min(8, root.addons-count - root.displayed-addons-count);
            } else if (root.displayed-addons-count > root.addons-count) {
                root.displayed-addons-count -= min(8, root.displayed-addons-count - root.addons-count);
            }
        }
    }

    Image {
        x: 16px;
        y: 13px;
        width: 20px;
        height: 20px;
        source: @image-url("../../../src/assets/logo-icon.svg");
        image-fit: contain;
    }

    Text {
        x: 45px;
        y: 14px;
        text: "K A L P A";
        color: Palette.gold;
        font-family: "Space Grotesk Light";
        font-size: 13px;
        font-weight: 900;
    }

    Rectangle { x: 104px; y: 15px; width: 1px; height: 18px; background: Palette.white-06; }

    Rectangle {
        x: 114px;
        y: 12px;
        width: 72px;
        height: 24px;
        border-radius: 12px;
        border-width: 0px;
        background: Palette.white-04;

        Text {
            width: parent.width;
            height: parent.height;
            text: "esotk.com";
            color: Palette.muted-dim;
            font-size: 10px;
            font-weight: 500;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        visible: !root.batch-active;
        x: root.chrome-width - 410px;
        y: 15px;
        width: 90px;
        text: root.displayed-addons-count + " addons";
        color: Palette.muted-dim;
        font-family: "Space Grotesk Light";
        font-size: 12px;
        font-weight: 700;
    }

    if (root.checking-updates) : Text {
        visible: !root.batch-active;
        x: root.chrome-width - 328px;
        y: 15px;
        text: ".";
        color: Palette.muted-dim;
        font-size: 12px;
        font-weight: 700;
    }

    HeaderIcon { visible: !root.batch-active; x: root.chrome-width - 292px; y: 10px; width: 28px; height: 28px; icon: @image-url("../assets/icons/refresh-cw.svg"); rotation: root.loading ? root.spinner-angle : 0deg; clicked => { root.refresh-requested(); } }
    HeaderIcon { visible: !root.batch-active; x: root.chrome-width - 256px; y: 10px; width: 28px; height: 28px; icon: @image-url("../assets/icons/package.svg"); clicked => { root.open-pack-hub-clicked(); } }
    HeaderIcon { visible: !root.batch-active; x: root.chrome-width - 220px; y: 10px; width: 28px; height: 28px; icon: @image-url("../assets/icons/file-sliders.svg"); clicked => { root.open-svm-clicked(); } }
    HeaderIcon { visible: !root.batch-active; x: root.chrome-width - 184px; y: 10px; width: 28px; height: 28px; icon: @image-url("../assets/icons/cloud-upload.svg"); clicked => { root.open-uploader-clicked(); } }
    HeaderIcon { visible: !root.batch-active; x: root.chrome-width - 148px; y: 10px; width: 28px; height: 28px; icon: @image-url("../assets/icons/settings.svg"); clicked => { root.open-settings-clicked(); } }

    if (root.batch-active) : Text {
        x: root.chrome-width - 560px;
        y: 15px;
        width: 92px;
        text: root.selected-count + " selected";
        color: Palette.gold;
        font-size: 12px;
        font-weight: 700;
        horizontal-alignment: right;
    }

    if (root.batch-active) : SmallAction {
        x: root.chrome-width - 456px;
        y: 12px;
        label: "Update";
        tone: Palette.gold;
        fill: Palette.gold-10;
        fill-hover: Palette.gold-15;
        fill-pressed: Palette.gold-20;
        clicked => { root.batch-update(); }
    }

    if (root.batch-active) : SmallAction {
        x: root.chrome-width - 392px;
        y: 12px;
        label: "Disable";
        tone: Palette.amber;
        fill: Palette.amber-04;
        fill-hover: Palette.amber-15;
        fill-pressed: Palette.amber-20;
        clicked => { root.batch-disable(); }
    }

    if (root.batch-active) : SmallAction {
        x: root.chrome-width - 318px;
        y: 12px;
        label: "Tag";
        tone: Palette.sky;
        fill: Palette.sky-10;
        fill-hover: Palette.sky-16;
        fill-pressed: Palette.sky-22;
        clicked => { root.batch-tag(); }
    }

    if (root.batch-active) : SmallAction {
        x: root.chrome-width - 272px;
        y: 12px;
        label: "Remove";
        tone: Palette.red;
        fill: Palette.red-04;
        fill-hover: Palette.red-15;
        fill-pressed: Palette.red-20;
        clicked => { root.batch-remove(); }
    }

    if (root.batch-active) : GhostIconButton {
        x: root.chrome-width - 180px;
        y: 10px;
        icon: @image-url("../assets/icons/x.svg");
        clicked => { root.batch-clear(); }
    }
    HeaderIcon { x: root.chrome-width - 104px; y: 8px; width: 32px; height: 32px; icon: @image-url("../assets/icons/minus.svg"); clicked => { root.minimize-requested(); } }
    HeaderIcon { x: root.chrome-width - 72px; y: 8px; width: 32px; height: 32px; icon: @image-url("../assets/icons/square.svg"); clicked => { root.maximize-requested(); } }
    HeaderIcon { x: root.chrome-width - 40px; y: 8px; width: 32px; height: 32px; icon: @image-url("../assets/icons/x.svg"); close: true; clicked => { root.close-requested(); } }
}

component Sidebar inherits Rectangle {
    forward-focus: list-key-focus;
    in property <[AddonEntry]> addons;
    in property <[DiscoverEntry]> discover-results;
    in property <bool> batch-active: false;
    in-out property <int> selected-index: 0;
    in-out property <int> selected-discover-index: 0;
    in-out property <bool> discover-active: false;
    in-out property <string> addon-search-query;
    in-out property <int> filter-mode: 0;
    in-out property <int> sort-mode: 0;
    in-out property <bool> sort-menu-open: false;
    in-out property <int> discover-tab: 0;
    in-out property <string> discover-query;
    in-out property <string> discover-url-input;
    in property <int> total-addon-count: 0;
    in property <int> addon-kind-count: 0;
    in property <int> library-kind-count: 0;
    in property <int> favorite-addon-count: 0;
    in property <int> outdated-addon-count: 0;
    in property <int> issue-addon-count: 0;
    in property <int> disabled-addon-count: 0;
    in property <int> testing-tag-count: 0;
    in property <int> broken-tag-count: 0;
    in property <int> essential-tag-count: 0;
    in property <int> raid-tag-count: 0;
    callback addon-selected(int);
    callback addon-selection-toggled(int);
    callback addon-context-open-folder(int);
    callback addon-context-open-esoui(int);
    callback addon-context-favorite(int);
    callback addon-context-toggle-disable(int);
    callback addon-context-remove(int);
    callback addon-search-edited(string);
    callback filter-selected(int);
    callback sort-selected(int);
    callback discover-tab-selected(int);
    callback discover-selected(int);
    callback discover-install(int);
    callback discover-query-edited(string);
    callback discover-url-edited(string);
    private property <string> count-label: root.addons.length == 1 ? "1 ADDON" : root.addons.length + " ADDONS";
    private property <string> sort-label: sort-mode == 1 ? "Author" : (sort-mode == 2 ? "Recently Updated" : (sort-mode == 3 ? "Recently Downloaded" : "Name"));
    private property <bool> compact-discover-chrome: root.discover-active && (root.discover-tab == 1 || root.discover-tab == 2);
    private property <length> discover-panel-y: root.compact-discover-chrome ? 86px : 165px;
    background: @linear-gradient(180deg, Tokens.bg-base-85 0%, Tokens.background 52%, Tokens.bg-base-85 100%);

    Hairline { x: root.width - 1px; width: 1px; height: root.height; opacity: 0.5; }

    Rectangle {
        x: 0px;
        y: 0px;
        width: root.width;
        height: 126px;
        background: @linear-gradient(180deg, Palette.white-04 0%, #00000000 100%);
    }

    Rectangle {
        x: 12px;
        y: 12px;
        width: root.width - 24px;
        height: 36px;
        border-radius: 12px;
        border-width: 0px;
        background: Palette.white-04;
        inner-shadow-offset-y: 1px;
