        if (!side.discover-active && root.addons.length == 0) : DiscoverEmptyState {
            x: root.sidebar-width;
            y: 48px + root.banner-height;
            width: root.content-width;
            height: root.height - 48px - root.banner-height;
            icon: @image-url("../assets/icons/search.svg");
            title: "No Addon Selected";
            subtitle: "Clear search or choose a different filter to show addon details.";
        }

        if (side.discover-active && root.discover-results.length > 0) : DiscoverDetailPane {
            x: root.sidebar-width;
