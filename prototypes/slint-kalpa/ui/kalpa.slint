component PackHubSelectedCard inherits Rectangle {
    in property <string> title;
    in property <bool> optional: false;
    height: 58px;
    border-radius: 9px;
    border-width: 0px;
    background: Palette.white-04;

    Text {
        x: 12px;
        y: 8px;
        width: parent.width - 24px;
