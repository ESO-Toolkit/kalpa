        y: 41px;
        width: 84px;
        height: 20px;
        text: root.addon-count;
        color: Palette.muted-half;
        font-size: 12px;
        font-weight: 650;
        vertical-alignment: center;
        overflow: elide;
    }

    Text {
        x: 176px;
        y: 41px;
        width: parent.width - 334px;
        height: 20px;
        text: root.author != "" ? "by " + root.author : "";
        color: Palette.muted-half;
        font-size: 12px;
        font-weight: 600;
        vertical-alignment: center;
        overflow: elide;
    }

    Text {
        x: parent.width - 154px;
        y: 41px;
        width: 104px;
        height: 20px;
        text: root.installed-label;
        color: Palette.muted-half;
        font-size: 11px;
        font-weight: 600;
        horizontal-alignment: right;
        vertical-alignment: center;
        overflow: elide;
    }

    GhostIconButton {
        x: parent.width - 40px;
        y: 22px;
        width: 28px;
        height: 28px;
        icon: @image-url("../assets/icons/x.svg");
        clicked => { root.remove(); }
    }

    touch := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width - 48px;
        height: parent.height;
        clicked => { root.open-detail(); }
    }
}

component PackHubTypeCard inherits Rectangle {
    in property <string> title;
    in property <string> description;
    in property <color> tone: Palette.gold;
    in property <bool> active: false;
    callback clicked;
    height: 58px;
    border-radius: 11px;
    border-width: 1px;
    border-color: root.active ? Palette.gold-20 : (touch.has-hover ? Palette.white-10 : Palette.white-06);
    background: root.active ? Palette.gold-10 : (touch.has-hover ? Palette.white-06 : Palette.white-03);

    animate background, border-color { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    Rectangle {
        visible: root.active;
        x: 1px;
        y: 1px;
        width: parent.width - 2px;
        height: parent.height - 2px;
        border-radius: 10px;
        border-width: 0px;
        background: Tokens.surface-66;
    }

    Pill {
        x: 12px;
        y: 10px;
        label: root.title;
        tone: root.tone;
        fill: root.active ? Palette.gold-10 : Palette.white-04;
        pill-height: 24px;
        label-font-size: 12px;
    }

    Text {
        x: 12px;
        y: 34px;
        width: parent.width - 24px;
        text: root.description;
        color: Palette.muted-half;
        font-size: 11px;
        font-weight: 600;
        overflow: elide;
    }

    Image {
        visible: root.active;
        x: parent.width - 26px;
        y: 12px;
        width: 14px;
        height: 14px;
        source: @image-url("../assets/icons/check.svg");
        image-fit: contain;
        colorize: Palette.gold;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component PackHubInstalledRow inherits Rectangle {
    in property <string> title;
    in property <string> meta;
    in property <bool> checked: true;
    callback clicked;
    height: 50px;
    border-radius: 10px;
    border-width: 1px;
    border-color: root.checked ? Palette.gold-20 : (touch.has-hover ? Palette.white-08 : Palette.white-06);
    background: touch.has-hover ? Palette.white-04 : Palette.white-02;

    animate background, border-color { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    Image {
        x: 12px;
        y: 16px;
        width: 14px;
        height: 14px;
        source: @image-url("../assets/icons/check.svg");
        image-fit: contain;
        colorize: root.checked ? Palette.gold : Palette.muted-half;
    }

    Text {
        x: 36px;
        y: 8px;
        width: parent.width - 58px;
        text: root.title;
        color: Palette.foreground;
        font-size: 13px;
        font-weight: 850;
        overflow: elide;
    }

    Text {
        x: 36px;
        y: 28px;
        width: parent.width - 58px;
        text: root.meta;
        color: Palette.muted-half;
        font-size: 11px;
        font-weight: 600;
        overflow: elide;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component PackHubSelectedCard inherits Rectangle {
    in property <string> title;
    in property <bool> optional: false;
    callback remove-clicked;
    callback required-clicked;
    callback optional-clicked;
    height: 58px;
    border-radius: 9px;
    border-width: 1px;
    border-color: Palette.white-08;
    background: Palette.white-04;

    Text {
        x: 12px;
        y: 8px;
        width: parent.width - 44px;
        text: root.title;
        color: Palette.foreground;
        font-size: 12px;
        font-weight: 850;
        overflow: elide;
    }

    GhostIconButton {
        x: parent.width - 28px;
        y: 5px;
        width: 22px;
        height: 22px;
        icon: @image-url("../assets/icons/x.svg");
        clicked => { root.remove-clicked(); }
    }

    Rectangle {
        x: 12px;
        y: 32px;
        width: (parent.width - 24px) / 2;
        height: 20px;
        border-radius: 6px;
        border-width: 1px;
        border-color: !root.optional ? Palette.gold-20 : Palette.white-06;
        background: !root.optional ? Palette.gold-15 : Palette.white-03;

        Text {
            width: parent.width;
            height: parent.height;
            text: "Required";
            color: !root.optional ? Palette.gold : Palette.muted-half;
            font-size: 10px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.required-clicked(); }
        }
    }

    Rectangle {
        x: 12px + (parent.width - 24px) / 2;
        y: 32px;
        width: (parent.width - 24px) / 2;
        height: 20px;
        border-radius: 6px;
        border-width: 1px;
        border-color: root.optional ? Palette.gold-20 : Palette.white-06;
        background: root.optional ? Palette.gold-15 : Palette.white-03;

        Text {
            width: parent.width;
            height: parent.height;
            text: "Optional";
            color: root.optional ? Palette.gold : Palette.muted-half;
            font-size: 10px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.optional-clicked(); }
        }
    }
}

component PackHubInstallRow inherits Rectangle {
    in property <string> title;
    in property <string> esoui-id;
    in property <bool> required: true;
    in property <bool> installed: false;
    in property <bool> selected: true;
    in property <bool> selection-enabled: true;
    callback selection-toggled;
    private property <bool> selectable: root.selection-enabled && !root.required && !root.installed;
    private property <bool> active-selection: root.required || root.selected || root.installed;
    height: 47px;
    border-radius: 9px;
    border-width: 1px;
    border-color: root.installed ? Palette.emerald-15 : (root.active-selection ? Palette.gold-20 : Palette.white-06);
    background: touch.has-hover && root.selectable ? Palette.white-06 : Palette.white-03;
    clip: true;

    animate background, border-color { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    Rectangle {
        x: 0px;
        y: 0px;
        width: 3px;
        height: parent.height;
        border-radius: 2px;
        border-width: 0px;
        background: root.installed ? Palette.emerald : (root.active-selection ? Palette.gold : Palette.muted-half);
    }

    Rectangle {
        x: 16px;
        y: 13px;
        width: 21px;
        height: 21px;
        border-radius: 6px;
        border-width: 1px;
        border-color: root.installed ? Palette.emerald-15 : (root.active-selection ? Palette.gold-20 : Palette.white-08);
        background: root.installed ? Palette.emerald-15 : (root.active-selection ? Palette.gold-15 : Palette.white-04);

        Image {
            x: 5px;
            y: 5px;
            width: 11px;
            height: 11px;
            source: root.active-selection ? @image-url("../assets/icons/check.svg") : @image-url("../assets/icons/package.svg");
            image-fit: contain;
            colorize: root.installed ? Palette.emerald : (root.active-selection ? Palette.gold : Palette.muted-half);
        }
    }

    Text {
        x: 52px;
        y: 0px;
        width: parent.width - 318px;
        height: parent.height;
        text: root.title;
        color: Palette.foreground;
        font-size: 13px;
        font-weight: 850;
        vertical-alignment: center;
        overflow: elide;
    }

    Text {
        x: parent.width - 248px;
        y: 0px;
        width: 70px;
        height: parent.height;
        text: root.required ? "REQUIRED" : (root.selection-enabled ? (root.selected ? "OPTIONAL" : "SKIPPED") : "OPTIONAL");
        color: root.required || root.selected ? Palette.gold : Palette.muted-half;
        font-size: 9px;
        font-weight: 900;
        vertical-alignment: center;
    }

    Text {
        visible: root.installed;
        x: parent.width - 166px;
        y: 0px;
        width: 78px;
        height: parent.height;
        text: "INSTALLED";
        color: Palette.emerald;
        font-size: 9px;
        font-weight: 900;
        vertical-alignment: center;
    }

    Text {
        x: parent.width - 86px;
        y: 0px;
        width: 70px;
        height: parent.height;
        text: root.esoui-id;
        color: Palette.muted-half;
        font-size: 12px;
        font-weight: 700;
        horizontal-alignment: right;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            if (root.selectable) {
                root.selection-toggled();
            }
        }
    }
}

component PackHubBrowseView inherits Rectangle {
    in property <[PackHubEntry]> packs;
    in-out property <string> query;
    in property <string> type-label: "All";
    in property <string> sort-label: "Votes";
    in property <bool> loading: false;
    in property <bool> has-more: false;
    in property <string> message: "";
    callback import-clicked;
    callback open-detail(int);
    callback query-edited(string);
    callback type-next;
    callback sort-next;
    callback load-more;
    callback retry;
    background: #00000000;

    PackHubButton {
        x: 0px;
        y: 0px;
        width: 82px;
        icon: @image-url("../assets/icons/clipboard-paste.svg");
        label: "Import";
        clicked => { root.import-clicked(); }
    }

    PackHubField {
        x: 0px;
        y: 52px;
        width: parent.width - 268px;
        placeholder: "Search packs...";
        focused: true;
        editable: true;
        value <=> root.query;
        edited(value) => { root.query-edited(value); }
    }

    PackHubSelectField { x: parent.width - 256px; y: 52px; width: 142px; label: root.type-label; clicked => { root.type-next(); } }
    PackHubSelectField { x: parent.width - 104px; y: 52px; width: 104px; label: root.sort-label; clicked => { root.sort-next(); } }

    if (root.packs.length == 0) : Rectangle {
        x: 0px;
        y: 102px;
        width: parent.width;
        height: 218px;
        border-radius: 12px;
        border-width: 0px;
        background: Palette.white-02;

        Text {
            x: 24px;
            y: root.message != "" && !root.loading ? 54px : 0px;
            width: parent.width - 48px;
            height: root.message != "" && !root.loading ? 30px : parent.height;
            text: root.loading ? "Loading Pack Hub packs..." : (root.message != "" ? "Could not load packs" : "No packs match this browse filter.");
            color: root.message != "" && !root.loading ? Palette.red : Palette.muted-strong;
            font-size: 14px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }

        Text {
            visible: root.message != "" && !root.loading;
            x: 42px;
            y: 88px;
            width: parent.width - 84px;
            height: 34px;
            text: root.message;
            color: Palette.muted-strong;
            font-size: 12px;
            font-weight: 600;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        PackHubButton {
            visible: root.message != "" && !root.loading;
            x: (parent.width - 92px) / 2;
            y: 146px;
            width: 92px;
            icon: @image-url("../assets/icons/refresh-cw.svg");
            label: "Retry";
            clicked => { root.retry(); }
        }
    }

    if (root.packs.length > 0) : ScrollView {
        x: 0px;
        y: 102px;
        width: parent.width;
        height: parent.height - (root.has-more || root.loading ? 148px : 102px);
        viewport-width: self.width;
        viewport-height: root.packs.length * 116px;
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        Rectangle {
            width: parent.width;
            height: root.packs.length * 116px;
            background: #00000000;

            for pack[index] in root.packs : PackHubPackCard {
                x: 0px;
                y: index * 116px;
                width: parent.width;
                title: pack.title;
                description: pack.description;
                tag: pack.tag;
                addon-count: pack.addon-count;
                vote-count: pack.vote-count;
                author: pack.author;
                author-initial: pack.author-initial;
                pack-type-label: pack.pack-type-label;
                monogram: pack.monogram;
                identity-kind: pack.identity-kind;
                type-kind: pack.type-kind;
                trial: pack.trial;
                open-detail => { root.open-detail(index); }
            }
        }
    }

    if (root.packs.length > 0) : PackHubButton {
        x: 0px;
        y: parent.height - 34px;
        width: parent.width;
        visible: root.has-more || root.loading;
        icon: @image-url("../assets/icons/refresh-cw.svg");
        label: root.loading ? "Loading..." : "Load More Packs";
        disabled: root.loading;
        clicked => { root.load-more(); }
    }
}

component PackHubCreateDetailsView inherits Rectangle {
    in-out property <string> title;
    in-out property <string> description;
    in-out property <int> pack-type: 0;
    callback next;
    private property <bool> can-proceed: root.title != "";
    background: #00000000;

    Text { x: 0px; y: 0px; text: "Creating a pack"; color: Palette.muted-half; font-size: 12px; font-weight: 700; }
    Text { x: parent.width - 260px; y: 0px; width: 260px; text: "Sign in to the full Pack Hub to publish"; color: Palette.muted-half; font-size: 12px; font-weight: 600; horizontal-alignment: right; overflow: elide; }

    PackHubStep { x: 0px; y: 30px; number: "1"; label: "Details"; active: true; }
    Image { x: 82px; y: 36px; width: 12px; height: 12px; source: @image-url("../assets/icons/chevron-right.svg"); image-fit: contain; colorize: Palette.muted-half; }
    PackHubStep { x: 104px; y: 30px; number: "2"; label: "Addons"; }

    Text { x: 0px; y: 64px; width: parent.width; text: "Create an addon pack - save it locally for personal use, or publish it to the community."; color: Palette.muted-strong; font-size: 14px; font-weight: 600; overflow: elide; }
    DetailSectionTitle { x: 0px; y: 96px; width: parent.width; label: "PACK NAME *"; }
    PackHubField {
        x: 0px;
        y: 118px;
        width: parent.width;
        placeholder: "e.g. Trial Essentials, PvP Toolkit";
        search: false;
        focused: true;
        editable: true;
        value <=> root.title;
    }
    Text { x: parent.width - 74px; y: 154px; width: 74px; text: "max 100"; color: Palette.muted-half; font-size: 10px; font-weight: 600; horizontal-alignment: right; }

    DetailSectionTitle { x: 0px; y: 178px; width: parent.width; label: "DESCRIPTION"; }
    Rectangle {
        x: 0px;
        y: 200px;
        width: parent.width;
        height: 78px;
        border-radius: 10px;
        border-width: 1px;
        border-color: Palette.white-08;
        background: Palette.white-04;
        clip: true;

        Text {
            visible: root.description == "";
            x: 14px;
            y: 13px;
            width: parent.width - 28px;
            text: "What is this pack for? Who should use it?";
            color: Palette.muted-half;
            font-size: 13px;
            font-weight: 600;
        }

        TextInput {
            x: 14px;
            y: 10px;
            width: parent.width - 28px;
            height: parent.height - 20px;
            text: root.description;
            color: Palette.foreground;
            font-size: 13px;
            font-family: "Geist";
            font-weight: 600;
            wrap: word-wrap;
            selection-background-color: Palette.sky-25;
            edited => { root.description = self.text; }
        }
    }
    Text { x: parent.width - 74px; y: 282px; width: 74px; text: "max 500"; color: Palette.muted-half; font-size: 10px; font-weight: 600; horizontal-alignment: right; }

    DetailSectionTitle { x: 0px; y: 312px; width: parent.width; label: "PACK TYPE"; }
    PackHubTypeCard { x: 0px; y: 338px; width: (parent.width - 16px) / 3; title: "Addon Pack"; description: "A collection of addons"; active: root.pack-type == 0; clicked => { root.pack-type = 0; } }
    PackHubTypeCard { x: (parent.width - 16px) / 3 + 8px; y: 338px; width: (parent.width - 16px) / 3; title: "Build Pack"; description: "A skill build or loadout"; tone: Tokens.accent; active: root.pack-type == 1; clicked => { root.pack-type = 1; } }
    PackHubTypeCard { x: ((parent.width - 16px) / 3 + 8px) * 2; y: 338px; width: (parent.width - 16px) / 3; title: "Roster Pack"; description: "A group or raid roster"; tone: Palette.violet; active: root.pack-type == 2; clicked => { root.pack-type = 2; } }

    // (Tag selection isn't implemented on the create path yet — the dead chips +
    // fake "0/5" counter were removed rather than advertise a non-existent feature.)

    PackHubButton {
        x: 0px;
        y: 430px;
        width: parent.width;
        icon: @image-url("../assets/icons/chevron-right.svg");
        label: "Next: Add Addons";
        primary: true;
        disabled: !root.can-proceed;
        clicked => { root.next(); }
    }
}

component PackHubCreateAddonsView inherits Rectangle {
    in property <[PackHubCreateAddonEntry]> installed-addons;
    in property <[PackHubCreateAddonEntry]> selected-addons;
    in-out property <string> filter;
    callback back;
    callback filter-edited(string);
    callback addon-toggle(int);
    callback selected-remove(int);
    callback selected-required-toggle(int);
    callback save-to-file;
    callback open-full-pack-hub;
    private property <string> selected-count-label: root.selected-addons.length == 1 ? "1 addon selected" : root.selected-addons.length + " addons selected";
    background: #00000000;

    Text { x: 0px; y: 0px; text: "Creating a pack"; color: Palette.muted-half; font-size: 12px; font-weight: 700; }
    Text { x: parent.width - 260px; y: 0px; width: 260px; text: "Sign in to the full Pack Hub to publish"; color: Palette.muted-half; font-size: 12px; font-weight: 600; horizontal-alignment: right; overflow: elide; }

    PackHubStep { x: 0px; y: 30px; number: "1"; label: "Details"; }
    Image { x: 82px; y: 36px; width: 12px; height: 12px; source: @image-url("../assets/icons/chevron-right.svg"); image-fit: contain; colorize: Palette.muted-half; }
    PackHubStep { x: 104px; y: 30px; number: "2"; label: "Addons"; active: true; }
    Text { x: parent.width - 170px; y: 70px; width: 170px; text: root.selected-count-label; color: root.selected-addons.length > 0 ? Palette.gold : Palette.muted-half; font-size: 13px; font-weight: 900; horizontal-alignment: right; }

    Image { x: 0px; y: 70px; width: 13px; height: 13px; source: @image-url("../assets/icons/arrow-left.svg"); image-fit: contain; colorize: Palette.muted-strong; }
    Text { x: 20px; y: 66px; width: 120px; text: "Back to details"; color: Palette.muted-strong; font-size: 12px; font-weight: 700; }
    TouchArea { x: 0px; y: 60px; width: 140px; height: 28px; clicked => { root.back(); } }

    DetailSectionTitle { x: 0px; y: 104px; width: parent.width; label: "MY INSTALLED ADDONS"; }

    PackHubField {
        x: 0px;
        y: 144px;
        width: parent.width;
        placeholder: "Filter installed addons...";
        editable: true;
        value <=> root.filter;
        edited(value) => { root.filter-edited(value); }
    }

    Rectangle {
        x: 0px;
        y: 188px;
        width: parent.width - 244px;
        height: 216px;
        border-radius: 11px;
        border-width: 1px;
        border-color: Palette.white-06;
        background: @linear-gradient(180deg, Palette.white-02 0%, #00000000 100%);
        clip: true;

        if (root.installed-addons.length == 0) : Text {
            x: 18px;
            y: 30px;
            width: parent.width - 36px;
            text: root.filter == "" ? "No installed addons with ESOUI IDs were found." : "No installed addons match this filter.";
            color: Palette.muted-half;
            font-size: 12px;
            font-weight: 700;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        for addon[index] in root.installed-addons : PackHubInstalledRow {
            x: 0px;
            y: index * 54px;
            width: parent.width - 8px;
            title: addon.title;
            meta: addon.meta;
            checked: addon.selected;
            clicked => { root.addon-toggle(index); }
        }
    }

    Rectangle {
        x: parent.width - 224px;
        y: 188px;
        width: 224px;
        height: 216px;
        border-radius: 11px;
        border-width: 1px;
        border-color: Palette.white-06;
        background: Palette.white-02;
        clip: true;

        DetailSectionTitle { x: 12px; y: 0px; width: parent.width - 24px; label: "SELECTED (" + root.selected-addons.length + ")"; }

        if (root.selected-addons.length == 0) : Text {
            x: 18px;
            y: 44px;
            width: parent.width - 36px;
            text: "Pick installed addons from the left to build this pack.";
            color: Palette.muted-half;
            font-size: 11px;
            font-weight: 700;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        for addon[index] in root.selected-addons : PackHubSelectedCard {
            x: 12px;
            y: 30px + index * 64px;
            width: parent.width - 24px;
            title: addon.title;
            optional: !addon.required;
            remove-clicked => { root.selected-remove(index); }
            required-clicked => { root.selected-required-toggle(index); }
            optional-clicked => { root.selected-required-toggle(index); }
        }
    }

    PackHubButton { x: 0px; y: 420px; width: parent.width; icon: @image-url("../assets/icons/save.svg"); label: "Save .esopack File"; disabled: root.selected-addons.length == 0; clicked => { root.save-to-file(); } }
    Hairline { x: 0px; y: 462px; width: parent.width; height: 1px; opacity: 0.35; }
    Text {
        x: 0px;
        y: 482px;
        width: parent.width;
        height: 34px;
        text: "Drafts and publishing use your Pack Hub account, so they open in the full Hub for now.";
        color: Palette.muted-half;
        font-size: 12px;
        font-weight: 600;
        horizontal-alignment: center;
        wrap: word-wrap;
    }
    PackHubButton {
        x: 0px;
        y: 524px;
        width: parent.width;
        icon: @image-url("../assets/icons/external-link.svg");
        label: "Open Full Hub to Publish";
        primary: true;
        clicked => { root.open-full-pack-hub(); }
    }
}

component PackHubInstallView inherits Rectangle {
    in property <PackHubEntry> pack;
    in property <[PackHubAddonEntry]> addons;
    in property <bool> loading: false;
    in property <string> message: "";
    in property <bool> sharing: false;
    in property <string> share-status: "";
    callback back;
    callback edit-requested;
    callback share-requested;
    callback addon-selection-toggle(int);
    background: #00000000;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width - 24px;
        height: 34px;
        text: root.pack.description;
        color: Palette.muted-strong;
        font-size: 14px;
        font-weight: 600;
        wrap: word-wrap;
        overflow: elide;
    }

    Pill { x: 0px; y: 40px; label: root.pack.pack-type-label; tone: Palette.muted-strong; fill: Palette.white-04; pill-height: 24px; }
    Pill { x: 108px; y: 40px; label: root.pack.tag; tone: root.pack.trial ? Palette.red : Palette.muted-strong; fill: Palette.white-04; pill-height: 24px; }
    Text { x: 190px; y: 44px; width: 132px; text: "by " + root.pack.author; color: Palette.muted-half; font-size: 11px; font-weight: 600; overflow: elide; }
    Text { x: 330px; y: 44px; width: 150px; text: root.pack.updated-label; color: Palette.muted-half; font-size: 10px; font-weight: 600; overflow: elide; }
    PackHubButton { x: parent.width - 216px; y: 36px; width: 104px; icon: @image-url("../assets/icons/external-link.svg"); label: "Manage"; clicked => { root.edit-requested(); } }
    PackHubButton { x: parent.width - 100px; y: 36px; width: 100px; icon: @image-url("../assets/icons/copy.svg"); label: root.sharing ? "Sharing" : "Share"; disabled: root.sharing || root.addons.length == 0; clicked => { root.share-requested(); } }

    if (root.share-status != "") : Rectangle {
        x: parent.width - 322px;
        y: 72px;
        width: 322px;
        height: 28px;
        border-radius: 8px;
        border-width: 1px;
        border-color: Palette.gold-20;
        background: Palette.gold-04;

        Text {
            x: 10px;
            y: 0px;
            width: parent.width - 20px;
            height: parent.height;
            text: root.share-status;
            color: Palette.gold;
            font-size: 11px;
            font-weight: 750;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    Rectangle {
        x: 0px;
        y: 82px;
        width: 54px;
        height: 34px;
        border-radius: 17px;
        border-width: 0px;
        background: Palette.white-03;

        Image { x: 13px; y: 10px; width: 13px; height: 13px; source: @image-url("../assets/icons/arrow-left.svg"); transform-rotation: 90deg; image-fit: contain; colorize: Palette.muted-half; }
        Text { x: 31px; y: 9px; text: root.pack.vote-count; color: Palette.muted-half; font-size: 13px; font-weight: 800; }
    }

    DetailSectionTitle { x: 0px; y: 112px; width: parent.width; label: "ADDONS"; }
    Text { x: parent.width - 176px; y: 112px; width: 176px; text: root.pack.addon-count; color: Palette.gold; font-size: 10px; font-weight: 800; horizontal-alignment: right; }

    if (root.addons.length == 0) : Rectangle {
        x: 0px;
        y: 142px;
        width: parent.width;
        height: 188px;
        border-radius: 12px;
        border-width: 0px;
        background: Palette.white-02;

        Text {
            x: 24px;
            y: 0px;
            width: parent.width - 48px;
            height: parent.height;
            text: root.loading ? "Loading pack details..." : root.message;
            color: Palette.muted-strong;
            font-size: 13px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
            wrap: word-wrap;
        }
    }

    if (root.addons.length > 0) : ScrollView {
        x: 0px;
        y: 142px;
        width: parent.width;
        height: parent.height - 142px;
        viewport-width: self.width;
        viewport-height: root.addons.length * 48px;
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        Rectangle {
            width: parent.width;
            height: root.addons.length * 48px;
            background: #00000000;

            for addon[index] in root.addons : PackHubInstallRow {
                x: 0px;
                y: index * 48px;
                width: parent.width;
                title: addon.title;
                esoui-id: addon.esoui-id;
                required: addon.required;
                installed: addon.installed;
                selected: addon.selected;
                selection-toggled => { root.addon-selection-toggle(index); }
            }
        }
    }
}

component PackHubImportView inherits Rectangle {
    in-out property <string> share-code;
    in-out property <string> file-path;
    in property <PackHubEntry> pack;
    in property <[PackHubAddonEntry]> addons;
    in property <bool> loading: false;
    in property <bool> has-settings: false;
    in property <string> message: "";
    in property <string> install-label: "Install Addons";
    private property <length> addons-title-y: root.has-settings ? 132px : 106px;
    private property <length> addon-list-y: root.addons-title-y + 30px;
    callback back;
    callback share-code-edited(string);
    callback file-path-edited(string);
    callback resolve-share-code;
    callback import-file;
    callback clear-import;
    callback install-import;
    callback addon-selection-toggle(int);
    background: #00000000;

    if (root.addons.length == 0) : Rectangle {
        width: parent.width;
        height: parent.height;
        background: #00000000;

        Rectangle {
            x: (parent.width - 54px) / 2;
            y: 8px;
            width: 54px;
            height: 54px;
            border-radius: 14px;
            border-width: 0px;
            background: Palette.white-04;

            Image {
                x: 16px;
                y: 16px;
                width: 22px;
                height: 22px;
                source: @image-url("../assets/icons/clipboard-paste.svg");
                image-fit: contain;
                colorize: Palette.gold;
            }
        }

        Text {
            x: 48px;
            y: 78px;
            width: parent.width - 96px;
            text: "Import a shared pack";
            color: Palette.foreground;
            font-size: 16px;
            font-weight: 900;
            horizontal-alignment: center;
        }

        Text {
            x: 62px;
            y: 104px;
            width: parent.width - 124px;
            text: "Enter a six-character Kalpa share code to preview and install the required addons.";
            color: Palette.muted-half;
            font-size: 12px;
            font-weight: 600;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        Rectangle {
            x: 42px;
            y: 154px;
            width: parent.width - 84px;
            height: 74px;
            border-radius: 12px;
            border-width: 0px;
            background: Palette.white-02;

            PackHubField {
                x: 14px;
                y: 19px;
                width: parent.width - 112px;
                placeholder: "HK7M3P";
                search: false;
                focused: true;
                editable: true;
                value <=> root.share-code;
                edited(value) => { root.share-code-edited(value); }
            }

            PackHubButton {
                x: parent.width - 88px;
                y: 21px;
                width: 74px;
                icon: @image-url("../assets/icons/search.svg");
                label: root.loading ? "Wait" : "Find";
                disabled: root.loading || root.share-code == "";
                clicked => { root.resolve-share-code(); }
            }
        }

        Text {
            x: 42px;
            y: 242px;
            width: parent.width - 84px;
            text: "or import a .esopack file";
            color: Palette.muted-half;
            font-size: 11px;
            font-weight: 800;
            horizontal-alignment: center;
        }

        Rectangle {
            x: 42px;
            y: 264px;
            width: parent.width - 84px;
            height: 74px;
            border-radius: 12px;
            border-width: 0px;
            background: Palette.white-02;

            PackHubField {
                x: 14px;
                y: 19px;
                width: parent.width - 128px;
                placeholder: "C:\\path\\pack.esopack";
                search: false;
                editable: true;
                value <=> root.file-path;
                edited(value) => { root.file-path-edited(value); }
            }

            PackHubButton {
                x: parent.width - 106px;
                y: 21px;
                width: 92px;
                icon: @image-url("../assets/icons/file-text.svg");
                label: "Import";
                disabled: root.loading || root.file-path == "";
                clicked => { root.import-file(); }
            }
        }

        if (root.message != "") : Rectangle {
            x: 42px;
            y: 350px;
            width: parent.width - 84px;
            height: 56px;
            border-radius: 12px;
            border-width: 0px;
            background: root.loading ? Palette.gold-04 : Palette.red-04;

            Image {
                x: 16px;
                y: 20px;
                width: 16px;
                height: 16px;
                source: root.loading ? @image-url("../assets/icons/refresh-cw.svg") : @image-url("../assets/icons/triangle-alert.svg");
                image-fit: contain;
                colorize: root.loading ? Palette.gold : Palette.red;
            }

            Text {
                x: 44px;
                y: 0px;
                width: parent.width - 60px;
                height: parent.height;
                text: root.message;
                color: root.loading ? Palette.gold : Palette.red;
                font-size: 12px;
                font-weight: 700;
                vertical-alignment: center;
                wrap: word-wrap;
            }
        }

        PackHubButton {
            x: 42px;
            y: parent.height - 44px;
            width: 78px;
            icon: @image-url("../assets/icons/arrow-left.svg");
            label: "Back";
            clicked => { root.back(); }
        }
    }

    if (root.addons.length > 0) : Rectangle {
        width: parent.width;
        height: parent.height;
        background: #00000000;

        Text {
            x: 0px;
            y: 0px;
            width: parent.width - 96px;
            text: root.pack.title;
            color: Palette.foreground;
            font-size: 15px;
            font-weight: 900;
            overflow: elide;
        }

        PackHubButton {
            x: parent.width - 78px;
            y: -4px;
            width: 78px;
            icon: @image-url("../assets/icons/x.svg");
            label: "Clear";
            clicked => { root.clear-import(); }
        }

        Text {
            x: 0px;
            y: 28px;
            width: parent.width;
            height: 30px;
            text: root.pack.description;
            color: Palette.muted-strong;
            font-size: 13px;
            font-weight: 600;
            wrap: word-wrap;
            overflow: elide;
        }

        Pill { x: 0px; y: 62px; label: root.pack.pack-type-label; tone: Palette.muted-strong; fill: Palette.white-04; pill-height: 24px; }
        Pill { x: 108px; y: 62px; label: root.pack.tag; tone: root.pack.trial ? Palette.red : Palette.muted-strong; fill: Palette.white-04; pill-height: 24px; }
        Text { x: 190px; y: 66px; width: parent.width - 190px; text: "shared by " + root.pack.author + " - " + root.pack.updated-label; color: Palette.muted-half; font-size: 11px; font-weight: 600; overflow: elide; }

        if (root.has-settings) : Rectangle {
            x: 0px;
            y: 94px;
            width: parent.width;
            height: 28px;
            border-radius: 9px;
            border-width: 0px;
            background: Palette.gold-04;

            Text {
                x: 12px;
                y: 0px;
                width: parent.width - 24px;
                height: parent.height;
                text: "Includes SavedVariables settings";
                color: Palette.gold;
                font-size: 11px;
                font-weight: 800;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        DetailSectionTitle { x: 0px; y: root.addons-title-y; width: parent.width; label: "ADDONS"; }
        Text { x: parent.width - 176px; y: root.addons-title-y; width: 176px; text: root.pack.addon-count; color: Palette.gold; font-size: 10px; font-weight: 800; horizontal-alignment: right; }

        ScrollView {
            x: 0px;
            y: root.addon-list-y;
            width: parent.width;
            height: parent.height - root.addon-list-y - 58px;
            viewport-width: self.width;
            viewport-height: root.addons.length * 48px;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            Rectangle {
                width: parent.width;
                height: root.addons.length * 48px;
                background: #00000000;

                for addon[index] in root.addons : PackHubInstallRow {
                    x: 0px;
                    y: index * 48px;
                    width: parent.width;
                    title: addon.title;
                    esoui-id: addon.esoui-id;
                    required: addon.required;
                    installed: addon.installed;
                    selected: addon.selected;
                    selection-enabled: false;
                    selection-toggled => { root.addon-selection-toggle(index); }
                }
            }
        }

        PackHubButton {
            x: 0px;
            y: parent.height - 38px;
            width: 78px;
            icon: @image-url("../assets/icons/arrow-left.svg");
            label: "Back";
            clicked => { root.back(); }
        }

        PackHubButton {
            x: parent.width - 208px;
            y: parent.height - 38px;
            width: 208px;
            icon: @image-url("../assets/icons/cloud-upload.svg");
            label: root.install-label;
            primary: true;
            disabled: root.loading || root.install-label == "All Addons Installed" || root.install-label == "Select Addons to Install";
            clicked => { root.install-import(); }
        }
    }
}

component PackHubMyPacksView inherits Rectangle {
    in property <[PackHubInstalledPackEntry]> installed-packs;
    in-out property <int> tab: 1;
    callback open-installed(int);
    callback remove-installed(int);
    callback open-full-pack-hub;
    background: #00000000;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width - 134px;
        text: "My Packs";
        color: Palette.foreground;
        font-size: 20px;
        font-weight: 950;
    }

    Text {
        x: 0px;
        y: 30px;
        width: parent.width - 134px;
        height: 34px;
        text: root.tab == 1 ? "Installed pack references are stored locally and match the WebView library." : "Created packs still require the account-backed Pack Hub session.";
        color: Palette.muted-strong;
        font-size: 12px;
        font-weight: 600;
        wrap: word-wrap;
    }

    PackHubButton {
        x: parent.width - 124px;
        y: 4px;
        width: 124px;
        icon: @image-url("../assets/icons/external-link.svg");
        label: "Full Hub";
        clicked => { root.open-full-pack-hub(); }
    }

    Rectangle {
        x: 0px;
        y: 76px;
        width: parent.width;
        height: 36px;
        border-radius: 10px;
        border-width: 0px;
        background: Palette.white-03;

        PackHubTabButton {
            x: 4px;
            y: 4px;
            width: (parent.width - 8px) / 2;
            label: "Created";
            active: root.tab == 0;
            clicked => { root.tab = 0; }
        }

        PackHubTabButton {
            x: 4px + (parent.width - 8px) / 2;
            y: 4px;
            width: (parent.width - 8px) / 2;
            label: "Installed";
            active: root.tab == 1;
            clicked => { root.tab = 1; }
        }
    }

    if (root.tab == 0) : Rectangle {
        x: 0px;
        y: 130px;
        width: parent.width;
        height: parent.height - 130px;
        border-radius: 12px;
        border-width: 1px;
        border-color: Palette.border;
        background: Palette.white-03;

        Rectangle {
            x: (parent.width - 44px) / 2;
            y: 58px;
            width: 44px;
            height: 44px;
            border-radius: 12px;
            border-width: 1px;
            border-color: Palette.gold-20;
            background: Palette.gold-04;

            Image {
                x: 11px;
                y: 11px;
                width: 22px;
                height: 22px;
                source: @image-url("../assets/icons/copy-plus.svg");
                image-fit: contain;
                colorize: Palette.gold;
            }
        }

        Text {
            x: 24px;
            y: 118px;
            width: parent.width - 48px;
            text: "Created packs need the signed-in Pack Hub session.";
            color: Palette.foreground;
            font-size: 14px;
            font-weight: 900;
            horizontal-alignment: center;
        }

        Text {
            x: 80px;
            y: 144px;
            width: parent.width - 160px;
            height: 34px;
            text: "Open the full Hub for edit, delete, publish, share codes, and private draft management.";
            color: Palette.muted-half;
            font-size: 12px;
            font-weight: 600;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        PackHubButton {
            x: (parent.width - 142px) / 2;
            y: 198px;
            width: 142px;
            icon: @image-url("../assets/icons/external-link.svg");
            label: "Open Full Hub";
            primary: true;
            clicked => { root.open-full-pack-hub(); }
        }
    }

    if (root.tab == 1 && root.installed-packs.length == 0) : Rectangle {
        x: 0px;
        y: 130px;
        width: parent.width;
        height: parent.height - 130px;
        border-radius: 12px;
        border-width: 1px;
        border-color: Palette.border;
        background: Palette.white-03;

        Rectangle {
            x: (parent.width - 44px) / 2;
            y: 64px;
            width: 44px;
            height: 44px;
            border-radius: 12px;
            border-width: 1px;
            border-color: Palette.sky-04;
            background: Palette.sky-04;

            Image {
                x: 11px;
                y: 11px;
                width: 22px;
                height: 22px;
                source: @image-url("../assets/icons/cloud-upload.svg");
                image-fit: contain;
                colorize: Palette.sky;
            }
        }

        Text {
            x: 24px;
            y: 124px;
            width: parent.width - 48px;
            text: "No installed packs yet";
            color: Palette.foreground;
            font-size: 14px;
            font-weight: 900;
            horizontal-alignment: center;
        }

        Text {
            x: 88px;
            y: 150px;
            width: parent.width - 176px;
            height: 34px;
            text: "Packs installed from Browse will appear here for quick reference.";
            color: Palette.muted-half;
            font-size: 12px;
            font-weight: 600;
            horizontal-alignment: center;
            wrap: word-wrap;
        }
    }

    if (root.tab == 1 && root.installed-packs.length > 0) : ScrollView {
        x: 0px;
        y: 130px;
        width: parent.width;
        height: parent.height - 130px;
        viewport-width: self.width;
        viewport-height: root.installed-packs.length * 84px;

        for pack[index] in root.installed-packs : PackHubInstalledPackCard {
            x: 0px;
            y: index * 84px;
            width: parent.width;
            pack-id: pack.pack-id;
            title: pack.title;
            pack-type-label: pack.pack-type-label;
            author: pack.author;
            addon-count: pack.addon-count;
            installed-label: pack.installed-label;
            monogram: pack.monogram;
            identity-kind: pack.identity-kind;
            type-kind: pack.type-kind;
            open-detail => { root.open-installed(index); }
            remove => { root.remove-installed(index); }
        }
    }
}

component PackHubOverlay inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <int> view: 0;
    in property <[PackHubEntry]> packs;
    in property <[PackHubAddonEntry]> detail-addons;
    in property <PackHubEntry> import-pack;
    in property <[PackHubAddonEntry]> import-addons;
    in property <[PackHubInstalledPackEntry]> installed-packs;
    in property <[PackHubCreateAddonEntry]> create-installed-addons;
    in property <[PackHubCreateAddonEntry]> create-selected-addons;
    in-out property <string> browse-query;
    in-out property <string> import-share-code;
    in-out property <string> import-file-path;
    in-out property <string> create-title;
    in-out property <string> create-description;
    in-out property <int> create-pack-type: 0;
    in-out property <string> create-filter;
    in property <string> browse-type-label: "All";
    in property <string> browse-sort-label: "Votes";
    in property <bool> browse-loading: false;
    in property <bool> browse-has-more: false;
    in property <string> browse-message: "";
    in property <bool> detail-loading: false;
    in property <string> detail-message: "";
    in property <bool> detail-sharing: false;
    in property <string> detail-share-status: "";
    in property <bool> signed-in: false;
    in property <string> pack-user: "";
    in property <bool> detail-delete-armed: false;
    in property <bool> detail-busy: false;
    in property <string> install-label: "Install Addons";
    in property <bool> import-loading: false;
    in property <bool> import-has-settings: false;
    in property <string> import-message: "";
    in property <string> import-install-label: "Install Addons";
    in-out property <int> selected-pack-index: 0;
    in-out property <int> my-packs-tab: 1;
    callback open-detail(int);
    callback open-installed-pack(int);
    callback remove-installed-pack(int);
    callback open-full-pack-hub;
    callback browse-query-edited(string);
    callback browse-type-next;
    callback browse-sort-next;
    callback browse-load-more;
    callback browse-retry;
    callback import-share-code-edited(string);
    callback import-file-path-edited(string);
    callback import-resolve-share-code;
    callback import-file;
    callback import-clear;
    callback import-addon-selection-toggle(int);
    callback import-install;
    callback create-filter-edited(string);
    callback create-addon-toggle(int);
    callback create-selected-remove(int);
    callback create-selected-required-toggle(int);
    callback create-save-to-file;
    callback detail-addon-selection-toggle(int);
    callback install-detail;
    callback manage-pack-detail;
    callback share-pack-detail;
    callback sign-in;
    callback sign-out;
    callback vote-detail;
    callback delete-detail;
    visible: root.open;
    background: #000000c4;
    private property <length> modal-width: root.width < 760px ? root.width - 48px : 674px;
    private property <length> modal-height: root.view == 0 ? 536px : (root.view == 3 ? 560px : (root.view == 5 ? 584px : min(root.height - 48px, 724px)));

    TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            root.open = false;
        }
    }

    panel := Rectangle {
        width: root.modal-width;
        height: root.modal-height;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        border-radius: 16px;
        border-width: 1px;
        border-color: Palette.border-strong;
        background: Tokens.surface;
        drop-shadow-blur: 30px;
        drop-shadow-offset-y: 12px;
        drop-shadow-color: #00000099;
        clip: true;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { }
        }

        if (root.view != 3) : Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000000;

            Image { x: 24px; y: 22px; width: 16px; height: 16px; source: @image-url("../assets/icons/package.svg"); image-fit: contain; colorize: Palette.gold; }
            Text { x: 50px; y: 18px; width: parent.width - 100px; text: "Pack Hub"; color: Palette.gold; font-size: 16px; font-weight: 900; }
            GhostIconButton {
                x: parent.width - 44px;
                y: 14px;
                icon: @image-url("../assets/icons/x.svg");
                clicked => {
                    root.open = false;
                }
            }

            Rectangle {
                x: 24px;
                y: 66px;
                width: parent.width - 48px;
                height: 36px;
                border-radius: 10px;
                border-width: 0px;
                background: Palette.white-03;

                PackHubTabButton { x: 4px; y: 4px; width: (parent.width - 8px) / 3; label: "Browse"; active: root.view == 0 || root.view == 5; clicked => { root.view = 0; } }
                PackHubTabButton { x: 4px + (parent.width - 8px) / 3; y: 4px; width: (parent.width - 8px) / 3; label: "My Packs"; active: root.view == 4; clicked => { root.view = 4; } }
                PackHubTabButton { x: 4px + ((parent.width - 8px) / 3) * 2; y: 4px; width: (parent.width - 8px) / 3; label: "Create"; active: root.view == 1 || root.view == 2; clicked => { root.view = 1; } }
            }

            Hairline { x: 0px; y: 118px; width: parent.width; height: 1px; opacity: 0.45; }

            if (root.view == 0) : PackHubBrowseView {
                x: 24px;
                y: 142px;
                width: parent.width - 48px;
                height: parent.height - 212px;
                packs: root.packs;
                query <=> root.browse-query;
                type-label: root.browse-type-label;
                sort-label: root.browse-sort-label;
                loading: root.browse-loading;
                has-more: root.browse-has-more;
                message: root.browse-message;
                import-clicked => { root.view = 5; }
                open-detail(index) => {
                    root.selected-pack-index = index;
                    root.view = 3;
                    root.open-detail(index);
                }
                query-edited(value) => { root.browse-query-edited(value); }
                type-next => { root.browse-type-next(); }
                sort-next => { root.browse-sort-next(); }
                load-more => { root.browse-load-more(); }
                retry => { root.browse-retry(); }
            }

            if (root.view == 5) : PackHubImportView {
                x: 24px;
                y: 142px;
                width: parent.width - 48px;
                height: parent.height - 166px;
                share-code <=> root.import-share-code;
                file-path <=> root.import-file-path;
                pack: root.import-pack;
                addons: root.import-addons;
                loading: root.import-loading;
                has-settings: root.import-has-settings;
                message: root.import-message;
                install-label: root.import-install-label;
                back => { root.view = 0; }
                share-code-edited(value) => { root.import-share-code-edited(value); }
                file-path-edited(value) => { root.import-file-path-edited(value); }
                resolve-share-code => { root.import-resolve-share-code(); }
                import-file => { root.import-file(); }
                clear-import => { root.import-clear(); }
                addon-selection-toggle(index) => { root.import-addon-selection-toggle(index); }
                install-import => { root.import-install(); }
            }

            if (root.view == 4) : PackHubMyPacksView {
                x: 24px;
                y: 142px;
                width: parent.width - 48px;
                height: parent.height - 212px;
                installed-packs: root.installed-packs;
                tab <=> root.my-packs-tab;
                open-installed(index) => { root.open-installed-pack(index); }
                remove-installed(index) => { root.remove-installed-pack(index); }
                open-full-pack-hub => { root.open-full-pack-hub(); }
            }

            if (root.view == 1) : PackHubCreateDetailsView {
                x: 24px;
                y: 126px;
                width: parent.width - 48px;
                height: parent.height - 214px;
                title <=> root.create-title;
                description <=> root.create-description;
                pack-type <=> root.create-pack-type;
                next => { root.view = 2; }
            }

            if (root.view == 2) : PackHubCreateAddonsView {
                x: 24px;
                y: 126px;
                width: parent.width - 48px;
                height: parent.height - 214px;
                installed-addons: root.create-installed-addons;
                selected-addons: root.create-selected-addons;
                filter <=> root.create-filter;
                back => { root.view = 1; }
                filter-edited(value) => { root.create-filter-edited(value); }
                addon-toggle(index) => { root.create-addon-toggle(index); }
                selected-remove(index) => { root.create-selected-remove(index); }
                selected-required-toggle(index) => { root.create-selected-required-toggle(index); }
                save-to-file => { root.create-save-to-file(); }
                open-full-pack-hub => { root.open-full-pack-hub(); }
            }

            Rectangle {
                x: 0px;
                y: parent.height - 64px;
                width: parent.width;
                height: 64px;
                background: @linear-gradient(0deg, Tokens.surface 0%, Tokens.surface-84 70%, #00000000 100%);

                PackHubButton {
                    x: parent.width - 94px;
                    y: 20px;
                    width: 70px;
                    icon: @image-url("../assets/icons/x.svg");
                    label: "Close";
                    show-icon: false;
                    clicked => {
                        root.open = false;
                    }
                }
            }
        }

        if (root.view == 3) : Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000000;

            GhostIconButton { x: 24px; y: 16px; icon: @image-url("../assets/icons/arrow-left.svg"); clicked => { root.view = 0; } }
            Image { x: 62px; y: 22px; width: 16px; height: 16px; source: @image-url("../assets/icons/package.svg"); image-fit: contain; colorize: Palette.gold; }
            Text { x: 88px; y: 18px; width: parent.width - 148px; text: root.packs[root.selected-pack-index].title; color: Palette.gold; font-size: 16px; font-weight: 900; overflow: elide; }
            GhostIconButton {
                x: parent.width - 44px;
                y: 14px;
                icon: @image-url("../assets/icons/x.svg");
                clicked => {
                    root.open = false;
                }
            }
            Hairline { x: 0px; y: 64px; width: parent.width; height: 1px; opacity: 0.45; }

            PackHubInstallView {
                x: 24px;
                y: 88px;
                width: parent.width - 48px;
                height: parent.height - 164px;
                pack: root.packs[root.selected-pack-index];
                addons: root.detail-addons;
                loading: root.detail-loading;
                message: root.detail-message != "" ? root.detail-message : "No addons are listed for this pack.";
                sharing: root.detail-sharing;
                share-status: root.detail-share-status;
                back => { root.view = 0; }
                edit-requested => { root.manage-pack-detail(); }
                share-requested => { root.share-pack-detail(); }
                addon-selection-toggle(index) => { root.detail-addon-selection-toggle(index); }
            }

            Rectangle {
                x: 0px;
                y: parent.height - 64px;
                width: parent.width;
                height: 64px;
                background: @linear-gradient(0deg, Tokens.surface 0%, Tokens.surface-84 70%, #00000000 100%);

                // No footer "Back" — the header already has a back arrow (top-left).
                // Removing it keeps the destructive "Confirm delete" control from
                // overlapping (and stealing clicks from) a cancel-intent Back button.

                // Signed-in status / sign-in-out on the left of the footer. Width is
                // capped + elided so a long ESO Logs display name can't overrun Upvote.
                SmallAction {
                    x: 20px;
                    y: 22px;
                    width: 196px;
                    label: root.signed-in ? ("Signed in: " + root.pack-user) : "Sign in to manage";
                    tone: root.signed-in ? Palette.emerald : Palette.sky;
                    fill: root.signed-in ? Palette.emerald-04 : Palette.sky-10;
                    fill-hover: root.signed-in ? Palette.emerald-20 : Palette.sky-16;
                    fill-pressed: root.signed-in ? Palette.emerald-20 : Palette.sky-22;
                    clicked => { if (root.signed-in) { root.sign-out(); } else { root.sign-in(); } }
                }

                // Vote (needs sign-in) + owner delete (armed → confirm).
                SmallAction {
                    x: 230px;
                    y: 22px;
                    label: "Upvote";
                    tone: Palette.gold;
                    fill: Palette.gold-04;
                    fill-hover: Palette.gold-20;
                    fill-pressed: Palette.gold-20;
                    clicked => { root.vote-detail(); }
                }

                if (root.signed-in) : SmallAction {
                    x: 316px;
                    y: 22px;
                    label: root.detail-busy ? "Deleting..." : (root.detail-delete-armed ? "Confirm delete" : "Delete");
                    tone: Palette.red;
                    fill: Palette.red-04;
                    fill-hover: Palette.red-20;
                    fill-pressed: Palette.red-20;
                    line: Palette.red-25;
                    clicked => { root.delete-detail(); }
                }

                PackHubButton { x: parent.width - 218px; y: 18px; width: 194px; icon: @image-url("../assets/icons/cloud-upload.svg"); label: root.install-label; primary: true; disabled: root.detail-addons.length == 0 || root.install-label == "All Addons Installed" || root.install-label == "Select Addons to Install"; clicked => { root.install-detail(); } }
            }
        }
    }
}

component BackupStatusCard inherits Rectangle {
    in property <string> title: "Your settings are protected";
    in property <string> subtitle: "Last backup 3 days ago - 40 files - 13.2 MB";
    in property <int> status-kind: 2;
    private property <color> tone: root.status-kind == 0 ? Palette.amber : (root.status-kind == 1 ? Palette.gold : Palette.emerald);
    private property <color> fill: root.status-kind == 0 ? Palette.amber-04 : (root.status-kind == 1 ? Palette.gold-04 : Palette.emerald-04);
    private property <color> line: root.status-kind == 0 ? Palette.amber-25 : (root.status-kind == 1 ? Palette.gold-20 : Palette.emerald-20);
    height: 66px;
    border-radius: 14px;
    border-width: 0px;
    background: root.fill;

    Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: parent.border-radius;
        border-width: 1px;
        border-color: root.line;
        background: #00000000;
    }

    Rectangle {
        x: 22px;
        y: 20px;
        width: 26px;
        height: 26px;
        border-radius: 8px;
        background: root.status-kind == 2 ? Palette.emerald-15 : (root.status-kind == 1 ? Palette.gold-15 : Palette.amber-04);

        Image {
            x: 6px;
            y: 6px;
            width: 14px;
            height: 14px;
            source: root.status-kind == 0 ? @image-url("../assets/icons/triangle-alert.svg") : (root.status-kind == 1 ? @image-url("../assets/icons/refresh-cw.svg") : @image-url("../assets/icons/check.svg"));
            image-fit: contain;
            colorize: root.tone;
        }
    }

    Text {
        x: 64px;
        y: 14px;
        width: parent.width - 86px;
        text: root.title;
        color: Palette.foreground;
        font-size: 17px;
        font-weight: 900;
        overflow: elide;
    }

    Text {
        x: 64px;
        y: 38px;
        width: parent.width - 86px;
        text: root.subtitle;
        color: Palette.muted-strong;
        font-size: 14px;
        font-weight: 600;
        overflow: elide;
    }
}

component BackupListRow inherits Rectangle {
    in property <string> title;
    in property <string> meta;
    in property <string> kind-label: "Manual";
    in property <int> kind: 0;
    in property <bool> latest: false;
    in property <bool> restorable: true;
    in property <bool> confirming-delete: false;
    callback restore-clicked;
    callback delete-clicked;
    callback delete-confirmed;
    callback delete-cancelled;
    height: 76px;
    border-radius: 13px;
    border-width: 0px;
    background: root.kind == 1 ? Palette.violet-04 : Palette.white-03;

    title-text := Text {
        x: 16px;
        y: 15px;
        width: 238px;
        text: root.title;
        color: Palette.foreground;
        font-size: 16px;
        font-weight: 900;
        overflow: elide;
    }

    Pill {
        x: 270px;
        y: 13px;
        label: root.kind-label;
        tone: root.kind == 2 ? Palette.sky : (root.kind == 1 ? Palette.violet : Palette.muted-strong);
        fill: root.kind == 2 ? Palette.sky-10 : (root.kind == 1 ? Palette.violet-04 : Palette.white-04);
        pill-height: 26px;
        label-font-size: 13px;
    }

    Pill {
        visible: root.latest;
        x: 378px;
        y: 13px;
        label: "Latest";
        tone: Palette.emerald;
        fill: Palette.emerald-04;
        pill-height: 26px;
        label-font-size: 13px;
    }

    Image {
        x: 16px;
        y: 48px;
        width: 13px;
        height: 13px;
        source: @image-url("../assets/icons/refresh-cw.svg");
        image-fit: contain;
        colorize: Palette.muted-strong;
    }

    Text {
        x: 36px;
        y: 43px;
        width: parent.width - 236px;
        text: root.meta;
        color: Palette.muted-strong;
        font-size: 13px;
        font-weight: 600;
        overflow: elide;
    }

    if (!root.confirming-delete) : PackHubButton {
        x: parent.width - 170px;
        y: 22px;
        width: 112px;
        icon: @image-url("../assets/icons/undo-2.svg");
        label: "Restore";
        primary: true;
        disabled: !root.restorable;
        clicked => { root.restore-clicked(); }
    }

    if (!root.confirming-delete) : GhostIconButton {
        x: parent.width - 42px;
        y: 24px;
        icon: @image-url("../assets/icons/trash-2.svg");
        clicked => { root.delete-clicked(); }
    }

    if (root.confirming-delete) : Text {
        x: parent.width - 214px;
        y: 0px;
        height: parent.height;
        text: "Delete?";
        color: Palette.amber;
        font-size: 12px;
        font-weight: 900;
        vertical-alignment: center;
    }

    if (root.confirming-delete) : PackHubButton {
        x: parent.width - 152px;
        y: 22px;
        width: 58px;
        icon: @image-url("../assets/icons/trash-2.svg");
        label: "Yes";
        primary: true;
        clicked => { root.delete-confirmed(); }
    }

    if (root.confirming-delete) : PackHubButton {
        x: parent.width - 84px;
        y: 22px;
        width: 58px;
        icon: @image-url("../assets/icons/x.svg");
        label: "No";
        show-icon: false;
        clicked => { root.delete-cancelled(); }
    }
}

component BackupCreateCard inherits Rectangle {
    in property <bool> label-open: false;
    in-out property <string> label-draft;
    callback begin-label;
    callback cancel-label;
    callback create-backup(string);
    height: root.label-open ? 156px : 130px;
    border-radius: 14px;
    border-width: 0px;
    background: Palette.white-03;

    Text {
        x: 18px;
        y: 16px;
        width: parent.width - 210px;
        text: "Create a new backup";
        color: Palette.foreground;
        font-size: 17px;
        font-weight: 900;
        overflow: elide;
    }

    Text {
        x: 18px;
        y: 44px;
        width: parent.width - 260px;
        height: 42px;
        text: "Takes a snapshot of your current addon settings. Safe to do anytime.";
        color: Palette.muted-strong;
        font-size: 13px;
        font-weight: 600;
        wrap: word-wrap;
    }

    PackHubButton {
        x: parent.width - 172px;
        y: 26px;
        width: 148px;
        icon: @image-url("../assets/icons/plus.svg");
        label: "Back Up Now";
        primary: true;
        clicked => { root.create-backup(root.label-draft); }
    }

    if (!root.label-open) : Text {
        x: 18px;
        y: 86px;
        width: parent.width - 36px;
        text: "Add a custom label (optional)";
        color: Palette.muted-strong;
        font-size: 13px;
        font-weight: 600;
    }

    if (!root.label-open) : TouchArea {
        x: 18px;
        y: 82px;
        width: 190px;
        height: 28px;
        clicked => { root.begin-label(); }
    }

    if (root.label-open) : PackHubField {
        x: 18px;
        y: 86px;
        width: parent.width - 120px;
        placeholder: root.label-draft == "" ? "Manual backup May 5 2026 9-23-PM" : "";
        search: false;
        focused: true;
    }

    if (root.label-open) : TextInput {
        x: 32px;
        y: 92px;
        width: parent.width - 150px;
        height: 28px;
        text: root.label-draft;
        color: Palette.foreground;
        font-size: 13px;
        font-family: "Geist";
        font-weight: 600;
        single-line: true;
        vertical-alignment: center;
        selection-background-color: Palette.sky-25;
        edited => { root.label-draft = self.text; }
    }

    if (root.label-open) : PackHubButton {
        x: parent.width - 92px;
        y: 88px;
        width: 68px;
        icon: @image-url("../assets/icons/x.svg");
        label: "Cancel";
        show-icon: false;
        clicked => { root.cancel-label(); }
    }

    Rectangle {
        x: 18px;
        y: root.label-open ? 130px : 108px;
        width: 18px;
        height: 18px;
        border-radius: 9px;
        background: #00000000;

        Text {
            width: parent.width;
            height: parent.height;
            text: "i";
            color: Palette.muted-strong;
            font-size: 12px;
            font-weight: 900;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Informational line only — the chevron (which implied an expandable disclosure
    // with no handler) was removed so it doesn't read as a dead control.
    Text {
        x: 42px;
        y: root.label-open ? 126px : 104px;
        width: parent.width - 86px;
        text: "Your SavedVariables, AddOns list, and character settings are backed up.";
        color: Palette.muted-strong;
        font-size: 13px;
        font-weight: 600;
        overflow: elide;
    }
}

component BackupRestoreOverlay inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <int> view: 0;
    in property <[SettingsBackupEntry]> backups;
    in property <string> status-title: "No backup yet";
    in property <string> status-subtitle: "Your addon settings aren't protected. Create your first backup below.";
    in property <int> status-kind: 0;
    in property <string> backup-list-summary: "0 - 0 B total";
    in-out property <string> backup-label-draft;
    in-out property <int> pending-delete-index: -1;
    in-out property <int> selected-backup-index: -1;
    in-out property <string> selected-backup-title: "";
    in-out property <string> selected-backup-meta: "";
    callback refresh-backups;
    callback create-backup(string);
    callback restore-backup(int);
    callback delete-backup(int);
    callback reveal-backups-folder;
    visible: root.open;
    background: #000000c4;
    private property <length> modal-width: root.width < 760px ? root.width - 48px : 674px;
    private property <length> modal-height: root.height < 820px ? root.height - 32px : 780px;
    private property <length> footer-height: 66px;
    private property <length> list-title-y: root.view == 1 ? 384px : 356px;
    private property <length> list-top: root.view == 1 ? 410px : 382px;
    private property <length> list-height: max(132px, root.modal-height - root.footer-height - root.list-top - 10px);

    TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.open = false; }
    }

    panel := Rectangle {
        width: root.modal-width;
        height: root.modal-height;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        border-radius: 16px;
        border-width: 1px;
        border-color: Palette.border-strong;
        background: Tokens.surface;
        drop-shadow-blur: 30px;
        drop-shadow-offset-y: 12px;
        drop-shadow-color: #00000099;
        clip: true;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { }
        }

        Text {
            x: 28px;
            y: 24px;
            width: parent.width - 92px;
            text: "Backup & Restore";
            color: Palette.gold;
            font-size: 18px;
            font-weight: 900;
            overflow: elide;
        }

        Text {
            x: 28px;
            y: 54px;
            width: parent.width - 92px;
            height: 48px;
            text: "Save a copy of your addon settings so you can recover them if something goes wrong, or move them to a new PC.";
            color: Palette.muted-strong;
            font-size: 14px;
            font-weight: 600;
            wrap: word-wrap;
        }

        GhostIconButton {
            x: parent.width - 52px;
            y: 20px;
            width: 36px;
            height: 36px;
            icon: @image-url("../assets/icons/x.svg");
            clicked => { root.open = false; }
        }

        Hairline { x: 0px; y: 116px; width: parent.width; height: 1px; opacity: 0.45; }

        BackupStatusCard {
            x: 28px;
            y: 134px;
            width: parent.width - 56px;
            title: root.status-title;
            subtitle: root.status-subtitle;
            status-kind: root.status-kind;
        }

        BackupCreateCard {
            x: 28px;
            y: 214px;
            width: parent.width - 56px;
            label-open: root.view == 1;
            label-draft <=> root.backup-label-draft;
            begin-label => { root.view = 1; }
            cancel-label => {
                root.backup-label-draft = "";
                root.view = 0;
            }
            create-backup(label) => { root.create-backup(label); }
        }

        DetailSectionTitle { x: 28px; y: root.list-title-y; width: 130px; label: "YOUR BACKUPS"; }
        Text { x: 150px; y: root.list-title-y - 2px; text: root.backup-list-summary; color: Palette.muted-half; font-size: 13px; font-weight: 800; }

        if (root.backups.length == 0) : Rectangle {
            x: 28px;
            y: root.list-top;
            width: parent.width - 56px;
            height: min(128px, root.list-height);
            border-radius: 13px;
            border-width: 1px;
            border-color: Palette.white-06;
            background: Palette.white-03;

            Image { x: (parent.width - 28px) / 2; y: 24px; width: 28px; height: 28px; source: @image-url("../assets/icons/folder-open.svg"); image-fit: contain; colorize: Palette.muted-half; }
            Text { x: 24px; y: 62px; width: parent.width - 48px; text: "No backups yet"; color: Palette.foreground; font-size: 14px; font-weight: 900; horizontal-alignment: center; }
            Text { x: 44px; y: 88px; width: parent.width - 88px; text: "Create your first backup so you can recover your settings if anything goes wrong."; color: Palette.muted-strong; font-size: 12px; font-weight: 600; horizontal-alignment: center; wrap: word-wrap; }
        }

        if (root.backups.length > 0) : ScrollView {
            x: 28px;
            y: root.list-top;
            width: parent.width - 56px;
            height: root.list-height;
            viewport-width: self.width;
            viewport-height: root.backups.length * 86px;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            Rectangle {
                width: parent.width;
                height: root.backups.length * 86px;
                background: #00000000;

                for backup[index] in root.backups : BackupListRow {
                    x: 0px;
                    y: index * 86px;
                    width: parent.width;
                    title: backup.display-name;
                    meta: backup.meta;
                    kind-label: backup.kind-label;
                    kind: backup.kind;
                    latest: backup.latest;
                    restorable: backup.restorable;
                    confirming-delete: root.pending-delete-index == index;
                    restore-clicked => {
                        root.selected-backup-index = index;
                        root.selected-backup-title = backup.display-name;
                        root.selected-backup-meta = backup.meta;
                        root.view = 2;
                    }
                    delete-clicked => { root.pending-delete-index = index; }
                    delete-cancelled => { root.pending-delete-index = -1; }
                    delete-confirmed => {
                        root.pending-delete-index = -1;
                        root.delete-backup(index);
                    }
                }
            }

            Rectangle { x: parent.width - 8px; y: 8px; width: 5px; height: parent.height - 16px; border-radius: 3px; background: Palette.white-04; }
            Rectangle { x: parent.width - 8px; y: 16px; width: 5px; height: 42px; border-radius: 3px; background: Palette.sky; }
        }

        Rectangle {
            x: 0px;
            y: parent.height - root.footer-height;
            width: parent.width;
            height: root.footer-height;
            background: @linear-gradient(0deg, Tokens.surface 0%, Tokens.surface-84 72%, #00000000 100%);

            Image {
                x: 32px;
                y: 29px;
                width: 14px;
                height: 14px;
                source: @image-url("../assets/icons/folder-open.svg");
                image-fit: contain;
                colorize: Palette.muted-strong;
            }

            Text {
                x: 54px;
                y: 20px;
                height: 32px;
                text: "Show in folder";
                color: Palette.muted-strong;
                font-size: 12px;
                font-weight: 800;
                vertical-alignment: center;
            }

            TouchArea { x: 24px; y: 18px; width: 144px; height: 36px; clicked => { root.reveal-backups-folder(); } }
            PackHubButton { x: parent.width - 96px; y: 20px; width: 68px; icon: @image-url("../assets/icons/x.svg"); label: "Close"; show-icon: false; clicked => { root.open = false; } }
        }

        if (root.view == 2) : Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: #020617a8;

            TouchArea { width: parent.width; height: parent.height; }

            dialog := Rectangle {
                x: 64px;
                y: 126px;
                width: parent.width - 128px;
                height: 444px;
                border-radius: 16px;
                border-width: 0px;
                background: Tokens.surface;
                drop-shadow-blur: 28px;
                drop-shadow-offset-y: 8px;
                drop-shadow-color: #00000099;
                clip: true;

            Text { x: 32px; y: 28px; text: "Restore this backup?"; color: Palette.gold; font-size: 18px; font-weight: 900; }
            Text { x: 32px; y: 64px; width: parent.width - 64px; height: 46px; text: "This will replace your current addon settings with the ones in this backup."; color: Palette.muted-strong; font-size: 14px; font-weight: 600; wrap: word-wrap; }
            GhostIconButton { x: parent.width - 52px; y: 24px; width: 36px; height: 36px; icon: @image-url("../assets/icons/x.svg"); clicked => { root.view = 0; } }
            Hairline { x: 0px; y: 118px; width: parent.width; height: 1px; opacity: 0.45; }

            Rectangle {
                x: 32px;
                y: 144px;
                width: parent.width - 64px;
                height: 74px;
                border-radius: 12px;
                border-width: 0px;
                background: Palette.white-03;

                Text { x: 18px; y: 16px; width: parent.width - 36px; text: root.selected-backup-title != "" ? root.selected-backup-title : "Select a backup from the list"; color: Palette.foreground; font-size: 15px; font-weight: 900; overflow: elide; }
                Text { x: 18px; y: 42px; width: parent.width - 36px; text: root.selected-backup-meta != "" ? root.selected-backup-meta : "No backup selected"; color: Palette.muted-strong; font-size: 13px; font-weight: 600; overflow: elide; }
            }

            Rectangle {
                x: 32px;
                y: 238px;
                width: parent.width - 64px;
                height: 76px;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.emerald-20;
                background: Tokens.accent-06;

                Image { x: 18px; y: 28px; width: 18px; height: 18px; source: @image-url("../assets/icons/check.svg"); image-fit: contain; colorize: Palette.emerald; }
                Text { x: 48px; y: 16px; width: parent.width - 66px; height: 44px; text: "Don't worry - this is reversible. We'll save your current settings as a safety snapshot first."; color: Palette.foreground; font-size: 12px; font-weight: 750; wrap: word-wrap; }
            }

            Text { x: 32px; y: 336px; width: parent.width - 64px; text: "ESO must be closed for the new settings to load - restart the game after restoring."; color: Palette.muted-strong; font-size: 12px; font-weight: 600; wrap: word-wrap; }

                Rectangle {
                    x: 0px;
                    y: parent.height - 68px;
                    width: parent.width;
                    height: 68px;
                    background: @linear-gradient(0deg, Tokens.surface 0%, Tokens.surface-84 75%, #00000000 100%);

                    PackHubButton { x: parent.width - 254px; y: 18px; width: 86px; icon: @image-url("../assets/icons/x.svg"); label: "Cancel"; show-icon: false; clicked => { root.view = 0; } }
                    PackHubButton { x: parent.width - 158px; y: 18px; width: 134px; icon: @image-url("../assets/icons/undo-2.svg"); label: "Yes, Restore"; primary: true; clicked => { root.restore-backup(root.selected-backup-index); } }
                }
            }
        }
    }
}

component UploaderModeButton inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    in property <bool> locked: false;
    callback clicked;
    height: 32px;
    border-radius: 8px;
    border-width: 0px;
    background: root.active ? Palette.white-08 : (root.locked ? #00000000 : (touch.has-hover ? Palette.white-03 : #00000000));

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: root.active ? Palette.foreground : (root.locked ? Palette.muted-dim : (touch.has-hover ? Palette.muted-strong : Palette.muted-half));
        opacity: root.locked && !root.active ? 0.6 : 1.0;
        font-size: 12px;
        font-weight: 850;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        mouse-cursor: root.locked && !root.active ? MouseCursor.not-allowed : MouseCursor.pointer;
        clicked => { root.clicked(); }
    }
}

component UploaderOptionButton inherits Rectangle {
    in property <string> label;
    in property <string> value;
    callback clicked;
    height: 34px;
    border-radius: 10px;
    border-width: 0px;
    background: touch.has-hover ? Palette.white-06 : Palette.white-03;

    Text {
        x: 12px;
        y: 5px;
        width: parent.width - 24px;
        text: root.label;
        color: Palette.muted-dim;
        font-family: "Space Grotesk Light";
        font-size: 9px;
        font-weight: 850;
        overflow: elide;
    }

    Text {
        x: 12px;
        y: 17px;
        width: parent.width - 34px;
        text: root.value;
        color: Palette.foreground;
        font-size: 11px;
        font-weight: 850;
        overflow: elide;
    }

    Image {
        x: parent.width - 22px;
        y: 12px;
        width: 10px;
        height: 10px;
        source: @image-url("../assets/icons/chevron-down.svg");
        image-fit: contain;
        colorize: Palette.muted-half;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component UploaderInfoCard inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <string> value;
    in property <color> tone: Palette.sky;
    border-radius: 12px;
    border-width: 1px;
    border-color: Palette.border;
    background: Palette.white-03;

    Image {
        x: 14px;
        y: 14px;
        width: 15px;
        height: 15px;
        source: root.icon;
        image-fit: contain;
        colorize: root.tone;
    }

    Text {
        x: 38px;
        y: 13px;
        width: parent.width - 52px;
        text: root.label;
        color: Palette.muted-dim;
        font-family: "Space Grotesk Light";
        font-size: 10px;
        font-weight: 800;
        overflow: elide;
    }

    Text {
        x: 14px;
        y: 38px;
        width: parent.width - 28px;
        text: root.value;
        color: Palette.foreground;
        font-size: 15px;
        font-weight: 850;
        overflow: elide;
    }
}

component UploaderLogRow inherits Rectangle {
    in property <string> title;
    in property <string> meta;
    in property <bool> selected: false;
    in property <bool> active: false;
    callback clicked;
    height: 56px;
    border-radius: 10px;
    border-width: 1px;
    border-color: root.selected ? Palette.gold-20 : Palette.border;
    background: root.selected ? Palette.gold-04 : (touch.has-hover ? Palette.white-04 : Palette.white-02);

    Image {
        x: 14px;
        y: 18px;
        width: 16px;
        height: 16px;
        source: @image-url("../assets/icons/file-text.svg");
        image-fit: contain;
        colorize: root.active ? Palette.emerald : (root.selected ? Palette.gold : Palette.muted-half);
    }

    Text {
        x: 40px;
        y: 10px;
        width: parent.width - 54px;
        text: root.title;
        color: Palette.foreground;
        font-size: 12px;
        font-weight: 850;
        overflow: elide;
    }

    Text {
        x: 40px;
        y: 32px;
        width: parent.width - (root.active ? 114px : 54px);
        text: root.meta;
        color: Palette.muted-half;
        font-size: 11px;
        font-weight: 600;
        overflow: elide;
    }

    if (root.active) : Text {
        x: parent.width - 72px;
        y: 32px;
        width: 58px;
        text: "ACTIVE";
        color: Palette.emerald;
        font-size: 10px;
        font-weight: 850;
        horizontal-alignment: right;
        overflow: elide;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component UploaderFightRow inherits Rectangle {
    in property <string> title;
    in property <string> meta;
    in property <string> result;
    in property <bool> live: false;
    height: 42px;
    background: #00000000;

    Rectangle {
        x: 0px;
        y: 11px;
        width: 20px;
        height: 20px;
        border-radius: 10px;
        border-width: 0px;
        background: root.live ? Palette.emerald-15 : Palette.gold-10;

        Image {
            x: 5px;
            y: 5px;
            width: 10px;
            height: 10px;
            source: @image-url("../assets/icons/check.svg");
            image-fit: contain;
            colorize: root.live ? Palette.emerald : Palette.gold;
        }
    }

    Text {
        x: 30px;
        y: 4px;
        width: parent.width - 142px;
        text: root.title;
        color: Palette.foreground;
        font-size: 12px;
        font-weight: 800;
        overflow: elide;
    }

    Text {
        x: 30px;
        y: 24px;
        width: parent.width - 142px;
        text: root.meta;
        color: Palette.muted-half;
        font-size: 10px;
        font-weight: 600;
        overflow: elide;
    }

    Text {
        x: parent.width - 104px;
        y: 12px;
        width: 104px;
        text: root.result;
        color: root.live ? Palette.emerald : Palette.gold;
        font-size: 10px;
        font-weight: 850;
        horizontal-alignment: right;
        overflow: elide;
    }
}

component UploaderOverlay inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <int> view: 0;
    in property <[UploaderLogEntry]> logs;
    in property <[UploaderFightEntry]> fights;
    in property <string> logs-summary: "No log folder detected";
    in property <string> selected-log-label: "No log selected";
    in property <string> fight-count-label: "0 ready";
    in property <string> route-label: "Archon App handoff";
    in property <bool> native-route: false;
    in property <bool> signed-in: false;
    in property <bool> live-active: false;
    in property <string> report-code: "";
    in property <string> status-title: "No log selected";
    in property <string> status-detail: "Select a log file to inspect fights before uploading.";
    in property <string> live-status-label: "Ready";
    in property <string> live-log-label: "No Encounter.log";
    in property <string> live-fight-label: "Waiting";
    in property <string> live-detail: "Start live mode before the pull. Kalpa will wait for the next logging session and keep the report active.";
    in-out property <int> region: 1;
    in-out property <int> visibility-mode: 2;
    callback refresh;
    callback log-selected(int);
    callback upload-requested;
    callback live-toggle;
    callback options-changed;
    callback split-requested;
    callback sign-in;
    callback sign-out;
    callback open-report;
    visible: root.open;
    background: #000000c4;
    private property <bool> manual: root.view < 2;
    private property <bool> uploading: root.view == 1;
    private property <bool> live-running: root.view == 3;
    private property <length> modal-width: root.width < 900px ? root.width - 48px : 820px;
    private property <length> modal-height: root.height < 720px ? root.height - 48px : 670px;
    private property <string> region-label: root.region == 2 ? "EU" : "NA";
    private property <string> visibility-label: root.visibility-mode == 0 ? "Public" : (root.visibility-mode == 1 ? "Private" : "Unlisted");

    // Don't let a stray backdrop click dismiss the modal mid-upload / mid-live-stream.
    TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            if (!root.uploading && !root.live-running) {
                root.open = false;
            }
        }
    }

    panel := Rectangle {
        width: root.modal-width;
        height: root.modal-height;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        border-radius: 16px;
        border-width: 1px;
        border-color: Palette.border-strong;
        background: Tokens.surface;
        drop-shadow-blur: 30px;
        drop-shadow-offset-y: 12px;
        drop-shadow-color: #00000099;
        clip: true;

        TouchArea { width: parent.width; height: parent.height; clicked => { } }

        Image { x: 28px; y: 26px; width: 18px; height: 18px; source: @image-url("../assets/icons/cloud-upload.svg"); image-fit: contain; colorize: Palette.gold; }
        Text { x: 58px; y: 21px; width: parent.width - 250px; text: "Upload to ESO Logs"; color: Palette.gold; font-size: 18px; font-weight: 900; overflow: elide; }
        Text { x: 58px; y: 52px; width: parent.width - 210px; text: root.manual ? (root.native-route ? "Signed in — Upload sends the report directly to ESO Logs." : "Select a log, review detected fights, then hand off to the uploader.") : (root.native-route ? "Signed in — Kalpa streams each fight straight to ESO Logs as it finishes." : "Kalpa watches the live encounter log, then hands the session to the external uploader."); color: Palette.muted-strong; font-size: 13px; font-weight: 600; overflow: elide; }

        Rectangle {
            x: parent.width - 184px;
            y: 24px;
            width: 116px;
            height: 28px;
            border-radius: 14px;
            border-width: 1px;
            border-color: root.manual ? Palette.gold-20 : (root.live-running ? Palette.emerald-20 : Palette.white-08);
            background: root.manual ? Palette.gold-04 : (root.live-running ? Palette.emerald-04 : Palette.white-03);

            Text {
                x: 12px;
                y: 0px;
                width: parent.width - 24px;
                height: parent.height;
                text: root.manual ? root.fight-count-label : root.live-status-label;
                color: root.manual ? Palette.gold : (root.live-running ? Palette.emerald : Palette.muted-strong);
                font-size: 11px;
                font-weight: 900;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        GhostIconButton {
            x: parent.width - 52px;
            y: 22px;
            width: 36px;
            height: 36px;
            icon: @image-url("../assets/icons/x.svg");
            clicked => { root.open = false; }
        }

        Rectangle {
            x: 28px;
            y: 92px;
            width: parent.width - 56px;
            height: 40px;
            border-radius: 12px;
            border-width: 0px;
            background: Palette.white-03;

            // Tabs are locked while a native live worker runs or a manual upload is
            // in flight — switching away would orphan the in-process driver/upload
            // (its Stop/Cancel lives in the current view). Stop/finish unlocks them.
            UploaderModeButton { x: 5px; y: 4px; width: (parent.width - 10px) / 2; label: "Manual Upload"; active: root.manual; locked: root.live-active || root.uploading; clicked => { if (!root.live-active && !root.uploading) { root.view = 0; } } }
            UploaderModeButton { x: 5px + (parent.width - 10px) / 2; y: 4px; width: (parent.width - 10px) / 2; label: "Live Logging"; active: !root.manual; locked: root.live-active || root.uploading; clicked => { if (!root.live-active && !root.uploading) { root.view = 2; } } }
        }

        Hairline { x: 0px; y: 152px; width: parent.width; height: 1px; opacity: 0.45; }

        if (root.manual) : Rectangle {
            x: 28px;
            y: 176px;
            width: parent.width - 56px;
            height: parent.height - 254px;
            background: #00000000;

            UploaderInfoCard { x: 0px; y: 0px; width: (parent.width - 18px) / 3; height: 74px; icon: @image-url("../assets/icons/file-text.svg"); label: "SELECTED LOG"; value: root.selected-log-label; tone: Palette.gold; }
            UploaderInfoCard { x: (parent.width - 18px) / 3 + 9px; y: 0px; width: (parent.width - 18px) / 3; height: 74px; icon: @image-url("../assets/icons/check.svg"); label: "FIGHTS"; value: root.fight-count-label; tone: Palette.emerald; }
            UploaderInfoCard { x: ((parent.width - 18px) / 3 + 9px) * 2; y: 0px; width: (parent.width - 18px) / 3; height: 74px; icon: @image-url("../assets/icons/cloud-upload.svg"); label: "ROUTE"; value: root.route-label; tone: root.native-route ? Palette.emerald : Palette.sky; }

            Rectangle {
                x: 0px;
                y: 96px;
                width: (parent.width - 18px) * 0.42;
                height: parent.height - 108px;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.border;
                background: Palette.white-02;
                clip: true;

                DetailSectionTitle { x: 18px; y: 16px; width: parent.width - 36px; label: "LOG FILES"; }

                if (root.logs.length == 0) : Text {
                    x: 18px;
                    y: 52px;
                    width: parent.width - 36px;
                    height: 92px;
                    text: root.logs-summary;
                    color: Palette.muted-strong;
                    font-size: 12px;
                    font-weight: 650;
                    wrap: word-wrap;
                }

                if (root.logs.length > 0) : ScrollView {
                    x: 18px;
                    y: 46px;
                    width: parent.width - 36px;
                    height: parent.height - 64px;
                    viewport-width: self.width;
                    viewport-height: root.logs.length * 64px;
                    vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                    Rectangle {
                        width: parent.width;
                        height: root.logs.length * 64px;
                        background: #00000000;

                        for log[index] in root.logs : UploaderLogRow {
                            x: 0px;
                            y: index * 64px;
                            width: parent.width;
                            title: log.title;
                            meta: log.meta;
                            selected: log.selected;
                            active: log.active;
                            clicked => { root.log-selected(index); }
                        }
                    }
                }
            }

            Rectangle {
                x: (parent.width - 18px) * 0.42 + 18px;
                y: 96px;
                width: parent.width - self.x;
                height: parent.height - 108px;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.border;
                background: Palette.white-02;
                clip: true;

                Text { x: 18px; y: 16px; width: parent.width - 36px; text: root.status-title; color: Palette.foreground; font-size: 15px; font-weight: 900; overflow: elide; }
                Text { x: 18px; y: 44px; width: parent.width - 36px; height: 34px; text: root.status-detail; color: Palette.muted-strong; font-size: 12px; font-weight: 600; wrap: word-wrap; overflow: elide; }

                if (!root.uploading) : UploaderOptionButton {
                    x: 18px;
                    y: 86px;
                    width: (parent.width - 44px) / 2;
                    label: "REGION";
                    value: root.region-label;
                    clicked => {
                        root.region = root.region == 2 ? 1 : 2;
                        root.options-changed();
                    }
                }

                if (!root.uploading) : UploaderOptionButton {
                    x: 26px + (parent.width - 44px) / 2;
                    y: 86px;
                    width: (parent.width - 44px) / 2;
                    label: "VISIBILITY";
                    value: root.visibility-label;
                    clicked => {
                        root.visibility-mode = root.visibility-mode == 2 ? 1 : (root.visibility-mode == 1 ? 0 : 2);
                        root.options-changed();
                    }
                }

                if (root.uploading) : Rectangle {
                    x: 18px;
                    y: 88px;
                    width: parent.width - 36px;
                    height: 42px;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: Palette.sky-15;
                    background: Palette.sky-04;

                    Image { x: 14px; y: 13px; width: 16px; height: 16px; source: @image-url("../assets/icons/cloud-upload.svg"); image-fit: contain; colorize: Palette.sky; }
                    Text { x: 42px; y: 0px; width: parent.width - 56px; height: parent.height; text: root.native-route ? "Uploading to ESO Logs..." : "Opening the ESO Logs uploader..."; color: Palette.foreground; font-size: 12px; font-weight: 850; vertical-alignment: center; overflow: elide; }
                }

                DetailSectionTitle { x: 18px; y: root.uploading ? 146px : 132px; width: parent.width - 36px; label: "FIGHTS"; }

                if (root.fights.length == 0) : Text {
                    x: 18px;
                    y: root.uploading ? 174px : 160px;
                    width: parent.width - 36px;
                    height: 74px;
                    text: "No completed fights were detected in the selected log.";
                    color: Palette.muted-half;
                    font-size: 12px;
                    font-weight: 650;
                    wrap: word-wrap;
                }

                if (root.fights.length > 0) : ScrollView {
                    x: 18px;
                    y: root.uploading ? 174px : 160px;
                    width: parent.width - 36px;
                    height: parent.height - (root.uploading ? 174px : 160px) - 44px;
                    viewport-width: self.width;
                    viewport-height: root.fights.length * 42px;
                    vertical-scrollbar-policy: ScrollBarPolicy.always-on;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                    Rectangle {
                        width: parent.width;
                        height: root.fights.length * 42px;
                        background: #00000000;

                        for fight[index] in root.fights : UploaderFightRow {
                            x: 0px;
                            y: index * 42px;
                            width: parent.width - 12px;
                            title: fight.title;
                            meta: fight.meta;
                            result: fight.result;
                            live: fight.live;
                        }
                    }
                }

                if (root.fights.length > 0) : Text {
                    x: 18px;
                    y: parent.height - 34px;
                    width: parent.width - 36px;
                    text: "Preview of recent fights - the uploader hands off the entire log, not just what is shown here.";
                    color: Palette.muted-half;
                    font-size: 11px;
                    font-weight: 650;
                    wrap: word-wrap;
                }
            }
        }

        if (!root.manual) : Rectangle {
            x: 28px;
            y: 176px;
            width: parent.width - 56px;
            height: parent.height - 254px;
            background: #00000000;

            UploaderInfoCard { x: 0px; y: 0px; width: (parent.width - 18px) / 3; height: 74px; icon: @image-url("../assets/icons/power.svg"); label: "STATUS"; value: root.live-status-label; tone: root.live-running ? Palette.emerald : Palette.gold; }
            UploaderInfoCard { x: (parent.width - 18px) / 3 + 9px; y: 0px; width: (parent.width - 18px) / 3; height: 74px; icon: @image-url("../assets/icons/file-text.svg"); label: "CURRENT LOG"; value: root.live-log-label; tone: Palette.sky; }
            UploaderInfoCard { x: ((parent.width - 18px) / 3 + 9px) * 2; y: 0px; width: (parent.width - 18px) / 3; height: 74px; icon: @image-url("../assets/icons/check.svg"); label: "FIGHTS"; value: root.live-fight-label; tone: Palette.emerald; }

            Rectangle {
                x: 0px;
                y: 96px;
                width: parent.width;
                height: 260px;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.border;
                background: Palette.white-02;

                Text { x: 20px; y: 18px; width: parent.width - 40px; text: root.live-running ? "Live report is armed" : "Ready for live logging"; color: Palette.foreground; font-size: 16px; font-weight: 900; overflow: elide; }
                Text { x: 20px; y: 48px; width: parent.width - 40px; text: root.live-detail; color: Palette.muted-strong; font-size: 13px; font-weight: 600; wrap: word-wrap; }

                if (!root.live-running) : UploaderOptionButton {
                    x: 20px;
                    y: 92px;
                    width: (parent.width - 50px) / 2;
                    label: "REGION";
                    value: root.region-label;
                    clicked => {
                        root.region = root.region == 2 ? 1 : 2;
                        root.options-changed();
                    }
                }

                if (!root.live-running) : UploaderOptionButton {
                    x: 30px + (parent.width - 50px) / 2;
                    y: 92px;
                    width: (parent.width - 50px) / 2;
                    label: "VISIBILITY";
                    value: root.visibility-label;
                    clicked => {
                        root.visibility-mode = root.visibility-mode == 2 ? 1 : (root.visibility-mode == 1 ? 0 : 2);
                        root.options-changed();
                    }
                }

                if (root.live-running) : Rectangle {
                    x: 20px;
                    y: 92px;
                    width: parent.width - 40px;
                    height: 46px;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: Palette.emerald-20;
                    background: Palette.emerald-04;

                    Image { x: 14px; y: 15px; width: 16px; height: 16px; source: @image-url("../assets/icons/check.svg"); image-fit: contain; colorize: Palette.emerald; }
                    Text { x: 42px; y: 12px; width: parent.width - 56px; text: "Live logging launched without reopening the WebView shell."; color: Palette.foreground; font-size: 12px; font-weight: 850; overflow: elide; }
                }

                DetailSectionTitle { x: 20px; y: root.live-running ? 164px : 142px; width: parent.width - 40px; label: root.live-running ? "LIVE FIGHTS" : "READINESS"; }

                if (!root.live-running) : UploaderFightRow { x: 20px; y: 172px; width: parent.width - 40px; title: "ESO Logs session"; meta: root.route-label; result: "CHECK"; live: true; }
                if (!root.live-running) : UploaderFightRow { x: 20px; y: 214px; width: parent.width - 40px; title: "Combat log watcher"; meta: root.logs-summary; result: "READY"; live: true; }

                if (root.live-running) : UploaderFightRow { x: 20px; y: 194px; width: parent.width - 40px; title: "ESO Logs uploader"; meta: root.live-detail; result: "RUNNING"; live: true; }
                if (root.live-running) : UploaderFightRow { x: 20px; y: 236px; width: parent.width - 40px; title: "Current log"; meta: root.live-log-label; result: "WATCH"; live: true; }
            }
        }

        Rectangle {
            x: 0px;
            y: parent.height - 76px;
            width: parent.width;
            height: 76px;
            background: @linear-gradient(0deg, Tokens.surface 0%, Tokens.surface-84 75%, #00000000 100%);

            PackHubButton { x: 28px; y: 22px; width: 116px; icon: @image-url("../assets/icons/refresh-cw.svg"); label: "Refresh"; clicked => { root.refresh(); } }
            if (root.manual) : PackHubButton { x: 152px; y: 22px; width: 108px; icon: @image-url("../assets/icons/files.svg"); label: "Split"; disabled: root.logs.length == 0; clicked => { root.split-requested(); } }
            SmallAction {
                x: 272px;
                y: 28px;
                label: root.signed-in ? "Sign out of ESO Logs" : "Sign in to ESO Logs";
                tone: root.signed-in ? Palette.muted-strong : Palette.sky;
                fill: root.signed-in ? Palette.white-06 : Palette.sky-10;
                fill-hover: root.signed-in ? Palette.white-08 : Palette.sky-16;
                fill-pressed: root.signed-in ? Palette.white-10 : Palette.sky-22;
                clicked => { if (root.signed-in) { root.sign-out(); } else { root.sign-in(); } }
            }
            if (root.manual && root.report-code != "") : SmallAction {
                x: 272px;
                y: 52px;
                label: "View report " + root.report-code;
                tone: Palette.emerald;
                fill: Palette.emerald-04;
                fill-hover: Palette.emerald-20;
                fill-pressed: Palette.emerald-20;
                clicked => { root.open-report(); }
            }
            PackHubButton { x: parent.width - 284px; y: 22px; width: 116px; icon: @image-url("../assets/icons/x.svg"); label: root.live-running ? "Stop" : "Cancel"; danger: root.live-running; disabled: root.uploading; clicked => { if (root.live-running) { root.live-toggle(); } else if (!root.uploading) { root.open = false; } } }
            // "Running" is a status only — the red Stop button is the sole stop control (was a hidden duplicate-stop).
            PackHubButton { x: parent.width - 156px; y: 22px; width: 128px; icon: root.manual ? @image-url("../assets/icons/cloud-upload.svg") : @image-url("../assets/icons/power.svg"); label: root.manual ? (root.uploading ? "Uploading" : "Upload") : (root.live-running ? "Running" : "Go Live"); primary: true; disabled: root.manual ? (root.logs.length == 0 || root.uploading) : (root.live-running || root.live-log-label != "Encounter.log"); clicked => { if (root.manual) { root.upload-requested(); } else if (!root.live-running) { root.live-toggle(); } } }
        }
    }
}

component SvmTabButton inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked;
    width: label-text.preferred-width + 28px;
    height: 38px;
    border-radius: 8px;
    background: touch.has-hover ? Palette.white-04 : #00000000;

    Text {
        x: 10px;
        y: 0px;
        height: parent.height - 4px;
        text: root.label;
        color: root.active ? Palette.foreground : Palette.muted-strong;
        font-size: 13px;
        font-weight: 850;
        vertical-alignment: center;
    }

    label-text := Text {
        visible: false;
        text: root.label;
        font-size: 13px;
        font-weight: 850;
    }

    Rectangle {
        x: 8px;
        y: parent.height - 3px;
        width: parent.width - 16px;
        height: 2px;
        border-radius: 1px;
        background: root.active ? Palette.foreground : #00000000;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component UploaderSplitRow inherits Rectangle {
    in property <string> title;
    in property <string> meta;
    in property <string> detail;
    in property <bool> checked: false;
    callback clicked;
    height: 60px;
    border-radius: 10px;
    border-width: root.checked ? 1px : 0px;
    border-color: root.checked ? Palette.gold-20 : #00000000;
    background: touch.has-hover ? Palette.white-04 : (root.checked ? Palette.gold-04 : Palette.white-03);

    Checkbox { x: 14px; y: 22px; checked: root.checked; }

    Text {
        x: 46px;
        y: 10px;
        width: parent.width - 72px;
        text: root.title;
        color: Palette.foreground;
        font-size: 14px;
        font-weight: 850;
        overflow: elide;
    }

    Text {
        x: 46px;
        y: 32px;
        width: parent.width - 190px;
        text: root.meta;
        color: Palette.muted-strong;
        font-size: 12px;
        font-weight: 600;
        overflow: elide;
    }

    Text {
        x: parent.width - 150px;
        y: 32px;
        width: 136px;
        text: root.detail;
        color: Palette.gold;
        font-size: 11px;
        font-weight: 800;
        horizontal-alignment: right;
        overflow: elide;
    }

    touch := TouchArea {
        x: 0px;
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component SplitWorkbench inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <int> mode: 0;
    in property <[UploaderSplitEntry]> items;
    in property <string> summary: "";
    in property <string> source-label: "";
    in property <string> status: "";
    in property <int> selected-count: 0;
    in property <bool> busy: false;
    callback mode-changed(int);
    callback item-toggled(int);
    callback select-all;
    callback select-none;
    callback run;
    callback close;
    visible: root.open;
    background: #000000c4;
    private property <length> modal-width: root.width < 860px ? root.width - 48px : 760px;
    private property <length> modal-height: root.height < 700px ? root.height - 48px : 640px;
    private property <length> list-height: root.modal-height - 254px;

    TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.close(); }
    }

    panel := Rectangle {
        width: root.modal-width;
        height: root.modal-height;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        border-radius: 16px;
        border-width: 1px;
        border-color: Palette.border-strong;
        background: Tokens.surface;
        drop-shadow-blur: 30px;
        drop-shadow-offset-y: 12px;
        drop-shadow-color: #00000099;
        clip: true;

        TouchArea { width: parent.width; height: parent.height; clicked => { } }

        Image { x: 28px; y: 26px; width: 18px; height: 18px; source: @image-url("../assets/icons/files.svg"); image-fit: contain; colorize: Palette.gold; }
        Text { x: 58px; y: 21px; width: parent.width - 90px; text: "Split log to disk"; color: Palette.gold; font-size: 18px; font-weight: 900; overflow: elide; }
        Text { x: 58px; y: 50px; width: parent.width - 90px; height: 32px; text: "Write self-contained .log files you can upload one at a time. Slices " + root.source-label + " locally; the upload itself still goes through the uploader."; color: Palette.muted-strong; font-size: 12px; font-weight: 600; wrap: word-wrap; overflow: elide; }

        HorizontalLayout {
            x: 28px;
            y: 90px;
            spacing: 4px;
            height: 38px;
            SvmTabButton { label: "By fight"; active: root.mode == 0; clicked => { root.mode-changed(0); } }
            SvmTabButton { label: "By session"; active: root.mode == 1; clicked => { root.mode-changed(1); } }
        }

        Text {
            x: 28px;
            y: 138px;
            width: parent.width - 220px;
            text: root.selected-count + " of " + root.items.length + " selected  -  " + root.summary;
            color: Palette.muted-strong;
            font-size: 12px;
            font-weight: 700;
            vertical-alignment: center;
            height: 24px;
            overflow: elide;
        }

        SmallAction {
            x: parent.width - 178px;
            y: 138px;
            label: "Select all";
            clicked => { root.select-all(); }
        }

        SmallAction {
            x: parent.width - 92px;
            y: 138px;
            label: "Clear";
            tone: Palette.muted-strong;
            fill: Palette.white-06;
            fill-hover: Palette.white-08;
            fill-pressed: Palette.white-10;
            clicked => { root.select-none(); }
        }

        if (root.items.length == 0) : Text {
            x: 28px;
            y: 176px;
            width: parent.width - 56px;
            height: root.list-height;
            text: "No sessions or fights were detected in this log yet. Pick a log with completed fights, then reopen Split.";
            color: Palette.muted-half;
            font-size: 13px;
            font-weight: 650;
            wrap: word-wrap;
        }

        if (root.items.length > 0) : ScrollView {
            x: 28px;
            y: 174px;
            width: parent.width - 56px;
            height: root.list-height;
            viewport-width: self.width;
            viewport-height: root.items.length * 66px;
            vertical-scrollbar-policy: ScrollBarPolicy.always-on;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

            Rectangle {
                width: parent.width;
                height: root.items.length * 66px;
                background: #00000000;

                for item[index] in root.items : UploaderSplitRow {
                    x: 0px;
                    y: index * 66px;
                    width: parent.width - 12px;
                    title: item.title;
                    meta: item.meta;
                    detail: item.detail;
                    checked: item.selected;
                    clicked => { root.item-toggled(index); }
                }
            }
        }

        Rectangle {
            x: 0px;
            y: parent.height - 76px;
            width: parent.width;
            height: 76px;
            background: @linear-gradient(0deg, Tokens.surface 0%, Tokens.surface-84 75%, #00000000 100%);

            Text {
                x: 28px;
                y: 0px;
                width: parent.width - 300px;
                height: parent.height;
                text: root.status;
                color: root.status != "" ? Palette.gold : Palette.muted-half;
                font-size: 12px;
                font-weight: 700;
                vertical-alignment: center;
                wrap: word-wrap;
                overflow: elide;
            }

            PackHubButton { x: parent.width - 268px; y: 22px; width: 108px; icon: @image-url("../assets/icons/x.svg"); label: "Cancel"; clicked => { root.close(); } }
            PackHubButton { x: parent.width - 152px; y: 22px; width: 124px; icon: @image-url("../assets/icons/save.svg"); label: root.busy ? "Splitting..." : "Split to disk"; primary: true; disabled: root.selected-count == 0 || root.busy; clicked => { root.run(); } }
        }
    }
}

component SvmStatCard inherits Rectangle {
    in property <string> value;
    in property <string> label;
    in property <bool> warning: false;
    height: 68px;
    border-radius: 10px;
    border-width: root.warning ? 1px : 0px;
    border-color: root.warning ? Palette.gold-20 : #00000000;
    background: root.warning ? Palette.gold-04 : Palette.white-03;

    Text {
        y: 16px;
        width: parent.width;
        text: root.value;
        color: root.warning ? Palette.gold : Palette.foreground;
        font-size: 20px;
        font-weight: 900;
        horizontal-alignment: center;
    }

    Text {
        y: 43px;
        width: parent.width;
        text: root.label;
        color: Palette.muted-strong;
        font-size: 11px;
        font-weight: 800;
        horizontal-alignment: center;
    }
}

component SvmOverviewRow inherits Rectangle {
    in property <string> title;
    in property <string> meta;
    in property <string> size-label;
    in property <length> meter-width: 42px;
    in property <bool> system: false;
    height: 58px;
    border-radius: 11px;
    border-width: 0px;
    background: touch.has-hover ? Palette.white-04 : Palette.white-03;

    Rectangle {
        x: 12px;
        y: 19px;
        width: 56px;
        height: 6px;
        border-radius: 3px;
        background: Palette.white-06;
    }

    Rectangle {
        x: 12px;
        y: 19px;
        width: root.meter-width;
        height: 6px;
        border-radius: 3px;
        background: Palette.gold;
    }

    Text {
        x: 24px;
        y: 30px;
        width: 56px;
        text: root.size-label;
        color: Palette.gold;
        font-size: 11px;
        font-weight: 900;
        horizontal-alignment: center;
    }

    Text {
        x: 88px;
        y: 10px;
        width: parent.width - 150px;
        text: root.title;
        color: Palette.foreground;
        font-size: 16px;
        font-weight: 850;
        overflow: elide;
    }

    Pill {
        visible: root.system;
        x: 230px;
        y: 10px;
        label: "System";
        tone: Palette.muted-strong;
        fill: Palette.white-06;
        pill-height: 22px;
        label-font-size: 12px;
    }

    Text {
        x: 88px;
        y: 34px;
        width: parent.width - 150px;
        text: root.meta;
        color: Palette.muted-strong;
        font-size: 12px;
        font-weight: 600;
        overflow: elide;
    }

    Image {
        x: parent.width - 34px;
        y: 22px;
        width: 14px;
        height: 14px;
        source: @image-url("../assets/icons/chevron-right.svg");
        image-fit: contain;
        colorize: touch.has-hover ? Palette.muted-strong : Palette.muted-dim;
    }

    touch := TouchArea { width: root.width; height: root.height; }
}

component SvmCleanupRow inherits Rectangle {
    in property <string> title;
    in property <string> meta;
    in property <bool> checked: false;
    callback clicked;
    height: 58px;
    border-radius: 10px;
    background: touch.has-hover ? Palette.white-04 : Palette.white-03;

    Checkbox { x: 12px; y: 21px; checked: root.checked; }

    Text {
        x: 44px;
        y: 11px;
        width: parent.width - 70px;
        text: root.title;
        color: Palette.foreground;
        font-size: 15px;
        font-weight: 850;
        overflow: elide;
    }

    Text {
        x: 44px;
        y: 35px;
        width: parent.width - 70px;
        text: root.meta;
        color: Palette.muted-strong;
        font-size: 12px;
        font-weight: 600;
        overflow: elide;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component SvmSelectField inherits Rectangle {
    in property <string> label;
    in property <bool> disabled: false;
    callback clicked;
    height: 38px;
    border-radius: 10px;
    border-width: 0px;
    background: root.disabled ? Palette.white-02 : (touch.has-hover ? Palette.white-06 : Palette.white-03);

    animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    Text {
        x: 12px;
        y: 0px;
        height: parent.height;
        width: parent.width - 46px;
        text: root.label;
        color: root.disabled ? Palette.muted-dim : Palette.foreground;
        font-size: 14px;
        font-weight: 850;
        vertical-alignment: center;
        overflow: elide;
    }

    Image {
        x: parent.width - 26px;
        y: 12px;
        width: 14px;
        height: 14px;
        source: @image-url("../assets/icons/chevron-down.svg");
        image-fit: contain;
        colorize: root.disabled ? Palette.muted-dim : Palette.muted-strong;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            if (!root.disabled) {
                root.clicked();
            }
        }
    }
}

component SvmToggle inherits Rectangle {
    in property <bool> checked: false;
    width: 40px;
    height: 22px;
    border-radius: 11px;
    background: root.checked ? Palette.gold : Palette.white-08;

    Rectangle {
        x: root.checked ? parent.width - 20px : 2px;
        y: 2px;
        width: 18px;
        height: 18px;
        border-radius: 9px;
        background: Palette.foreground;
    }
}

component SvmEditorTreeRow inherits Rectangle {
    in property <string> label;
    in property <string> path;
    in property <string> count;
    in property <int> indent: 0;
    in property <bool> active: false;
    in property <bool> expanded: false;
    callback clicked(string);
    height: 28px;
    border-radius: 7px;
    background: root.active ? Palette.white-10 : (touch.has-hover ? Palette.white-04 : #00000000);

    animate background { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

    Image {
        visible: root.indent > 0 || root.expanded;
        x: 8px + root.indent * 18px;
        y: 8px;
        width: 12px;
        height: 12px;
        source: root.expanded ? @image-url("../assets/icons/chevron-down.svg") : @image-url("../assets/icons/chevron-right.svg");
        image-fit: contain;
        colorize: Palette.muted-strong;
    }

    Text {
        x: 24px + root.indent * 18px;
        y: 0px;
        height: parent.height;
        width: parent.width - 76px - root.indent * 18px;
        text: root.label;
        color: root.active ? Palette.foreground : Palette.muted-strong;
        font-size: 12px;
        font-weight: root.active ? 900 : 750;
        vertical-alignment: center;
        overflow: elide;
    }

    Text {
        x: parent.width - 46px;
        y: 0px;
        height: parent.height;
        width: 36px;
        text: root.count;
        color: Palette.muted-dim;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: right;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(root.path); }
    }
}

component SvmSettingRow inherits Rectangle {
    in property <string> label;
    in property <string> key-name;
    in property <int> kind: 0;
    in property <string> value: "";
    in property <bool> checked: false;
    callback clicked;
    callback value-edited(string);
    height: 42px;
    border-radius: 8px;
    background: touch.has-hover ? Palette.white-03 : #00000000;

    animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            if (root.kind == 0) {
                root.clicked();
            }
        }
    }

    Text {
        x: 12px;
        y: 8px;
        // Cap so the label ends before the key-name column at x:190 (was
        // parent.width-250, which overran and overlapped the key name).
        width: 170px;
        text: root.label;
        color: Palette.foreground;
        font-size: 13px;
        font-weight: 850;
        overflow: elide;
    }

    Text {
        x: 190px;
        y: 9px;
        width: parent.width - 420px;
        text: root.key-name;
        color: Palette.muted-dim;
        font-size: 11px;
        font-weight: 650;
        overflow: elide;
    }

    if (root.kind == 0) : SvmToggle {
        x: parent.width - 64px;
        y: 8px;
        checked: root.checked;
    }

    // String value: a real visible editable field. It commits on Enter or
    // blur (not per keystroke), so `root.value` stays constant while typing
    // and the caret never resets. See PARITY-BACKLOG.md item 1.
    if (root.kind == 1) : Rectangle {
        x: parent.width - 210px;
        y: 4px;
        width: 176px;
        height: 30px;
        border-radius: 9px;
        border-width: 1px;
        border-color: str-input.has-focus ? Palette.sky : Palette.white-08;
        background: Palette.white-04;
        clip: true;

        str-input := TextInput {
            x: 12px;
            y: 0px;
            width: parent.width - 24px;
            height: parent.height;
            text: root.value;
            color: Palette.foreground;
            font-size: 13px;
            font-family: "Geist";
            font-weight: 750;
            single-line: true;
            vertical-alignment: center;
            selection-background-color: Palette.sky-25;
            accepted => { root.value-edited(self.text); }
            changed has-focus => {
                if (!self.has-focus && self.text != root.value) {
                    root.value-edited(self.text);
                }
            }
        }
    }

    // Number value: same commit-on-Enter/blur behaviour, right-aligned.
    if (root.kind == 2) : Rectangle {
        x: parent.width - 210px;
        y: 4px;
        width: 176px;
        height: 30px;
        border-radius: 9px;
        border-width: 1px;
        border-color: num-input.has-focus ? Palette.sky : Palette.white-08;
        background: Palette.white-04;
        clip: true;

        num-input := TextInput {
            x: 12px;
            y: 0px;
            width: parent.width - 24px;
            height: parent.height;
            text: root.value;
            color: Palette.foreground;
            font-size: 13px;
            font-family: "Geist";
            font-weight: 800;
            single-line: true;
            horizontal-alignment: right;
            vertical-alignment: center;
            selection-background-color: Palette.sky-25;
            accepted => { root.value-edited(self.text); }
            changed has-focus => {
                if (!self.has-focus && self.text != root.value) {
                    root.value-edited(self.text);
                }
            }
        }
    }
}

component SavedVariablesOverlay inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <int> view: 0;
    in property <[SavedVariableEntry]> files;
    in property <[SavedVariableEntry]> orphaned-files;
    in property <[SvmEditorTreeEntry]> editor-tree;
    in property <[SvmEditorSettingEntry]> editor-settings;
    in property <string> file-count-label;
    in property <string> total-size-label;
    in property <string> orphan-count-label;
    in property <string> orphan-size-label;
    in property <string> large-count-label;
    in-out property <int> cleanup-selected-count: 0;
    in property <bool> has-orphans: false;
    in property <bool> has-files: false;
    in property <string> copy-file-label: "No profile files";
    in property <string> copy-source-label: "No source profile";
    in property <string> copy-dest-label: "No destination profile";
    in property <string> copy-source-name: "";
    in property <string> copy-dest-name: "";
    in property <string> copy-addon-name: "";
    in property <string> copy-status-label: "";
    in property <bool> copy-ready: false;
    in property <bool> copy-has-file: false;
    in property <bool> copy-has-source: false;
    in property <bool> copy-has-dest: false;
    in property <string> editor-file-label: "No file selected";
    in property <string> editor-path-label: "";
    in property <string> editor-message-label: "";
    in property <bool> editor-has-file: false;
    in property <bool> editor-dirty: false;
    in-out property <string> editor-tree-filter;
    callback editor-tree-filter-edited(string);
    callback refresh;
    callback clean-orphans;
    callback orphan-selection-toggled(int);
    callback orphan-select-all(bool);
    callback copy-select-file;
    callback copy-select-source;
    callback copy-select-dest;
    callback copy-profile;
    callback editor-select-file;
    callback editor-save;
    callback editor-preview;
    callback editor-discard;
    callback editor-restore;
    callback editor-copy-raw;
    callback editor-toggle-setting(int);
    callback editor-select-path(string);
    callback editor-edit-setting(int, string);
    callback editor-expand-all;
    callback editor-collapse-all;
    visible: root.open;
    background: #000000c4;
    private property <length> modal-width: root.width < 980px ? root.width - 48px : 900px;
    private property <length> modal-height: root.height < 738px ? root.height - 48px : 690px;
    private property <bool> confirm-discard: false;
    private property <int> discard-intent: 0;

    TouchArea {
        width: root.width;
        height: root.height;
        clicked => {
            if (root.editor-dirty && root.view == 3) {
                root.discard-intent = 1;
                root.confirm-discard = true;
            } else {
                root.open = false;
            }
        }
    }

    panel := Rectangle {
        width: root.modal-width;
        height: root.modal-height;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        border-radius: 16px;
        border-width: 1px;
        border-color: Palette.border-strong;
        background: @linear-gradient(180deg, Tokens.surface 0%, Tokens.background 100%);
        drop-shadow-blur: 34px;
        drop-shadow-offset-y: 14px;
        drop-shadow-color: #00000099;
        clip: true;

        TouchArea { width: parent.width; height: parent.height; clicked => { } }

        Text {
            x: 28px;
            y: 26px;
            width: parent.width - 96px;
            text: "SavedVariables Manager";
            color: Palette.gold;
            font-size: 18px;
            font-weight: 900;
            overflow: elide;
        }

        GhostIconButton {
            x: parent.width - 52px;
            y: 22px;
            width: 36px;
            height: 36px;
            icon: @image-url("../assets/icons/x.svg");
            clicked => {
                if (root.editor-dirty && root.view == 3) {
                    root.discard-intent = 1;
                    root.confirm-discard = true;
                } else {
                    root.open = false;
                }
            }
        }

        Hairline { x: 0px; y: 72px; width: parent.width; height: 1px; opacity: 0.5; }

        SvmTabButton { x: 28px; y: 88px; label: "Overview"; active: root.view == 0; clicked => { root.view = 0; } }
        SvmTabButton { x: 110px; y: 88px; label: "Cleanup"; active: root.view == 1; clicked => { root.view = 1; } }
        SvmTabButton { x: 192px; y: 88px; label: "Copy Profile"; active: root.view == 2; clicked => { root.view = 2; } }
        SvmTabButton { x: 306px; y: 88px; label: "Editor"; active: root.view == 3; clicked => { root.view = 3; } }

        if (root.view == 0) : Rectangle {
            x: 28px;
            y: 134px;
            width: parent.width - 56px;
            height: parent.height - 222px;
            background: #00000000;

            SvmStatCard { x: 0px; y: 0px; width: (parent.width - 24px) / 3; value: root.file-count-label; label: "FILES"; }
            SvmStatCard { x: (parent.width - 24px) / 3 + 12px; y: 0px; width: (parent.width - 24px) / 3; value: root.total-size-label; label: "TOTAL SIZE"; }
            SvmStatCard { x: ((parent.width - 24px) / 3 + 12px) * 2; y: 0px; width: (parent.width - 24px) / 3; value: root.orphan-count-label; label: "ORPHANED"; warning: root.has-orphans; }

            Rectangle {
                visible: root.has-orphans;
                x: 0px;
                y: 78px;
                width: parent.width;
                height: 42px;
                border-radius: 10px;
                border-width: 1px;
                border-color: Palette.gold-20;
                background: Palette.gold-04;

                Image { x: 14px; y: 13px; width: 16px; height: 16px; source: @image-url("../assets/icons/package.svg"); image-fit: contain; colorize: Palette.gold; }
                Text { x: 40px; y: 0px; height: parent.height; text: root.orphan-count-label + " orphaned files (" + root.orphan-size-label + ") from uninstalled addons. Clean up ->"; color: Palette.gold; font-size: 13px; font-weight: 900; vertical-alignment: center; }
                TouchArea { width: parent.width; height: parent.height; clicked => { root.view = 1; } }
            }

            Pill { x: 0px; y: 130px; label: "All files"; tone: Palette.gold; fill: Palette.gold-04; line: Palette.gold-20; pill-height: 24px; }
            Pill { x: 76px; y: 130px; label: "Orphaned " + root.orphan-count-label; tone: root.has-orphans ? Palette.gold : Palette.muted-strong; fill: Palette.white-03; line: Palette.white-08; pill-height: 24px; }
            Pill { x: 190px; y: 130px; label: "Large " + root.large-count-label; tone: Palette.muted-strong; fill: Palette.white-03; line: Palette.white-08; pill-height: 24px; }
            Text { x: parent.width - 140px; y: 136px; text: "Size"; color: Palette.muted-strong; font-size: 12px; font-weight: 750; }
            PackHubButton { x: parent.width - 88px; y: 126px; width: 88px; icon: @image-url("../assets/icons/refresh-cw.svg"); label: "Refresh"; clicked => { root.refresh(); } }

            if (!root.has-files) : Rectangle {
                x: 0px;
                y: 176px;
                width: parent.width;
                height: 312px;
                border-radius: 12px;
                background: Palette.white-02;
                clip: true;

                Text { x: 24px; y: 0px; width: parent.width - 48px; height: parent.height; text: "No SavedVariables files found."; color: Palette.muted-strong; font-size: 14px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
            }

            if (root.has-files) : ScrollView {
                x: 0px;
                y: 176px;
                width: parent.width;
                height: 312px;
                viewport-width: self.width;
                viewport-height: root.files.length * 62px;
                vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                Rectangle {
                    width: parent.width;
                    height: root.files.length * 62px;
                    border-radius: 12px;
                    background: Palette.white-02;
                    clip: true;

                    for file[index] in root.files : SvmOverviewRow {
                        x: 0px;
                        y: index * 62px;
                        width: parent.width;
                        title: file.title;
                        meta: file.meta;
                        size-label: file.size-label;
                        meter-width: file.meter-width * 1px;
                        system: file.system;
                    }
                }

                Rectangle { x: parent.width - 10px; y: 14px; width: 5px; height: 260px; border-radius: 3px; background: Palette.white-04; }
                Rectangle { x: parent.width - 10px; y: 26px; width: 5px; height: 34px; border-radius: 3px; background: Palette.sky; }
            }
        }

        if (root.view == 1) : Rectangle {
            x: 28px;
            y: 134px;
            width: parent.width - 56px;
            height: parent.height - 222px;
            background: #00000000;

            Image { x: 0px; y: 5px; width: 16px; height: 16px; source: @image-url("../assets/icons/package.svg"); image-fit: contain; colorize: Palette.gold; }
            Text { x: 24px; y: 0px; text: "Orphaned Files"; color: Palette.foreground; font-size: 16px; font-weight: 900; }
            Text { x: 184px; y: 1px; text: "(" + root.orphan-count-label + " files, " + root.orphan-size-label + ")"; color: Palette.muted-strong; font-size: 15px; font-weight: 700; }
            Text { x: 0px; y: 32px; width: parent.width - 120px; text: "These files belong to addons that are no longer installed."; color: Palette.muted-strong; font-size: 13px; font-weight: 600; }
            Text {
                x: parent.width - 92px;
                y: 4px;
                width: 92px;
                text: root.cleanup-selected-count == root.orphaned-files.length && root.orphaned-files.length > 0 ? "Clear all" : "Select all";
                color: Palette.muted-strong;
                font-size: 13px;
                font-weight: 800;
                horizontal-alignment: right;
            }
            TouchArea {
                x: parent.width - 104px;
                y: -4px;
                width: 104px;
                height: 30px;
                clicked => { root.orphan-select-all(!(root.cleanup-selected-count == root.orphaned-files.length && root.orphaned-files.length > 0)); }
            }

            if (root.orphaned-files.length == 0) : Rectangle {
                x: 0px;
                y: 62px;
                width: parent.width;
                height: 244px;
                border-radius: 12px;
                background: Palette.white-02;
                clip: true;

                Text { x: 24px; y: 0px; width: parent.width - 48px; height: parent.height; text: "No orphaned SavedVariables files found."; color: Palette.muted-strong; font-size: 14px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
            }

            if (root.orphaned-files.length > 0) : ScrollView {
                x: 0px;
                y: 62px;
                width: parent.width;
                height: 244px;
                viewport-width: self.width;
                viewport-height: root.orphaned-files.length * 64px;
                vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                Rectangle {
                    width: parent.width;
                    height: root.orphaned-files.length * 64px;
                    border-radius: 12px;
                    background: Palette.white-02;
                    clip: true;

                    for file[index] in root.orphaned-files : SvmCleanupRow {
                        x: 0px;
                        y: index * 64px;
                        width: parent.width;
                        title: file.title;
                        meta: file.size-label + " - " + file.meta;
                        checked: file.selected;
                        clicked => { root.orphan-selection-toggled(index); }
                    }
                }
                Rectangle { x: parent.width - 10px; y: 8px; width: 5px; height: 214px; border-radius: 3px; background: Palette.white-04; }
                Rectangle { x: parent.width - 10px; y: 16px; width: 5px; height: 42px; border-radius: 3px; background: Palette.sky; }
            }

            Rectangle {
                x: 0px;
                y: 322px;
                width: parent.width;
                height: 56px;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.white-06;
                background: Palette.white-03;

                Text {
                    x: 14px;
                    y: 0px;
                    height: parent.height;
                    text: root.cleanup-selected-count == 0 ? "Select files to clean up" : (root.cleanup-selected-count == 1 ? "1 file selected" : root.cleanup-selected-count + " files selected");
                    color: Palette.muted-strong;
                    font-size: 13px;
                    font-weight: 750;
                    vertical-alignment: center;
                }
                PackHubButton { x: parent.width - 116px; y: 12px; width: 102px; icon: @image-url("../assets/icons/trash-2.svg"); label: "Clean Up"; primary: true; disabled: root.cleanup-selected-count == 0; clicked => { root.clean-orphans(); } }
            }
        }

        if (root.view == 2) : Rectangle {
            x: 28px;
            y: 134px;
            width: parent.width - 56px;
            height: parent.height - 222px;
            background: #00000000;

            Text { x: 0px; y: 0px; width: parent.width; text: "Copy addon settings from one character to another within the same SavedVariables file."; color: Palette.muted-strong; font-size: 15px; font-weight: 650; }

            Text { x: 0px; y: 46px; text: "1. Select SavedVariables file"; color: Palette.muted-strong; font-size: 13px; font-weight: 800; }
            SvmSelectField {
                x: 0px;
                y: 68px;
                width: parent.width;
                label: root.copy-file-label;
                disabled: !root.copy-has-file;
                clicked => { root.copy-select-file(); }
            }

            Text { x: 0px; y: 124px; text: "2. Source character"; color: Palette.muted-strong; font-size: 13px; font-weight: 800; }
            SvmSelectField {
                x: 0px;
                y: 146px;
                width: parent.width;
                label: root.copy-source-label;
                disabled: !root.copy-has-source;
                clicked => { root.copy-select-source(); }
            }

            Text { x: 0px; y: 202px; text: "3. Destination character"; color: Palette.muted-strong; font-size: 13px; font-weight: 800; }
            SvmSelectField {
                x: 0px;
                y: 224px;
                width: parent.width;
                label: root.copy-dest-label;
                disabled: !root.copy-has-dest;
                clicked => { root.copy-select-dest(); }
            }

            Text {
                visible: root.copy-status-label != "";
                x: 0px;
                y: 272px;
                width: parent.width;
                text: root.copy-status-label;
                color: Palette.muted-strong;
                font-size: 12px;
                font-weight: 700;
                overflow: elide;
            }

            Rectangle {
                visible: root.copy-ready;
                x: 0px;
                y: 292px;
                width: parent.width;
                height: 92px;
                border-radius: 12px;
                border-width: 1px;
                border-color: Palette.gold-20;
                background: Palette.gold-04;

                Text { x: 14px; y: 16px; text: "Copy "; color: Palette.foreground; font-size: 14px; font-weight: 850; }
                Text { x: 52px; y: 16px; width: 154px; text: root.copy-source-name; color: Palette.gold; font-size: 14px; font-weight: 900; overflow: elide; }
                Text { x: 212px; y: 16px; text: "->"; color: Palette.foreground; font-size: 14px; font-weight: 850; }
                Text { x: 236px; y: 16px; width: 154px; text: root.copy-dest-name; color: Palette.sky; font-size: 14px; font-weight: 900; overflow: elide; }
                Text { x: 396px; y: 16px; width: parent.width - 410px; text: "in " + root.copy-addon-name; color: Palette.foreground; font-size: 14px; font-weight: 850; overflow: elide; }
                PackHubButton { x: 14px; y: 48px; width: 132px; icon: @image-url("../assets/icons/copy.svg"); label: "Copy Profile"; primary: true; disabled: !root.copy-ready; clicked => { root.copy-profile(); } }
            }
        }

        if (root.view == 3) : Rectangle {
            x: 28px;
            y: 126px;
            width: parent.width - 56px;
            height: parent.height - 196px;
            background: #00000000;

            SvmSelectField { x: 0px; y: 0px; width: 236px; label: root.editor-file-label; disabled: !root.editor-has-file; clicked => {
                if (root.editor-dirty) {
                    root.discard-intent = 2;
                    root.confirm-discard = true;
                } else {
                    root.editor-select-file();
                }
            } }
            // Tightened + narrower file field so all five actions fit the toolbar
            // even at reduced (high-DPI) modal widths (was clipping "Raw" off the edge).
            PackHubButton { x: 244px; y: 0px; width: 116px; icon: @image-url("../assets/icons/save.svg"); label: "Save Changes"; primary: true; disabled: !root.editor-dirty; clicked => { root.editor-save(); } }
            PackHubButton { x: 368px; y: 0px; width: 78px; icon: @image-url("../assets/icons/file-text.svg"); label: "Preview"; disabled: !root.editor-dirty; clicked => { root.editor-preview(); } }
            PackHubButton { x: 454px; y: 0px; width: 78px; icon: @image-url("../assets/icons/x.svg"); label: "Discard"; disabled: !root.editor-dirty; clicked => { root.editor-discard(); } }
            PackHubButton { x: 540px; y: 0px; width: 84px; icon: @image-url("../assets/icons/undo-2.svg"); label: "Restore"; disabled: !root.editor-has-file; clicked => { root.editor-restore(); } }
            PackHubButton { x: 632px; y: 0px; width: 72px; icon: @image-url("../assets/icons/file-text.svg"); label: "Raw"; disabled: !root.editor-has-file; clicked => { root.editor-copy-raw(); } }

            Rectangle {
                x: 0px;
                y: 50px;
                width: parent.width;
                height: 382px;
                border-radius: 12px;
                background: Palette.white-02;
                clip: true;

                Rectangle {
                    x: 0px;
                    y: 0px;
                    width: 214px;
                    height: parent.height;
                    background: Palette.white-02;
                    border-width: 0px;

                    DetailSectionTitle { x: 14px; y: 14px; width: parent.width - 28px; label: "BRANCHES"; }

                    if (root.editor-has-file) : Rectangle {
                        x: 12px;
                        y: 38px;
                        width: parent.width - 24px;
                        height: 26px;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: tree-filter-input.has-focus ? Palette.sky : Palette.white-08;
                        background: Palette.white-04;
                        clip: true;

                        Image { x: 8px; y: 7px; width: 12px; height: 12px; source: @image-url("../assets/icons/search.svg"); image-fit: contain; colorize: Palette.muted-half; }
                        Text { visible: root.editor-tree-filter == ""; x: 26px; width: parent.width - 34px; height: parent.height; text: "Filter branches..."; color: Palette.muted-half; font-size: 11px; font-weight: 700; vertical-alignment: center; overflow: elide; }
                        tree-filter-input := TextInput {
                            x: 26px;
                            y: 0px;
                            width: parent.width - 34px;
                            height: parent.height;
                            text: root.editor-tree-filter;
                            color: Palette.foreground;
                            font-size: 11px;
                            font-family: "Geist";
                            single-line: true;
                            vertical-alignment: center;
                            selection-background-color: Palette.sky-25;
                            edited => {
                                root.editor-tree-filter = self.text;
                                root.editor-tree-filter-edited(self.text);
                            }
                        }
                    }

                    if (!root.editor-has-file) : Text { x: 16px; y: 62px; width: parent.width - 32px; text: "No SavedVariables files found."; color: Palette.muted-strong; font-size: 12px; font-weight: 800; horizontal-alignment: center; }

                    if (root.editor-has-file) : ScrollView {
                        x: 0px;
                        y: 72px;
                        width: parent.width;
                        height: parent.height - 106px;
                        viewport-width: self.width;
                        viewport-height: max(root.editor-tree.length * 28px, self.height);
                        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                        for row[index] in root.editor-tree : SvmEditorTreeRow {
                            x: 10px;
                            y: index * 28px;
                            width: parent.width - 20px;
                            label: row.label;
                            path: row.path;
                            count: row.count;
                            indent: row.indent;
                            active: row.active;
                            expanded: row.expanded;
                            clicked(path) => { root.editor-select-path(path); }
                        }
                    }

                    Rectangle { x: parent.width - 8px; y: 82px; width: 5px; height: 246px; border-radius: 3px; background: Palette.white-04; visible: root.editor-tree.length * 28px > parent.height - 106px; }
                    Rectangle { x: parent.width - 8px; y: 96px; width: 5px; height: 142px; border-radius: 3px; background: Palette.sky; visible: root.editor-tree.length * 28px > parent.height - 106px; }

                    Hairline { x: 0px; y: parent.height - 34px; width: parent.width; height: 1px; opacity: 0.45; }
                    Text { x: 34px; y: parent.height - 24px; text: "Expand All"; color: Palette.muted-strong; font-size: 11px; font-weight: 800; }
                    TouchArea { x: 24px; y: parent.height - 32px; width: 78px; height: 28px; clicked => { root.editor-expand-all(); } }
                    Text { x: parent.width - 86px; y: parent.height - 24px; text: "Collapse All"; color: Palette.muted-strong; font-size: 11px; font-weight: 800; }
                    TouchArea { x: parent.width - 100px; y: parent.height - 32px; width: 92px; height: 28px; clicked => { root.editor-collapse-all(); } }
                }

                Hairline { x: 214px; y: 0px; width: 1px; height: parent.height; opacity: 0.45; }

                Rectangle {
                    x: 226px;
                    y: 14px;
                    width: parent.width - 246px;
                    height: 30px;
                    border-radius: 9px;
                    background: Palette.white-03;

                    Text { x: 12px; y: 0px; height: parent.height; width: parent.width - 24px; text: root.editor-path-label; color: Palette.muted-strong; font-size: 12px; font-weight: 800; vertical-alignment: center; overflow: elide; }
                }

                Text { x: 226px; y: 58px; text: "SETTINGS"; color: Palette.muted-strong; font-size: 11px; font-weight: 900; }

                if (root.editor-settings.length == 0) : Text {
                    x: 226px;
                    y: 104px;
                    width: parent.width - 246px;
                    text: root.editor-message-label;
                    color: Palette.muted-strong;
                    font-size: 13px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    overflow: elide;
                }

                if (root.editor-settings.length > 0) : ScrollView {
                    x: 226px;
                    y: 84px;
                    width: parent.width - 246px;
                    height: 282px;
                    viewport-width: self.width;
                    viewport-height: max(root.editor-settings.length * 42px, self.height);
                    vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                    for setting[index] in root.editor-settings : SvmSettingRow {
                        x: 0px;
                        y: index * 42px;
                        width: parent.width;
                        label: setting.label;
                        key-name: setting.key-name;
                        kind: setting.kind;
                        value: setting.value;
                        checked: setting.checked;
                        clicked => { root.editor-toggle-setting(index); }
                        value-edited(value) => { root.editor-edit-setting(index, value); }
                    }
                }

                Rectangle { x: parent.width - 14px; y: 64px; width: 5px; height: 286px; border-radius: 3px; background: Palette.white-04; visible: root.editor-settings.length * 42px > 282px; }
                Rectangle { x: parent.width - 14px; y: 80px; width: 5px; height: 72px; border-radius: 3px; background: Palette.sky; visible: root.editor-settings.length * 42px > 282px; }
            }
        }

        Rectangle {
            x: 0px;
            y: parent.height - 76px;
            width: parent.width;
            height: 76px;
            background: @linear-gradient(0deg, Tokens.surface 0%, Tokens.surface-84 72%, #00000000 100%);

            PackHubButton { x: parent.width - 96px; y: 22px; width: 68px; icon: @image-url("../assets/icons/x.svg"); label: "Close"; show-icon: false; clicked => {
                if (root.editor-dirty && root.view == 3) {
                    root.discard-intent = 1;
                    root.confirm-discard = true;
                } else {
                    root.open = false;
                }
            } }
        }

        if (root.confirm-discard) : Rectangle {
            width: parent.width;
            height: parent.height;
            background: #000000b4;

            TouchArea { width: parent.width; height: parent.height; clicked => { } }

            Rectangle {
                width: 372px;
                height: 172px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                border-radius: 14px;
                border-width: 1px;
                border-color: Palette.border-strong;
                background: Tokens.surface;
                drop-shadow-blur: 26px;
                drop-shadow-offset-y: 10px;
                drop-shadow-color: #00000099;

                Text { x: 24px; y: 24px; width: parent.width - 48px; text: "Discard unsaved changes?"; color: Palette.foreground; font-size: 15px; font-weight: 900; }
                Text { x: 24px; y: 54px; width: parent.width - 48px; height: 44px; text: "Your edits to this file have not been saved. Discarding will lose them."; color: Palette.muted-strong; font-size: 12px; font-weight: 600; wrap: word-wrap; }

                PackHubButton { x: 24px; y: parent.height - 52px; width: 158px; icon: @image-url("../assets/icons/trash-2.svg"); label: "Discard"; danger: true; clicked => {
                    root.confirm-discard = false;
                    if (root.discard-intent == 2) {
                        root.editor-select-file();
                    } else {
                        root.open = false;
                    }
                    root.discard-intent = 0;
                } }
                PackHubButton { x: parent.width - 182px; y: parent.height - 52px; width: 158px; icon: @image-url("../assets/icons/undo-2.svg"); label: "Keep editing"; primary: true; clicked => {
                    root.confirm-discard = false;
                    root.discard-intent = 0;
                } }
            }
        }
    }
}

component Header inherits Rectangle {
    in property <int> addons-count: 113;
    in-out property <int> displayed-addons-count: 113;
    in property <length> chrome-width: 1462px;
    in property <bool> batch-active: false;
    in property <int> selected-count: 0;
    in property <bool> loading: false;
    in property <bool> checking-updates: false;
    in-out property <angle> spinner-angle: 0deg;
    callback minimize-requested;
    callback maximize-requested;
    callback close-requested;
    callback batch-update;
    callback batch-disable;
    callback batch-tag;
    callback batch-remove;
    callback batch-clear;
    callback refresh-requested;
    callback open-pack-hub-clicked;
    callback open-svm-clicked;
    callback open-uploader-clicked;
    callback open-settings-clicked;
    callback window-drag;
    callback window-toggle-maximize;

    background: @linear-gradient(180deg, Tokens.bg-base-85 0%, Tokens.bg-base-60 100%);
    height: 48px;
    drop-shadow-blur: 18px;
    drop-shadow-offset-y: 4px;
    drop-shadow-color: #00000066;

    Rectangle {
        width: root.width;
        height: 1px;
        background: #ffffff0d;
    }

    Hairline { y: root.height - 1px; width: root.width; height: 1px; opacity: 0.5; }

    Rectangle {
        x: 0px;
        y: root.height - 1px;
        width: root.width;
        height: 1px;
        background: @linear-gradient(90deg, #00000000 0%, Palette.gold-20 50%, #00000000 100%);
    }

    // Frameless-window drag region. Declared before the header controls so the
    // icon buttons (later siblings) stay on top and remain clickable; empty
    // header space initiates a native window move / double-click maximize.
    TouchArea {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        mouse-cursor: default;
        // Start the native window move only once the pointer actually starts
        // dragging, so a plain click still selects and a double-click can
        // toggle maximize without an accidental move.
        moved => {
            root.window-drag();
        }
        double-clicked => {
            root.window-toggle-maximize();
        }
    }

    spinner-timer := Timer {
        interval: Tokens.low-memory-preset ? 120ms : 16ms;
        running: (root.loading || root.checking-updates) && !Tokens.reduced-motion;
        triggered => {
            if (root.spinner-angle >= 354deg) {
                root.spinner-angle = 0deg;
            } else {
                root.spinner-angle += Tokens.low-memory-preset ? 45deg : 6deg;
            }
        }
    }

    count-timer := Timer {
        interval: 33ms;
        running: root.displayed-addons-count != root.addons-count;
        triggered => {
            if (Tokens.reduced-motion || Tokens.low-memory-preset) {
                root.displayed-addons-count = root.addons-count;
            } else if (root.displayed-addons-count < root.addons-count) {
                root.displayed-addons-count += min(8, root.addons-count - root.displayed-addons-count);
            } else if (root.displayed-addons-count > root.addons-count) {
                root.displayed-addons-count -= min(8, root.displayed-addons-count - root.addons-count);
            }
        }
    }

    Image {
        x: 16px;
        y: 13px;
        width: 20px;
        height: 20px;
        source: @image-url("../../../src/assets/logo-icon.svg");
        image-fit: contain;
    }

    Text {
        x: 45px;
        y: 14px;
        text: "K A L P A";
        color: Palette.gold;
        font-family: "Space Grotesk Light";
        font-size: 13px;
        font-weight: 900;
    }

    Rectangle { x: 104px; y: 15px; width: 1px; height: 18px; background: Palette.white-06; }

    Rectangle {
        x: 114px;
        y: 12px;
        width: 72px;
        height: 24px;
        border-radius: 12px;
        border-width: 0px;
        background: Palette.white-04;

        Text {
            width: parent.width;
            height: parent.height;
            text: "esotk.com";
            color: Palette.muted-dim;
            font-size: 10px;
            font-weight: 500;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        visible: !root.batch-active;
        x: root.chrome-width - 410px;
        y: 15px;
        width: 90px;
        text: root.displayed-addons-count + " addons";
        color: Palette.muted-dim;
        font-family: "Space Grotesk Light";
        font-size: 12px;
        font-weight: 700;
    }

    if (root.checking-updates) : Text {
        visible: !root.batch-active;
        x: root.chrome-width - 328px;
        y: 15px;
        text: ".";
        color: Palette.muted-dim;
        font-size: 12px;
        font-weight: 700;
    }

    HeaderIcon { visible: !root.batch-active; x: root.chrome-width - 292px; y: 10px; width: 28px; height: 28px; icon: @image-url("../assets/icons/refresh-cw.svg"); rotation: root.loading || root.checking-updates ? root.spinner-angle : 0deg; clicked => { root.refresh-requested(); } }
    HeaderIcon { visible: !root.batch-active; x: root.chrome-width - 256px; y: 10px; width: 28px; height: 28px; icon: @image-url("../assets/icons/package.svg"); clicked => { root.open-pack-hub-clicked(); } }
    HeaderIcon { visible: !root.batch-active; x: root.chrome-width - 220px; y: 10px; width: 28px; height: 28px; icon: @image-url("../assets/icons/file-sliders.svg"); clicked => { root.open-svm-clicked(); } }
    HeaderIcon { visible: !root.batch-active; x: root.chrome-width - 184px; y: 10px; width: 28px; height: 28px; icon: @image-url("../assets/icons/cloud-upload.svg"); clicked => { root.open-uploader-clicked(); } }
    HeaderIcon { visible: !root.batch-active; x: root.chrome-width - 148px; y: 10px; width: 28px; height: 28px; icon: @image-url("../assets/icons/settings.svg"); clicked => { root.open-settings-clicked(); } }

    if (root.batch-active) : Text {
        x: root.chrome-width - 560px;
        y: 15px;
        width: 92px;
        text: root.selected-count + " selected";
        color: Palette.gold;
        font-size: 12px;
        font-weight: 700;
        horizontal-alignment: right;
    }

    if (root.batch-active) : SmallAction {
        x: root.chrome-width - 456px;
        y: 12px;
        label: "Update";
        tone: Palette.gold;
        fill: Palette.gold-10;
        fill-hover: Palette.gold-15;
        fill-pressed: Palette.gold-20;
        line: Palette.gold-20;
        clicked => { root.batch-update(); }
    }

    if (root.batch-active) : SmallAction {
        x: root.chrome-width - 392px;
        y: 12px;
        label: "Disable";
        tone: Palette.amber;
        fill: Palette.amber-04;
        fill-hover: Palette.amber-15;
        fill-pressed: Palette.amber-20;
        line: Palette.amber-20;
        clicked => { root.batch-disable(); }
    }

    if (root.batch-active) : SmallAction {
        x: root.chrome-width - 318px;
        y: 12px;
        label: "Tag";
        tone: Palette.sky;
        fill: Palette.sky-10;
        fill-hover: Palette.sky-16;
        fill-pressed: Palette.sky-22;
        line: Palette.sky-20;
        clicked => { root.batch-tag(); }
    }

    if (root.batch-active) : SmallAction {
        x: root.chrome-width - 272px;
        y: 12px;
        label: "Remove";
        tone: Palette.red;
        fill: Palette.red-04;
        fill-hover: Palette.red-15;
        fill-pressed: Palette.red-20;
        line: Palette.red-20;
        clicked => { root.batch-remove(); }
    }

    if (root.batch-active) : GhostIconButton {
        x: root.chrome-width - 180px;
        y: 10px;
        icon: @image-url("../assets/icons/x.svg");
        clicked => { root.batch-clear(); }
    }
    HeaderIcon { x: root.chrome-width - 104px; y: 8px; width: 32px; height: 32px; icon: @image-url("../assets/icons/minus.svg"); clicked => { root.minimize-requested(); } }
    HeaderIcon { x: root.chrome-width - 72px; y: 8px; width: 32px; height: 32px; icon: @image-url("../assets/icons/square.svg"); clicked => { root.maximize-requested(); } }
    HeaderIcon { x: root.chrome-width - 40px; y: 8px; width: 32px; height: 32px; icon: @image-url("../assets/icons/x.svg"); close: true; clicked => { root.close-requested(); } }
}

component Sidebar inherits Rectangle {
    forward-focus: list-key-focus;
    in property <[AddonEntry]> addons;
    in property <[DiscoverEntry]> discover-results;
    in property <bool> batch-active: false;
    in-out property <int> selected-index: 0;
    in-out property <int> selected-discover-index: 0;
    in-out property <bool> discover-active: false;
    in-out property <string> addon-search-query;
    in-out property <int> filter-mode: 0;
    in-out property <int> sort-mode: 0;
    in-out property <bool> sort-menu-open: false;
    in-out property <int> discover-tab: 0;
    in-out property <string> discover-query;
    in-out property <string> discover-url-input;
    in-out property <string> discover-category-filter;
    in-out property <int> discover-popular-sort: 0;
    in-out property <string> discover-category-label: "Combat";
    in-out property <string> discover-category-sort-label: "Downloads";
    in-out property <[DiscoverSelectOption]> discover-category-options;
    in-out property <[DiscoverSelectOption]> discover-category-sort-options;
    in-out property <bool> discover-browse-loading: false;
    in-out property <bool> discover-browse-has-more: false;
    in-out property <string> discover-browse-message;
    in property <int> total-addon-count: 0;
    in property <int> addon-kind-count: 0;
    in property <int> library-kind-count: 0;
    in property <int> favorite-addon-count: 0;
    in property <int> outdated-addon-count: 0;
    in property <int> issue-addon-count: 0;
    in property <int> disabled-addon-count: 0;
    in property <int> testing-tag-count: 0;
    in property <int> broken-tag-count: 0;
    in property <int> essential-tag-count: 0;
    in property <int> raid-tag-count: 0;
    callback addon-selected(int);
    callback addon-selection-toggled(int);
    callback addon-context-open-folder(int);
    callback addon-context-open-esoui(int);
    callback addon-context-favorite(int);
    callback addon-context-toggle-disable(int);
    callback addon-context-remove(int);
    callback addon-search-edited(string);
    callback filter-selected(int);
    callback sort-selected(int);
    callback discover-tab-selected(int);
    callback discover-selected(int);
    callback discover-install(int);
    callback discover-query-edited(string);
    callback discover-url-edited(string);
    callback discover-category-filter-edited(string);
    callback discover-popular-sort-selected(int);
    callback discover-category-next;
    callback discover-category-sort-next;
    callback discover-category-selected(int);
    callback discover-category-sort-selected(int);
    callback discover-load-more;
    callback discover-browse-retry;
    private property <string> count-label: root.addons.length == 1 ? "1 ADDON" : root.addons.length + " ADDONS";
    private property <string> sort-label: sort-mode == 1 ? "Author" : (sort-mode == 2 ? "Recently Updated" : (sort-mode == 3 ? "Recently Downloaded" : "Name"));
    private property <bool> compact-discover-chrome: root.discover-active && (root.discover-tab == 1 || root.discover-tab == 2);
    private property <length> discover-panel-y: root.compact-discover-chrome ? 86px : 165px;
    background: Tokens.low-memory-preset ? Tokens.background : @linear-gradient(180deg, Tokens.bg-base-85 0%, Tokens.background 52%, Tokens.bg-base-85 100%);

    Hairline { x: root.width - 1px; width: 1px; height: root.height; opacity: 0.5; }

    Rectangle {
        x: 0px;
        y: 0px;
        width: root.width;
        height: 126px;
        visible: !Tokens.low-memory-preset;
        background: @linear-gradient(180deg, Palette.white-04 0%, #00000000 100%);
    }

    Rectangle {
        x: 12px;
        y: 12px;
        width: root.width - 24px;
        height: 36px;
        border-radius: 12px;
        border-width: 0px;
        background: Palette.white-04;
        inner-shadow-offset-y: 1px;
        inner-shadow-blur: 1px;
        inner-shadow-color: #00000026;

        Rectangle {
            x: root.discover-active ? parent.width / 2 : 4px;
            y: 4px;
            width: (parent.width - 8px) / 2;
            height: 28px;
            border-radius: 8px;
            border-width: 0px;
            background: Palette.white-08;
            drop-shadow-blur: 4px;
            drop-shadow-offset-y: 1px;
            drop-shadow-color: #00000040;

            animate x { duration: Tokens.low-memory-preset ? 0ms : 180ms; easing: ease-in-out; }

            Text {
                width: parent.width;
                height: parent.height;
                text: root.discover-active ? "Discover" : "My Addons";
                color: Palette.foreground;
                font-size: 13px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;

                animate color { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
            }
        }

        Text {
            x: root.discover-active ? 0px : parent.width / 2;
            y: 0px;
            width: parent.width / 2;
            height: parent.height;
            text: root.discover-active ? "My Addons" : "Discover";
            color: Palette.muted;
            font-size: 13px;
            font-weight: 500;
            horizontal-alignment: center;
            vertical-alignment: center;

            animate color { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
        }

        TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width / 2;
            height: parent.height;
            clicked => { root.discover-active = false; }
        }

        TouchArea {
            x: parent.width / 2;
            y: 0px;
            width: parent.width / 2;
            height: parent.height;
            clicked => { root.discover-active = true; }
        }
    }

    Rectangle {
        x: 12px;
        y: 56px;
        width: root.width - 24px;
        height: 34px;
        border-radius: 10px;
        border-width: 1px;
        border-color: Palette.white-08;
        visible: !root.compact-discover-chrome && (!root.discover-active || root.discover-tab == 0 || root.discover-tab == 3);
        background: root.discover-active && (root.discover-tab == 0 || root.discover-tab == 3) ? Palette.white-06 : Palette.white-04;
        inner-shadow-offset-y: 0px;
        inner-shadow-blur: 0px;
        inner-shadow-color: #00000000;
        clip: true;

        animate background, border-color { duration: Tokens.low-memory-preset ? 0ms : 90ms; easing: ease-in-out; }

        Image {
            visible: !(root.discover-active && root.discover-tab == 3);
            x: 13px;
            y: 11px;
            width: 14px;
            height: 14px;
            source: @image-url("../assets/icons/search.svg");
            image-fit: contain;
            colorize: root.discover-active && root.discover-tab == 0 ? Palette.muted-strong : Palette.muted-half;
        }

        Image {
            visible: root.discover-active && root.discover-tab == 3;
            x: 13px;
            y: 11px;
            width: 14px;
            height: 14px;
            source: @image-url("../assets/icons/link.svg");
            image-fit: contain;
            colorize: Palette.muted-strong;
        }

        Text {
            visible: root.discover-active ? (root.discover-tab == 0 ? root.discover-query == "" : (root.discover-tab == 3 ? root.discover-url-input == "" : true)) : root.addon-search-query == "";
            x: 36px;
            width: parent.width - 48px;
            height: parent.height;
            text: root.discover-active ? (root.discover-tab == 1 ? "Browse popular ESOUI addons" : (root.discover-tab == 2 ? "Browse ESOUI categories" : (root.discover-tab == 3 ? "Paste ESOUI URL or ID" : "Search ESOUI addons..."))) : "Search addons...";
            color: Palette.muted-strong;
            font-size: 13px;
            font-weight: 600;
            vertical-alignment: center;
        }

        // Visible TextInput (draws its own caret) — replaces the opacity:0.01
        // invisible-TextEdit + separate display-Text hack.
        TextInput {
            visible: !root.discover-active;
            x: 36px;
            y: 0px;
            width: parent.width - 48px;
            height: parent.height;
            text: root.addon-search-query;
            color: Palette.foreground;
            font-size: 14px;
            font-family: "Geist";
            single-line: true;
            vertical-alignment: center;
            selection-background-color: Palette.sky-25;
            edited => {
                root.addon-search-query = self.text;
                root.addon-search-edited(self.text);
            }
        }

        TextInput {
            visible: root.discover-active && (root.discover-tab == 0 || root.discover-tab == 3);
            x: 36px;
            y: 0px;
            width: parent.width - 48px;
            height: parent.height;
            text: root.discover-tab == 3 ? root.discover-url-input : root.discover-query;
            color: Palette.foreground;
            font-size: 14px;
            font-family: "Geist";
            single-line: true;
            vertical-alignment: center;
            selection-background-color: Palette.sky-25;
            edited => {
                if (root.discover-tab == 3) {
                    root.discover-url-input = self.text;
                    root.discover-url-edited(self.text);
                } else {
                    root.discover-query = self.text;
                    root.discover-query-edited(self.text);
                }
            }
        }

    }

    if (!root.discover-active) : Rectangle {
        x: 12px;
        y: 100px;
        // 24px tab row + a thin scrollbar beneath it; still clears the y:134 hairline.
        width: root.width - 24px;
        height: 33px;
        background: #00000000;
        clip: true;

        filters-scroll := ScrollView {
            width: parent.width;
            height: 24px;
            viewport-width: raid-filter.x + (root.raid-tag-count > 0 ? raid-filter.width : 0px);
            viewport-height: 24px;
            // Scrollbar off — an as-needed bar overlaps the 24px tab row. Overflowed
            // tag filters remain reachable by dragging the strip.
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;

            private property <length> gap: 4px;
            private property <length> addons-x: all-filter.width + self.gap;
            private property <length> libs-x: self.addons-x + addons-filter.width + self.gap;
            private property <length> favorites-x: self.libs-x + libs-filter.width + self.gap;
            private property <length> outdated-x: self.favorites-x + (root.favorite-addon-count > 0 ? favorites-filter.width + self.gap : 0px);
            private property <length> issues-x: self.outdated-x + (root.outdated-addon-count > 0 ? outdated-filter.width + self.gap : 0px);
            private property <length> disabled-x: self.issues-x + (root.issue-addon-count > 0 ? issues-filter.width + self.gap : 0px);
            private property <length> testing-x: self.disabled-x + (root.disabled-addon-count > 0 ? disabled-filter.width + self.gap : 0px);
            private property <length> broken-x: self.testing-x + (root.testing-tag-count > 0 ? testing-filter.width + self.gap : 0px);
            private property <length> essential-x: self.broken-x + (root.broken-tag-count > 0 ? broken-filter.width + self.gap : 0px);
            private property <length> raid-x: self.essential-x + (root.essential-tag-count > 0 ? essential-filter.width + self.gap : 0px);
            private property <length> active-x: root.filter-mode == 1 ? self.addons-x : (root.filter-mode == 2 ? self.libs-x : (root.filter-mode == 3 ? self.favorites-x : (root.filter-mode == 4 ? self.outdated-x : (root.filter-mode == 5 ? self.issues-x : (root.filter-mode == 6 ? self.disabled-x : (root.filter-mode == 7 ? self.testing-x : (root.filter-mode == 8 ? self.broken-x : (root.filter-mode == 9 ? self.essential-x : (root.filter-mode == 10 ? self.raid-x : 0px)))))))));
            private property <length> active-width: root.filter-mode == 1 ? addons-filter.width : (root.filter-mode == 2 ? libs-filter.width : (root.filter-mode == 3 ? favorites-filter.width : (root.filter-mode == 4 ? outdated-filter.width : (root.filter-mode == 5 ? issues-filter.width : (root.filter-mode == 6 ? disabled-filter.width : (root.filter-mode == 7 ? testing-filter.width : (root.filter-mode == 8 ? broken-filter.width : (root.filter-mode == 9 ? essential-filter.width : (root.filter-mode == 10 ? raid-filter.width : all-filter.width)))))))));

            Rectangle {
                visible: root.filter-mode != 0 && all-touch.has-hover;
                width: all-filter.width;
                height: 24px;
                border-radius: 8px;
                background: Palette.white-04;
            }

            Rectangle {
                visible: root.filter-mode != 1 && addons-touch.has-hover;
                x: filters-scroll.addons-x;
                width: addons-filter.width;
                height: 24px;
                border-radius: 8px;
                background: Palette.white-04;
            }

            Rectangle {
                visible: root.filter-mode != 2 && libs-touch.has-hover;
                x: filters-scroll.libs-x;
                width: libs-filter.width;
                height: 24px;
                border-radius: 8px;
                background: Palette.white-04;
            }

            Rectangle {
                visible: root.favorite-addon-count > 0 && root.filter-mode != 3 && favorites-touch.has-hover;
                x: filters-scroll.favorites-x;
                width: favorites-filter.width;
                height: 24px;
                border-radius: 8px;
                background: Palette.white-04;
            }

            Rectangle {
                visible: root.outdated-addon-count > 0 && root.filter-mode != 4 && outdated-touch.has-hover;
                x: filters-scroll.outdated-x;
                width: outdated-filter.width;
                height: 24px;
                border-radius: 8px;
                background: Palette.white-04;
            }

            Rectangle {
                visible: root.issue-addon-count > 0 && root.filter-mode != 5 && issues-touch.has-hover;
                x: filters-scroll.issues-x;
                width: issues-filter.width;
                height: 24px;
                border-radius: 8px;
                background: Palette.white-04;
            }

            Rectangle {
                visible: root.disabled-addon-count > 0 && root.filter-mode != 6 && disabled-touch.has-hover;
                x: filters-scroll.disabled-x;
                width: disabled-filter.width;
                height: 24px;
                border-radius: 8px;
                background: Palette.white-04;
            }

            Rectangle {
                visible: root.testing-tag-count > 0 && root.filter-mode != 7 && testing-touch.has-hover;
                x: filters-scroll.testing-x;
                width: testing-filter.width;
                height: 24px;
                border-radius: 8px;
                background: Palette.white-04;
            }

            Rectangle {
                visible: root.broken-tag-count > 0 && root.filter-mode != 8 && broken-touch.has-hover;
                x: filters-scroll.broken-x;
                width: broken-filter.width;
                height: 24px;
                border-radius: 8px;
                background: Palette.white-04;
            }

            Rectangle {
                visible: root.essential-tag-count > 0 && root.filter-mode != 9 && essential-touch.has-hover;
                x: filters-scroll.essential-x;
                width: essential-filter.width;
                height: 24px;
                border-radius: 8px;
                background: Palette.white-04;
            }

            Rectangle {
                visible: root.raid-tag-count > 0 && root.filter-mode != 10 && raid-touch.has-hover;
                x: filters-scroll.raid-x;
                width: raid-filter.width;
                height: 24px;
                border-radius: 8px;
                background: Palette.white-04;
            }

            Rectangle {
                x: filters-scroll.active-x;
                width: filters-scroll.active-width;
                height: 24px;
                border-radius: 8px;
                background: Palette.gold-10;
                drop-shadow-blur: 0px;
                drop-shadow-color: #00000000;

                animate x, width { duration: Tokens.low-memory-preset ? 0ms : 180ms; easing: ease-in-out; }
            }

            all-filter := FilterTab { x: 0px; label: "All (" + root.total-addon-count + ")"; active: root.filter-mode == 0; hovered: all-touch.has-hover; }
            addons-filter := FilterTab { x: filters-scroll.addons-x; label: "Addons (" + root.addon-kind-count + ")"; active: root.filter-mode == 1; hovered: addons-touch.has-hover; }
            libs-filter := FilterTab { x: filters-scroll.libs-x; label: "Libs (" + root.library-kind-count + ")"; active: root.filter-mode == 2; hovered: libs-touch.has-hover; }
            favorites-filter := FilterTab { visible: root.favorite-addon-count > 0; x: filters-scroll.favorites-x; label: "★ (" + root.favorite-addon-count + ")"; active: root.filter-mode == 3; hovered: favorites-touch.has-hover; }
            outdated-filter := FilterTab { visible: root.outdated-addon-count > 0; x: filters-scroll.outdated-x; label: "Outdated (" + root.outdated-addon-count + ")"; active: root.filter-mode == 4; hovered: outdated-touch.has-hover; }
            issues-filter := FilterTab { visible: root.issue-addon-count > 0; x: filters-scroll.issues-x; label: "Issues (" + root.issue-addon-count + ")"; active: root.filter-mode == 5; hovered: issues-touch.has-hover; }
            disabled-filter := FilterTab { visible: root.disabled-addon-count > 0; x: filters-scroll.disabled-x; label: "Disabled (" + root.disabled-addon-count + ")"; active: root.filter-mode == 6; hovered: disabled-touch.has-hover; }
            testing-filter := FilterTab { visible: root.testing-tag-count > 0; x: filters-scroll.testing-x; label: "testing (" + root.testing-tag-count + ")"; active: root.filter-mode == 7; hovered: testing-touch.has-hover; }
            broken-filter := FilterTab { visible: root.broken-tag-count > 0; x: filters-scroll.broken-x; label: "broken (" + root.broken-tag-count + ")"; active: root.filter-mode == 8; hovered: broken-touch.has-hover; }
            essential-filter := FilterTab { visible: root.essential-tag-count > 0; x: filters-scroll.essential-x; label: "essential (" + root.essential-tag-count + ")"; active: root.filter-mode == 9; hovered: essential-touch.has-hover; }
            raid-filter := FilterTab { visible: root.raid-tag-count > 0; x: filters-scroll.raid-x; label: "raid (" + root.raid-tag-count + ")"; active: root.filter-mode == 10; hovered: raid-touch.has-hover; }

            all-touch := TouchArea {
                x: 0px;
                width: all-filter.width;
                height: parent.height;
                clicked => {
                    root.filter-mode = 0;
                    root.filter-selected(0);
                }
            }

            addons-touch := TouchArea {
                x: filters-scroll.addons-x;
                width: addons-filter.width;
                height: parent.height;
                clicked => {
                    root.filter-mode = 1;
                    root.filter-selected(1);
                }
            }

            libs-touch := TouchArea {
                x: filters-scroll.libs-x;
                width: libs-filter.width;
                height: parent.height;
                clicked => {
                    root.filter-mode = 2;
                    root.filter-selected(2);
                }
            }

            favorites-touch := TouchArea {
                visible: root.favorite-addon-count > 0;
                x: filters-scroll.favorites-x;
                width: favorites-filter.width;
                height: parent.height;
                clicked => {
                    root.filter-mode = 3;
                    root.filter-selected(3);
                }
            }

            outdated-touch := TouchArea {
                visible: root.outdated-addon-count > 0;
                x: filters-scroll.outdated-x;
                width: outdated-filter.width;
                height: parent.height;
                clicked => {
                    root.filter-mode = 4;
                    root.filter-selected(4);
                }
            }

            issues-touch := TouchArea {
                visible: root.issue-addon-count > 0;
                x: filters-scroll.issues-x;
                width: issues-filter.width;
                height: parent.height;
                clicked => {
                    root.filter-mode = 5;
                    root.filter-selected(5);
                }
            }

            disabled-touch := TouchArea {
                visible: root.disabled-addon-count > 0;
                x: filters-scroll.disabled-x;
                width: disabled-filter.width;
                height: parent.height;
                clicked => {
                    root.filter-mode = 6;
                    root.filter-selected(6);
                }
            }

            testing-touch := TouchArea {
                visible: root.testing-tag-count > 0;
                x: filters-scroll.testing-x;
                width: testing-filter.width;
                height: parent.height;
                clicked => {
                    root.filter-mode = 7;
                    root.filter-selected(7);
                }
            }

            broken-touch := TouchArea {
                visible: root.broken-tag-count > 0;
                x: filters-scroll.broken-x;
                width: broken-filter.width;
                height: parent.height;
                clicked => {
                    root.filter-mode = 8;
                    root.filter-selected(8);
                }
            }

            essential-touch := TouchArea {
                visible: root.essential-tag-count > 0;
                x: filters-scroll.essential-x;
                width: essential-filter.width;
                height: parent.height;
                clicked => {
                    root.filter-mode = 9;
                    root.filter-selected(9);
                }
            }

            raid-touch := TouchArea {
                visible: root.raid-tag-count > 0;
                x: filters-scroll.raid-x;
                width: raid-filter.width;
                height: parent.height;
                clicked => {
                    root.filter-mode = 10;
                    root.filter-selected(10);
                }
            }
        }

        // Thin draggable scrollbar for the filter strip. The tab TouchAreas swallow
        // drag and wheel gestures, so overflowing filters (broken, essential, raid…)
        // are otherwise unreachable — this exposes them without covering the tab row.
        if (filters-scroll.viewport-width > filters-scroll.width) : Rectangle {
            x: 0px;
            y: 25px;
            width: parent.width;
            // 8px hit zone so the thin bar is easy to grab; the visible bar is 3px.
            height: 8px;
            background: transparent;

            Rectangle {
                y: 2px;
                width: parent.width;
                height: 3px;
                border-radius: 1.5px;
                background: Palette.white-04;
            }

            filter-thumb := Rectangle {
                y: 2px;
                height: 3px;
                width: max(28px, parent.width * filters-scroll.width / filters-scroll.viewport-width);
                x: (parent.width - self.width) * (-filters-scroll.viewport-x / max(1px, filters-scroll.viewport-width - filters-scroll.width));
                border-radius: 1.5px;
                background: Tokens.primary.with-alpha(0.65);
            }

            TouchArea {
                property <length> anchor-vp;
                property <length> anchor-mouse;
                mouse-cursor: pointer;
                pointer-event(ev) => {
                    if (ev.kind == PointerEventKind.down) {
                        self.anchor-vp = filters-scroll.viewport-x;
                        self.anchor-mouse = self.mouse-x;
                    }
                }
                moved => {
                    if (self.pressed) {
                        filters-scroll.viewport-x = min(0px, max(
                            -(filters-scroll.viewport-width - filters-scroll.width),
                            self.anchor-vp - (self.mouse-x - self.anchor-mouse) * (filters-scroll.viewport-width - filters-scroll.width) / max(1px, parent.width - filter-thumb.width)
                        ));
                    }
                }
            }
        }
    }

    if (root.discover-active) : Rectangle {
        x: 12px;
        y: root.compact-discover-chrome ? 56px : 100px;
        width: root.width - 24px;
        height: 24px;
        background: #00000000;
        private property <length> tab-gap: 4px;
        private property <length> tab-w: (self.width - self.tab-gap * 3) / 4;

        DiscoverSubTab {
            x: 0px;
            width: parent.tab-w;
            icon: @image-url("../assets/icons/search.svg");
            label: "Search";
            active: root.discover-tab == 0;
            clicked => {
                root.discover-tab = 0;
                root.discover-tab-selected(0);
            }
        }

        DiscoverSubTab {
            x: parent.tab-w + parent.tab-gap;
            width: parent.tab-w;
            icon: @image-url("../assets/icons/flame.svg");
            label: "Popular";
            active: root.discover-tab == 1;
            clicked => {
                root.discover-tab = 1;
                root.discover-tab-selected(1);
            }
        }

        DiscoverSubTab {
            x: (parent.tab-w + parent.tab-gap) * 2;
            width: parent.tab-w;
            icon: @image-url("../assets/icons/folder-open.svg");
            label: "Category";
            active: root.discover-tab == 2;
            clicked => {
                root.discover-tab = 2;
                root.discover-tab-selected(2);
            }
        }

        DiscoverSubTab {
            x: (parent.tab-w + parent.tab-gap) * 3;
            width: parent.tab-w;
            icon: @image-url("../assets/icons/link.svg");
            label: "URL / ID";
            active: root.discover-tab == 3;
            clicked => {
                root.discover-tab = 3;
                root.discover-tab-selected(3);
            }
        }
    }

    Hairline { visible: !root.compact-discover-chrome; y: 134px; width: root.width; height: 1px; opacity: 0.5; }

    Text {
        visible: !root.compact-discover-chrome;
        x: 12px;
        y: 146px;
        text: root.discover-active ? (root.discover-results.length > 0 ? (root.discover-results.length == 1 ? "1 RESULT" : root.discover-results.length + " RESULTS") : (root.discover-tab == 1 ? "POPULAR ADDONS" : (root.discover-tab == 2 ? "CATEGORIES" : (root.discover-tab == 3 ? "URL / ID" : "DISCOVER")))) : root.count-label;
        color: Palette.muted-half;
        font-family: "Space Grotesk Light";
        font-size: 11px;
        font-weight: 700;
    }

    Rectangle {
        visible: !root.discover-active;
        x: root.width - self.width - 12px;
        y: 141px;
        width: min(158px, max(70px, sort-text.preferred-width + 32px));
        height: 24px;
        border-radius: 8px;
        background: sort-touch.has-hover ? Palette.white-04 : #00000000;

        animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

        sort-text := Text {
            x: 9px;
            y: 0px;
            width: parent.width - 29px;
            height: parent.height;
            text: root.sort-label;
            color: sort-touch.has-hover ? Palette.muted : Palette.muted-half;
            font-family: "Space Grotesk Light";
            font-size: 11px;
            font-weight: 700;
            vertical-alignment: center;
            overflow: elide;

            animate color { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
        }

        Image {
            x: parent.width - 20px;
            y: 6px;
            width: 12px;
            height: 12px;
            source: @image-url("../assets/icons/chevron-down.svg");
            image-fit: contain;
            colorize: sort-touch.has-hover ? Palette.muted : Palette.muted-half;

            animate colorize { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }
        }

        sort-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.sort-menu-open = !root.sort-menu-open;
            }
        }
    }

    Hairline { visible: !root.compact-discover-chrome; y: 164px; width: root.width; height: 1px; opacity: 0.5; }

    list-key-focus := FocusScope {
        x: 0px;
        y: 165px;
        width: root.width;
        height: root.height - 165px;
        enabled: !root.discover-active;

        key-pressed(event) => {
            if (root.addons.length == 0) {
                return reject;
            }

            if (event.text == Key.DownArrow) {
                root.selected-index = root.selected-index < root.addons.length - 1 ? root.selected-index + 1 : 0;
                root.addon-selected(root.selected-index);
                return accept;
            } else if (event.text == Key.UpArrow) {
                root.selected-index = root.selected-index > 0 ? root.selected-index - 1 : root.addons.length - 1;
                root.addon-selected(root.selected-index);
                return accept;
            } else if (event.text == Key.Home) {
                root.selected-index = 0;
                root.addon-selected(root.selected-index);
                return accept;
            } else if (event.text == Key.End) {
                root.selected-index = root.addons.length - 1;
                root.addon-selected(root.selected-index);
                return accept;
            } else if (event.text == " ") {
                root.addon-selection-toggled(root.selected-index);
                return accept;
            }

            return reject;
        }
    }

    list-scroll := ListView {
        x: 0px;
        y: 165px;
        width: root.width;
        height: root.height - 165px;
        visible: !root.discover-active;
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        for addon[index] in root.addons : AddonRow {
            width: parent.width;
            title: addon.title;
            meta: addon.meta;
            current: index == root.selected-index;
            favorite: addon.favorite;
            selected: addon.selected;
            batch-active: root.batch-active;
            library: addon.is-library;
            disabled: addon.disabled;
            state: addon.state;
            badge: addon.badge;
            badge-kind: addon.badge-kind;
            badge2: addon.badge2;
            badge2-kind: addon.badge2-kind;
            badge3: addon.badge3;
            badge3-kind: addon.badge3-kind;
            clicked => {
                root.selected-index = index;
                root.addon-selected(index);
            }
            selected-toggled => { root.addon-selection-toggled(index); }
            context-open-folder => {
                root.selected-index = index;
                root.addon-context-open-folder(index);
            }
            context-open-esoui => {
                root.selected-index = index;
                root.addon-context-open-esoui(index);
            }
            context-favorite => {
                root.selected-index = index;
                root.addon-context-favorite(index);
            }
            context-toggle-disable => {
                root.selected-index = index;
                root.addon-context-toggle-disable(index);
            }
            context-remove => {
                root.selected-index = index;
                root.addon-context-remove(index);
            }
        }
    }

    if (!root.discover-active && root.addons.length == 0) : DiscoverEmptyState {
        x: 0px;
        y: 165px;
        width: root.width;
        height: root.height - 165px;
        icon: @image-url("../assets/icons/search.svg");
        title: "No addons found";
        subtitle: "Adjust the search or filter to restore the list.";
    }

    if (root.discover-active) : DiscoverModePanel {
        x: 0px;
        y: root.discover-panel-y;
        width: root.width;
        height: root.height - root.discover-panel-y;
        tab: root.discover-tab;
        entries: root.discover-results;
        popular-sort: root.discover-popular-sort;
        category-label: root.discover-category-label;
        category-sort-label: root.discover-category-sort-label;
        category-options: root.discover-category-options;
        category-sort-options: root.discover-category-sort-options;
        loading: root.discover-browse-loading;
        has-more: root.discover-browse-has-more;
        message: root.discover-browse-message;
        selected-index <=> root.selected-discover-index;
        query <=> root.discover-query;
        url-input <=> root.discover-url-input;
        category-filter <=> root.discover-category-filter;
        result-selected(index) => { root.discover-selected(index); }
        install-result(index) => { root.discover-install(index); }
        query-edited(value) => { root.discover-query-edited(value); }
        url-edited(value) => { root.discover-url-edited(value); }
        category-filter-edited(value) => { root.discover-category-filter-edited(value); }
        popular-sort-selected(sort) => { root.discover-popular-sort-selected(sort); }
        category-next => { root.discover-category-next(); }
        category-sort-next => { root.discover-category-sort-next(); }
        category-selected(index) => { root.discover-category-selected(index); }
        category-sort-selected(index) => { root.discover-category-sort-selected(index); }
        load-more => { root.discover-load-more(); }
        retry => { root.discover-browse-retry(); }
    }

    Rectangle {
        visible: root.compact-discover-chrome && root.discover-results.length > 6;
        x: root.width - 10px;
        y: root.discover-panel-y + 46px;
        width: 10px;
        height: root.height - root.discover-panel-y - 46px;
        border-radius: 6px;
        background: Palette.white-03;
    }

    Rectangle {
        visible: root.compact-discover-chrome && root.discover-results.length > 6;
        x: root.width - 8px;
        y: root.discover-panel-y + 58px;
        width: 6px;
        height: 360px;
        border-radius: 6px;
        background: #38bdf84f;
    }

    Rectangle {
        x: root.width - 10px;
        y: 165px;
        width: 10px;
        height: root.height - 165px;
        border-radius: 6px;
        background: Palette.white-03;
        visible: !root.discover-active && list-scroll.viewport-height > list-scroll.height;
    }

    Rectangle {
        x: root.width - 8px;
        y: list-scroll.viewport-height > list-scroll.height ? 165px + (-list-scroll.viewport-y) * ((root.height - 165px - self.height) / (list-scroll.viewport-height - list-scroll.height)) : 165px;
        width: 6px;
        height: 54px;
        border-radius: 6px;
        background: Palette.sky-scroll-thumb;
        visible: !root.discover-active && list-scroll.viewport-height > list-scroll.height;
    }

    // Draggable scrollbar: press or drag anywhere on the track to reposition
    // the list. viewport-y is clamped by the ListView, so overshoot is safe.
    list-scrollbar-touch := TouchArea {
        x: root.width - 12px;
        y: 165px;
        width: 12px;
        height: root.height - 165px;
        visible: !root.discover-active && list-scroll.viewport-height > list-scroll.height;
        moved => {
            list-scroll.viewport-y = -(clamp((self.mouse-y - 27px) / max(1px, (root.height - 165px) - 54px), 0, 1)) * (list-scroll.viewport-height - (root.height - 165px));
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                list-scroll.viewport-y = -(clamp((self.mouse-y - 27px) / max(1px, (root.height - 165px) - 54px), 0, 1)) * (list-scroll.viewport-height - (root.height - 165px));
            }
        }
    }

    if (root.sort-menu-open && !root.discover-active) : Rectangle {
        x: root.width - 146px;
        y: 168px;
        width: 134px;
        height: 122px;
        border-radius: 10px;
        border-width: 0px;
        background: Tokens.bg-base-85;
        drop-shadow-blur: 20px;
        drop-shadow-offset-y: 8px;
        drop-shadow-color: #00000080;
        clip: true;

        sort-name := SortMenuRow {
            y: 8px;
            width: parent.width;
            label: "Name";
            active: root.sort-mode == 0;
            clicked => {
                root.sort-mode = 0;
                root.sort-menu-open = false;
                root.sort-selected(0);
            }
        }
        sort-author := SortMenuRow {
            y: 36px;
            width: parent.width;
            label: "Author";
            active: root.sort-mode == 1;
            clicked => {
                root.sort-mode = 1;
                root.sort-menu-open = false;
                root.sort-selected(1);
            }
        }
        sort-updated := SortMenuRow {
            y: 64px;
            width: parent.width;
            label: "Updated";
            active: root.sort-mode == 2;
            clicked => {
                root.sort-mode = 2;
                root.sort-menu-open = false;
                root.sort-selected(2);
            }
        }
        sort-install := SortMenuRow {
            y: 92px;
            width: parent.width;
            label: "Downloaded";
            active: root.sort-mode == 3;
            clicked => {
                root.sort-mode = 3;
                root.sort-menu-open = false;
                root.sort-selected(3);
            }
        }
    }
}

component ConflictChoiceButton inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    in property <color> tone: Palette.gold;
    callback clicked;
    width: label-text.preferred-width + 22px;
    preferred-width: self.width;
    height: 28px;
    border-radius: 7px;
    border-width: 0px;
    background: root.active ? Palette.gold-15 : (touch.has-hover ? Palette.white-06 : Palette.white-03);

    animate background { duration: Tokens.low-memory-preset ? 0ms : 150ms; easing: ease-in-out; }

    label-text := Text {
        x: 11px;
        height: root.height;
        text: root.label;
        color: root.active ? root.tone : (touch.has-hover ? Palette.foreground : Palette.muted-strong);
        font-size: 12px;
        font-weight: 700;
        vertical-alignment: center;
    }

    touch := TouchArea {
        width: root.width;
        height: root.height;
        clicked => { root.clicked(); }
    }
}

component ConflictFileRow inherits Rectangle {
    in property <int> row-index: 0;
    in property <ConflictFileEntry> entry;
    callback decision-clicked(int, int);
    callback view-diff(int);
    height: 76px;
    border-radius: 10px;
    border-width: 0px;
    background: Palette.white-02;

    Text {
        x: 12px;
        y: 10px;
        width: parent.width - 250px;
        text: root.entry.relative-path;
        color: Palette.foreground;
        font-family: "Space Grotesk Light";
        font-size: 13px;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        visible: root.entry.decision != 0;
        x: parent.width - 140px;
        y: 10px;
        width: 128px;
        text: root.entry.decision == 1 ? "KEEPING YOURS" : "TAKING UPDATE";
        color: root.entry.decision == 1 ? Palette.gold : Palette.sky;
        font-family: "Space Grotesk Light";
        font-size: 10px;
        font-weight: 800;
        horizontal-alignment: right;
        overflow: elide;
    }

    ConflictChoiceButton {
        x: 12px;
        y: 36px;
        label: "Keep my version";
        active: root.entry.decision == 1;
        tone: Palette.gold;
        clicked => { root.decision-clicked(root.row-index, 1); }
    }

    ConflictChoiceButton {
        x: 136px;
        y: 36px;
        label: "Take the update";
        active: root.entry.decision == 2;
        tone: Palette.sky;
        clicked => { root.decision-clicked(root.row-index, 2); }
    }

    ConflictChoiceButton {
        x: 272px;
        y: 36px;
        label: "View differences";
        tone: Palette.muted-strong;
        clicked => { root.view-diff(root.row-index); }
    }
}

component DetailConflictPanel inherits Rectangle {
    in property <AddonEntry> addon;
    in property <int> conflict-count: 0;
    in property <[ConflictFileEntry]> conflict-files;
    in property <int> auto-kept-count: 0;
    in property <int> safe-file-count: 0;
    in property <string> update-version;
    in property <bool> all-decided: false;
    in property <string> diff-file;
    in property <string> diff-user-preview;
    in property <string> diff-upstream-preview;
    in property <bool> diff-binary: false;
    in property <bool> diff-loading: false;
    callback decision-clicked(int, int);
    callback view-diff(int);
    callback apply-clicked;
    callback skip-clicked;
    private property <bool> has-diff: root.diff-file != "";
    private property <length> auto-row-height: root.auto-kept-count > 0 ? 18px : 0px;
    height: 130px + root.auto-row-height + root.conflict-files.length * 84px + (root.has-diff ? 132px : 0px);
    background: #00000000;

    stack := VerticalLayout {
        width: root.width;
        height: root.height;
        spacing: 8px;

        Rectangle {
            width: parent.width;
            height: 74px;
            border-radius: 12px;
            border-width: 0px;
            background: Palette.amber-04;

            Text {
                x: 14px;
                y: 12px;
                width: parent.width - 28px;
                text: root.addon.folder-name + " " + root.addon.version + " -> " + root.update-version;
                color: Palette.amber;
                font-family: "Space Grotesk Light";
                font-size: 14px;
                font-weight: 800;
                overflow: elide;
            }

            Text {
                x: 14px;
                y: 38px;
                width: parent.width - 28px;
                text: "You've edited " + root.conflict-count + " file" + (root.conflict-count == 1 ? "" : "s") + " that this update also changed. Pick the version to keep for each file.";
                color: Palette.muted-strong;
                font-size: 12px;
                font-weight: 500;
                overflow: elide;
            }
        }

        Text {
            visible: root.auto-kept-count > 0;
            width: parent.width;
            height: root.auto-row-height;
            text: root.auto-kept-count + " locally edited file" + (root.auto-kept-count == 1 ? "" : "s") + " are unchanged in this update - automatically preserved";
            color: Palette.emerald;
            font-size: 12px;
            font-weight: 600;
            overflow: elide;
        }

        for conflict[index] in root.conflict-files : ConflictFileRow {
            width: parent.width;
            row-index: index;
            entry: conflict;
            decision-clicked(row, decision) => { root.decision-clicked(row, decision); }
            view-diff(row) => { root.view-diff(row); }
        }

        if (root.has-diff) : Rectangle {
            width: parent.width;
            height: 126px;
            border-radius: 9px;
            border-width: 0px;
            background: Palette.white-02;

            Text {
                x: 12px;
                y: 8px;
                width: parent.width - 24px;
                text: root.diff-loading ? "Loading differences..." : root.diff-file;
                color: root.diff-loading ? Palette.muted-strong : Palette.foreground;
                font-family: "Space Grotesk Light";
                font-size: 12px;
                font-weight: 800;
                overflow: elide;
            }

            if (root.diff-binary) : Text {
                x: 12px;
                y: 44px;
                width: parent.width - 24px;
                text: "Binary file - differences cannot be shown inline.";
                color: Palette.muted-strong;
                font-size: 12px;
                font-weight: 650;
                horizontal-alignment: center;
            }

            if (!root.diff-binary) : Text { x: 12px; y: 34px; width: parent.width / 2 - 18px; text: "Your version"; color: Palette.gold; font-size: 11px; font-weight: 700; }
            if (!root.diff-binary) : Text { x: parent.width / 2 + 8px; y: 34px; width: parent.width / 2 - 20px; text: "The update"; color: Palette.sky; font-size: 11px; font-weight: 700; }
            if (!root.diff-binary) : Text { x: 12px; y: 54px; width: parent.width / 2 - 18px; height: 64px; text: root.diff-user-preview; color: Palette.gold; font-family: "Space Grotesk Light"; font-size: 11px; wrap: word-wrap; overflow: elide; }
            if (!root.diff-binary) : Text { x: parent.width / 2 + 8px; y: 54px; width: parent.width / 2 - 20px; height: 64px; text: root.diff-upstream-preview; color: Palette.sky; font-family: "Space Grotesk Light"; font-size: 11px; wrap: word-wrap; overflow: elide; }
            if (!root.diff-binary) : Rectangle { x: parent.width / 2; y: 30px; width: 1px; height: parent.height - 36px; background: Palette.white-04; }
        }

        Rectangle {
            width: parent.width;
            height: 34px;
            background: #00000000;

            Text {
                x: 2px;
                height: parent.height;
                width: 260px;
                text: root.safe-file-count + " other file" + (root.safe-file-count == 1 ? "" : "s") + " will update normally";
                color: Palette.muted-half;
                font-size: 11px;
                font-weight: 500;
                vertical-alignment: center;
            }

            apply := SettingsActionButton {
                x: parent.width - self.width - skip.width - 10px;
                y: 3px;
                icon: @image-url("../assets/icons/save.svg");
                label: "Apply & Update";
                primary: root.all-decided;
                clicked => { root.apply-clicked(); }
            }

            skip := SettingsActionButton {
                x: parent.width - self.width;
                y: 3px;
                icon: @image-url("../assets/icons/chevron-right.svg");
                label: "Skip Update";
                clicked => { root.skip-clicked(); }
            }
        }
    }
}

component DetailPane inherits Rectangle {
    in property <AddonEntry> addon;
    in property <[FileEntry]> files;
    in property <[BackupEntry]> edit-backups;
    in property <[ConflictFileEntry]> conflict-files;
    in property <int> file-modified-count: 0;
    in property <int> pending-conflict-count: 0;
    in property <int> conflict-auto-kept-count: 0;
    in property <int> conflict-safe-file-count: 0;
    in property <string> conflict-update-version;
    in property <bool> conflict-all-decided: false;
    in property <string> conflict-diff-file;
    in property <string> conflict-diff-user-preview;
    in property <string> conflict-diff-upstream-preview;
    in property <bool> conflict-diff-binary: false;
    in property <bool> conflict-diff-loading: false;
    private property <bool> has-selected-conflicts: root.conflict-files.length > 0;
    private property <bool> has-update: root.addon.state == 1 || root.addon.badge == "Update" || root.addon.badge2 == "Update" || root.addon.badge3 == "Update";
    in-out property <bool> files-active: false;
    in-out property <string> selected-file-path;
    in-out property <string> selected-file-name;
    in-out property <string> selected-file-content;
    in-out property <string> selected-original-content;
    in-out property <string> editor-line-numbers;
    in-out property <string> editor-message;
    in-out property <length> file-tree-scroll-y: 0px;
    in-out property <string> custom-tag-draft;
    in-out property <bool> editor-open: false;
    in-out property <bool> editor-editable: false;
    in-out property <bool> editor-binary: false;
    in-out property <bool> editor-error: false;
    in-out property <bool> show-backups: false;
    callback file-selected(string);
    callback folder-toggled(string);
    callback file-content-edited(string);
    callback save-file(string, string);
    callback open-folder;
    callback open-external(string);
    callback rescan;
    callback load-backups;
    callback restore-backup(int);
    callback tag-clicked(string);
    callback add-tag-clicked;
    callback custom-tag-submitted(string);
    callback open-esoui(string);
    callback toggle-addon-disabled;
    callback remove-addon;
    callback update-addon;
    callback install-dependency(string, bool);
    callback remove-dependency(string, bool);
    callback conflict-decision-selected(int, int);
    callback conflict-view-diff(int);
    callback conflict-apply;
    callback conflict-skip;
    background: Tokens.low-memory-preset ? Tokens.background : #00000000;
    clip: true;

    detail-scroll := ScrollView {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        viewport-width: root.width;
        // Follow the real content height so a long description / extra dependencies
        // scroll instead of being clipped at the fixed pane height.
        viewport-height: detail-content.preferred-height + 58px;
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        detail-content := VerticalLayout {
            x: 24px;
            y: 29px;
            width: root.width - 48px;
            spacing: 0px;

            GradientHeading {
                width: parent.width;
                label: root.addon.title;
            }

            Rectangle { height: 2px; background: #00000000; }

            HorizontalLayout {
                height: 22px;
                spacing: 8px;
                Pill {
                    label: root.addon.folder-name + "/";
                    tone: Palette.muted-dim;
                    fill: Palette.white-03;
                    line: Palette.white-10;
                }
                Pill {
                    label: "ESOUI #" + root.addon.esoui-id;
                    tone: Palette.sky;
                    fill: Palette.sky-04;
                    line: Palette.sky-20;
                }
            }

            if (!root.files-active && root.has-update && !root.has-selected-conflicts) : Rectangle { height: 14px; background: #00000000; }
            if (!root.files-active && root.has-update && !root.has-selected-conflicts) : Rectangle {
                width: parent.width;
                height: 46px;
                border-radius: 10px;
                border-width: 1px;
                border-color: Palette.gold-20;
                background: Palette.gold-06;

                Image {
                    x: 14px;
                    y: 15px;
                    width: 16px;
                    height: 16px;
                    source: @image-url("../assets/icons/refresh-cw.svg");
                    image-fit: contain;
                    colorize: Palette.gold;
                }

                Text {
                    x: 42px;
                    y: 0px;
                    width: parent.width - 160px;
                    height: parent.height;
                    text: "An update is available for this addon.";
                    color: Palette.gold;
                    font-size: 13px;
                    font-weight: 800;
                    vertical-alignment: center;
                    overflow: elide;
                }

                SmallAction {
                    x: parent.width - self.width - 12px;
                    y: 11px;
                    label: "Update";
                    tone: Palette.gold;
                    fill: Palette.gold-10;
                    fill-hover: Palette.gold-15;
                    fill-pressed: Palette.gold-20;
                    line: Palette.gold-20;
                    clicked => { root.update-addon(); }
                }
            }

            if (!root.files-active && root.has-selected-conflicts) : Rectangle { height: 16px; background: #00000000; }

            if (!root.files-active && root.has-selected-conflicts) : DetailConflictPanel {
                width: parent.width;
                addon: root.addon;
                conflict-count: root.conflict-files.length;
                conflict-files: root.conflict-files;
                auto-kept-count: root.conflict-auto-kept-count;
                safe-file-count: root.conflict-safe-file-count;
                update-version: root.conflict-update-version;
                all-decided: root.conflict-all-decided;
                diff-file: root.conflict-diff-file;
                diff-user-preview: root.conflict-diff-user-preview;
                diff-upstream-preview: root.conflict-diff-upstream-preview;
                diff-binary: root.conflict-diff-binary;
                diff-loading: root.conflict-diff-loading;
                decision-clicked(row, decision) => { root.conflict-decision-selected(row, decision); }
                view-diff(row) => { root.conflict-view-diff(row); }
                apply-clicked => { root.conflict-apply(); }
                skip-clicked => { root.conflict-skip(); }
            }

            Rectangle { height: 7px; background: #00000000; }

            Rectangle {
                height: 36px;
                background: #00000000;
                DetailTabStrip {
                    x: 0px;
                    y: 0px;
                    width: 176px;
                    height: 36px;
                    files-active: root.files-active;
                    details-clicked => { root.files-active = false; }
                    files-clicked => {
                        root.files-active = true;
                        root.rescan();
                    }
                }
            }

            Rectangle { height: 14px; background: #00000000; }

            if (root.files-active) : DetailFilesPanel {
                width: parent.width;
                panel-width: parent.width;
                addon: root.addon;
                files: root.files;
                backups: root.edit-backups;
                modified-count: root.file-modified-count;
                selected-file-path <=> root.selected-file-path;
                selected-file-name <=> root.selected-file-name;
                selected-file-content <=> root.selected-file-content;
                selected-original-content <=> root.selected-original-content;
                editor-line-numbers <=> root.editor-line-numbers;
                editor-message <=> root.editor-message;
                tree-scroll-y <=> root.file-tree-scroll-y;
                editor-open <=> root.editor-open;
                editor-editable <=> root.editor-editable;
                editor-binary <=> root.editor-binary;
                editor-error <=> root.editor-error;
                show-backups <=> root.show-backups;
                file-selected(path) => { root.file-selected(path); }
                folder-toggled(path) => { root.folder-toggled(path); }
                file-content-edited(content) => { root.file-content-edited(content); }
                save-file(path, content) => { root.save-file(path, content); }
                open-folder => { root.open-folder(); }
                open-external(path) => { root.open-external(path); }
                rescan => { root.rescan(); }
                load-backups => { root.load-backups(); }
                restore-backup(index) => { root.restore-backup(index); }
            }

            if (!root.files-active) : DetailInfoPanel {
                width: parent.width;
                addon: root.addon;
                open-esoui(id) => { root.open-esoui(id); }
            }

            if (!root.files-active) : Rectangle { height: 14px; background: #00000000; }

            if (!root.files-active) : DetailSectionTitle {
                width: parent.width;
                label: "TAGS";
            }

            if (!root.files-active) : Rectangle { height: 8px; background: #00000000; }

            if (!root.files-active) : DetailTagsSection {
                width: parent.width;
                tags: root.addon.tags;
                custom-tag-draft <=> root.custom-tag-draft;
                tag-clicked(id) => { root.tag-clicked(id); }
                add-tag-clicked => { root.add-tag-clicked(); }
                custom-tag-submitted(value) => { root.custom-tag-submitted(value); }
            }

            if (!root.files-active) : Rectangle { height: 28px; background: #00000000; }

            if (!root.files-active) : DetailSectionTitle {
                width: parent.width;
                label: "DESCRIPTION";
            }

            if (!root.files-active) : Rectangle { height: 8px; background: #00000000; }

            if (!root.files-active) : DetailDescriptionSection {
                width: parent.width;
                description: root.addon.description;
            }

            if (!root.files-active) : Rectangle { height: 24px; background: #00000000; }

            if (!root.files-active && root.addon.required-dependencies.length > 0) : DetailSectionTitle {
                width: parent.width;
                label: "REQUIRED DEPENDENCIES";
            }

            if (!root.files-active && root.addon.required-dependencies.length > 0) : Rectangle { height: 16px; background: #00000000; }

            if (!root.files-active && root.addon.required-dependencies.length > 0) : DetailDependencySection {
                width: parent.width;
                dependencies: root.addon.required-dependencies;
                install-dependency(name, optional) => { root.install-dependency(name, optional); }
                remove-dependency(name, optional) => { root.remove-dependency(name, optional); }
            }

            if (!root.files-active && root.addon.optional-dependencies.length > 0) : Rectangle { height: 24px; background: #00000000; }

            if (!root.files-active && root.addon.optional-dependencies.length > 0) : DetailSectionTitle {
                width: parent.width;
                label: "OPTIONAL DEPENDENCIES";
            }

            if (!root.files-active && root.addon.optional-dependencies.length > 0) : Rectangle { height: 16px; background: #00000000; }

            if (!root.files-active && root.addon.optional-dependencies.length > 0) : DetailDependencySection {
                width: parent.width;
                dependencies: root.addon.optional-dependencies;
                optional-section: true;
                install-dependency(name, optional) => { root.install-dependency(name, optional); }
                remove-dependency(name, optional) => { root.remove-dependency(name, optional); }
            }

            if (!root.files-active) : Rectangle { height: 24px; background: #00000000; }

            if (!root.files-active) : DetailActionFooter {
                width: parent.width;
                addon-disabled: root.addon.disabled;
                dependent-summary: root.addon.dependent-summary;
                toggle-disabled => { root.toggle-addon-disabled(); }
                remove-addon => { root.remove-addon(); }
            }

            Rectangle { height: 40px; background: #00000000; }
        }

    }

    Rectangle {
        x: root.width - 10px;
        y: 8px;
        width: 10px;
        height: root.height - 16px;
        border-radius: 6px;
        background: Palette.white-03;
        visible: detail-scroll.viewport-height > detail-scroll.height;
    }

    Rectangle {
        x: root.width - 8px;
        y: detail-scroll.viewport-height > detail-scroll.height ? 8px + (-detail-scroll.viewport-y) * ((root.height - 16px - self.height) / (detail-scroll.viewport-height - detail-scroll.height)) : 8px;
        width: 6px;
        height: 156px;
        border-radius: 6px;
        background: Palette.sky-scroll-thumb;
        visible: detail-scroll.viewport-height > detail-scroll.height;
    }

    TouchArea {
        x: root.width - 12px;
        y: 8px;
        width: 12px;
        height: root.height - 16px;
        visible: detail-scroll.viewport-height > detail-scroll.height;
        moved => {
            detail-scroll.viewport-y = -(clamp((self.mouse-y - 78px) / max(1px, (root.height - 16px) - 156px), 0, 1)) * (detail-scroll.viewport-height - detail-scroll.height);
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                detail-scroll.viewport-y = -(clamp((self.mouse-y - 78px) / max(1px, (root.height - 16px) - 156px), 0, 1)) * (detail-scroll.viewport-height - detail-scroll.height);
            }
        }
    }
}

component DiscoverStatCard inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <string> value;
    in property <int> accent-kind: 0;
    in property <length> card-width: 120px;
    private property <color> tone: root.accent-kind == 1 ? Palette.emerald : (root.accent-kind == 2 ? Palette.gold : (root.accent-kind == 3 ? Palette.violet : Palette.sky));
    width: root.card-width;
    height: 64px;
    border-radius: 12px;
    border-width: 0px;
    background: Palette.white-08;
    clip: true;

    Rectangle {
        x: 1px;
        y: 1px;
        width: parent.width - 2px;
        height: parent.height - 2px;
        border-radius: 11px;
        border-width: 0px;
        background: @linear-gradient(180deg, Palette.white-02 0%, #ffffff03 100%);
    }

    Image {
        x: 10px;
        y: 10px;
        width: 14px;
        height: 14px;
        source: root.icon;
        image-fit: contain;
        colorize: root.tone;
    }

    Text {
        x: 30px;
        y: 10px;
        width: parent.width - 40px;
        text: root.label;
        color: Palette.muted-dim;
        font-family: "Space Grotesk Light";
        font-size: 10px;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        x: 10px;
        y: 32px;
        width: parent.width - 20px;
        text: root.value == "" ? "-" : root.value;
        color: Palette.foreground;
        font-size: 14px;
        font-weight: 700;
        overflow: elide;
    }
}

component DiscoverDetailPane inherits Rectangle {
    in property <DiscoverEntry> entry;
    in property <[DiscoverScreenshotEntry]> screenshots;
    in property <int> selected-index: 0;
    in-out property <int> screenshot-index: 0;
    in property <length> pane-width: 1082px;
    callback install-clicked(int);
    callback remove-clicked(int);
    callback open-esoui(string);
    callback screenshot-prev;
    callback screenshot-next;
    callback screenshot-select(int);
    private property <bool> show-screenshots: root.screenshots.length > 0;
    private property <int> safe-screenshot-index: min(max(root.screenshot-index, 0), max(root.screenshots.length - 1, 0));
    background: Tokens.low-memory-preset ? Tokens.background : #00000000;
    clip: true;

    detail-scroll := ScrollView {
        width: root.pane-width;
        height: root.height;
        viewport-width: root.pane-width;
        // Follow the real content height so a long description is fully scrollable
        // (was hardcoded, which clipped anything past the fixed layout).
        viewport-height: content.preferred-height + 58px;
        vertical-scrollbar-policy: ScrollBarPolicy.always-off;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

        content := VerticalLayout {
            x: 24px;
            y: 29px;
            width: root.pane-width - 48px;
            spacing: 0px;

            Rectangle {
                width: parent.width;
                height: 96px;
                background: #00000000;
                property <length> action-col: 174px;
                property <length> text-col: max(150px, self.width - self.action-col);

                // Title — two-layer gradient approximation
                Text {
                    x: 0px;
                    y: 0px;
                    width: parent.text-col;
                    text: root.entry.title;
                    color: Palette.gold;
                    font-family: "Space Grotesk Light";
                    font-size: 20px;
                    font-weight: 600;
                    overflow: elide;
                }

                Text {
                    x: 0px;
                    y: 0px;
                    width: parent.text-col;
                    text: root.entry.title;
                    color: Palette.gold-hot;
                    opacity: 0.34;
                    font-family: "Space Grotesk Light";
                    font-size: 20px;
                    font-weight: 600;
                    overflow: elide;
                }

                // Metadata row: version pill + author + category pill
                version-pill := Pill {
                    visible: root.entry.version != "";
                    x: 0px;
                    y: 34px;
                    label: "v" + root.entry.version;
                    tone: Palette.muted-half;
                    fill: Palette.white-04;
                    line: Palette.white-10;
                    pill-height: 19px;
                    pill-padding-x: 7px;
                    label-font-size: 11px;
                    pill-max-width: 200px;
                }

                author-line := Text {
                    x: root.entry.version != "" ? version-pill.width + 10px : 0px;
                    y: 34px;
                    width: min(self.preferred-width, parent.text-col - self.x - (root.entry.category != "" ? 74px : 6px));
                    height: 19px;
                    text: root.entry.author == "" ? "" : "by " + root.entry.author;
                    color: Palette.muted-half;
                    font-size: 14px;
                    font-weight: 500;
                    vertical-alignment: center;
                    overflow: elide;
                }

                Pill {
                    visible: root.entry.category != "";
                    x: min(author-line.x + author-line.width + 10px, parent.text-col - self.width);
                    y: 34px;
                    label: root.entry.category;
                    tone: Palette.muted-strong;
                    fill: Palette.white-03;
                    line: Palette.white-10;
                }

                // Compatibility (full content width, clear of the action column)
                Text {
                    visible: root.entry.compatibility != "";
                    x: 0px;
                    y: 64px;
                    width: parent.width - 8px;
                    text: "Compatible with " + root.entry.compatibility;
                    color: Palette.muted-dim;
                    font-size: 12px;
                    font-weight: 500;
                    overflow: elide;
                }

                // Right action column
                install-action := SmallAction {
                    x: parent.width - self.width;
                    y: 0px;
                    label: root.entry.installed ? "Reinstall" : "Install";
                    tone: Palette.gold;
                    fill: Palette.gold-10;
                    fill-hover: Palette.gold-15;
                    fill-pressed: Palette.gold-20;
                    line: Palette.gold-20;
                    clicked => { root.install-clicked(root.selected-index); }
                }

                SmallAction {
                    visible: root.entry.installed;
                    x: install-action.x - self.width - 8px;
                    y: 0px;
                    label: "Uninstall";
                    tone: Palette.red;
                    fill: Palette.red-04;
                    fill-hover: Palette.red-15;
                    fill-pressed: Palette.red-20;
                    line: Palette.red-20;
                    clicked => { root.remove-clicked(root.selected-index); }
                }

                PlainLinkAction {
                    x: parent.width - self.width;
                    y: 36px;
                    label: "View on ESOUI";
                    tone: Palette.muted-half;
                    clicked => { root.open-esoui(root.entry.esoui-id); }
                }
            }

            Rectangle { height: 16px; background: #00000000; }

            stats-row := Rectangle {
                width: parent.width;
                height: 68px;
                background: #00000000;
                private property <length> stat-gap: 8px;
                private property <length> stat-width: (self.width - self.stat-gap * 3) / 4;

                DiscoverStatCard {
                    x: 0px;
                    card-width: parent.stat-width;
                    icon: @image-url("../assets/icons/cloud-upload.svg");
                    label: "DOWNLOADS";
                    value: root.entry.downloads;
                    accent-kind: 0;
                }

                DiscoverStatCard {
                    x: parent.stat-width + parent.stat-gap;
                    card-width: parent.stat-width;
                    icon: @image-url("../assets/icons/package.svg");
                    label: "MONTHLY";
                    value: root.entry.monthly-downloads;
                    accent-kind: 1;
                }

                DiscoverStatCard {
                    x: (parent.stat-width + parent.stat-gap) * 2;
                    card-width: parent.stat-width;
                    icon: @image-url("../assets/icons/square.svg");
                    label: "FAVORITES";
                    value: root.entry.favorites;
                    accent-kind: 2;
                }

                DiscoverStatCard {
                    x: (parent.stat-width + parent.stat-gap) * 3;
                    card-width: parent.stat-width;
                    icon: @image-url("../assets/icons/refresh-cw.svg");
                    label: "UPDATED";
                    value: root.entry.updated;
                    accent-kind: 3;
                }
            }

            Rectangle { height: 16px; background: #00000000; }

            Rectangle {
                width: parent.width;
                height: 28px;
                border-radius: 0px;
                border-width: 0px;
                background: #00000000;

                Text {
                    visible: root.entry.created != "";
                    x: 0px;
                    y: 5px;
                    width: parent.width * 0.45;
                    text: "Created " + root.entry.created;
                    color: Palette.muted-half;
                    font-size: 12px;
                    font-weight: 500;
                    overflow: elide;
                }

                Text {
                    visible: root.entry.md5 != "";
                    x: parent.width * 0.45;
                    y: 5px;
                    width: parent.width * 0.55;
                    text: "MD5 " + root.entry.md5;
                    color: Palette.muted-half;
                    font-family: "Space Grotesk Light";
                    font-size: 12px;
                    font-weight: 600;
                    overflow: elide;
                }
            }

            Rectangle { height: 24px; background: #00000000; }

            if (root.show-screenshots) : DetailSectionTitle {
                width: parent.width;
                label: "SCREENSHOTS (" + root.screenshots.length + ")";
            }

            if (root.show-screenshots) : Rectangle { height: 8px; background: #00000000; }

            if (root.show-screenshots) : Rectangle {
                width: parent.width;
                height: 300px;
                border-radius: 12px;
                border-width: 0px;
                background: Palette.white-08;
                drop-shadow-blur: 16px;
                drop-shadow-offset-y: 8px;
                drop-shadow-color: #00000033;
                clip: true;

                Rectangle {
                    x: 1px;
                    y: 1px;
                    width: parent.width - 2px;
                    height: parent.height - 2px;
                    border-radius: 11px;
                    border-width: 0px;
                    background: @linear-gradient(180deg, Palette.white-03 0%, Palette.white-02 100%);
                }

                Image {
                    x: parent.width / 2 - 258px;
                    y: 8px;
                    width: 516px;
                    height: 268px;
                    source: root.screenshots[root.safe-screenshot-index].image;
                    image-fit: contain;
                }

                Rectangle {
                    visible: root.screenshots.length > 1;
                    x: 16px;
                    y: parent.height / 2 - 18px;
                    width: 36px;
                    height: 36px;
                    border-radius: 18px;
                    border-width: 0px;
                    background: #00000059;

                    Image { x: 11px; y: 11px; width: 14px; height: 14px; source: @image-url("../assets/icons/chevron-right.svg"); image-fit: contain; colorize: Palette.foreground; transform-rotation: 180deg; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.screenshot-prev(); } }
                }

                Rectangle {
                    visible: root.screenshots.length > 1;
                    x: parent.width - 52px;
                    y: parent.height / 2 - 18px;
                    width: 36px;
                    height: 36px;
                    border-radius: 18px;
                    border-width: 0px;
                    background: #00000059;

                    Image { x: 11px; y: 11px; width: 14px; height: 14px; source: @image-url("../assets/icons/chevron-right.svg"); image-fit: contain; colorize: Palette.foreground; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.screenshot-next(); } }
                }

                Rectangle {
                    visible: root.screenshots.length > 1;
                    x: parent.width - 60px;
                    y: 12px;
                    width: 44px;
                    height: 22px;
                    border-radius: 8px;
                    border-width: 0px;
                    background: #00000066;

                    Text { width: parent.width; height: parent.height; text: (root.safe-screenshot-index + 1) + " / " + root.screenshots.length; color: Palette.foreground; font-size: 10px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                }

                Rectangle {
                    visible: root.screenshots.length > 1;
                    x: parent.width / 2 - 26px;
                    y: parent.height - 42px;
                    width: 52px;
                    height: 18px;
                    border-radius: 9px;
                    border-width: 0px;
                    background: #00000059;

                    for shot[index] in root.screenshots : Rectangle {
                        visible: index < 3;
                        x: 11px + index * 12px;
                        y: 6px;
                        width: 6px;
                        height: 6px;
                        border-radius: 3px;
                        background: shot.selected ? Palette.gold : Palette.muted-half;
                    }
                }
            }

            if (root.show-screenshots) : Rectangle { height: 16px; background: #00000000; }

            if (root.show-screenshots) : Rectangle {
                width: parent.width;
                height: 58px;
                background: #00000000;

                for shot[index] in root.screenshots : Rectangle {
                    visible: index < 4;
                    x: index * 112px;
                    y: 0px;
                    width: 100px;
                    height: 58px;
                    border-radius: 7px;
                    border-width: shot.selected ? 2px : 0px;
                    border-color: Palette.gold;
                    background: shot.selected ? Palette.gold-25 : Palette.white-04;
                    clip: true;

                    Image { x: shot.selected ? 2px : 0px; y: shot.selected ? 2px : 0px; width: shot.selected ? 96px : 100px; height: shot.selected ? 54px : 58px; source: shot.image; image-fit: cover; opacity: shot.selected ? 0.98 : 0.55; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.screenshot-select(index); } }
                }
            }

            if (root.show-screenshots) : Rectangle { height: 24px; background: #00000000; }

            DetailSectionTitle {
                width: parent.width;
                label: "DESCRIPTION";
            }

            Rectangle { height: 8px; background: #00000000; }

            Rectangle {
                width: parent.width;
                // Grow with the wrapped description so the whole thing is reachable by
                // scrolling (was a fixed 178px box that elided long descriptions).
                height: max(178px, description-text.preferred-height + 30px);
                border-radius: 12px;
                border-width: 0px;
                background: @linear-gradient(180deg, Palette.white-03 0%, Palette.white-02 100%);

                description-text := Text {
                    x: 16px;
                    y: 15px;
                    width: parent.width - 32px;
                    text: root.entry.description;
                    color: Palette.text-soft;
                    font-size: 14px;
                    font-weight: 500;
                    wrap: word-wrap;
                }
            }

            Rectangle { height: 40px; background: #00000000; }
        }
    }

    Rectangle {
        x: root.pane-width - 10px;
        y: 8px;
        width: 10px;
        height: root.height - 16px;
        border-radius: 6px;
        background: Palette.white-02;
        visible: detail-scroll.viewport-height > detail-scroll.height;
    }

    Rectangle {
        x: root.pane-width - 8px;
        y: detail-scroll.viewport-height > detail-scroll.height ? 8px + (-detail-scroll.viewport-y) * ((root.height - 16px - self.height) / (detail-scroll.viewport-height - detail-scroll.height)) : 8px;
        width: 6px;
        height: 156px;
        border-radius: 6px;
        background: Palette.white-10;
        visible: detail-scroll.viewport-height > detail-scroll.height;
    }

    TouchArea {
        x: root.pane-width - 12px;
        y: 8px;
        width: 12px;
        height: root.height - 16px;
        visible: detail-scroll.viewport-height > detail-scroll.height;
        moved => {
            detail-scroll.viewport-y = -(clamp((self.mouse-y - 78px) / max(1px, (root.height - 16px) - 156px), 0, 1)) * (detail-scroll.viewport-height - detail-scroll.height);
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                detail-scroll.viewport-y = -(clamp((self.mouse-y - 78px) / max(1px, (root.height - 16px) - 156px), 0, 1)) * (detail-scroll.viewport-height - detail-scroll.height);
            }
        }
    }
}

export component KalpaWindow inherits Window {
