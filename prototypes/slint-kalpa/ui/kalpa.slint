export global BackdropSkins {
    in-out property <image> orb-one;
    in-out property <image> orb-two;
    in-out property <image> orb-three;
}

global Palette {
    out property <color> bg-base: Tokens.bg-base;
    out property <color> app-bg: Tokens.background;
    out property <color> panel: Tokens.surface;
    out property <color> panel-soft: #111827;
    out property <color> glass: Tokens.surface-84;
    out property <color> glass-soft: Tokens.surface-66;
    out property <color> white-02: #ffffff05;
    out property <color> white-03: #ffffff08;
    out property <color> white-04: #ffffff0a;
    out property <color> white-06: #ffffff10;
    out property <color> white-08: #ffffff14;
    out property <color> white-10: #ffffff1a;
    out property <color> foreground: Tokens.foreground;
    out property <color> text-soft: #cbd5e1;
    out property <color> muted: Tokens.muted-foreground;
    out property <color> muted-soft: Tokens.muted-foreground-30;
    out property <color> muted-half: Tokens.muted-foreground-50;
    out property <color> muted-strong: Tokens.muted-foreground-70;
    out property <color> muted-dim: #64748b;
    out property <color> muted-faint: #475569;
    out property <color> gold: Tokens.primary;
    out property <color> gold-hot: Tokens.primary-hover;
    out property <color> gold-04: Tokens.primary-04;
    out property <color> gold-06: Tokens.primary-06;
    out property <color> gold-10: Tokens.primary-10;
    out property <color> gold-15: Tokens.primary-15;
    out property <color> gold-20: Tokens.primary-20;
    out property <color> gold-25: Tokens.primary-25;
    out property <color> gold-30: Tokens.primary-30;
    out property <color> sky: Tokens.accent;
    out property <color> sky-04: Tokens.accent-04;
    out property <color> sky-06: Tokens.accent-06;
    out property <color> sky-10: Tokens.accent-10;
    out property <color> sky-15: Tokens.accent-15;
    out property <color> sky-16: Tokens.accent-16;
    out property <color> sky-20: Tokens.accent-20;
    out property <color> sky-22: Tokens.accent-22;
    out property <color> sky-25: Tokens.accent-25;
    out property <color> sky-scroll: Tokens.accent-scroll;
    out property <color> sky-scroll-thumb: Tokens.accent-scroll-thumb;
    out property <color> logo: #4dc2e6;
    out property <color> emerald: Tokens.status-success;
    out property <color> emerald-04: Tokens.status-success-04;
    out property <color> emerald-15: Tokens.status-success-15;
    out property <color> emerald-20: Tokens.status-success-20;
    out property <color> emerald-25: Tokens.status-success-25;
    out property <color> red: Tokens.status-error;
    out property <color> red-04: Tokens.status-error-04;
    out property <color> red-15: Tokens.status-error-15;
    out property <color> red-20: Tokens.status-error-20;
    out property <color> red-25: Tokens.status-error-25;
    out property <color> violet: Tokens.status-library;
    out property <color> violet-04: Tokens.status-library-04;
    out property <color> violet-15: Tokens.status-library-15;
    out property <color> violet-20: Tokens.status-library-20;
    out property <color> violet-25: Tokens.status-library-25;
    out property <color> amber: Tokens.status-warning;
    out property <color> amber-04: Tokens.status-warning-04;
    out property <color> amber-15: Tokens.status-warning-15;
    out property <color> amber-20: Tokens.status-warning-20;
