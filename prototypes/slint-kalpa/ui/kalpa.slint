            file-selected(path) => { root.file-selected(path); }
            folder-toggled(path) => { root.folder-toggled(path); }
            file-content-edited(content) => { root.file-content-edited(content); }
            save-file(path, content) => { root.save-file(path, content); }
            open-folder => { root.open-folder(); }
            open-external(path) => { root.open-external(path); }
            rescan => { root.rescan-files(); }
            load-backups => { root.load-edit-backups(); }
            restore-backup(index) => { root.restore-edit-backup(index); }
            tag-clicked(id) => { root.tag-clicked(id); }
            add-tag-clicked => { root.add-tag-clicked(); }
            custom-tag-submitted(value) => { root.custom-tag-submitted(value); }
            open-esoui(id) => { root.open-esoui(id); }
            toggle-addon-disabled => { root.toggle-addon-disabled(); }
            remove-addon => { root.remove-addon(); }
