{
  "name": "kalpa",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "An open-source desktop addon manager for Elder Scrolls Online",
  "author": "ESO-Toolkit",
  "license": "BSL-1.1",
  "keywords": [
    "tauri",
    "addon-manager",
    "elder-scrolls-online",
    "eso",
    "rust"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ESO-Toolkit/kalpa.git"
  },
  "homepage": "https://github.com/ESO-Toolkit/kalpa",
  "bugs": {
    "url": "https://github.com/ESO-Toolkit/kalpa/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "check": "tsc --noEmit && eslint src/ && prettier --check \"src/**/*.{ts,tsx,css}\"",
    "check:env": "node scripts/check-env.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.2",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  }
}
