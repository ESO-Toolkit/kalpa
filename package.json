{
  "name": "kalpa",
  "version": "0.1.0-beta.9",
  "private": true,
  "description": "An open-source desktop addon manager for Elder Scrolls Online",
  "author": "ESO-Toolkit",
  "license": "BSL-1.1",
  "keywords": [
    "tauri",
    "addon-manager",
    "elder-scrolls-online",
    "eso",
    "rust"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ESO-Toolkit/kalpa.git"
  },
  "homepage": "https://github.com/ESO-Toolkit/kalpa",
  "bugs": {
    "url": "https://github.com/ESO-Toolkit/kalpa/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "check": "tsc --noEmit && eslint src/ && prettier --check \"src/**/*.{ts,tsx,css}\"",
    "check:env": "node scripts/check-env.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/legacy-modes": "^6.5.2",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@lezer/highlight": "^1.2.3",
    "@tanstack/react-virtual": "^3.14.4",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@uiw/codemirror-themes": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "lucide-react": "^1.22.0",
    "motion": "^12.42.2",
    "react": "^19.2.4",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.7",
    "react-use-measure": "^2.1.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
