{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kalpa",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "theme": "Dark",
        "backgroundColor": "#060c18"
      }
    ]
  },
  "bundle": {
    "targets": ["app", "dmg"],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
